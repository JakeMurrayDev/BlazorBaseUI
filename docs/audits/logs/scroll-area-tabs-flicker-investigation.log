### Ran Playwright code
```js
await (async (page) => {
    await page.setViewportSize({ width: 1215, height: 640 });
    await page.locator("text=Combining With Tabs").scrollIntoViewIfNeeded();
    await page.waitForTimeout(250);

    async function sample(label) {
      return await page.evaluate((label) => {
        const shell = document.querySelector(".scroll-area-tabs-shell");
        const list = document.querySelector(".scroll-area-tabs-list");
        const viewport = document.querySelector(".scroll-area-tabs-viewport");
        const activeTab = list?.querySelector("[role=tab][aria-selected=true]");
        const activePanel = activeTab?.getAttribute("aria-controls")
          ? document.getElementById(activeTab.getAttribute("aria-controls"))
          : null;
        const panels = Array.from(shell?.querySelectorAll("[role=tabpanel]") ?? []).map((panel, index) => {
          const rect = panel.getBoundingClientRect();
          const style = getComputedStyle(panel);
          return {
            index,
            hidden: panel.hidden,
            inert: panel.hasAttribute("inert"),
            display: style.display,
            top: Math.round(rect.top * 100) / 100,
            height: Math.round(rect.height * 100) / 100,
            visible: !panel.hidden && style.display !== "none" && style.visibility !== "hidden" && rect.width > 0 && rect.height > 0
          };
        });
        return {
          label,
          shellHeight: Math.round(shell.getBoundingClientRect().height * 100) / 100,
          stripScrollLeft: viewport.scrollLeft,
          stripScrollWidth: viewport.scrollWidth,
          stripClientWidth: viewport.clientWidth,
          visibleCount: panels.filter(panel => panel.visible).length,
          listParentClass: list.parentElement.className,
          activePanelParentClass: activePanel?.parentElement?.className ?? null,
          panels
        };
      }, label);
    }

    const samples = [await sample("before")];
    await page.locator(".scroll-area-tabs-tab").nth(1).click();
    for (let index = 0; index < 10; index += 1) {
      await page.waitForTimeout(16);
      samples.push(await sample(`after-design-tokens-${index}`));
    }
    await page.locator(".scroll-area-tabs-tab").nth(2).click();
    for (let index = 0; index < 10; index += 1) {
      await page.waitForTimeout(16);
      samples.push(await sample(`after-interop-${index}`));
    }

    return {
      maxVisibleCount: Math.max(...samples.map(sample => sample.visibleCount)),
      shellHeights: [...new Set(samples.map(sample => sample.shellHeight))],
      stripScrollLefts: [...new Set(samples.map(sample => sample.stripScrollLeft))],
      stripWidths: [...new Set(samples.map(sample => `${sample.stripClientWidth}/${sample.stripScrollWidth}`))],
      nestedListParentClass: samples[0].listParentClass,
      activePanelParentClass: samples[0].activePanelParentClass,
      samples
    };
  })(page);
