@using System.Globalization
@using Microsoft.JSInterop

@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<RenderElement TState="ScrollAreaCornerState"
               Tag="div"
               State="state"
               Enabled="ShouldRenderCorner"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="ChildContent"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private const string JsModulePath = ScrollAreaConstants.JsModulePath;

    private readonly Lazy<Task<IJSObjectReference>> moduleTask;

    private bool isRegistered;
    private string? registeredRootId;
    private ScrollAreaCornerState state = new();
    private RenderElement<ScrollAreaCornerState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();

    private bool ShouldRenderCorner => Context is not null && !Context.HiddenState.Corner;

    [CascadingParameter]
    private ScrollAreaRootContext? Context { get; set; }

    /// <summary>
    /// Allows you to replace the component's HTML element
    /// with a different tag, or compose it with another component.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<ScrollAreaCornerState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on the component state.
    /// </summary>
    [Parameter]
    public Func<ScrollAreaCornerState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on the component state.
    /// </summary>
    [Parameter]
    public Func<ScrollAreaCornerState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    public ScrollAreaCorner()
    {
        moduleTask = new Lazy<Task<IJSObjectReference>>(() =>
            JSRuntime.InvokeAsync<IJSObjectReference>("import", JsModulePath).AsTask());
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!ShouldRenderCorner || Context is null || !Element.HasValue)
        {
            await UnregisterAsync();
            return;
        }

        var rootId = Context.RootId;
        if (isRegistered && registeredRootId == rootId)
        {
            return;
        }

        if (isRegistered)
        {
            await UnregisterAsync();
        }

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("registerCorner", rootId, Element.Value);
            isRegistered = true;
            registeredRootId = rootId;
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        await UnregisterAsync();

        if (moduleTask.IsValueCreated)
        {
            try
            {
                var module = await moduleTask.Value;
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex;
            }
        }
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>
        {
            ["style"] = string.Create(
                CultureInfo.InvariantCulture,
                $"position: absolute; bottom: 0; inset-inline-end: 0; width: {Context?.CornerSize.Width ?? 0}px; height: {Context?.CornerSize.Height ?? 0}px")
        };

        componentAttributes = attrs;
    }

    private async Task UnregisterAsync()
    {
        if (!isRegistered)
        {
            return;
        }

        if (!moduleTask.IsValueCreated || string.IsNullOrEmpty(registeredRootId))
        {
            ClearRegistration();
            return;
        }

        var rootId = registeredRootId;
        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("unregisterCorner", rootId);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }
        finally
        {
            ClearRegistration();
        }
    }

    private void ClearRegistration()
    {
        isRegistered = false;
        registeredRootId = null;
    }
}
