@using System.Globalization
@using Microsoft.JSInterop

@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

@if (ShouldRenderScrollbar)
{
    <CascadingValue Value="scrollbarContext">
        <RenderElement TState="ScrollAreaScrollbarState"
                       Tag="div"
                       State="State"
                       Render="Render"
                       ClassValue="ClassValue"
                       StyleValue="StyleValue"
                       ComponentAttributes="componentAttributes"
                       ChildContent="ChildContent"
                       @attributes="AdditionalAttributes"
                       @ref="renderElementReference" />
    </CascadingValue>
}

@code {
    private const string JsModulePath = ScrollAreaConstants.JsModulePath;

    private readonly Lazy<Task<IJSObjectReference>> moduleTask;

    private bool isRegistered;
    private string? registeredRootId;
    private string? registeredOrientation;
    private ScrollAreaScrollbarContext scrollbarContext = new();
    private RenderElement<ScrollAreaScrollbarState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();

    private Orientation ResolvedOrientation => Orientation == Orientation.Horizontal
        ? Orientation.Horizontal
        : Orientation.Vertical;

    private bool IsHidden => ResolvedOrientation == Orientation.Vertical
        ? Context?.HiddenState.Y ?? true
        : Context?.HiddenState.X ?? true;

    private bool ShouldRenderScrollbar => Context is not null && (KeepMounted || !IsHidden);

    private ScrollAreaScrollbarState State
    {
        get
        {
            var rootState = Context?.State ?? ScrollAreaRootState.Default;
            return new ScrollAreaScrollbarState(
                Hovering: Context?.Hovering ?? false,
                Scrolling: ResolvedOrientation == Orientation.Vertical
                    ? Context?.ScrollingY ?? false
                    : Context?.ScrollingX ?? false,
                Orientation: ResolvedOrientation,
                HasOverflowX: rootState.HasOverflowX,
                HasOverflowY: rootState.HasOverflowY,
                OverflowXStart: rootState.OverflowXStart,
                OverflowXEnd: rootState.OverflowXEnd,
                OverflowYStart: rootState.OverflowYStart,
                OverflowYEnd: rootState.OverflowYEnd,
                CornerHidden: rootState.CornerHidden);
        }
    }

    [CascadingParameter]
    private ScrollAreaRootContext? Context { get; set; }

    /// <summary>
    /// Gets or sets whether the scrollbar controls vertical or horizontal scroll.
    /// Defaults to <see cref="BlazorBaseUI.Orientation.Vertical"/>.
    /// </summary>
    [Parameter]
    public Orientation Orientation { get; set; } = Orientation.Vertical;

    /// <summary>
    /// Gets or sets whether to keep the HTML element in the DOM when the viewport is not scrollable.
    /// </summary>
    [Parameter]
    public bool KeepMounted { get; set; }

    /// <summary>
    /// Allows you to replace the component's HTML element
    /// with a different tag, or compose it with another component.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<ScrollAreaScrollbarState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on the component state.
    /// </summary>
    [Parameter]
    public Func<ScrollAreaScrollbarState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on the component state.
    /// </summary>
    [Parameter]
    public Func<ScrollAreaScrollbarState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    public ScrollAreaScrollbar()
    {
        moduleTask = new Lazy<Task<IJSObjectReference>>(() =>
            JSRuntime.InvokeAsync<IJSObjectReference>("import", JsModulePath).AsTask());
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        scrollbarContext.Orientation = ResolvedOrientation;
        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!ShouldRenderScrollbar || Context is null || !Element.HasValue)
        {
            await UnregisterAsync();
            return;
        }

        try
        {
            var module = await moduleTask.Value;
            var orientation = ResolvedOrientation.ToDataAttributeString() ?? "vertical";
            await module.InvokeVoidAsync(
                "registerScrollbar",
                Context.RootId,
                Element.Value,
                orientation,
                KeepMounted);
            isRegistered = true;
            registeredRootId = Context.RootId;
            registeredOrientation = orientation;
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        await UnregisterAsync();

        if (moduleTask.IsValueCreated)
        {
            try
            {
                var module = await moduleTask.Value;
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex;
            }
        }
    }

    private void BuildComponentAttributes()
    {
        var currentState = State;
        var attrs = new Dictionary<string, object>
        {
            ["data-orientation"] = currentState.Orientation.ToDataAttributeString() ?? "vertical",
            ["style"] = BuildStyle()
        };

        if (!string.IsNullOrEmpty(Context?.RootId))
        {
            attrs["data-id"] = $"{Context.RootId}-scrollbar";
        }

        if (currentState.Hovering)
        {
            attrs["data-hovering"] = string.Empty;
        }

        ScrollAreaAttributeHelper.AddRootStateAttributes(
            attrs,
            new ScrollAreaRootState(
                Scrolling: currentState.Scrolling,
                HasOverflowX: currentState.HasOverflowX,
                HasOverflowY: currentState.HasOverflowY,
                OverflowXStart: currentState.OverflowXStart,
                OverflowXEnd: currentState.OverflowXEnd,
                OverflowYStart: currentState.OverflowYStart,
                OverflowYEnd: currentState.OverflowYEnd,
                CornerHidden: currentState.CornerHidden));

        componentAttributes = attrs;
    }

    private string BuildStyle()
    {
        var visibility = Context?.HasMeasuredScrollbar != true && !KeepMounted
            ? "visibility: hidden; "
            : string.Empty;

        if (ResolvedOrientation == Orientation.Vertical)
        {
            return string.Create(
                CultureInfo.InvariantCulture,
                $"position: absolute; touch-action: none; -webkit-user-select: none; user-select: none; {visibility}top: 0; bottom: var(--scroll-area-corner-height); inset-inline-end: 0; --scroll-area-thumb-height: {Context?.ThumbSize.Height ?? 0}px");
        }

        return string.Create(
            CultureInfo.InvariantCulture,
            $"position: absolute; touch-action: none; -webkit-user-select: none; user-select: none; {visibility}inset-inline-start: 0; inset-inline-end: var(--scroll-area-corner-width); bottom: 0; --scroll-area-thumb-width: {Context?.ThumbSize.Width ?? 0}px");
    }

    private async Task UnregisterAsync()
    {
        if (!isRegistered || !moduleTask.IsValueCreated || string.IsNullOrEmpty(registeredRootId))
        {
            return;
        }

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync(
                "unregisterScrollbar",
                registeredRootId,
                registeredOrientation ?? "vertical");
            isRegistered = false;
            registeredRootId = null;
            registeredOrientation = null;
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }
    }
}
