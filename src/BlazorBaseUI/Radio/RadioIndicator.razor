@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<RenderElement TState="RadioIndicatorState"
               Tag="span"
               State="state"
               Enabled="IsPresent"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="ChildContent"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private const string AnimationsModulePath = "./_content/BlazorBaseUI/blazor-baseui-animations.min.js";

    private bool isMounted;
    private bool hasRendered;
    private bool hasInitialized;
    private bool startTransitionPending;
    private bool endTransitionPending;
    private TransitionStatus transitionStatus = TransitionStatus.Undefined;
    private RenderElement<RadioIndicatorState>? renderElementReference;
    private RadioIndicatorState state = new(false, false, false, false, null, false, false, false, false, TransitionStatus.Undefined);
    private Dictionary<string, object> componentAttributes = new();
    private Lazy<Task<IJSObjectReference>> moduleTask = default!;
    private DotNetObjectReference<RadioIndicator>? dotNetRef;

    private bool Rendered => RadioContext?.Checked == true;

    private bool IsPresent => KeepMounted || isMounted || Rendered;

    [CascadingParameter]
    private RadioRootContext? RadioContext { get; set; }

    /// <summary>
    /// Determines whether to keep the HTML element in the DOM when the radio button is inactive.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool KeepMounted { get; set; }

    /// <summary>
    /// Gets or sets a custom render fragment that replaces the default element.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<RadioIndicatorState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets a function that returns a CSS class based on the component's state.
    /// </summary>
    [Parameter]
    public Func<RadioIndicatorState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets a function that returns an inline style based on the component's state.
    /// </summary>
    [Parameter]
    public Func<RadioIndicatorState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        moduleTask = new Lazy<Task<IJSObjectReference>>(() =>
            JSRuntime.InvokeAsync<IJSObjectReference>("import", AnimationsModulePath).AsTask());
        dotNetRef = DotNetObjectReference.Create(this);
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        if (RadioContext is null)
        {
            throw new InvalidOperationException(
                "Base UI: RadioRootContext is missing. Radio parts must be placed within <Radio.Root>.");
        }

        UpdateTransitionStatus();

        UpdateStateFromContext();

        hasInitialized = true;
        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            hasRendered = true;
        }

        if (startTransitionPending)
        {
            startTransitionPending = false;
            await StartEntryTransitionAsync();
        }

        if (endTransitionPending)
        {
            endTransitionPending = false;
            await StartExitTransitionAsync();
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (moduleTask.IsValueCreated)
        {
            try
            {
                var module = await moduleTask.Value;
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }

        dotNetRef?.Dispose();
    }

    /// <summary>
    /// Called from JavaScript after the starting-style frame has been applied.
    /// </summary>
    [JSInvokable]
    public void OnTransitionStarted()
    {
        transitionStatus = TransitionStatus.Undefined;
        UpdateStateFromContext();
        BuildComponentAttributes();
        _ = InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Called from JavaScript after exit animations and transitions complete.
    /// </summary>
    [JSInvokable]
    public void OnTransitionEnded()
    {
        if (Rendered)
        {
            endTransitionPending = false;
            transitionStatus = TransitionStatus.Undefined;
            UpdateStateFromContext();
            BuildComponentAttributes();
            _ = InvokeAsync(StateHasChanged);
            return;
        }

        isMounted = false;
        transitionStatus = TransitionStatus.Undefined;
        UpdateStateFromContext();
        BuildComponentAttributes();
        _ = InvokeAsync(StateHasChanged);
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();

        attrs["data-checked"] = state.Checked;
        attrs["data-unchecked"] = !state.Checked;
        attrs["data-disabled"] = state.Disabled;
        attrs["data-readonly"] = state.ReadOnly;
        attrs["data-required"] = state.Required;
        attrs["data-valid"] = state.Valid == true;
        attrs["data-invalid"] = state.Valid == false;
        attrs["data-touched"] = state.Touched;
        attrs["data-dirty"] = state.Dirty;
        attrs["data-filled"] = state.Filled;
        attrs["data-focused"] = state.Focused;
        TransitionAttributeHelper.ApplyTransitionStyleAttributes(attrs, state.TransitionStatus);

        componentAttributes = attrs;
    }

    private void UpdateStateFromContext()
    {
        if (RadioContext is null)
            return;

        state = new RadioIndicatorState(
            RadioContext.Checked,
            RadioContext.Disabled,
            RadioContext.ReadOnly,
            RadioContext.Required,
            RadioContext.State.Valid,
            RadioContext.State.Touched,
            RadioContext.State.Dirty,
            RadioContext.State.Filled,
            RadioContext.State.Focused,
            transitionStatus);
    }

    private void UpdateTransitionStatus()
    {
        var wasRendered = isMounted;
        var isRendered = Rendered;

        if (isRendered && !wasRendered)
        {
            isMounted = true;

            if (hasRendered || hasInitialized)
            {
                transitionStatus = TransitionStatus.Starting;
                startTransitionPending = true;
            }
        }
        else if (!isRendered && wasRendered)
        {
            if (hasRendered)
            {
                transitionStatus = TransitionStatus.Ending;
                endTransitionPending = true;
            }
            else
            {
                isMounted = false;
                transitionStatus = TransitionStatus.Undefined;
            }
        }
        else if (isRendered)
        {
            endTransitionPending = false;

            if (transitionStatus == TransitionStatus.Ending)
            {
                transitionStatus = TransitionStatus.Undefined;
            }
        }
    }

    private async Task StartEntryTransitionAsync()
    {
        if (!Element.HasValue || dotNetRef is null)
            return;

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("applyStartingStyle", Element.Value, dotNetRef);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task StartExitTransitionAsync()
    {
        if (!Element.HasValue || dotNetRef is null)
            return;

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("waitForExitTransition", Element.Value, dotNetRef);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }
}
