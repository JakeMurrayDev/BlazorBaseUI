@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop

@implements IAsyncDisposable

<RenderElement TState="CollapsibleRootState"
               Tag="button"
               State="state"
               Enabled="Context is not null"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="ChildContent"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private const string JsModulePath = "./_content/BlazorBaseUI/blazor-baseui-button.js";

    private readonly Lazy<Task<IJSObjectReference>> moduleTask;

    private bool hasRendered;
    private bool previousDisabled;
    private bool previousNativeButton;
    private CollapsibleRootState state = new(false, false, TransitionStatus.Undefined);
    private RenderElement<CollapsibleRootState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();

    private bool ResolvedDisabled => Disabled ?? Context?.Disabled ?? false;

    private bool NeedsJsInterop => !NativeButton || ResolvedDisabled;

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = null!;

    [CascadingParameter]
    private CollapsibleRootContext? Context { get; set; }

    /// <summary>
    /// Gets or sets whether the component should ignore user interaction.
    /// When <see langword="null"/>, inherits the value from the parent <see cref="CollapsibleRoot"/>.
    /// </summary>
    [Parameter]
    public bool? Disabled { get; set; }

    /// <summary>
    /// Determines whether to render a native <c>&lt;button&gt;</c> element.
    /// Defaults to <see langword="true"/>.
    /// </summary>
    [Parameter]
    public bool NativeButton { get; set; } = true;

    /// <summary>
    /// Allows you to replace the component's HTML element
    /// with a different tag, or compose it with another component.
    /// Accepts a function that returns the element to render.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<CollapsibleRootState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on the component state.
    /// </summary>
    [Parameter]
    public Func<CollapsibleRootState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on the component state.
    /// </summary>
    [Parameter]
    public Func<CollapsibleRootState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    public CollapsibleTrigger()
    {
        moduleTask = new Lazy<Task<IJSObjectReference>>(() =>
            JSRuntime.InvokeAsync<IJSObjectReference>("import", JsModulePath).AsTask());
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        var currentOpen = Context?.Open ?? false;
        var currentDisabled = ResolvedDisabled;
        var currentTransitionStatus = Context?.TransitionStatus ?? TransitionStatus.Undefined;
        if (state.Open != currentOpen || state.Disabled != currentDisabled || state.TransitionStatus != currentTransitionStatus)
        {
            state = state with { Open = currentOpen, Disabled = currentDisabled, TransitionStatus = currentTransitionStatus };
        }

        BuildComponentAttributes();

        if (!hasRendered)
        {
            return;
        }

        var stateChanged = currentDisabled != previousDisabled || NativeButton != previousNativeButton;

        if (stateChanged)
        {
            var previousNeedsJs = !previousNativeButton || previousDisabled;
            var currentNeedsJs = NeedsJsInterop;

            previousDisabled = currentDisabled;
            previousNativeButton = NativeButton;

            if (currentNeedsJs)
            {
                _ = SyncJsAsync(dispose: false);
            }
            else if (previousNeedsJs)
            {
                _ = SyncJsAsync(dispose: true);
            }
        }
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            hasRendered = true;
            previousDisabled = ResolvedDisabled;
            previousNativeButton = NativeButton;

            if (NeedsJsInterop)
            {
                await SyncJsAsync(dispose: false);
            }
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (moduleTask.IsValueCreated && Element.HasValue)
        {
            try
            {
                var module = await moduleTask.Value;
                await module.InvokeVoidAsync("sync", Element.Value, false, false, false, true);
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }
    }

    private void BuildComponentAttributes()
    {
        if (Context is null) return;

        var attrs = new Dictionary<string, object>();
        var disabled = ResolvedDisabled;

        if (NativeButton)
        {
            // focusableWhenDisabled is always true for collapsible triggers (matches React useButton config)
            AccessibilityUtilities.ApplyNativeButtonAttributes(attrs, disabled, focusableWhenDisabled: true);
        }
        else
        {
            AccessibilityUtilities.ApplyButtonAttributes(attrs, disabled, focusableWhenDisabled: true);
        }

        if (Context.Open)
            attrs["aria-controls"] = Context.PanelId;

        attrs["aria-expanded"] = Context.Open ? "true" : "false";
        attrs["onclick"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleClickAsync);
        attrs["data-panel-open"] = state.Open;
        attrs["data-disabled"] = state.Disabled;
        TransitionAttributeHelper.ApplyTransitionStyleAttributes(attrs, state.TransitionStatus);

        componentAttributes = attrs;
    }

    private async Task HandleClickAsync(MouseEventArgs args)
    {
        if (ResolvedDisabled)
        {
            return;
        }

        if (Context is not null)
        {
            await Context.HandleTrigger();
        }

        await EventUtilities.InvokeOnClickAsync(AdditionalAttributes, args);
    }

    private async Task SyncJsAsync(bool dispose)
    {
        if (!Element.HasValue)
        {
            return;
        }

        try
        {
            var module = await moduleTask.Value; // lint-ignore:RULE-13 Lazy module access for first-time activation; IsValueCreated only required in Dispose paths.
            // focusableWhenDisabled is always true for collapsible triggers (matches React's useButton config)
            await module.InvokeVoidAsync("sync", Element.Value, ResolvedDisabled, true, NativeButton, dispose);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }
}
