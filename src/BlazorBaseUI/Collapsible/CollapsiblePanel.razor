@using System.Globalization
@using Microsoft.JSInterop

@implements IAsyncDisposable

<RenderElement TState="CollapsiblePanelState"
               Tag="div"
               State="state"
               Enabled="IsPresent"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="computedStyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="ChildContent"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private const string JsModulePath = "./_content/BlazorBaseUI/blazor-baseui-collapsible.min.js";

    private readonly Lazy<Task<IJSObjectReference>> moduleTask;

    private string? defaultId;
    private string? registeredPanelId;
    private double? measuredHeight;
    private double? measuredWidth;
    private bool hasRendered;
    private bool isMounted;
    private bool jsInitialized;
    private bool shouldPreventMountAnimation;
    private DotNetObjectReference<CollapsiblePanel>? dotNetRef;
    private CollapsiblePanelState state = new(false, false, TransitionStatus.Undefined);
    private AnimationAction pendingAnimation = AnimationAction.None;
    private RenderElement<CollapsiblePanelState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private Func<CollapsiblePanelState, string?>? computedStyleValue;

    private bool CurrentOpen => Context?.Open ?? false;

    private string ResolvedId
    {
        get
        {
            var id = AttributeUtilities.GetIdOrDefault(AdditionalAttributes, () =>
                string.IsNullOrEmpty(Context?.PanelId)
                    ? defaultId ??= Guid.NewGuid().ToIdString()
                    : Context.PanelId);

            if (id != registeredPanelId)
            {
                Context?.SetPanelId(id);
                registeredPanelId = id;
            }

            return id;
        }
    }

    private bool IsPresent => Context is not null && (KeepMounted || HiddenUntilFound || isMounted || CurrentOpen);

    private bool IsHidden => !CurrentOpen && !isMounted;

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = null!;

    [CascadingParameter]
    private CollapsibleRootContext? Context { get; set; }

    /// <summary>
    /// Determines whether to keep the element in the DOM while the panel is hidden.
    /// This is ignored when <see cref="HiddenUntilFound"/> is used.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool KeepMounted { get; set; }

    /// <summary>
    /// Determines whether the browser's built-in page search can find and expand the panel contents.
    /// Overrides <see cref="KeepMounted"/> and uses <c>hidden="until-found"</c> to hide the element without removing it from the DOM.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool HiddenUntilFound { get; set; }

    /// <summary>
    /// Allows you to replace the component's HTML element
    /// with a different tag, or compose it with another component.
    /// Accepts a function that returns the element to render.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<CollapsiblePanelState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on the component state.
    /// </summary>
    [Parameter]
    public Func<CollapsiblePanelState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on the component state.
    /// </summary>
    [Parameter]
    public Func<CollapsiblePanelState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    public CollapsiblePanel()
    {
        moduleTask = new Lazy<Task<IJSObjectReference>>(() =>
            JSRuntime.InvokeAsync<IJSObjectReference>("import", JsModulePath).AsTask());
    }

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        var initialOpen = Context?.Open ?? false;
        isMounted = initialOpen;
        shouldPreventMountAnimation = initialOpen;
        state = new CollapsiblePanelState(
            initialOpen,
            Context?.Disabled ?? false,
            initialOpen ? TransitionStatus.Idle : TransitionStatus.Undefined);

        computedStyleValue = s =>
        {
            var userStyle = StyleValue?.Invoke(s);
            if (!IsPresent)
            {
                return userStyle;
            }

            var cssVars =
                $"--collapsible-panel-height: {FormatCssSize(measuredHeight)}; --collapsible-panel-width: {FormatCssSize(measuredWidth)}";
            var style = string.IsNullOrEmpty(userStyle) ? cssVars : $"{cssVars}; {userStyle}";

            if (shouldPreventMountAnimation && CurrentOpen)
            {
                style = $"{style}; animation-name: none";
            }

            return style;
        };

        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        var currentOpen = CurrentOpen;
        var currentDisabled = Context?.Disabled ?? false;
        var nextTransitionStatus = state.TransitionStatus;

        if (currentOpen != state.Open)
        {
            if (currentOpen)
            {
                isMounted = true;
                pendingAnimation = AnimationAction.Open;
                nextTransitionStatus = TransitionStatus.Starting;
            }
            else
            {
                pendingAnimation = AnimationAction.Close;
            }
        }
        else if (currentOpen && !isMounted)
        {
            // Race condition recovery: close animation completed after state was already set to open
            isMounted = true;
            pendingAnimation = AnimationAction.Open;
            nextTransitionStatus = TransitionStatus.Starting;
        }

        if (state.Open != currentOpen || state.Disabled != currentDisabled || state.TransitionStatus != nextTransitionStatus)
        {
            state = state with
            {
                Open = currentOpen,
                Disabled = currentDisabled,
                TransitionStatus = nextTransitionStatus
            };
        }

        // Register panel ID with context early so trigger can reference it
        // This must happen in OnParametersSet, not during render, for StateHasChanged to work
        _ = ResolvedId;

        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            hasRendered = true;
            dotNetRef = DotNetObjectReference.Create(this);

            if (IsPresent && Element.HasValue)
            {
                try
                {
                    var module = await moduleTask.Value;
                    await module.InvokeVoidAsync("initialize", Element.Value, dotNetRef, CurrentOpen, null, HiddenUntilFound, KeepMounted);
                    jsInitialized = true;
                }
                catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
                {
                    _ = ex; // Expected during circuit disconnect - safe to ignore.
                }
            }

            return;
        }

        if (pendingAnimation == AnimationAction.Open)
        {
            pendingAnimation = AnimationAction.None;
            _ = OpenAsync();
        }
        else if (pendingAnimation == AnimationAction.Close)
        {
            pendingAnimation = AnimationAction.None;
            _ = CloseAsync();
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (moduleTask.IsValueCreated && Element.HasValue)
        {
            try
            {
                var module = await moduleTask.Value;
                await module.InvokeVoidAsync("dispose", Element.Value);
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }

        dotNetRef?.Dispose();
    }

    /// <summary>
    /// Called from JavaScript when the panel transition status changes.
    /// </summary>
    /// <param name="status">The new transition status string.</param>
    /// <param name="height">The measured panel height, when a transition needs a pixel endpoint.</param>
    /// <param name="width">The measured panel width, when a transition needs a pixel endpoint.</param>
    [JSInvokable]
    public void OnTransitionStatusChanged(string status, double? height, double? width)
    {
        if (height.HasValue || width.HasValue)
        {
            measuredHeight = height;
            measuredWidth = width;
        }

        var transitionStatus = status switch
        {
            "starting" => TransitionStatus.Starting,
            "ending" => TransitionStatus.Ending,
            "idle" => TransitionStatus.Idle,
            _ => TransitionStatus.Undefined
        };

        state = state with { TransitionStatus = transitionStatus };
        Context?.SetTransitionStatus(transitionStatus);
        StateHasChanged();
    }

    /// <summary>
    /// Called from JavaScript when an open or close animation finishes.
    /// </summary>
    /// <param name="animationType">The type of animation that ended (<c>"open"</c> or <c>"close"</c>).</param>
    /// <param name="completed">Whether the animation ran to completion.</param>
    [JSInvokable]
    public void OnAnimationEnded(string animationType, bool completed)
    {
        if (animationType == "close")
        {
            if (completed && !CurrentOpen)
            {
                isMounted = false;
                measuredHeight = null;
                measuredWidth = null;
                if (!KeepMounted && !HiddenUntilFound)
                {
                    jsInitialized = false;
                }
            }
        }
        else if (completed)
        {
            measuredHeight = null;
            measuredWidth = null;
        }

        state = state with { TransitionStatus = TransitionStatus.Idle };
        Context?.SetTransitionStatus(TransitionStatus.Idle);
        shouldPreventMountAnimation = false;
        StateHasChanged();
    }

    /// <summary>
    /// Called from JavaScript when the browser's "find in page" reveals <c>hidden="until-found"</c> content.
    /// </summary>
    [JSInvokable]
    public async Task OnBeforeMatch()
    {
        // Called when browser's "find in page" reveals hidden="until-found" content
        if (Context is not null)
        {
            await Context.HandleBeforeMatch();
        }
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();

        attrs["id"] = ResolvedId;

        if (IsHidden)
        {
            attrs["hidden"] = HiddenUntilFound ? "until-found" : true;
        }

        attrs["data-open"] = state.Open;
        attrs["data-closed"] = !state.Open;
        attrs["data-disabled"] = state.Disabled;
        TransitionAttributeHelper.ApplyTransitionStyleAttributes(attrs, state.TransitionStatus);

        componentAttributes = attrs;
    }

    private async Task OpenAsync()
    {
        if (!hasRendered || !Element.HasValue)
        {
            return;
        }

        try
        {
            var module = await moduleTask.Value;
            dotNetRef ??= DotNetObjectReference.Create(this);

            if (!jsInitialized)
            {
                await module.InvokeVoidAsync("initialize", Element.Value, dotNetRef, false, null, HiddenUntilFound, KeepMounted);
                jsInitialized = true;
            }

            await module.InvokeVoidAsync("open", Element.Value, false);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task CloseAsync()
    {
        if (!hasRendered || !Element.HasValue)
        {
            return;
        }

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("close", Element.Value);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private static string FormatCssSize(double? value)
    {
        return value.HasValue
            ? string.Create(CultureInfo.InvariantCulture, $"{value.Value:0.###}px")
            : "auto";
    }

    private enum AnimationAction { None, Open, Close }
}
