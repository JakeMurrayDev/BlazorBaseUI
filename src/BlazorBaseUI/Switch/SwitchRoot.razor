@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using BlazorBaseUI.Field
@using BlazorBaseUI.Form
@using BlazorBaseUI.Utilities.LabelableProvider

@implements IAsyncDisposable
@implements IFieldStateSubscriber

@inject IJSRuntime JSRuntime

<CascadingValue Value="context">
    @if (NativeButton)
    {
        <RenderElement TState="SwitchRootState"
                       Tag="button"
                       State="state"
                       Render="Render"
                       ClassValue="ClassValue"
                       StyleValue="StyleValue"
                       ComponentAttributes="nativeButtonAttributes"
                       ChildContent="ChildContent"
                       @attributes="AdditionalAttributes"
                       @ref="renderElementReference" />
    }
    else
    {
        <RenderElement TState="SwitchRootState"
                       Tag="span"
                       State="state"
                       Render="Render"
                       ClassValue="ClassValue"
                       StyleValue="StyleValue"
                       ComponentAttributes="componentAttributes"
                       ChildContent="ChildContent"
                       @attributes="AdditionalAttributes"
                       @ref="renderElementReference" />
    }
</CascadingValue>

@if (!CurrentChecked && ResolvedName is not null && UncheckedValue is not null)
{
    <input type="hidden" form="@Form" name="@ResolvedName" value="@UncheckedValue" />
}

<input type="checkbox"
       id="@(NativeButton ? null : inputId)"
       checked="@CurrentChecked"
       disabled="@ResolvedDisabled"
       required="@Required"
       form="@Form"
       aria-hidden="true"
       aria-describedby="@InputAriaDescribedBy"
       tabindex="-1"
       style="@HiddenInputStyle"
       name="@(ResolvedName is not null ? ResolvedName : null)"
       value="@Value"
       @onclick="HandleInputClick"
       @onchange="HandleInputChangeAsync"
       @onfocus="HandleInputFocusAsync"
       @ref="inputElement" />

@code {
    private const string JsModulePath = "./_content/BlazorBaseUI/blazor-baseui-switch.min.js";
    private const string VisuallyHiddenStyle = "position:fixed;top:0;left:0;overflow:hidden;white-space:nowrap;border:0;padding:0;width:1px;height:1px;margin:-1px;clip-path:inset(50%);";
    private const string VisuallyHiddenInputStyle = "position:absolute;overflow:hidden;white-space:nowrap;border:0;padding:0;width:1px;height:1px;margin:-1px;clip-path:inset(50%);";

    private readonly Lazy<Task<IJSObjectReference>> moduleTask;
    private readonly string fieldControlSource = Guid.NewGuid().ToIdString();

    private bool hasRendered;
    private bool isChecked;
    private bool fieldControlRegistered;
    private bool jsReinitializePending;
    private bool jsUpdatePending;
    private bool previousChecked;
    private bool previousDisabled;
    private bool previousReadOnly;
    private bool previousRequired;
    private bool previousNativeButton;
    private bool? previousValid;
    private bool previousTouched;
    private bool previousDirty;
    private bool previousFilled;
    private bool previousFocused;
    private string? defaultId;
    private string? registeredControlId;
    private string? registeredName;
    private string resolvedControlId = null!;
    private string switchId = null!;
    private string inputId = null!;
    private ElementReference inputElement;
    private SwitchRootState state = SwitchRootState.Default;
    private SwitchRootContext context = null!;
    private RenderElement<SwitchRootState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private Dictionary<string, object> nativeButtonAttributes = new();
    private MouseEventArgs? lastInputClickArgs;

    private bool IsControlled => Checked.HasValue;

    private bool CurrentChecked => IsControlled ? Checked!.Value : isChecked;

    private bool ResolvedDisabled => Disabled || (FieldContext?.Disabled ?? false);

    private string? ResolvedName => FieldContext?.Name ?? Name;

    private string ResolvedControlId => AttributeUtilities.GetIdOrDefault(AdditionalAttributes, () => defaultId ??= Guid.NewGuid().ToIdString());

    private FieldRootState FieldState => FieldContext?.State ?? FieldRootState.Default;

    private string HiddenInputStyle => ResolvedName is not null ? VisuallyHiddenInputStyle : VisuallyHiddenStyle;

    private string? ExplicitAriaLabelledBy => AttributeUtilities.GetAttributeStringValueIgnoreCase(AdditionalAttributes, "aria-labelledby");

    private string? ExternalAriaDescribedBy => AttributeUtilities.GetAttributeStringValueIgnoreCase(AdditionalAttributes, "aria-describedby");

    private string? FieldAriaDescribedBy => LabelableContext?.GetAriaDescribedBy();

    private string? InputAriaDescribedBy => FieldAriaDescribedBy;

    private bool EnableNativeLabelFallback => string.IsNullOrEmpty(ExplicitAriaLabelledBy) &&
                                              string.IsNullOrEmpty(LabelableContext?.LabelId) &&
                                              !NativeButton;

    [CascadingParameter]
    private FieldRootContext? FieldContext { get; set; }

    [CascadingParameter]
    private FormContext? FormContext { get; set; }

    [CascadingParameter]
    private LabelableContext? LabelableContext { get; set; }

    /// <summary>
    /// Gets or sets whether the switch is currently active.
    /// To render an uncontrolled switch, use <see cref="DefaultChecked"/> instead.
    /// </summary>
    [Parameter]
    public bool? Checked { get; set; }

    /// <summary>
    /// Determines whether the switch is initially active.
    /// To render a controlled switch, use <see cref="Checked"/> instead.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool DefaultChecked { get; set; }

    /// <summary>
    /// Determines whether the component should ignore user interaction.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Determines whether the user should be unable to activate or deactivate the switch.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool ReadOnly { get; set; }

    /// <summary>
    /// Determines whether the user must activate the switch before submitting a form.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool Required { get; set; }

    /// <summary>
    /// Gets or sets the name that identifies the field when a form is submitted.
    /// </summary>
    [Parameter]
    public string? Name { get; set; }

    /// <summary>
    /// Gets or sets the form that owns the hidden input when the switch is rendered outside the form.
    /// </summary>
    [Parameter]
    public string? Form { get; set; }

    /// <summary>
    /// Gets or sets the value submitted with the form when the switch is off.
    /// By default, unchecked switches do not submit any value, matching native checkbox behavior.
    /// </summary>
    [Parameter]
    public string? UncheckedValue { get; set; }

    /// <summary>
    /// Gets or sets the value submitted with the form when the switch is on.
    /// By default, the switch submits the "on" value, matching native checkbox behavior.
    /// </summary>
    [Parameter]
    public string? Value { get; set; }

    /// <summary>
    /// Determines whether the component renders a native <c>&lt;button&gt;</c> element when replacing it
    /// via the <see cref="Render"/> prop.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool NativeButton { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the checked state changes via two-way binding.
    /// </summary>
    [Parameter]
    public EventCallback<bool> CheckedChanged { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the switch is activated or deactivated.
    /// </summary>
    [Parameter]
    public EventCallback<SwitchCheckedChangeEventArgs> OnCheckedChange { get; set; }

    /// <summary>
    /// Allows you to replace the component's HTML element
    /// with a different tag, or compose it with another component.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<SwitchRootState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets a function that returns a CSS class based on the component's state.
    /// </summary>
    [Parameter]
    public Func<SwitchRootState, string>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets a function that returns a CSS style based on the component's state.
    /// </summary>
    [Parameter]
    public Func<SwitchRootState, string>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <summary>
    /// Gets the <see cref="ElementReference"/> to the hidden <c>&lt;input&gt;</c> element.
    /// </summary>
    public ElementReference InputElement => inputElement;

    public SwitchRoot()
    {
        moduleTask = new Lazy<Task<IJSObjectReference>>(() =>
            JSRuntime.InvokeAsync<IJSObjectReference>("import", JsModulePath).AsTask());
    }

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        switchId = Guid.NewGuid().ToIdString();
        resolvedControlId = ResolvedControlId;
        inputId = resolvedControlId;
        UpdateLabelableControlId();

        if (!IsControlled)
        {
            isChecked = DefaultChecked;
        }

        var initialValue = CurrentChecked;
        FieldContext?.Validation.SetInitialValue(initialValue);
        FieldContext?.SetFilled(initialValue);
        FieldContext?.RegisterFocusHandlerFunc(FocusAsync);
        RegisterFieldControl();
        FieldContext?.SubscribeFunc(this);

        previousChecked = CurrentChecked;
        previousDisabled = ResolvedDisabled;
        previousReadOnly = ReadOnly;
        previousRequired = Required;
        previousNativeButton = NativeButton;
        previousValid = FieldState.Valid;
        previousTouched = FieldState.Touched;
        previousDirty = FieldState.Dirty;
        previousFilled = FieldState.Filled;
        previousFocused = FieldState.Focused;

        state = SwitchRootState.FromFieldState(
            FieldState,
            CurrentChecked,
            ResolvedDisabled,
            ReadOnly,
            Required);

        UpdateContext(CurrentChecked, ResolvedDisabled, state);

        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        var newResolvedId = ResolvedControlId;
        if (newResolvedId != resolvedControlId)
        {
            resolvedControlId = newResolvedId;
            inputId = newResolvedId;
            UpdateLabelableControlId();
            jsUpdatePending = true;
        }

        UpdateLabelableControlId();
        RegisterFieldControl();

        var currentChecked = CurrentChecked;
        var currentDisabled = ResolvedDisabled;
        var fieldState = FieldState;

        var stateChanged = previousChecked != currentChecked ||
                           previousDisabled != currentDisabled ||
                           previousReadOnly != ReadOnly ||
                           previousRequired != Required ||
                           previousValid != fieldState.Valid ||
                           previousTouched != fieldState.Touched ||
                           previousDirty != fieldState.Dirty ||
                           previousFilled != fieldState.Filled ||
                           previousFocused != fieldState.Focused;

        if (stateChanged)
        {
            state = SwitchRootState.FromFieldState(
                fieldState,
                currentChecked,
                currentDisabled,
                ReadOnly,
                Required);

            UpdateContext(currentChecked, currentDisabled, state);
        }

        BuildComponentAttributes();

        if (hasRendered)
        {
            if (currentChecked != previousChecked)
            {
                previousChecked = currentChecked;
                HandleCheckedChanged();
            }

            if (currentDisabled != previousDisabled || ReadOnly != previousReadOnly || NativeButton != previousNativeButton)
            {
                if (NativeButton != previousNativeButton)
                {
                    jsReinitializePending = true;
                }
                else
                {
                    jsUpdatePending = true;
                }
            }
        }

        previousChecked = currentChecked;
        previousDisabled = currentDisabled;
        previousReadOnly = ReadOnly;
        previousRequired = Required;
        previousNativeButton = NativeButton;
        previousValid = fieldState.Valid;
        previousTouched = fieldState.Touched;
        previousDirty = fieldState.Dirty;
        previousFilled = fieldState.Filled;
        previousFocused = fieldState.Focused;
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            hasRendered = true;
            await InitializeJsAsync();
            return;
        }

        if (jsReinitializePending)
        {
            jsReinitializePending = false;
            jsUpdatePending = false;
            await InitializeJsAsync();
            return;
        }

        if (jsUpdatePending || EnableNativeLabelFallback)
        {
            jsUpdatePending = false;
            await UpdateJsStateAsync();
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        LabelableContext?.SetControlId(null);
        if (fieldControlRegistered)
            FieldContext?.RegisterFieldControl(fieldControlSource, null);

        FieldContext?.UnsubscribeFunc(this);

        if (moduleTask.IsValueCreated && Element.HasValue)
        {
            try
            {
                var module = await moduleTask.Value;
                await module.InvokeVoidAsync("dispose", Element.Value);
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }
    }

    /// <inheritdoc />
    public void NotifyStateChanged()
    {
        UpdateStateAndContext();
        _ = InvokeAsync(StateHasChanged);
    }

    private void BuildComponentAttributes()
    {
        var attrs = CreateBaseRootAttributes(isNativeButton: false);
        attrs["id"] = switchId;
        AddAttributeUnlessOverridden(attrs, "tabindex", ResolvedDisabled ? -1 : 0);
        componentAttributes = attrs;

        var btnAttrs = CreateBaseRootAttributes(isNativeButton: true);
        btnAttrs["id"] = resolvedControlId;
        AddAttributeUnlessOverridden(btnAttrs, "type", "button");

        if (ResolvedDisabled)
        {
            btnAttrs["disabled"] = true;
        }

        nativeButtonAttributes = btnAttrs;
    }

    private Dictionary<string, object> CreateBaseRootAttributes(bool isNativeButton)
    {
        var attrs = new Dictionary<string, object>();

        AddAttributeUnlessOverridden(attrs, "role", "switch");
        AddAttributeUnlessOverridden(attrs, "aria-checked", CurrentChecked ? "true" : "false");

        if (ResolvedDisabled && !isNativeButton)
            AddAttributeUnlessOverridden(attrs, "aria-disabled", "true");

        if (ReadOnly)
            AddAttributeUnlessOverridden(attrs, "aria-readonly", "true");

        if (Required)
            AddAttributeUnlessOverridden(attrs, "aria-required", "true");

        if (!string.IsNullOrEmpty(LabelableContext?.LabelId))
            AddAttributeUnlessOverridden(attrs, "aria-labelledby", LabelableContext.LabelId);

        var describedBy = AttributeUtilities.CombineIdRefs(ExternalAriaDescribedBy, FieldAriaDescribedBy);
        if (!string.IsNullOrEmpty(describedBy))
            attrs["aria-describedby"] = describedBy;

        if (state.Valid == false)
            AddAttributeUnlessOverridden(attrs, "aria-invalid", "true");

        attrs["onfocus"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleFocus);
        attrs["onblur"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleBlur);

        AddAttributeUnlessOverridden(attrs, "data-checked", state.Checked);
        AddAttributeUnlessOverridden(attrs, "data-unchecked", !state.Checked);
        AddAttributeUnlessOverridden(attrs, "data-disabled", state.Disabled);
        AddAttributeUnlessOverridden(attrs, "data-readonly", state.ReadOnly);
        AddAttributeUnlessOverridden(attrs, "data-required", state.Required);
        AddAttributeUnlessOverridden(attrs, "data-valid", state.Valid == true);
        AddAttributeUnlessOverridden(attrs, "data-invalid", state.Valid == false);
        AddAttributeUnlessOverridden(attrs, "data-touched", state.Touched);
        AddAttributeUnlessOverridden(attrs, "data-dirty", state.Dirty);
        AddAttributeUnlessOverridden(attrs, "data-filled", state.Filled);
        AddAttributeUnlessOverridden(attrs, "data-focused", state.Focused);

        return attrs;
    }

    private async Task InitializeJsAsync()
    {
        if (!Element.HasValue)
        {
            return;
        }

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("initialize", Element.Value, inputElement, ResolvedDisabled, ReadOnly, NativeButton, EnableNativeLabelFallback);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task UpdateJsStateAsync()
    {
        if (!hasRendered || !Element.HasValue)
        {
            return;
        }

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("updateState", Element.Value, inputElement, ResolvedDisabled, ReadOnly, NativeButton, EnableNativeLabelFallback);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private Task HandleFocus(FocusEventArgs e)
    {
        if (ResolvedDisabled)
        {
            return Task.CompletedTask;
        }

        FieldContext?.SetFocused(true);
        return EventUtilities.InvokeOnFocusAsync(AdditionalAttributes, e);
    }

    private Task HandleBlur(FocusEventArgs e)
    {
        if (ResolvedDisabled)
        {
            return Task.CompletedTask;
        }

        FieldContext?.SetTouched(true);
        FieldContext?.SetFocused(false);

        if (FieldContext?.ValidationMode == ValidationMode.OnBlur)
        {
            _ = FieldContext.Validation.CommitAsync(CurrentChecked);
        }

        return EventUtilities.InvokeOnBlurAsync(AdditionalAttributes, e);
    }

    private async Task HandleInputChangeAsync(ChangeEventArgs e)
    {
        var inputClickArgs = lastInputClickArgs;
        lastInputClickArgs = null;

        if (ReadOnly || ResolvedDisabled)
        {
            await ResetInputCheckedAsync();
            return;
        }

        var nextChecked = e.Value is bool b ? b : bool.TryParse(e.Value?.ToString(), out var parsed) && parsed;

        if (nextChecked == CurrentChecked)
        {
            return;
        }

        await SetChecked(nextChecked, inputClickArgs);
    }

    private void HandleInputClick(MouseEventArgs e)
    {
        lastInputClickArgs = e;
    }

    private async Task HandleInputFocusAsync(FocusEventArgs e)
    {
        await FocusAsync();
    }

    private async Task SetChecked(bool value, MouseEventArgs? mouseEventArgs = null)
    {
        var eventArgs = new SwitchCheckedChangeEventArgs(value, SwitchChangeReason.None, mouseEventArgs);

        if (OnCheckedChange.HasDelegate)
        {
            await OnCheckedChange.InvokeAsync(eventArgs);

            if (eventArgs.IsCanceled)
            {
                await ResetInputCheckedAsync();
                return;
            }
        }

        if (!IsControlled)
        {
            isChecked = value;
            UpdateStateAndContext();
        }

        if (CheckedChanged.HasDelegate)
        {
            await CheckedChanged.InvokeAsync(value);
        }

        if (!IsControlled)
        {
            HandleCheckedChanged();
        }
    }

    private async Task ResetInputCheckedAsync()
    {
        if (!hasRendered)
        {
            return;
        }

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("setInputChecked", inputElement, CurrentChecked);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private void HandleCheckedChanged()
    {
        FormContext?.ClearErrors(ResolvedName);

        var initialValue = FieldContext?.ValidityData.InitialValue;
        var isDirty = initialValue is bool initial ? CurrentChecked != initial : CurrentChecked;

        FieldContext?.SetDirty(isDirty);
        FieldContext?.SetFilled(CurrentChecked);

        if (FieldContext?.ShouldValidateOnChangeFunc() == true)
        {
            if (FieldContext.ValidationDebounceTime > 0)
            {
                FieldContext.Validation.CommitDebounced(CurrentChecked);
            }
            else
            {
                _ = FieldContext.Validation.CommitAsync(CurrentChecked);
            }
        }
        else
        {
            _ = FieldContext?.Validation.CommitAsync(CurrentChecked, revalidateOnly: true);
        }
    }

    private void UpdateStateAndContext()
    {
        var currentChecked = CurrentChecked;
        var currentDisabled = ResolvedDisabled;
        var fieldState = FieldState;

        state = SwitchRootState.FromFieldState(
            fieldState,
            currentChecked,
            currentDisabled,
            ReadOnly,
            Required);

        UpdateContext(currentChecked, currentDisabled, state);

        BuildComponentAttributes();

        previousChecked = currentChecked;
        previousDisabled = currentDisabled;
        previousReadOnly = ReadOnly;
        previousRequired = Required;
        previousValid = fieldState.Valid;
        previousTouched = fieldState.Touched;
        previousDirty = fieldState.Dirty;
        previousFilled = fieldState.Filled;
        previousFocused = fieldState.Focused;
    }

    private void RegisterFieldControl()
    {
        if (FieldContext is null)
            return;

        var registrationName = string.IsNullOrEmpty(Name) ? null : Name;
        if (fieldControlRegistered && registeredControlId == switchId && registeredName == registrationName)
            return;

        FieldContext.RegisterFieldControl(
            fieldControlSource,
            new FieldControlRegistration(
                Id: switchId,
                Name: registrationName,
                GetValue: GetRegisteredValue,
                ValidateAsync: ValidateRegisteredValueAsync,
                FocusAsync: FocusAsync));

        fieldControlRegistered = true;
        registeredControlId = switchId;
        registeredName = registrationName;
    }

    private void UpdateContext(bool currentChecked, bool currentDisabled, SwitchRootState currentState)
    {
        context = new SwitchRootContext
        {
            Checked = currentChecked,
            Disabled = currentDisabled,
            ReadOnly = ReadOnly,
            Required = Required,
            State = currentState
        };
    }

    private object? GetRegisteredValue() => CurrentChecked;

    private Task ValidateRegisteredValueAsync() =>
        FieldContext?.Validation.CommitAsync(CurrentChecked) ?? Task.CompletedTask;

    private void UpdateLabelableControlId()
    {
        LabelableContext?.SetControlId(NativeButton ? resolvedControlId : inputId);
    }

    private void AddAttributeUnlessOverridden(Dictionary<string, object> attrs, string key, object value)
    {
        if (!AttributeUtilities.HasAttributeIgnoreCase(AdditionalAttributes, key))
            attrs[key] = value;
    }

    private async ValueTask FocusAsync()
    {
        if (!hasRendered || !Element.HasValue)
        {
            return;
        }

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("focus", Element.Value);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }
}
