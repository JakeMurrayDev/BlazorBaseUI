@using Microsoft.AspNetCore.Components.Web
@using BlazorBaseUI.FocusGuard

<RenderElement TState="NavigationMenuViewportState"
               Tag="div"
               State="state"
               Enabled="RootContext is not null"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="ViewportContent"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private ElementReference viewportTargetElement;
    private FocusGuard? afterGuardReference;
    private NavigationMenuViewportState state;
    private RenderElement<NavigationMenuViewportState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();

    private RenderFragment ViewportContent => builder =>
    {
        builder.OpenComponent<FocusGuard>(0);
        builder.AddAttribute(1, "OnFocus", EventCallback.Factory.Create(this, HandleBeforeGuardFocusAsync));
        builder.CloseComponent();

        builder.OpenElement(2, "div");
        builder.AddAttribute(3, "id", RootContext?.ViewportTargetId ?? string.Empty);
        builder.AddAttribute(4, "data-blazor-base-ui-navigation-menu-viewport-target", true);
        builder.AddElementReferenceCapture(5, element => viewportTargetElement = element);
        builder.AddContent(6, ChildContent);
        builder.CloseElement();

        builder.OpenComponent<FocusGuard>(7);
        builder.AddAttribute(8, "OnFocus", EventCallback.Factory.Create(this, HandleAfterGuardFocusAsync));
        builder.AddComponentReferenceCapture(9, instance => afterGuardReference = (FocusGuard)instance);
        builder.CloseComponent();
    };

    [CascadingParameter]
    private NavigationMenuRootContext? RootContext { get; set; }

    /// <summary>
    /// Allows you to replace the component's HTML element
    /// with a different tag, or compose it with another component.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<NavigationMenuViewportState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on the component state.
    /// </summary>
    [Parameter]
    public Func<NavigationMenuViewportState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on the component state.
    /// </summary>
    [Parameter]
    public Func<NavigationMenuViewportState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        state = new NavigationMenuViewportState();
        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            RootContext?.SetViewportElement(Element);
            RootContext?.SetViewportTargetElement(viewportTargetElement);
        }
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();

        attrs["id"] = RootContext?.ViewportId ?? string.Empty;
        attrs["onblur"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleBlurAsync);

        if (RootContext?.ViewportInert == true)
        {
            attrs["inert"] = true;
        }

        componentAttributes = attrs;
    }

    private Task HandleBlurAsync(FocusEventArgs e)
    {
        RootContext?.SetViewportInert(true);
        return EventUtilities.InvokeOnBlurAsync(AdditionalAttributes, e);
    }

    private Task HandleBeforeGuardFocusAsync()
    {
        RootContext?.RequestFocusInside(Element, null);
        return Task.CompletedTask;
    }

    private Task HandleAfterGuardFocusAsync()
    {
        RootContext?.RequestFocusPrevious(afterGuardReference?.Element);
        return Task.CompletedTask;
    }
}
