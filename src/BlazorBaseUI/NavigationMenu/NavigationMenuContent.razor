@using Microsoft.AspNetCore.Components.Web

@implements IDisposable

@if (ShouldRenderContent)
{
    <RenderElement TState="NavigationMenuContentState"
                   Tag="div"
                   State="state"
                   Enabled="RootContext is not null && ItemContext is not null"
                   Render="Render"
                   ClassValue="ClassValue"
                   StyleValue="StyleValue"
                   ComponentAttributes="componentAttributes"
                   ChildContent="ChildContent"
                   @attributes="AdditionalAttributes"
                   @ref="renderElementReference" />
}

@code {
    private bool focusInside;
    private bool elementRegistered;
    private ElementReference? previousElement;
    private NavigationMenuContentState state;
    private RenderElement<NavigationMenuContentState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();

    private bool ShouldRenderContent => RootContext is not null && ItemContext is not null && (state.Open || KeepMounted || elementRegistered || RootContext.GetMounted());

    [CascadingParameter]
    private NavigationMenuRootContext? RootContext { get; set; }

    [CascadingParameter]
    private NavigationMenuItemContext? ItemContext { get; set; }

    /// <summary>
    /// Determines whether the content remains mounted while closed.
    /// </summary>
    [Parameter]
    public bool KeepMounted { get; set; }

    /// <summary>
    /// Allows you to replace the component's HTML element
    /// with a different tag, or compose it with another component.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<NavigationMenuContentState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on the component state.
    /// </summary>
    [Parameter]
    public Func<NavigationMenuContentState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on the component state.
    /// </summary>
    [Parameter]
    public Func<NavigationMenuContentState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        var open = IsItemActive();
        var activationDirection = RootContext?.ActivationDirection ?? ActivationDirection.None;
        var transitionStatus = RootContext?.TransitionStatus ?? TransitionStatus.Undefined;
        state = new NavigationMenuContentState(open, activationDirection, transitionStatus);
        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override void OnAfterRender(bool firstRender)
    {
        var currentElement = renderElementReference?.Element;
        if (ItemContext is not null && currentElement.HasValue && !Nullable.Equals(previousElement, currentElement))
        {
            previousElement = currentElement;
            RootContext?.SetContentElement(ItemContext.Value, currentElement);
            elementRegistered = true;
            BuildComponentAttributes();
            _ = InvokeAsync(StateHasChanged);
        }
    }

    /// <inheritdoc />
    public void Dispose()
    {
        if (ItemContext is not null)
        {
            RootContext?.DisposeContentElement(ItemContext.Value);
        }
    }

    private bool IsItemActive()
    {
        if (RootContext is null || ItemContext is null)
        {
            return false;
        }

        return RootContext.GetValue() == ItemContext.Value;
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();
        var mounted = RootContext?.GetMounted() ?? false;

        if (state.Open)
        {
            attrs["data-open"] = true;

            if (!elementRegistered)
            {
                attrs["style"] = "position: absolute; top: 0; left: 0; visibility: hidden; pointer-events: none";
            }
        }
        else
        {
            attrs["data-closed"] = true;

            if (KeepMounted && !mounted)
            {
                attrs["hidden"] = true;
            }

            if (mounted || elementRegistered)
            {
                attrs["style"] = "position: absolute; top: 0; left: 0; visibility: hidden; pointer-events: none";
                if (!focusInside)
                {
                    attrs["inert"] = true;
                }
            }
        }

        var dirAttr = state.ActivationDirection.ToDataAttributeString();
        if (!string.IsNullOrEmpty(dirAttr))
        {
            attrs["data-activation-direction"] = dirAttr;
        }

        if (state.TransitionStatus == TransitionStatus.Starting)
        {
            attrs["data-starting-style"] = true;
        }
        else if (state.TransitionStatus == TransitionStatus.Ending)
        {
            attrs["data-ending-style"] = true;
        }

        attrs["onfocus"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleFocusAsync);
        attrs["onblur"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleBlurAsync);

        componentAttributes = attrs;
    }

    private Task HandleFocusAsync(FocusEventArgs e)
    {
        focusInside = true;
        BuildComponentAttributes();
        return EventUtilities.InvokeOnFocusAsync(AdditionalAttributes, e);
    }

    private Task HandleBlurAsync(FocusEventArgs e)
    {
        focusInside = false;
        BuildComponentAttributes();
        return EventUtilities.InvokeOnBlurAsync(AdditionalAttributes, e);
    }
}
