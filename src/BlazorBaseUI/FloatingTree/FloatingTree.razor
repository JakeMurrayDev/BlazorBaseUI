@using Microsoft.JSInterop

@implements IAsyncDisposable

@inject IJSRuntime JS

<CascadingValue Value="context" IsFixed="true">
    @ChildContent
</CascadingValue>

@code {
    private readonly Lazy<Task<IJSObjectReference>> moduleTask;
    private FloatingTreeContext context = null!;

    public FloatingTree()
    {
        moduleTask = new(() => JS.InvokeAsync<IJSObjectReference>(
            "import", "./_content/BlazorBaseUI/blazor-baseui-floating.js").AsTask());
    }

    private bool isExternal;

    /// <summary>
    /// The child content to render within the tree context.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// An optional external tree context to use instead of creating a new one.
    /// When provided, this component shares the external tree's state and skips
    /// JS-side initialization/disposal (the external tree owns its lifecycle).
    /// </summary>
    [Parameter]
    public FloatingTreeContext? ExternalTree { get; set; }

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        if (ExternalTree is not null)
        {
            context = ExternalTree;
            isExternal = true;
        }
        else
        {
            var treeId = Guid.NewGuid().ToString("N");
            context = new FloatingTreeContext(treeId);
        }

        context.ModuleTask ??= moduleTask;
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !isExternal)
        {
            try
            {
                var module = await moduleTask.Value;
                await module.InvokeVoidAsync("getFloatingTree", context.TreeId);
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex;
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (!isExternal && moduleTask.IsValueCreated)
        {
            try
            {
                var module = await moduleTask.Value;
                await module.InvokeVoidAsync("disposeFloatingTree", context.TreeId);
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }
    }
}
