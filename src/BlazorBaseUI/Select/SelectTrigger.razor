@using BlazorBaseUI.Field
@using BlazorBaseUI.Utilities
@using BlazorBaseUI.Utilities.LabelableProvider
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JS

<RenderElement TState="SelectTriggerState"
               Tag="button"
               State="state"
               Enabled="RootContext is not null"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="ChildContent"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private const string SelectModule = "./_content/BlazorBaseUI/blazor-baseui-select.js";
    private const int SelectedDelayMs = 400;
    private const int UnselectedDelayMs = 200;

    private string triggerId = null!;
    private SelectTriggerState state;
    private RenderElement<SelectTriggerState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();

    private Lazy<Task<IJSObjectReference>> moduleTask = null!;
    private DotNetObjectReference<SelectTrigger>? selfReference;
    private bool jsInitialized;

    private CancellationTokenSource? selectedDelayCts;
    private CancellationTokenSource? unselectedDelayCts;
    private (bool Open, bool Placeholder, bool HasNullItemLabel)? lastGatingKey;
    private bool suppressFocusCloseOnce;

    [CascadingParameter]
    private ISelectRootContext? RootContext { get; set; }

    [CascadingParameter]
    private LabelableContext? LabelableContext { get; set; }

    /// <summary>
    /// Determines whether the component should ignore user interaction.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Determines whether to render a native <c>&lt;button&gt;</c> element.
    /// Defaults to <see langword="true"/>.
    /// </summary>
    [Parameter]
    public bool NativeButton { get; set; } = true;

    /// <summary>
    /// Gets or sets the id attribute of the trigger element.
    /// </summary>
    [Parameter]
    public string? Id { get; set; }

    /// <summary>
    /// Allows you to replace the component's HTML element
    /// with a different tag, or compose it with another component.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<SelectTriggerState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on the component state.
    /// </summary>
    [Parameter]
    public Func<SelectTriggerState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on the component state.
    /// </summary>
    [Parameter]
    public Func<SelectTriggerState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        moduleTask = new Lazy<Task<IJSObjectReference>>(
            () => JS.InvokeAsync<IJSObjectReference>("import", SelectModule).AsTask());

        triggerId = Id ?? RootContext?.RootId ?? Guid.NewGuid().ToIdString();
        LabelableContext?.SetControlId(triggerId);

        if (RootContext is not null)
        {
            RootContext.TriggerId = triggerId;
            RootContext.StateChanged += OnRootStateChanged;
        }

        RebuildState();
        BuildComponentAttributes();
        SyncSelectionGating();
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        if (Id is not null && Id != triggerId)
        {
            triggerId = Id;
            LabelableContext?.SetControlId(triggerId);
            if (RootContext is not null)
            {
                RootContext.TriggerId = triggerId;
            }
        }

        RebuildState();
        BuildComponentAttributes();
        SyncSelectionGating();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            RootContext?.SetTriggerElement(Element);

            if (RootContext is not null && Element.HasValue)
            {
                try
                {
                    var module = await moduleTask.Value;
                    selfReference = DotNetObjectReference.Create(this);
                    await module.InvokeVoidAsync("initializeTrigger", RootContext.RootId, Element.Value, selfReference);
                    jsInitialized = true;
                }
                catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
                {
                    _ = ex;
                }
            }
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        LabelableContext?.SetControlId(null);

        if (RootContext is not null)
        {
            if (RootContext.TriggerId == triggerId)
            {
                RootContext.TriggerId = null;
            }

            RootContext.StateChanged -= OnRootStateChanged;
        }

        selectedDelayCts?.Cancel();
        selectedDelayCts?.Dispose();
        unselectedDelayCts?.Cancel();
        unselectedDelayCts?.Dispose();

        if (jsInitialized && moduleTask.IsValueCreated && RootContext is not null)
        {
            try
            {
                var module = await moduleTask.Value;
                await module.InvokeVoidAsync("disposeTrigger", RootContext.RootId);
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex;
            }
        }

        selfReference?.Dispose();
    }

    private void OnRootStateChanged()
    {
        RebuildState();
        BuildComponentAttributes();
        SyncSelectionGating();
        InvokeAsync(StateHasChanged);
    }

    private void RebuildState()
    {
        var open = RootContext?.GetOpen() ?? false;
        var disabled = Disabled || (RootContext?.Disabled ?? false);
        var placeholder = RootContext?.IsPlaceholder ?? true;
        var readOnly = RootContext?.ReadOnly ?? false;
        var fieldState = RootContext?.FieldState ?? FieldRootState.Default;
        var value = RootContext?.CurrentValueBoxed;
        state = SelectTriggerState.FromFieldState(fieldState, open, disabled, placeholder, readOnly, value);
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();
        var open = RootContext?.GetOpen() ?? false;
        var disabled = state.Disabled;
        var placeholder = state.Placeholder;
        var fieldState = RootContext?.FieldState ?? FieldRootState.Default;

        attrs["role"] = "combobox";

        if (NativeButton)
        {
            AccessibilityUtilities.ApplyNativeButtonAttributes(attrs, disabled, focusableWhenDisabled: false);
        }
        else
        {
            AccessibilityUtilities.ApplyButtonAttributes(attrs, disabled, focusableWhenDisabled: false);
        }

        // Ensure the combobox role wins over any role injected by ApplyButtonAttributes.
        attrs["role"] = "combobox";

        attrs["aria-haspopup"] = "listbox";
        attrs["aria-expanded"] = open ? "true" : "false";
        attrs["id"] = triggerId;

        if (disabled)
        {
            attrs["data-disabled"] = true;
        }

        if (RootContext?.ReadOnly == true)
        {
            attrs["aria-readonly"] = "true";
            attrs["data-readonly"] = true;
        }

        if (RootContext?.Required == true)
        {
            attrs["aria-required"] = "true";
        }

        var labelledById = AccessibilityUtilities.ResolveAriaLabelledBy(
            LabelableContext?.LabelId,
            RootContext?.LabelId);
        if (!string.IsNullOrEmpty(labelledById))
        {
            attrs["aria-labelledby"] = labelledById;
        }

        var describedBy = LabelableContext?.GetAriaDescribedBy();
        if (!string.IsNullOrEmpty(describedBy))
        {
            attrs["aria-describedby"] = describedBy;
        }

        if (fieldState.Valid == false)
        {
            attrs["aria-invalid"] = "true";
        }

        if (placeholder)
        {
            attrs["data-placeholder"] = true;
        }

        if (open)
        {
            attrs["data-popup-open"] = true;

            var listboxId = RootContext?.ListId ?? RootContext?.PopupId;
            if (listboxId is not null)
            {
                attrs["aria-controls"] = listboxId;
            }

            var openReason = RootContext?.OpenChangeReason ?? SelectOpenChangeReason.None;
            if (openReason == SelectOpenChangeReason.TriggerPress)
            {
                attrs["data-pressed"] = true;
            }
        }

        attrs["data-valid"] = fieldState.Valid == true;
        attrs["data-invalid"] = fieldState.Valid == false;
        attrs["data-touched"] = fieldState.Touched;
        attrs["data-dirty"] = fieldState.Dirty;
        attrs["data-filled"] = fieldState.Filled;
        attrs["data-focused"] = fieldState.Focused;

        attrs["onmousedown"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleMouseDownAsync);
        attrs["onkeydown"] = EventCallback.Factory.Create<KeyboardEventArgs>(this, HandleKeyDownAsync);
        attrs["onfocus"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleFocusAsync);

        // onblur and onpointermove are owned by the JS module (see initializeTrigger)
        // so it can do relatedTarget containment and pointermove tracking without
        // interop round-trips for every mouse move.

        componentAttributes = attrs;
    }

    private async Task HandleMouseDownAsync(MouseEventArgs e)
    {
        if (state.Disabled || RootContext is null)
        {
            return;
        }

        // Match React's `useClick({ event: 'mousedown' })`: only primary button toggles.
        if (e.Button != 0)
        {
            return;
        }

        RootContext.OpenInteractionType = InteractionType.Click;
        var nextOpen = !RootContext.GetOpen();
        if (nextOpen)
        {
            // Suppress the close-on-focus guard for the focus event that fires as
            // a side effect of this click. React's onFocus reads `open` from a
            // render-time captured store value, so on the first click the closure
            // still observes `open === false` and skips the guard. Blazor reads
            // live state via RootContext.GetOpen(), which is already true by the
            // time focus runs (and AlignItemWithTriggerActive is also true once
            // the positioner has re-rendered), so without this flag the guard
            // would close the popup we just opened.
            suppressFocusCloseOnce = true;
        }
        await RootContext.SetOpenAsync(nextOpen, SelectOpenChangeReason.TriggerPress);
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs e)
    {
        if (state.Disabled || RootContext is null)
        {
            return;
        }

        RootContext.KeyboardActive = true;

        if (e.Key == "ArrowDown" || e.Key == "ArrowUp" || e.Key == "Enter" || e.Key == " ")
        {
            if (!RootContext.GetOpen())
            {
                RootContext.OpenInteractionType = InteractionType.Keyboard;
                await RootContext.SetOpenAsync(true, SelectOpenChangeReason.TriggerPress);
            }
        }
        else if (!RootContext.GetOpen() && e.Key.Length == 1 && !e.CtrlKey && !e.AltKey && !e.MetaKey)
        {
            await RootContext.HandleClosedTypeaheadAsync(e.Key);
        }

        await EventUtilities.InvokeOnKeyDownAsync(AdditionalAttributes, e);
    }

    private async Task HandleFocusAsync(FocusEventArgs e)
    {
        if (RootContext is null)
        {
            return;
        }

        RootContext.OnTriggerFocus();

        var skipFocusClose = suppressFocusCloseOnce;
        suppressFocusCloseOnce = false;

        if (!skipFocusClose && RootContext.GetOpen() && RootContext.AlignItemWithTriggerActive)
        {
            await RootContext.SetOpenAsync(false, SelectOpenChangeReason.None);
        }

        // Queue a tick before flipping ForceMount, matching React's
        // `timeoutFocus.start(0, …)` so the first render after focus sees
        // the flag while items mount asynchronously.
        _ = InvokeAsync(() =>
        {
            if (RootContext is not null)
            {
                RootContext.ForceMount = true;
                RootContext.NotifyStateChanged();
            }
        });
    }

    [JSInvokable]
    public Task NotifyPointerMove()
    {
        if (RootContext is not null)
        {
            RootContext.KeyboardActive = false;
        }
        return Task.CompletedTask;
    }

    [JSInvokable]
    public async Task NotifyCancelOpen()
    {
        if (RootContext is null)
        {
            return;
        }

        if (RootContext.GetOpen())
        {
            await RootContext.SetOpenAsync(false, SelectOpenChangeReason.CancelOpen);
        }
    }

    [JSInvokable]
    public Task NotifyRealBlur()
    {
        // Clear the suppression flag on real blur so a later focus event that
        // arrives via Tab navigation (rather than as a side effect of a click
        // that just opened the popup) runs the close-on-focus guard normally.
        suppressFocusCloseOnce = false;
        RootContext?.OnTriggerBlur();
        return Task.CompletedTask;
    }

    /// <summary>
    /// Mirrors the React <c>useEffect</c> that opens/closes the mouse-up gating
    /// windows: a single 400 ms window when no selected item exists, or a 200 ms
    /// (unselected) → 400 ms (selected) pair when one does.
    /// </summary>
    private void SyncSelectionGating()
    {
        if (RootContext is null)
        {
            return;
        }

        var open = RootContext.GetOpen();
        var placeholder = RootContext.IsPlaceholder;
        var hasNullItemLabel = RootContext.HasNullItemLabel;
        var key = (open, placeholder, hasNullItemLabel);

        if (lastGatingKey == key)
        {
            return;
        }

        lastGatingKey = key;

        selectedDelayCts?.Cancel();
        selectedDelayCts?.Dispose();
        selectedDelayCts = null;

        unselectedDelayCts?.Cancel();
        unselectedDelayCts?.Dispose();
        unselectedDelayCts = null;

        if (!open)
        {
            RootContext.AllowSelectedMouseUp = false;
            RootContext.AllowUnselectedMouseUp = false;
            return;
        }

        var hasSelectedItemInList = !placeholder || hasNullItemLabel;

        if (!hasSelectedItemInList)
        {
            selectedDelayCts = new CancellationTokenSource();
            var token = selectedDelayCts.Token;
            _ = DelayThenAsync(SelectedDelayMs, token, () =>
            {
                if (RootContext is null || token.IsCancellationRequested) return;
                RootContext.AllowSelectedMouseUp = true;
                RootContext.AllowUnselectedMouseUp = true;
                RootContext.NotifyStateChanged();
            });
        }
        else
        {
            unselectedDelayCts = new CancellationTokenSource();
            var unselectedToken = unselectedDelayCts.Token;
            _ = DelayThenAsync(UnselectedDelayMs, unselectedToken, () =>
            {
                if (RootContext is null || unselectedToken.IsCancellationRequested) return;
                RootContext.AllowUnselectedMouseUp = true;
                RootContext.NotifyStateChanged();

                selectedDelayCts = new CancellationTokenSource();
                var selectedToken = selectedDelayCts.Token;
                _ = DelayThenAsync(UnselectedDelayMs, selectedToken, () =>
                {
                    if (RootContext is null || selectedToken.IsCancellationRequested) return;
                    RootContext.AllowSelectedMouseUp = true;
                    RootContext.NotifyStateChanged();
                });
            });
        }
    }

    private async Task DelayThenAsync(int delayMs, CancellationToken token, Action action)
    {
        try
        {
            await Task.Delay(delayMs, token);
            if (!token.IsCancellationRequested)
            {
                action();
            }
        }
        catch (OperationCanceledException ex)
        {
            // Expected: the gating key changed and we restarted the wait; nothing to do.
            _ = ex;
        }
        catch (Exception ex)
        {
            await DispatchExceptionAsync(ex);
        }
    }
}
