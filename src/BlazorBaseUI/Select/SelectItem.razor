@typeparam TValue
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<CascadingValue TValue="SelectItemContext" Value="itemContext" IsFixed="true">
    <RenderElement TState="SelectItemState"
                   Tag="@(NativeButton ? "button" : "div")"
                   State="state"
                   Render="Render"
                   ClassValue="ClassValue"
                   StyleValue="StyleValue"
                   ComponentAttributes="componentAttributes"
                   ChildContent="ChildContent"
                   @attributes="AdditionalAttributes"
                   @ref="renderElementReference" />
</CascadingValue>

@code {
    private const string SelectModule = "./_content/BlazorBaseUI/blazor-baseui-select.js";

    private bool highlighted;
    private bool selected;
    private int itemIndex = -1;
    private SelectItemState state;
    private SelectItemContext itemContext = new();
    private RenderElement<SelectItemState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private bool hasRegisteredValue;
    private object? registeredValueBox;
    private object? registeredLabelResolverKey;
    private bool hasRegisteredLabelResolver;
    private ElementReference? textElement;
    private Lazy<Task<IJSObjectReference>>? moduleTask;

    // Pointer/drag tracking, mirroring React `pointerTypeRef` + `didPointerDownRef`.
    private string pointerType = "mouse";
    private bool didPointerDown;

    private Lazy<Task<IJSObjectReference>> ModuleTask => moduleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>("import", SelectModule).AsTask());

    [CascadingParameter]
    private ISelectRootContext? RootContext { get; set; }

    [CascadingParameter]
    private SelectRootContext<TValue>? TypedRootContext { get; set; }

    /// <summary>
    /// Gets or sets the value of this item.
    /// </summary>
    [Parameter]
    public TValue? Value { get; set; }

    /// <summary>
    /// Determines whether the component should ignore user interaction.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets the text label used for typeahead matching. When omitted, typeahead
    /// falls back to the rendered <c>textContent</c> of the item's <see cref="SelectItemText"/>.
    /// </summary>
    [Parameter]
    public string? Label { get; set; }

    /// <summary>
    /// Gets or sets whether the item renders as a native <c>&lt;button&gt;</c> element
    /// with <c>type="button"</c>. When <see langword="false"/> (the React default),
    /// renders a <c>&lt;div&gt;</c> with <c>role="option"</c>.
    /// </summary>
    [Parameter]
    public bool NativeButton { get; set; }

    /// <summary>
    /// Allows you to replace the component's HTML element
    /// with a different tag, or compose it with another component.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<SelectItemState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on the component state.
    /// </summary>
    [Parameter]
    public Func<SelectItemState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on the component state.
    /// </summary>
    [Parameter]
    public Func<SelectItemState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        itemContext.SetTextElement = HandleTextElementChanged;

        if (RootContext is not null)
        {
            RootContext.StateChanged += OnRootStateChanged;
            RootContext.HighlightCleared += OnHighlightCleared;
            RootContext.ItemMapChanged += OnItemMapChanged;

            itemIndex = RootContext.RegisterItem(this);
        }
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        if (TypedRootContext is not null && Value is not null && !string.IsNullOrEmpty(Label))
        {
            TypedRootContext.RegisterItemLabel(Value, Label);
        }

        // Value registration mirrors React CompositeList map entries. Re-register
        // when the bound Value changes so the positioner's prune logic sees an
        // up-to-date visible set.
        if (RootContext is not null)
        {
            var boxedValue = (object?)Value;
            var currentlyTracksSame = hasRegisteredValue &&
                RootContext.AreValuesEqual(registeredValueBox, boxedValue);

            if (!currentlyTracksSame)
            {
                if (hasRegisteredValue)
                {
                    RootContext.UnregisterItemValue(registeredValueBox);
                }

                RootContext.RegisterItemValue(boxedValue);
                registeredValueBox = boxedValue;
                hasRegisteredValue = true;
            }
        }

        UpdateLabelResolverRegistration();
        RefreshDerivedState();
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (RootContext is not null)
        {
            RootContext.StateChanged -= OnRootStateChanged;
            RootContext.HighlightCleared -= OnHighlightCleared;
            RootContext.ItemMapChanged -= OnItemMapChanged;

            // Remove from the per-instance registry FIRST so that when
            // UnregisterItemValue fires ItemMapChanged below, subscribers'
            // GetItemIndex-based refresh sees a clean list and computes
            // correct sibling indexes.
            RootContext.UnregisterItem(this);

            if (hasRegisteredLabelResolver)
            {
                RootContext.UnregisterItemLabelResolver(registeredLabelResolverKey);
                hasRegisteredLabelResolver = false;
                registeredLabelResolverKey = null;
            }

            if (hasRegisteredValue)
            {
                RootContext.UnregisterItemValue(registeredValueBox);
                hasRegisteredValue = false;
                registeredValueBox = null;
            }
        }

        if (TypedRootContext is not null && Value is not null)
        {
            TypedRootContext.UnregisterItemLabel(Value);
        }

        itemContext.SetTextElement = null;

        if (moduleTask is not null && moduleTask.IsValueCreated)
        {
            try
            {
                var module = await moduleTask.Value;
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex;
            }
        }
    }

    // Stores the captured <SelectItemText> element for later use as a lazy typeahead
    // label source. Ownership of the root's `SelectedItemTextElement` is handled by
    // <SelectItemText> itself (mirrors React's localRef on SelectItemText), so this
    // method only records the node — it never writes to the root.
    private void HandleTextElementChanged(ElementReference? element)
    {
        textElement = element;
    }

    private void UpdateLabelResolverRegistration()
    {
        if (RootContext is null)
        {
            return;
        }

        var boxedValue = (object?)Value;

        if (hasRegisteredLabelResolver && !RootContext.AreValuesEqual(registeredLabelResolverKey, boxedValue))
        {
            RootContext.UnregisterItemLabelResolver(registeredLabelResolverKey);
            hasRegisteredLabelResolver = false;
            registeredLabelResolverKey = null;
        }

        if (!hasRegisteredLabelResolver)
        {
            RootContext.RegisterItemLabelResolver(boxedValue, ResolveTypeaheadLabelAsync);
            registeredLabelResolverKey = boxedValue;
            hasRegisteredLabelResolver = true;
        }
    }

    private async Task<string?> ResolveTypeaheadLabelAsync()
    {
        if (!string.IsNullOrEmpty(Label))
        {
            return Label;
        }

        if (!textElement.HasValue)
        {
            return null;
        }

        try
        {
            var module = await ModuleTask.Value;
            return await module.InvokeAsync<string?>("getElementText", textElement.Value);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
            return null;
        }
    }

    private void OnRootStateChanged()
    {
        if (RefreshDerivedState())
        {
            InvokeAsync(StateHasChanged);
        }
    }

    private void OnHighlightCleared()
    {
        if (RefreshDerivedState())
        {
            InvokeAsync(StateHasChanged);
        }
    }

    private void OnItemMapChanged()
    {
        if (RefreshDerivedState())
        {
            InvokeAsync(StateHasChanged);
        }
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // The C# `RegisterItem` registry returns insertion-order indexes which can
        // diverge from DOM order when items are inserted mid-list (e.g., a conditional
        // @if block adds an item between two existing ones). JS's keyboard navigation
        // and `data-highlighted` writes always use DOM order via `querySelectorAll`,
        // so we ask JS for the authoritative index after every render and reconcile.
        if (RootContext is null || !Element.HasValue)
        {
            return;
        }

        // Skip the JS reconciliation while the popup is closed (or its exit
        // transition has completed and items are only still mounted because
        // KeepMounted/ForceMount kept the portal alive). DOM order can't have
        // shifted relative to the listbox while the listbox isn't visible, and
        // running per-item JS interop on every parent re-render for closed
        // Selects is the dominant per-render cost when multiple demos share a
        // page (~N_items round-trips per outer render).
        if (!RootContext.GetMounted())
        {
            return;
        }

        try
        {
            var module = await ModuleTask.Value;
            var domIndex = await module.InvokeAsync<int>("getOptionDomIndex", Element.Value);
            if (domIndex != itemIndex && domIndex >= 0)
            {
                itemIndex = domIndex;
                if (RefreshDerivedState())
                {
                    StateHasChanged();
                }
            }
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }
    }

    private bool RefreshDerivedState()
    {
        // `itemIndex` is the DOM-order index seeded in OnInitialized via RegisterItem
        // (C# insertion order, correct for static lists) and corrected in
        // OnAfterRenderAsync via JS `getOptionDomIndex` (authoritative for dynamic
        // mid-list insertions). Don't call `RootContext.GetItemIndex(this)` here —
        // that returns the C# registration order which may be stale.
        var idx = itemIndex;
        var newSelected = RootContext?.IsValueSelected(Value) ?? false;

        // When this item matches the currently-selected value, promote its index
        // to the root's <see cref="ISelectRootContext.SelectedIndex"/> so
        // <see cref="SelectItemText"/> can claim the selected-text-element slot
        // via its <c>SelectedByFocus</c> branch. Mirrors React's
        // <c>useIsoLayoutEffect</c> in SelectItem.tsx that writes
        // <c>store.set('selectedIndex', index)</c> when the item value matches.
        // Required when <see cref="SelectRoot{TValue}.Items"/> is not supplied
        // (the only path that previously wrote SelectedIndex); without this,
        // sections bound with <c>@bind-Value</c> after the user picks a non-first
        // item would leave <c>SelectedIndex = -1</c> after close/reopen, and the
        // align-item-with-trigger layout would fall back to aligning item 0 with
        // the trigger.
        if (newSelected && idx >= 0 && TypedRootContext is not null &&
            TypedRootContext.SelectedIndex != idx)
        {
            TypedRootContext.SelectedIndex = idx;
        }

        var newHighlighted = idx >= 0 && (RootContext?.ActiveIndex ?? -1) == idx;
        var newHasRegistered = idx >= 0;
        var newSelectedByFocus = idx >= 0 && (RootContext?.IsSelectedByFocus(idx) ?? false);

        var changed = selected != newSelected
            || highlighted != newHighlighted
            || itemContext.HasRegistered != newHasRegistered
            || itemContext.SelectedByFocus != newSelectedByFocus
            || itemContext.Index != idx;

        selected = newSelected;
        highlighted = newHighlighted;
        itemContext.Selected = newSelected;
        itemContext.Index = idx;
        itemContext.HasRegistered = newHasRegistered;
        itemContext.SelectedByFocus = newSelectedByFocus;
        state = new SelectItemState(Disabled, newSelected, newHighlighted);

        // The root's SelectedItemTextElement is owned by <SelectItemText> — see its
        // OnAfterRender for the React-parity claim/release logic (selectedByFocus or
        // index-0 fallback). This method intentionally does NOT write to it.

        if (changed || componentAttributes.Count == 0)
        {
            BuildComponentAttributes();
        }

        return changed;
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>
        {
            ["data-selected"] = selected,
            ["data-highlighted"] = highlighted,
            ["data-disabled"] = Disabled,
            ["aria-selected"] = selected ? "true" : "false",
        };

        if (NativeButton)
        {
            AccessibilityUtilities.ApplyNativeButtonAttributes(
                attrs,
                Disabled,
                focusableWhenDisabled: true,
                tabIndex: highlighted ? 0 : -1);
        }
        else
        {
            AccessibilityUtilities.ApplyButtonAttributes(
                attrs,
                Disabled,
                focusableWhenDisabled: true,
                tabIndex: highlighted ? 0 : -1);
        }

        // `ApplyButtonAttributes` writes role="button"; override back to the listbox
        // option role. `ApplyNativeButtonAttributes` does not write role, so this is
        // a no-op in the native-button path.
        attrs["role"] = "option";

        if (!string.IsNullOrEmpty(Label))
        {
            attrs["data-blazor-base-ui-label"] = Label;
        }

        attrs["onclick"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleClickAsync);
        attrs["onpointerenter"] = EventCallback.Factory.Create<PointerEventArgs>(this, HandlePointerEnter);
        attrs["onpointerdown"] = EventCallback.Factory.Create<PointerEventArgs>(this, HandlePointerDown);
        attrs["ontouchstart"] = EventCallback.Factory.Create<TouchEventArgs>(this, HandleTouchStartAsync);
        attrs["onmouseup"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleMouseUpAsync);
        attrs["onmouseenter"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleMouseEnterAsync);
        attrs["onmouseleave"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleMouseLeaveAsync);
        attrs["onmousemove"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleMouseMoveAsync);
        attrs["onfocus"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleFocusAsync);

        componentAttributes = attrs;
    }

    private async Task HandleClickAsync(MouseEventArgs e)
    {
        didPointerDown = false;

        if (Disabled || TypedRootContext is null)
        {
            return;
        }

        // React parity: for mouse, require the item to already be highlighted
        // (it was hovered/focused first). Touch skips this check — a tap commits directly.
        if (pointerType != "touch" && !highlighted)
        {
            return;
        }

        await TypedRootContext.SelectValueAsync(Value);
        await EventUtilities.InvokeOnClickAsync(AdditionalAttributes, e);
    }

    private void HandlePointerEnter(PointerEventArgs e)
    {
        pointerType = string.IsNullOrEmpty(e.PointerType) ? "mouse" : e.PointerType;
    }

    private void HandlePointerDown(PointerEventArgs e)
    {
        pointerType = string.IsNullOrEmpty(e.PointerType) ? pointerType : e.PointerType;
        didPointerDown = true;
    }

    private async Task HandleTouchStartAsync(TouchEventArgs e)
    {
        pointerType = "touch";

        if (RootContext is not null)
        {
            RootContext.AllowSelectedMouseUp = false;
            RootContext.AllowUnselectedMouseUp = false;
        }

        await EventUtilities.InvokeOnTouchStartAsync(AdditionalAttributes, e);
    }

    private async Task HandleMouseUpAsync(MouseEventArgs e)
    {
        if (Disabled || TypedRootContext is null || RootContext is null)
        {
            return;
        }

        // React parity: if the user pressed and released on the same item, `onclick`
        // will fire next and handle the commit. Skip the drag-to-select path here.
        if (didPointerDown)
        {
            didPointerDown = false;
            return;
        }

        var disallowSelected = !RootContext.AllowSelectedMouseUp && selected;
        var disallowUnselected = !RootContext.AllowUnselectedMouseUp && !selected;

        if (disallowSelected || disallowUnselected || (pointerType != "touch" && !highlighted))
        {
            return;
        }

        await TypedRootContext.SelectValueAsync(Value);
        await EventUtilities.InvokeOnMouseUpAsync(AdditionalAttributes, e);
    }

    private async Task HandleMouseEnterAsync(MouseEventArgs e)
    {
        if (!Disabled
            && (RootContext?.HighlightItemOnHover ?? true)
            && !(RootContext?.KeyboardActive ?? false)
            && (RootContext?.SelectedIndex ?? -1) < 0
            && itemIndex >= 0
            && RootContext is not null)
        {
            await RootContext.SetHoverActiveIndexAsync(itemIndex);
        }

        await EventUtilities.InvokeOnMouseEnterAsync(AdditionalAttributes, e);
    }

    private async Task HandleMouseMoveAsync(MouseEventArgs e)
    {
        if (!Disabled
            && (RootContext?.HighlightItemOnHover ?? true)
            && !(RootContext?.KeyboardActive ?? false)
            && itemIndex >= 0
            && RootContext is not null
            && RootContext.ActiveIndex != itemIndex)
        {
            await RootContext.SetHoverActiveIndexAsync(itemIndex);
        }

        await EventUtilities.InvokeOnMouseMoveAsync(AdditionalAttributes, e);
    }

    private async Task HandleMouseLeaveAsync(MouseEventArgs e)
    {
        if ((RootContext?.HighlightItemOnHover ?? true)
            && !(RootContext?.KeyboardActive ?? false)
            && pointerType != "touch"
            && itemIndex >= 0
            && RootContext is not null)
        {
            // Defer one turn so a sibling's onmouseenter can move ActiveIndex first;
            // the compare-and-clear inside ClearHoverActiveIndexAsync then skips us.
            await Task.Yield();
            await RootContext.ClearHoverActiveIndexAsync(itemIndex);
        }

        await EventUtilities.InvokeOnMouseLeaveAsync(AdditionalAttributes, e);
    }

    private async Task HandleFocusAsync(FocusEventArgs e)
    {
        if (itemIndex >= 0 && RootContext is not null && RootContext.ActiveIndex != itemIndex)
        {
            await RootContext.SetHoverActiveIndexAsync(itemIndex);
        }

        await EventUtilities.InvokeOnFocusAsync(AdditionalAttributes, e);
    }
}
