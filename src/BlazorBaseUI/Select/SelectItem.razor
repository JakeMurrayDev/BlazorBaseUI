@typeparam TValue
@using Microsoft.AspNetCore.Components.Web
@implements IDisposable

<CascadingValue TValue="SelectItemContext" Value="itemContext" IsFixed="true">
    <RenderElement TState="SelectItemState"
                   Tag="div"
                   State="state"
                   Render="Render"
                   ClassValue="ClassValue"
                   StyleValue="StyleValue"
                   ComponentAttributes="componentAttributes"
                   ChildContent="ChildContent"
                   @attributes="AdditionalAttributes"
                   @ref="renderElementReference" />
</CascadingValue>

@code {
    private bool highlighted;
    private bool selected;
    private SelectItemState state;
    private SelectItemContext itemContext = new();
    private RenderElement<SelectItemState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();

    [CascadingParameter]
    private ISelectRootContext? RootContext { get; set; }

    [CascadingParameter]
    private SelectRootContext<TValue>? TypedRootContext { get; set; }

    /// <summary>
    /// Gets or sets the value of this item.
    /// </summary>
    [Parameter]
    public TValue? Value { get; set; }

    /// <summary>
    /// Determines whether the component should ignore user interaction.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets the text label to use when the item is matched during keyboard text navigation.
    /// </summary>
    [Parameter]
    public string? Label { get; set; }

    /// <summary>
    /// Allows you to replace the component's HTML element
    /// with a different tag, or compose it with another component.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<SelectItemState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on the component state.
    /// </summary>
    [Parameter]
    public Func<SelectItemState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on the component state.
    /// </summary>
    [Parameter]
    public Func<SelectItemState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        if (RootContext is not null)
        {
            RootContext.StateChanged += OnRootStateChanged;
            RootContext.HighlightCleared += OnHighlightCleared;
        }
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        selected = RootContext?.IsValueSelected(Value) ?? false;
        itemContext.Selected = selected;
        state = new SelectItemState(Disabled, selected, highlighted);
        BuildComponentAttributes();

        if (TypedRootContext is not null && Value is not null && !string.IsNullOrEmpty(Label))
        {
            TypedRootContext.RegisterItemLabel(Value, Label);
        }
    }

    /// <inheritdoc />
    public void Dispose()
    {
        if (RootContext is not null)
        {
            RootContext.StateChanged -= OnRootStateChanged;
            RootContext.HighlightCleared -= OnHighlightCleared;
        }

        if (TypedRootContext is not null && Value is not null)
        {
            TypedRootContext.UnregisterItemLabel(Value);
        }
    }

    private void OnRootStateChanged()
    {
        var newSelected = RootContext?.IsValueSelected(Value) ?? false;
        if (newSelected != selected)
        {
            selected = newSelected;
            itemContext.Selected = selected;
            state = new SelectItemState(Disabled, selected, highlighted);
            BuildComponentAttributes();
            InvokeAsync(StateHasChanged);
        }
    }

    private void OnHighlightCleared()
    {
        if (highlighted)
        {
            highlighted = false;
            state = state with { Highlighted = false };
            BuildComponentAttributes();
            InvokeAsync(StateHasChanged);
        }
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();

        attrs["role"] = "option";
        attrs["aria-selected"] = selected ? "true" : "false";
        attrs["tabindex"] = highlighted ? 0 : -1;

        if (Disabled)
        {
            attrs["aria-disabled"] = "true";
            attrs["data-disabled"] = true;
        }

        if (selected)
        {
            attrs["data-selected"] = true;
        }

        attrs["data-highlighted"] = highlighted;

        if (!string.IsNullOrEmpty(Label))
        {
            attrs["data-label"] = Label;
        }

        attrs["onclick"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleClickAsync);
        attrs["onmouseenter"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleMouseEnterAsync);
        attrs["onmouseleave"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleMouseLeaveAsync);
        attrs["onmousemove"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleMouseMoveAsync);

        componentAttributes = attrs;
    }

    private async Task HandleClickAsync(MouseEventArgs e)
    {
        if (Disabled || TypedRootContext is null)
        {
            return;
        }

        await TypedRootContext.SelectValueAsync(Value);

        await EventUtilities.InvokeOnClickAsync(AdditionalAttributes, e);
    }

    private async Task HandleMouseEnterAsync(MouseEventArgs e)
    {
        var shouldHighlight = RootContext?.HighlightItemOnHover ?? true;
        if (!Disabled && shouldHighlight)
        {
            highlighted = true;
            state = state with { Highlighted = true };
            BuildComponentAttributes();
            StateHasChanged();

            if (RootContext is not null)
            {
                _ = RootContext.ClearHighlightsAsync();
            }
        }

        await EventUtilities.InvokeOnMouseEnterAsync(AdditionalAttributes, e);
    }

    private async Task HandleMouseLeaveAsync(MouseEventArgs e)
    {
        var shouldHighlight = RootContext?.HighlightItemOnHover ?? true;
        if (shouldHighlight)
        {
            highlighted = false;
            state = state with { Highlighted = false };
            BuildComponentAttributes();
            StateHasChanged();
        }

        await EventUtilities.InvokeOnMouseLeaveAsync(AdditionalAttributes, e);
    }

    private Task HandleMouseMoveAsync(MouseEventArgs e)
    {
        var shouldHighlight = RootContext?.HighlightItemOnHover ?? true;
        if (!Disabled && !highlighted && shouldHighlight)
        {
            highlighted = true;
            state = state with { Highlighted = true };
            BuildComponentAttributes();
            StateHasChanged();
        }

        return Task.CompletedTask;
    }
}
