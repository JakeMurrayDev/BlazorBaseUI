@typeparam TValue
@using BlazorBaseUI.DirectionProvider
@using BlazorBaseUI.Field
@using BlazorBaseUI.Form
@using BlazorBaseUI.Utilities
@using BlazorBaseUI.Utilities.LabelableProvider
@using Microsoft.JSInterop

@implements IAsyncDisposable
@implements IFieldStateSubscriber
@inject IJSRuntime JSRuntime

<CascadingValue TValue="IFloatingRootContext" Value="typedContext?.FloatingRootContext" IsFixed="true">
    <CascadingValue TValue="ISelectRootContext" Value="context" IsFixed="true">
        <CascadingValue TValue="SelectRootContext<TValue>" Value="typedContext" IsFixed="true">
            @ChildContent
        </CascadingValue>
    </CascadingValue>
</CascadingValue>

@{
    var hasName = !string.IsNullOrEmpty(ResolvedName);
    var hasField = FieldContext is not null;
    var serializedValue = typedContext?.GetFormValue(CurrentValue) ?? CurrentValue?.ToString() ?? string.Empty;
    var hasMultipleSelection = Multiple && GetCurrentValues().Count > 0;
    var hiddenInputName = Multiple ? null : ResolvedName;
    var hiddenInputId = hiddenInputName is null ? $"{rootId}-hidden-input" : null;
    var describedBy = LabelableContext?.GetAriaDescribedBy();
}

<input style="border:0;clip:rect(0 0 0 0);height:1px;margin:-1px;overflow:hidden;padding:0;position:absolute;white-space:nowrap;width:1px"
       tabindex="-1"
       aria-hidden="true"
       id="@hiddenInputId"
       name="@hiddenInputName"
       form="@Form"
       autocomplete="@AutoComplete"
       value="@serializedValue"
       disabled="@ResolvedDisabled"
       required="@(Required && !hasMultipleSelection)"
       readonly="@ReadOnly"
       aria-invalid="@(FieldState.Valid == false ? "true" : null)"
       aria-describedby="@(string.IsNullOrEmpty(describedBy) ? null : describedBy)"
       @ref="hiddenInputElement"
       @onfocus="HandleHiddenInputFocus"
       @onchange="HandleHiddenInputChange" />

@if (Multiple && hasName)
{
    var values = GetCurrentValues();
    @foreach (var v in values)
    {
        <input type="hidden" name="@ResolvedName" form="@Form" value="@(typedContext?.GetFormValue(v) ?? v?.ToString())" />
    }
}

@code {
    private string rootId = null!;

    private Lazy<Task<IJSObjectReference>>? moduleTask;
    private bool hasRendered;
    private bool isOpen;
    private bool previousReadOnly;
    private bool previousDisabled;
    private Direction previousDirection;
    private readonly TransitionLifecycleManager transition = new();
    private int activeIndex = -1;
    private TValue? internalValue;
    private List<TValue> internalValues = new();
    private ElementReference hiddenInputElement;
    private ElementReference? previousHiddenInputElement;
    private ElementReference? triggerElement;
    private ElementReference? popupElement;
    private ElementReference? positionerElement;
    private ElementReference? valueElement;
    private ElementReference? selectedItemTextElement;
    private ElementReference? listElement;
    private SelectOpenChangeReason openChangeReason = SelectOpenChangeReason.None;
    private SelectRootState state;
    internal SelectRootContext<TValue> typedContext = null!;
    private ISelectRootContext context = null!;
    private DotNetObjectReference<SelectRoot<TValue>>? dotNetRef;
    private bool hasValueParameter;
    private bool hasValuesParameter;
    private SelectRootActions? previousActionsRef;

    private Lazy<Task<IJSObjectReference>> ModuleTask => moduleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>(
            "import", "./_content/BlazorBaseUI/blazor-baseui-select.js").AsTask());

    private bool IsControlled => Open.HasValue;

    private bool CurrentOpen => IsControlled ? Open!.Value : isOpen;

    private TValue? CurrentValue => IsValueControlled ? Value : internalValue;

    private bool IsValueControlled => hasValueParameter;

    private bool ResolvedDisabled => Disabled || (FieldContext?.Disabled ?? false);

    private string? ResolvedName => Name ?? FieldContext?.Name;

    private FieldRootState FieldState => FieldContext?.State ?? FieldRootState.Default;

    private Direction EffectiveDirection => Direction != Direction.Undefined
        ? Direction
        : DirectionContext?.Direction ?? Direction.Ltr;

    /// <summary>
    /// Gets or sets whether the select popup is currently open.
    /// </summary>
    [Parameter]
    public bool? Open { get; set; }

    /// <summary>
    /// Determines whether the select popup is initially open.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool DefaultOpen { get; set; }

    /// <summary>
    /// Gets or sets the currently selected value.
    /// </summary>
    [Parameter]
    public TValue? Value { get; set; }

    /// <summary>
    /// Gets or sets the default selected value.
    /// </summary>
    [Parameter]
    public TValue? DefaultValue { get; set; }

    /// <summary>
    /// Gets or sets the default selected values for multiple selection.
    /// </summary>
    [Parameter]
    public IReadOnlyList<TValue>? DefaultValues { get; set; }

    /// <summary>
    /// Gets or sets whether multiple items can be selected.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool Multiple { get; set; }

    /// <summary>
    /// Determines whether items are highlighted when the pointer moves over them.
    /// Defaults to <see langword="true"/>.
    /// </summary>
    [Parameter]
    public bool HighlightItemOnHover { get; set; } = true;

    /// <summary>
    /// Determines whether the component should ignore user interaction.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Determines whether the component is read-only.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool ReadOnly { get; set; }

    /// <summary>
    /// Determines whether a value is required.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool Required { get; set; }

    /// <summary>
    /// Gets or sets the modal behavior of the select when open.
    /// </summary>
    [Parameter]
    public SelectModalMode Modal { get; set; } = SelectModalMode.True;

    /// <summary>
    /// Gets or sets the text direction of the select.
    /// </summary>
    [Parameter]
    public Direction Direction { get; set; } = Direction.Undefined;

    /// <summary>
    /// Gets or sets the identifier of the select root.
    /// When provided, this ID is used as the root identifier and as the default trigger ID.
    /// </summary>
    [Parameter]
    public string? Id { get; set; }

    /// <summary>
    /// Gets or sets the name of the hidden form input.
    /// </summary>
    [Parameter]
    public string? Name { get; set; }

    /// <summary>
    /// Provides a hint to the browser for autofill on the hidden form input.
    /// </summary>
    [Parameter]
    public string? AutoComplete { get; set; }

    /// <summary>
    /// Gets or sets the id of the native form associated with the hidden input.
    /// </summary>
    [Parameter]
    public string? Form { get; set; }

    /// <summary>
    /// Gets or sets a function to convert a value to its string label for display.
    /// </summary>
    [Parameter]
    public Func<TValue?, string?>? ItemToStringLabel { get; set; }

    /// <summary>
    /// Gets or sets a function to convert a value to its string representation for form submission.
    /// </summary>
    [Parameter]
    public Func<TValue?, string?>? ItemToStringValue { get; set; }

    /// <summary>
    /// Gets or sets a custom equality comparer for item values.
    /// When provided, this function is used instead of the default equality comparer
    /// to determine if two values are equal (e.g., for case-insensitive string comparison).
    /// </summary>
    [Parameter]
    public Func<TValue, TValue, bool>? IsItemEqualToValue { get; set; }

    /// <summary>
    /// Gets or sets the static list of options for pre-mount label resolution.
    /// Provides label lookup before <see cref="SelectItem{TValue}"/> components mount,
    /// mirroring React Base UI's <c>items</c> prop used for <c>resolveSelectedLabel</c>.
    /// </summary>
    [Parameter]
    public IReadOnlyList<SelectOption<TValue>>? Items { get; set; }

    /// <summary>
    /// Gets or sets the grouped static options for pre-mount label resolution.
    /// Mirrors React Base UI's grouped <c>{ items: [...] }</c> shape accepted by
    /// <c>resolveSelectedLabel</c>. Usable together with <see cref="Items"/>; both
    /// are scanned when resolving a label.
    /// </summary>
    [Parameter]
    public IReadOnlyList<SelectOptionGroup<TValue>>? ItemGroups { get; set; }

    /// <summary>
    /// Gets or sets the callback for two-way binding of the open state.
    /// </summary>
    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the select is opened or closed.
    /// </summary>
    [Parameter]
    public EventCallback<SelectOpenChangeEventArgs> OnOpenChange { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked after any open/close transition animations complete.
    /// </summary>
    [Parameter]
    public EventCallback<bool> OnOpenChangeComplete { get; set; }

    /// <summary>
    /// Gets or sets the callback for two-way binding of the selected value.
    /// </summary>
    [Parameter]
    public EventCallback<TValue?> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the currently selected values for multiple selection.
    /// </summary>
    [Parameter]
    public IReadOnlyList<TValue>? Values { get; set; }

    /// <summary>
    /// Gets or sets the callback for two-way binding of the selected values in multi-select mode.
    /// </summary>
    [Parameter]
    public EventCallback<IReadOnlyList<TValue>> ValuesChanged { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the selected value changes.
    /// </summary>
    [Parameter]
    public EventCallback<SelectValueChangeEventArgs<TValue>> OnValueChange { get; set; }

    /// <summary>
    /// Gets or sets the imperative actions object for the select root.
    /// </summary>
    [Parameter]
    public SelectRootActions? ActionsRef { get; set; }

    /// <summary>
    /// Gets or sets a callback that receives the hidden input element reference.
    /// </summary>
    [Parameter]
    public Action<ElementReference?>? InputRef { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [CascadingParameter]
    private FieldRootContext? FieldContext { get; set; }

    [CascadingParameter]
    private FormContext? FormContext { get; set; }

    [CascadingParameter]
    private LabelableContext? LabelableContext { get; set; }

    [CascadingParameter]
    private DirectionProviderContext? DirectionContext { get; set; }

    /// <inheritdoc />
    public override Task SetParametersAsync(ParameterView parameters)
    {
        hasValueParameter = parameters.TryGetValue<TValue?>(nameof(Value), out _);
        hasValuesParameter = parameters.TryGetValue<IReadOnlyList<TValue>?>(nameof(Values), out _);

        return base.SetParametersAsync(parameters);
    }

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        rootId = Id ?? Guid.NewGuid().ToIdString();
        isOpen = DefaultOpen;

        if (CurrentOpen)
        {
            transition.BeginOpen();
        }

        if (!IsValueControlled)
        {
            if (Multiple && DefaultValues is not null)
            {
                internalValues = new List<TValue>(DefaultValues);
            }
            else if (DefaultValue is not null)
            {
                internalValue = DefaultValue;
            }
        }

        var isFilled = !IsPlaceholderState();
        FieldContext?.Validation.SetInitialValue(GetValidationValue());
        FieldContext?.SetFilled(isFilled);
        FieldContext?.RegisterFocusHandler(FocusTriggerAsync);
        FieldContext?.Subscribe(this);

        state = SelectRootState.FromFieldState(FieldState, CurrentOpen);

        typedContext = new SelectRootContext<TValue>
        {
            RootId = rootId,
            Open = CurrentOpen,
            Mounted = transition.IsMounted,
            Disabled = ResolvedDisabled,
            ReadOnly = ReadOnly,
            Required = Required,
            Multiple = Multiple,
            HighlightItemOnHover = HighlightItemOnHover,
            OpenChangeReason = openChangeReason,
            TransitionStatus = transition.TransitionStatus,
            ActiveIndex = activeIndex,
            FieldState = FieldState,
            Items = Items,
            ItemGroups = ItemGroups,
            ItemToStringLabel = ItemToStringLabel,
            ItemToStringValue = ItemToStringValue,
            IsItemEqualToValue = IsItemEqualToValue,
            GetOpen = () => CurrentOpen,
            GetMounted = () => transition.IsMounted,
            GetTriggerElement = () => triggerElement,
            SetTriggerElement = SetTriggerElement,
            GetPopupElement = () => popupElement,
            SetPopupElement = SetPopupElement,
            GetPositionerElement = () => positionerElement,
            SetPositionerElement = SetPositionerElement,
            GetValueElement = () => valueElement,
            SetValueElement = SetValueElement,
            GetSelectedItemTextElement = () => selectedItemTextElement,
            SetSelectedItemTextElement = SetSelectedItemTextElement,
            SetListElement = SetListElement,
            ClearHighlightsAsync = ClearHighlightsInternalAsync,
            SetActiveIndex = SetActiveIndex,
            SetOpenAsync = SetOpenAsyncFromContext,
            GetValue = () => CurrentValue,
            GetValues = GetCurrentValues,
            SelectValueAsync = SelectValueInternalAsync,
            SetValueBoxedFunc = SetValueBoxedInternalAsync,
            SyncActiveIndexSilentFunc = SyncActiveIndexSilentAsync,
            OnTriggerFocusAction = HandleTriggerFocus,
            OnTriggerBlurAction = HandleTriggerBlur,
            OpenInteractionType = InteractionType.None,
            AllowSelectedMouseUp = false,
            AllowUnselectedMouseUp = false,
            KeyboardActive = false,
            Modal = Modal == SelectModalMode.True,
            InitialValueBoxed = Multiple
                ? (GetCurrentValues().Count == 0 ? null : (object?)GetCurrentValues()[0])
                : (object?)CurrentValue
        };

        typedContext.FloatingRootContext = new SelectFloatingRootContextAdapter(typedContext);
        context = typedContext;
        previousDisabled = ResolvedDisabled;
        previousDirection = EffectiveDirection;
        SyncActionsRef();
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        var currentOpen = CurrentOpen;
        var effectiveDirection = EffectiveDirection;
        if (state.Open != currentOpen)
        {
            if (currentOpen)
            {
                transition.BeginOpen();
                activeIndex = 0;
            }
            else
            {
                transition.BeginClose();
                context.OpenInteractionType = InteractionType.None;
                SyncSelectedIndex();
            }

            context.TransitionStatus = transition.TransitionStatus;
            context.Open = currentOpen;
            context.Mounted = transition.IsMounted;
            context.ActiveIndex = activeIndex;
            context.OpenChangeReason = SelectOpenChangeReason.None;

            if (hasRendered)
            {
                _ = SyncRootOpenAsync(currentOpen, SelectOpenChangeReason.None);
            }
        }

        context.Disabled = ResolvedDisabled;
        context.ReadOnly = ReadOnly;
        context.Required = Required;
        context.Multiple = Multiple;
        context.HighlightItemOnHover = HighlightItemOnHover;
        var modal = Modal == SelectModalMode.True;
        if (context.Modal != modal)
        {
            context.Modal = modal;
            typedContext.NotifyStateChanged();
        }

        typedContext.Items = Items;
        typedContext.ItemGroups = ItemGroups;
        typedContext.ItemToStringLabel = ItemToStringLabel;
        typedContext.ItemToStringValue = ItemToStringValue;
        typedContext.IsItemEqualToValue = IsItemEqualToValue;
        typedContext.FieldState = FieldState;

        state = SelectRootState.FromFieldState(FieldState, currentOpen);

        if (!currentOpen)
        {
            SyncSelectedIndex();
        }

        if (hasRendered && previousReadOnly != ReadOnly)
        {
            previousReadOnly = ReadOnly;
            _ = SyncReadOnlyAsync(ReadOnly);
        }

        if (hasRendered && previousDisabled != ResolvedDisabled)
        {
            previousDisabled = ResolvedDisabled;
            _ = SyncDisabledAsync(ResolvedDisabled);
        }

        if (hasRendered && previousDirection != effectiveDirection)
        {
            previousDirection = effectiveDirection;
            _ = SyncDirectionAsync(effectiveDirection);
        }

        SyncActionsRef();
    }

    private async Task SyncReadOnlyAsync(bool readOnly)
    {
        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync("setReadOnly", rootId, readOnly);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task SyncDisabledAsync(bool disabled)
    {
        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync("setDisabled", rootId, disabled);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task SyncDirectionAsync(Direction direction)
    {
        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync("setDirection", rootId, direction.ToAttributeString() ?? "ltr");
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    /// <inheritdoc />
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            hasRendered = true;
            previousReadOnly = ReadOnly;
            previousDisabled = ResolvedDisabled;
            previousDirection = EffectiveDirection;
            dotNetRef = DotNetObjectReference.Create(this);
            _ = InitializeJsAsync();
        }

        NotifyInputRefIfNeeded();
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        FieldContext?.Unsubscribe(this);

        if (moduleTask?.IsValueCreated == true && hasRendered)
        {
            try
            {
                var module = await ModuleTask.Value;
                await module.InvokeVoidAsync("disposeRoot", rootId);
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }

        if (previousActionsRef is not null)
        {
            previousActionsRef.Unmount = null;
        }

        InputRef?.Invoke(null);
        typedContext?.Dispose();
        dotNetRef?.Dispose();
    }

    /// <inheritdoc />
    public void NotifyStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Invoked from JavaScript when a click occurs outside the select.
    /// </summary>
    [JSInvokable]
    public async Task OnOutsidePress()
    {
        await SetOpenAsync(false, SelectOpenChangeReason.OutsidePress);
    }

    /// <summary>
    /// Invoked from JavaScript when the Escape key is pressed.
    /// </summary>
    [JSInvokable]
    public async Task OnEscapeKey()
    {
        await SetOpenAsync(false, SelectOpenChangeReason.EscapeKey);
    }

    /// <summary>
    /// Invoked from JavaScript when the Tab key is pressed while open.
    /// </summary>
    [JSInvokable]
    public async Task OnTabKey()
    {
        await SetOpenAsync(false, SelectOpenChangeReason.FocusOut);
    }

    /// <summary>
    /// Invoked from JavaScript when keyboard/mouse active state changes.
    /// </summary>
    [JSInvokable]
    public void OnKeyboardActiveChange(bool active)
    {
        context.KeyboardActive = active;
    }

    /// <summary>
    /// Invoked from JavaScript after the opening starting styles have been applied.
    /// </summary>
    [JSInvokable]
    public void OnStartingStyleApplied()
    {
        if (!transition.HandleStartingStyleApplied())
        {
            return;
        }

        context.TransitionStatus = transition.TransitionStatus;
        typedContext.NotifyStateChanged();
        StateHasChanged();
    }

    /// <summary>
    /// Invoked from JavaScript when a transition animation completes.
    /// </summary>
    [JSInvokable]
    public void OnTransitionEnd(bool open)
    {
        var unmounted = transition.HandleTransitionEnd(open);
        context.TransitionStatus = transition.TransitionStatus;

        if (unmounted)
        {
            context.Mounted = false;
            activeIndex = -1;
            context.ActiveIndex = activeIndex;

            // Reset the focus-driven force-mount latch so the portal can drop
            // its children once the exit transition completes. SelectTrigger
            // sets `ForceMount = true` on focus to mirror React's
            // `timeoutFocus.start(0, …)` (so items mount before the popup
            // formally opens), and React clears its analog when the popup
            // closes. Without this reset, every focused-then-closed Select
            // keeps its portal+items mounted forever — multiple selects on a
            // page snowball into per-render JS interop in every mounted item
            // (SelectItem.OnAfterRenderAsync calls `getOptionDomIndex`).
            context.ForceMount = false;
        }

        _ = InvokeOpenChangeCompleteAsync(open);
        StateHasChanged();
    }

    /// <summary>
    /// Invoked from JavaScript when scroll arrow visibility changes.
    /// </summary>
    [JSInvokable]
    public void OnScrollArrowVisibilityChange(bool up, bool down)
    {
        if (context.ScrollUpArrowVisible != up || context.ScrollDownArrowVisible != down)
        {
            context.ScrollUpArrowVisible = up;
            context.ScrollDownArrowVisible = down;
            typedContext.NotifyStateChanged();
            StateHasChanged();
        }
    }

    /// <summary>
    /// Invoked from JavaScript when the active item index changes.
    /// </summary>
    [JSInvokable]
    public void OnActiveIndexChange(int index)
    {
        if (activeIndex != index)
        {
            activeIndex = index;
            context.ActiveIndex = index;
            typedContext.NotifyHighlightCleared();
            typedContext.NotifyStateChanged();
            StateHasChanged();
        }
    }

    /// <summary>
    /// Sets the open state of the select with the specified reason.
    /// </summary>
    private async Task SetOpenAsync(bool nextOpen, SelectOpenChangeReason reason)
    {
        if (CurrentOpen == nextOpen)
        {
            return;
        }

        var args = new SelectOpenChangeEventArgs(nextOpen, reason);
        await OnOpenChange.InvokeAsync(args);

        if (args.IsCanceled)
        {
            return;
        }

        openChangeReason = reason;
        context.OpenChangeReason = reason;

        if (nextOpen)
        {
            transition.BeginOpen();
            activeIndex = 0;
        }
        else
        {
            transition.BeginClose();
            context.OpenInteractionType = InteractionType.None;
            SyncSelectedIndex();

            if (reason is SelectOpenChangeReason.OutsidePress or SelectOpenChangeReason.FocusOut)
            {
                FieldContext?.SetTouched(true);
                FieldContext?.SetFocused(false);

                if (FieldContext?.ValidationMode == ValidationMode.OnBlur)
                {
                    await (FieldContext?.Validation.CommitAsync(GetValidationValue()) ?? Task.CompletedTask);
                }
            }
        }

        context.TransitionStatus = transition.TransitionStatus;
        context.Mounted = transition.IsMounted;
        context.ActiveIndex = activeIndex;

        if (!IsControlled)
        {
            isOpen = nextOpen;
        }

        state = SelectRootState.FromFieldState(FieldState, nextOpen);
        context.Open = nextOpen;

        if (hasRendered)
        {
            await SyncRootOpenAsync(nextOpen, reason);
        }

        await OpenChanged.InvokeAsync(nextOpen);

        typedContext.NotifyStateChanged();
        StateHasChanged();
    }

    private async Task SyncRootOpenAsync(bool open, SelectOpenChangeReason reason)
    {
        try
        {
            var module = await ModuleTask.Value;
            var reasonString = reason switch
            {
                SelectOpenChangeReason.EscapeKey => "escape-key",
                SelectOpenChangeReason.ItemPress => "item-press",
                SelectOpenChangeReason.OutsidePress => "outside-press",
                _ => null
            };

            await module.InvokeVoidAsync("setRootOpen", rootId, open, reasonString);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task SelectValueInternalAsync(TValue? value)
    {
        if (ReadOnly)
        {
            return;
        }

        if (Multiple)
        {
            var values = new List<TValue>(GetCurrentValues());
            var index = values.FindIndex(v => typedContext.AreEqual(v, value));
            if (index >= 0)
            {
                values.RemoveAt(index);
            }
            else if (value is not null)
            {
                values.Add(value);
            }

            var eventArgs = new SelectValueChangeEventArgs<TValue>(value, values);
            await OnValueChange.InvokeAsync(eventArgs);

            if (eventArgs.IsCanceled)
            {
                return;
            }

            if (!IsValuesControlled)
            {
                internalValues = values;
            }

            if (ValuesChanged.HasDelegate)
            {
                await ValuesChanged.InvokeAsync(values);
            }

            if (ValueChanged.HasDelegate)
            {
                await ValueChanged.InvokeAsync(value);
            }

            HandleValueChanged();

            typedContext.NotifyStateChanged();
            StateHasChanged();
        }
        else
        {
            var eventArgs = new SelectValueChangeEventArgs<TValue>(value);
            await OnValueChange.InvokeAsync(eventArgs);

            if (eventArgs.IsCanceled)
            {
                return;
            }

            if (!IsValueControlled)
            {
                internalValue = value;
            }

            if (ValueChanged.HasDelegate)
            {
                await ValueChanged.InvokeAsync(value);
            }

            HandleValueChanged();

            await SetOpenAsync(false, SelectOpenChangeReason.ItemPress);
        }
    }

    private async Task SetValueBoxedInternalAsync(object? boxedValue, SelectOpenChangeReason reason)
    {
        if (ReadOnly)
        {
            return;
        }

        if (Multiple)
        {
            var replacement = new List<TValue>();
            if (boxedValue is System.Collections.IEnumerable enumerable and not string)
            {
                foreach (var item in enumerable)
                {
                    if (item is TValue tv)
                    {
                        replacement.Add(tv);
                    }
                }
            }

            var eventArgs = new SelectValueChangeEventArgs<TValue>(
                replacement.Count > 0 ? replacement[0] : default,
                replacement);
            await OnValueChange.InvokeAsync(eventArgs);

            if (eventArgs.IsCanceled)
            {
                return;
            }

            if (!IsValuesControlled)
            {
                internalValues = replacement;
            }

            if (ValuesChanged.HasDelegate)
            {
                await ValuesChanged.InvokeAsync(replacement);
            }

            HandleValueChanged();
            typedContext.NotifyStateChanged();
            StateHasChanged();
        }
        else
        {
            TValue? value = boxedValue is TValue tv ? tv : default;

            var eventArgs = new SelectValueChangeEventArgs<TValue>(value);
            await OnValueChange.InvokeAsync(eventArgs);

            if (eventArgs.IsCanceled)
            {
                return;
            }

            if (!IsValueControlled)
            {
                internalValue = value;
            }

            if (ValueChanged.HasDelegate)
            {
                await ValueChanged.InvokeAsync(value);
            }

            HandleValueChanged();
            typedContext.NotifyStateChanged();
            StateHasChanged();
        }
    }

    private object? GetValidationValue()
    {
        if (Multiple)
        {
            return GetCurrentValues();
        }

        return CurrentValue;
    }

    private void HandleValueChanged()
    {
        FormContext?.ClearErrors(ResolvedName);

        var validationValue = GetValidationValue();
        var initialValue = FieldContext?.ValidityData.InitialValue;
        var isDirty = !EqualityComparer<object>.Default.Equals(validationValue, initialValue);

        FieldContext?.SetDirty(isDirty);
        FieldContext?.SetFilled(!IsPlaceholderState());

        if (FieldContext?.ShouldValidateOnChange() == true)
        {
            _ = FieldContext.Validation.CommitAsync(validationValue);
        }
        else
        {
            _ = FieldContext?.Validation.CommitAsync(validationValue, revalidateOnly: true);
        }
    }

    private void HandleTriggerFocus()
    {
        if (ResolvedDisabled)
        {
            return;
        }

        FieldContext?.SetFocused(true);
    }

    private void HandleTriggerBlur()
    {
        if (ResolvedDisabled)
        {
            return;
        }

        if (CurrentOpen)
        {
            return;
        }

        FieldContext?.SetTouched(true);
        FieldContext?.SetFocused(false);

        if (FieldContext?.ValidationMode == ValidationMode.OnBlur)
        {
            _ = FieldContext.Validation.CommitAsync(GetValidationValue());
        }
    }

    private async Task HandleHiddenInputFocus()
    {
        await FocusTriggerAsync();
    }

    private async Task HandleHiddenInputChange(ChangeEventArgs e)
    {
        if (Multiple || ReadOnly || typedContext is null)
        {
            return;
        }

        var inputValue = e.Value?.ToString();
        if (string.IsNullOrEmpty(inputValue))
        {
            return;
        }

        var matchValue = typedContext.FindValueByFormString(inputValue);
        if (matchValue.Found)
        {
            await SelectValueInternalAsync(matchValue.Value);
        }
    }

    private void SyncSelectedIndex()
    {
        if (typedContext is null)
        {
            return;
        }

        // Mirror React's `findItemIndex(lastSelectedValue)` rule used when the popup
        // closes: in Multiple mode, highlight follows the last entry in `Values`.
        TValue? targetValue;
        bool hasTarget;
        if (Multiple)
        {
            var values = GetCurrentValues();
            if (values.Count == 0)
            {
                typedContext.SelectedIndex = -1;
                return;
            }

            targetValue = values[values.Count - 1];
            hasTarget = true;
        }
        else
        {
            targetValue = CurrentValue;
            hasTarget = true;
        }

        if (!hasTarget)
        {
            typedContext.SelectedIndex = -1;
            return;
        }

        if (typedContext.Items is not null)
        {
            for (var i = 0; i < typedContext.Items.Count; i++)
            {
                if (typedContext.AreEqual(typedContext.Items[i].Value, targetValue))
                {
                    typedContext.SelectedIndex = i;
                    return;
                }
            }
        }

        // Fall back to live registered values (React's `valuesRef` equivalent) so
        // multi-select highlights work without static `Items` and so single-select
        // recovers when only dynamic `<SelectItem>` registrations are present.
        var registered = typedContext.RegisteredValues;
        var equal = typedContext.AreValuesEqual;
        for (var i = 0; i < registered.Count; i++)
        {
            if (equal(registered[i], targetValue))
            {
                typedContext.SelectedIndex = i;
                return;
            }
        }

        typedContext.SelectedIndex = -1;
    }

    private async ValueTask FocusTriggerAsync()
    {
        if (!hasRendered || !triggerElement.HasValue)
        {
            return;
        }

        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync("focusTrigger", triggerElement.Value);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private bool IsPlaceholderState()
    {
        if (Multiple)
        {
            return GetCurrentValues().Count == 0;
        }

        return CurrentValue is null;
    }

    private bool IsValuesControlled => hasValuesParameter;

    private IReadOnlyList<TValue> GetCurrentValues()
    {
        if (IsValuesControlled && Values is not null)
        {
            return Values;
        }

        return internalValues;
    }

    private async Task InitializeJsAsync()
    {
        try
        {
            var module = await ModuleTask.Value;
            var modal = Modal == SelectModalMode.True;
            var directionStr = EffectiveDirection.ToAttributeString() ?? "ltr";
            await module.InvokeVoidAsync("initializeRoot", rootId, dotNetRef, false, modal, directionStr, ReadOnly, ResolvedDisabled);

            if (triggerElement.HasValue)
            {
                await module.InvokeVoidAsync("setTriggerElement", rootId, triggerElement.Value);
            }

            if (popupElement.HasValue)
            {
                await module.InvokeVoidAsync("setPopupElement", rootId, popupElement.Value);
            }

            if (listElement.HasValue)
            {
                await module.InvokeVoidAsync("setListElement", rootId, listElement.Value);
            }

            if (CurrentOpen)
            {
                await module.InvokeVoidAsync("setRootOpen", rootId, true, (string?)null);
            }
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private void SetTriggerElement(ElementReference? element)
    {
        triggerElement = element;

        if (hasRendered && element.HasValue)
        {
            _ = SetTriggerElementAsync(element.Value);
        }
    }

    private void SyncActionsRef()
    {
        if (previousActionsRef is not null && previousActionsRef != ActionsRef)
        {
            previousActionsRef.Unmount = null;
        }

        if (ActionsRef is not null)
        {
            ActionsRef.Unmount = ForceUnmount;
        }

        previousActionsRef = ActionsRef;
    }

    private void ForceUnmount()
    {
        transition.ForceUnmount();
        context.Mounted = false;
        context.TransitionStatus = transition.TransitionStatus;
        context.ForceMount = false;
        activeIndex = -1;
        context.ActiveIndex = activeIndex;
        typedContext.NotifyStateChanged();
        StateHasChanged();
    }

    private void NotifyInputRefIfNeeded()
    {
        if (InputRef is null)
        {
            return;
        }

        ElementReference? currentElement = hiddenInputElement;

        if (SameElement(currentElement, previousHiddenInputElement))
        {
            return;
        }

        InputRef(currentElement);
        previousHiddenInputElement = currentElement;
    }

    private static bool SameElement(ElementReference? a, ElementReference? b)
    {
        if (a is { } left && b is { } right)
        {
            return left.Id == right.Id;
        }

        return !a.HasValue && !b.HasValue;
    }

