    private async Task SyncActiveIndexSilentAsync(int index)
    {
        // Lightweight state sync for hover paths. The JS `setActiveIndex` export
        // only writes `rootState.activeIndex` (no focus, no scroll, no DOM attr
        // writes). The DOM-mutating version is named `setActiveItem` internally.
        activeIndex = index;

