@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<RenderElement TState="TooltipViewportState"
               Tag="div"
               Enabled="RootContext is not null"
               State="state"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference">
    <div data-current>
        @ChildContent
    </div>
</RenderElement>

@code {
    private Lazy<Task<IJSObjectReference>>? moduleTask;
    private DotNetObjectReference<TooltipViewport>? dotNetRef;
    private string viewportId = null!;
    private TooltipViewportState state;
    private RenderElement<TooltipViewportState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private string? previousActiveTriggerId;
    private string? activationDirection;
    private bool isTransitioning;
    private bool hasRendered;
    private bool autoResizeInitialized;

    private Lazy<Task<IJSObjectReference>> ModuleTask => moduleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>(
            "import", "./_content/BlazorBaseUI/blazor-baseui-tooltip-viewport.js").AsTask());

    [CascadingParameter]
    private TooltipRootContext? RootContext { get; set; }

    [CascadingParameter]
    private TooltipPositionerContext? PositionerContext { get; set; }

    /// <summary>
    /// Gets or sets a custom render template for the viewport element.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<TooltipViewportState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets a function that returns CSS class names based on the current state.
    /// </summary>
    [Parameter]
    public Func<TooltipViewportState, string>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets a function that returns inline styles based on the current state.
    /// </summary>
    [Parameter]
    public Func<TooltipViewportState, string>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        viewportId = Guid.NewGuid().ToIdString();
        if (RootContext is not null)
        {
            RootContext.HasViewport = true;
        }
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        var instantType = RootContext?.InstantType ?? TooltipInstantType.None;
        state = new TooltipViewportState(instantType, activationDirection, isTransitioning);
        BuildComponentAttributes();

        // Detect trigger change
        var currentTriggerId = RootContext?.ActiveTriggerId;
        if (hasRendered
            && currentTriggerId != previousActiveTriggerId
            && previousActiveTriggerId is not null
            && currentTriggerId is not null
            && RootContext?.GetOpen() == true)
        {
            var prevTriggerEl = RootContext.GetTriggerElementById(previousActiveTriggerId);
            var newTriggerEl = RootContext.GetTriggerElementById(currentTriggerId);
            if (prevTriggerEl.HasValue && newTriggerEl.HasValue)
            {
                _ = BeginTransitionAsync(prevTriggerEl.Value, newTriggerEl.Value);
            }
        }
        previousActiveTriggerId = currentTriggerId;
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            hasRendered = true;
            if (Element.HasValue)
            {
                try
                {
                    dotNetRef = DotNetObjectReference.Create(this);
                    var module = await ModuleTask.Value;
                    await module.InvokeVoidAsync("initializeViewport", viewportId, Element.Value, dotNetRef);
                }
                catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
                {
                    _ = ex; // Expected during circuit disconnect - safe to ignore.
                }
            }
        }

        // Initialize auto-resize when popup/positioner elements become available
        if (!autoResizeInitialized && hasRendered)
        {
            var popupEl = RootContext?.GetPopupElement();
            var positionerEl = RootContext?.GetPositionerElement();
            if (popupEl.HasValue && positionerEl.HasValue)
            {
                try
                {
                    var module = await ModuleTask.Value;
                    var side = PositionerContext?.Side ?? Side.Top;
                    await module.InvokeVoidAsync("initializeAutoResize", viewportId, popupEl.Value, positionerEl.Value, side.ToDataAttributeString());
                    autoResizeInitialized = true;
                }
                catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
                {
                    _ = ex; // Expected during circuit disconnect - safe to ignore.
                }
            }
        }
    }

    /// <summary>
    /// Handles the start of a viewport transition from JavaScript interop.
    /// </summary>
    /// <param name="direction">The activation direction string, or empty if not applicable.</param>
    [JSInvokable]
    public void OnTransitionStarted(string direction)
    {
        activationDirection = string.IsNullOrEmpty(direction) ? null : direction;
        isTransitioning = true;
        var instantType = RootContext?.InstantType ?? TooltipInstantType.None;
        state = new TooltipViewportState(instantType, activationDirection, isTransitioning);
        BuildComponentAttributes();
        StateHasChanged();
    }

    /// <summary>
    /// Handles the end of a viewport transition from JavaScript interop.
    /// </summary>
    [JSInvokable]
    public void OnTransitionEnded()
    {
        activationDirection = null;
        isTransitioning = false;
        var instantType = RootContext?.InstantType ?? TooltipInstantType.None;
        state = new TooltipViewportState(instantType, activationDirection, isTransitioning);
        BuildComponentAttributes();
        StateHasChanged();
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (RootContext is not null)
        {
            RootContext.HasViewport = false;
        }

        if (moduleTask?.IsValueCreated == true && hasRendered)
        {
            try
            {
                var module = await moduleTask.Value;
                await module.InvokeVoidAsync("disposeViewport", viewportId);
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }

        dotNetRef?.Dispose();
    }

    private async Task BeginTransitionAsync(ElementReference prevTrigger, ElementReference newTrigger)
    {
        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync("beginTransition", viewportId, prevTrigger, newTrigger);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();

        var instantAttr = state.Instant.ToDataAttributeString();
        if (!string.IsNullOrEmpty(instantAttr))
        {
            attrs["data-instant"] = instantAttr;
        }

        if (!string.IsNullOrEmpty(activationDirection))
        {
            attrs["data-activation-direction"] = activationDirection;
        }

        attrs["data-transitioning"] = isTransitioning;

        componentAttributes = attrs;
    }
}
