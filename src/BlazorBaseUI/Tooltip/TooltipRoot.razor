@using BlazorBaseUI.FloatingDelayGroup
@using Microsoft.JSInterop
@implements IAsyncDisposable
@implements ITooltipHandleSubscriber
@inject IJSRuntime JSRuntime

<CascadingValue Value="context">
    @if (ChildContentWithPayload is not null)
    {
        @ChildContentWithPayload(new TooltipRootPayloadContext(payload))
    }
    else
    {
        @ChildContent
    }
</CascadingValue>

@code {
    private readonly string rootId = Guid.NewGuid().ToIdString();
    private readonly string popupId = Guid.NewGuid().ToIdString();
    private readonly Dictionary<string, ElementReference?> triggerElements = new();
    private readonly Dictionary<string, object?> triggerPayloads = new();

    private Lazy<Task<IJSObjectReference>>? moduleTask;
    private bool hasRendered;
    private bool isOpen;
    private readonly TransitionLifecycleManager transition = new();
    private string? activeTriggerId;
    private object? payload;
    private ElementReference? positionerElement;
    private ElementReference? popupElement;
    private TooltipOpenChangeReason openChangeReason = TooltipOpenChangeReason.None;
    private TooltipInstantType instantType = TooltipInstantType.None;
    private TooltipInstantType? previousInstantType;
    private bool preventUnmountOnClose;
    private TooltipRootState state;
    private TooltipRootContext context = null!;
    private DotNetObjectReference<TooltipRoot>? dotNetRef;
    private ITooltipHandle? subscribedHandle;
    private FloatingDelayGroupContext? subscribedDelayGroupContext;
    private DelayGroupMemberCallback? delayGroupCallback;
    private DotNetObjectReference<DelayGroupMemberCallback>? delayGroupCallbackRef;
    private bool syncTriggerAttributesAfterRender;
    private bool syncRootOpenAfterRender;
    private bool rootOpenToSyncAfterRender;
    private bool syncDelayGroupAfterRender;
    private bool delayGroupOpenToSyncAfterRender;

    private Lazy<Task<IJSObjectReference>> ModuleTask => moduleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>(
            "import", "./_content/BlazorBaseUI/blazor-baseui-tooltip.min.js").AsTask());

    [CascadingParameter]
    private TooltipProviderContext? ProviderContext { get; set; }

    [CascadingParameter]
    private FloatingDelayGroupContext? DelayGroupContext { get; set; }

    /// <summary>
    /// Determines whether the tooltip is currently open.
    /// To render a controlled tooltip, use this prop. Otherwise, the component manages its own state.
    /// </summary>
    [Parameter]
    public bool? Open { get; set; }

    /// <summary>
    /// Determines whether the tooltip is initially open.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool DefaultOpen { get; set; }

    /// <summary>
    /// Determines whether the tooltip is disabled.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Determines whether the tooltip contents can be hovered without closing the tooltip.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool DisableHoverablePopup { get; set; }

    /// <summary>
    /// Gets or sets which axis the tooltip should track the cursor on.
    /// Defaults to <see cref="Tooltip.TrackCursorAxis.None"/>.
    /// </summary>
    [Parameter]
    public TrackCursorAxis TrackCursorAxis { get; set; } = TrackCursorAxis.None;

    /// <summary>
    /// Gets or sets the ID of the trigger that the tooltip is associated with.
    /// This is useful in conjunction with the <see cref="Open"/> prop to create a controlled tooltip.
    /// </summary>
    [Parameter]
    public string? TriggerId { get; set; }

    /// <summary>
    /// Gets or sets the ID of the trigger that the tooltip is initially associated with.
    /// This is useful in conjunction with the <see cref="DefaultOpen"/> prop.
    /// </summary>
    [Parameter]
    public string? DefaultTriggerId { get; set; }

    /// <summary>
    /// Gets or sets the imperative actions reference for the tooltip.
    /// Provides <see cref="TooltipRootActions.Unmount"/>, <see cref="TooltipRootActions.Close"/>,
    /// and <see cref="TooltipRootActions.Open"/> actions.
    /// </summary>
    [Parameter]
    public TooltipRootActions? ActionsRef { get; set; }

    /// <summary>
    /// Gets or sets the handle to associate the tooltip with detached triggers.
    /// If specified, allows external triggers to control the tooltip's open state.
    /// </summary>
    [Parameter]
    public ITooltipHandle? Handle { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the open state changes for two-way binding.
    /// </summary>
    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the tooltip is opened or closed.
    /// The event args include the reason for the state change and can be canceled.
    /// </summary>
    [Parameter]
    public EventCallback<TooltipOpenChangeEventArgs> OnOpenChange { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked after any animations complete when the tooltip is opened or closed.
    /// </summary>
    [Parameter]
    public EventCallback<bool> OnOpenChangeComplete { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Defines the child components of this instance with access to the active trigger's payload.
    /// </summary>
    [Parameter]
    public RenderFragment<TooltipRootPayloadContext>? ChildContentWithPayload { get; set; }

    private bool IsControlled => Open.HasValue;

    private bool CurrentOpen => IsControlled ? Open!.Value : isOpen;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        isOpen = DefaultOpen;

        if (CurrentOpen)
        {
            transition.BeginOpen();
        }

        activeTriggerId = DefaultTriggerId;
        state = new TooltipRootState(CurrentOpen);
        context = new TooltipRootContext
        {
            RootId = rootId,
            PopupId = popupId,
            Open = CurrentOpen,
            Mounted = transition.IsMounted,
            Disabled = Disabled,
            OpenChangeReason = openChangeReason,
            TransitionStatus = transition.TransitionStatus,
            InstantType = instantType,
            TrackCursorAxis = TrackCursorAxis,
            DisableHoverablePopup = DisableHoverablePopup,
            IsDelayGroupInstantPhase = DelayGroupContext?.IsInstantPhase == true,
            ActiveTriggerId = activeTriggerId,
            Payload = payload,
            GetOpen = () => state.Open,
            GetMounted = () => transition.IsMounted,
            GetPayload = () => payload,
            GetTriggerElement = GetTriggerElement,
            RegisterTriggerElement = RegisterTriggerElement,
            UnregisterTriggerElement = UnregisterTriggerElement,
            SetPositionerElement = SetPositionerElement,
            SetPopupElement = SetPopupElement,
            SetOpenAsync = SetOpenAsync,
            SetTriggerPayload = SetTriggerPayload,
            ForceUnmount = ForceUnmount,
            GetTriggerElementById = GetTriggerElementById,
            GetPopupElement = () => popupElement,
            GetPositionerElement = () => positionerElement
        };

        if (ActionsRef is not null)
        {
            ActionsRef.Unmount = ForceUnmount;
            ActionsRef.Close = () => _ = SetOpenWithExceptionHandlingAsync(false, TooltipOpenChangeReason.ImperativeAction, null);
            ActionsRef.Open = () => _ = SetOpenWithExceptionHandlingAsync(true, TooltipOpenChangeReason.ImperativeAction, null);
            ActionsRef.OpenWithTriggerId = triggerId => _ = SetOpenWithExceptionHandlingAsync(true, TooltipOpenChangeReason.ImperativeAction, triggerId);
        }

        SubscribeToHandle();
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        var currentOpen = CurrentOpen;
        var parameterOpenChanged = state.Open != currentOpen;
        if (parameterOpenChanged)
        {
            ApplyOpenParameterChange(currentOpen);
        }

        if (TriggerId is not null)
        {
            activeTriggerId = TriggerId;
            context.ActiveTriggerId = activeTriggerId;
        }

        TrySetImplicitActiveTrigger();

        if (parameterOpenChanged)
        {
            CompleteOpenParameterChange(currentOpen);
        }

        context.Disabled = Disabled;

        if (Disabled && state.Open)
        {
            _ = SetOpenAsync(false, TooltipOpenChangeReason.Disabled, null);
        }

        context.DisableHoverablePopup = DisableHoverablePopup;
        context.TrackCursorAxis = TrackCursorAxis;

        if (ActionsRef is not null)
        {
            ActionsRef.Unmount = ForceUnmount;
            ActionsRef.Close = () => _ = SetOpenWithExceptionHandlingAsync(false, TooltipOpenChangeReason.ImperativeAction, null);
            ActionsRef.Open = () => _ = SetOpenWithExceptionHandlingAsync(true, TooltipOpenChangeReason.ImperativeAction, null);
            ActionsRef.OpenWithTriggerId = triggerId => _ = SetOpenWithExceptionHandlingAsync(true, TooltipOpenChangeReason.ImperativeAction, triggerId);
        }

        // Handle change of handle parameter
        if (Handle != subscribedHandle)
        {
            UnsubscribeFromHandle();
            SubscribeToHandle();
        }

        if (!ReferenceEquals(DelayGroupContext, subscribedDelayGroupContext))
        {
            if (subscribedDelayGroupContext is not null)
            {
                subscribedDelayGroupContext.StateChanged -= HandleDelayGroupStateChanged;
            }

            subscribedDelayGroupContext = DelayGroupContext;
            if (subscribedDelayGroupContext is not null)
            {
                subscribedDelayGroupContext.StateChanged += HandleDelayGroupStateChanged;
            }
        }

        RefreshCascadingContext();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            hasRendered = true;
            dotNetRef = DotNetObjectReference.Create(this);
            await InitializeJsAsync();
            await RegisterDelayGroupMemberAsync();
        }

        if (hasRendered && syncRootOpenAfterRender)
        {
            syncRootOpenAfterRender = false;
            await SyncOpenStateToJsAsync(rootOpenToSyncAfterRender, true);
        }

        if (hasRendered && syncDelayGroupAfterRender)
        {
            syncDelayGroupAfterRender = false;
            await SyncDelayGroupOpenStateAsync(delayGroupOpenToSyncAfterRender);
        }

        if (hasRendered && syncTriggerAttributesAfterRender)
        {
            syncTriggerAttributesAfterRender = false;
            await SyncTriggerAttributesAsync();
        }
    }

    /// <summary>
    /// Handles an escape key press event from JavaScript interop.
    /// </summary>
    [JSInvokable]
    public async Task OnEscapeKey()
    {
        await SetOpenAsync(false, TooltipOpenChangeReason.EscapeKey, null);
    }

    /// <summary>
    /// Handles a hover open event from JavaScript interop.
    /// </summary>
    [JSInvokable]
    public async Task OnHoverOpen(string? triggerId)
    {
        await SetOpenAsync(true, TooltipOpenChangeReason.TriggerHover, triggerId);
    }

    /// <summary>
    /// Handles a hover close event from JavaScript interop.
    /// </summary>
    [JSInvokable]
    public async Task OnHoverClose(string? triggerId)
    {
        await SetOpenAsync(false, TooltipOpenChangeReason.TriggerHover, triggerId);
    }

    /// <summary>
    /// Handles an outside press event from JavaScript interop.
    /// </summary>
    [JSInvokable]
    public async Task OnOutsidePress()
    {
        await SetOpenAsync(false, TooltipOpenChangeReason.OutsidePress, null);
    }

    /// <summary>
    /// Handles the starting style application event from JavaScript interop.
    /// </summary>
    [JSInvokable]
    public void OnStartingStyleApplied()
    {
        if (transition.HandleStartingStyleApplied())
        {
            context.TransitionStatus = transition.TransitionStatus;
            RefreshCascadingContext();
            StateHasChanged();
        }
    }

    /// <summary>
    /// Handles a transition end event from JavaScript interop.
    /// </summary>
    /// <param name="open">Whether the tooltip is open after the transition.</param>
    [JSInvokable]
    public void OnTransitionEnd(bool open)
    {
        var unmounted = transition.HandleTransitionEnd(open, preventUnmountOnClose);
        preventUnmountOnClose = false;
        context.TransitionStatus = transition.TransitionStatus;

        if (unmounted)
        {
            context.Mounted = false;
            activeTriggerId = null;
            context.ActiveTriggerId = null;
            payload = null;
            context.Payload = null;
        }

        if (previousInstantType.HasValue)
        {
            instantType = previousInstantType.Value;
            previousInstantType = null;
        }
        else
        {
            instantType = TooltipInstantType.None;
        }
        context.InstantType = instantType;

        _ = InvokeOpenChangeCompleteAsync(open);
        RefreshCascadingContext();
        StateHasChanged();
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        UnsubscribeFromHandle();

        if (subscribedDelayGroupContext is not null)
        {
            subscribedDelayGroupContext.StateChanged -= HandleDelayGroupStateChanged;
            subscribedDelayGroupContext = null;
        }

        if (DelayGroupContext is not null)
        {
            try
            {
                await DelayGroupContext.UnregisterMemberAsync(rootId);
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }

        delayGroupCallbackRef?.Dispose();

        if (moduleTask?.IsValueCreated == true && hasRendered)
        {
            try
            {
                var module = await ModuleTask.Value;
                await module.InvokeVoidAsync("disposeCursorTracking", rootId);
                await module.InvokeVoidAsync("disposeRoot", rootId);
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }

        dotNetRef?.Dispose();
    }

    void IComponentHandleSubscriberBase<TooltipOpenChangeReason>.OnTriggerRegistered(string triggerId, ElementReference? element)
    {
        triggerElements[triggerId] = element;

        if (state.Open && activeTriggerId == triggerId)
        {
            payload = GetPayloadFromHandle(triggerId);
            context.Payload = payload;
        }

        if (hasRendered && element.HasValue && activeTriggerId == triggerId)
        {
            _ = SetTriggerElementJsAsync(triggerId, element.Value);
        }
    }

    void IComponentHandleSubscriberBase<TooltipOpenChangeReason>.OnTriggerUnregistered(string triggerId)
    {
        triggerElements.Remove(triggerId);
        triggerPayloads.Remove(triggerId);
    }

    void IComponentHandleSubscriberBase<TooltipOpenChangeReason>.OnTriggerElementUpdated(string triggerId, ElementReference? element)
    {
        triggerElements[triggerId] = element;

        if (hasRendered && element.HasValue && activeTriggerId == triggerId)
        {
            _ = SetTriggerElementJsAsync(triggerId, element.Value);
        }
    }

    void IComponentHandleSubscriberBase<TooltipOpenChangeReason>.OnOpenChangeRequested(bool open, TooltipOpenChangeReason reason, string? triggerId, string? interactionType)
    {
        _ = InvokeAsync(async () =>
        {
            try
            {
                await SetOpenAsync(open, reason, triggerId);
            }
            catch (Exception ex)
            {
                await DispatchExceptionAsync(ex);
            }
        });
    }

    void IComponentHandleSubscriberBase<TooltipOpenChangeReason>.OnStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Sets the tooltip's open state with the specified reason and trigger association.
    /// </summary>
    /// <param name="nextOpen">The desired open state.</param>
    /// <param name="reason">The reason for the state change.</param>
    /// <param name="triggerId">The ID of the trigger initiating the change, or <see langword="null"/>.</param>
    internal async Task SetOpenAsync(bool nextOpen, TooltipOpenChangeReason reason, string? triggerId)
    {
        var currentOpen = state.Open;
        var activeTriggerChanged = nextOpen && triggerId is not null && triggerId != activeTriggerId;

        if (currentOpen == nextOpen && !activeTriggerChanged)
        {
            return;
        }

        if (Disabled && nextOpen)
        {
            return;
        }

        var triggerReference = triggerId is null ? null : GetTriggerElementById(triggerId);
        var args = new TooltipOpenChangeEventArgs(nextOpen, reason, triggerId, triggerReference);
        await OnOpenChange.InvokeAsync(args);

        if (args.IsCanceled)
        {
            return;
        }

        if (!nextOpen)
        {
            preventUnmountOnClose = args.PreventUnmount;
        }

        openChangeReason = reason;
        context.OpenChangeReason = reason;

        if (nextOpen)
        {
            if (triggerId is not null)
            {
                SetActiveTrigger(triggerId);
            }

            instantType = reason == TooltipOpenChangeReason.TriggerFocus
                ? TooltipInstantType.Focus
                : (DelayGroupContext?.IsInstantPhase == true || ProviderContext?.IsInInstantPhase() == true ? TooltipInstantType.Delay : TooltipInstantType.None);
            if (!currentOpen || !transition.IsMounted)
            {
                transition.BeginOpen();
            }

            if (!currentOpen && DelayGroupContext is not null)
            {
                _ = SyncDelayGroupOpenStateAsync(true);
            }
        }
        else
        {
            instantType = reason switch
            {
                TooltipOpenChangeReason.EscapeKey or TooltipOpenChangeReason.OutsidePress => TooltipInstantType.Dismiss,
                _ => TooltipInstantType.None
            };
            if (currentOpen)
            {
                transition.BeginClose();
            }

            if (currentOpen && DelayGroupContext is not null)
            {
                _ = SyncDelayGroupOpenStateAsync(false);
            }
        }

        context.InstantType = instantType;
        context.TransitionStatus = transition.TransitionStatus;
        context.Mounted = transition.IsMounted;

        if (!IsControlled)
        {
            isOpen = nextOpen;
        }

        state = new TooltipRootState(nextOpen);
        context.Open = nextOpen;

        TrySetImplicitActiveTrigger();

        if (nextOpen && activeTriggerId is null)
        {
            payload = null;
            context.Payload = null;
        }

        ApplyInstantPhaseOverride();

        SyncHandleState(nextOpen, activeTriggerId);

        if (currentOpen != nextOpen)
        {
            await OpenChanged.InvokeAsync(nextOpen);
        }

        if (hasRendered)
        {
            await SyncOpenStateToJsAsync(nextOpen, currentOpen != nextOpen || activeTriggerChanged);
        }

        context.NotifyStateChanged();
        RefreshCascadingContext();
        syncTriggerAttributesAfterRender = true;
        StateHasChanged();
    }

    /// <summary>
    /// Registers a trigger element with the tooltip root.
    /// </summary>
    /// <param name="triggerId">The ID of the trigger to register.</param>
    /// <param name="element">The element reference for the trigger.</param>
    internal void RegisterTriggerElement(string triggerId, ElementReference? element)
    {
        triggerElements[triggerId] = element;

        TrySetImplicitActiveTrigger();

        if (hasRendered && element.HasValue && activeTriggerId == triggerId)
        {
            _ = SetTriggerElementJsAsync(triggerId, element.Value);
        }
    }

    /// <summary>
    /// Unregisters a trigger element from the tooltip root.
    /// </summary>
    /// <param name="triggerId">The ID of the trigger to unregister.</param>
    internal void UnregisterTriggerElement(string triggerId)
    {
        triggerElements.Remove(triggerId);
        triggerPayloads.Remove(triggerId);

        if (activeTriggerId == triggerId && state.Open)
        {
            activeTriggerId = null;
            context.ActiveTriggerId = null;
            payload = null;
            context.Payload = null;
        }
    }

    /// <summary>
    /// Sets the payload associated with a specific trigger.
    /// </summary>
    /// <param name="triggerId">The ID of the trigger.</param>
    /// <param name="triggerPayload">The payload value to associate with the trigger.</param>
    internal void SetTriggerPayload(string triggerId, object? triggerPayload)
    {
        triggerPayloads[triggerId] = triggerPayload;

        if (activeTriggerId == triggerId && state.Open)
        {
            payload = triggerPayload;
            context.Payload = payload;
        }
    }

    /// <summary>
    /// Stores the positioner element reference for positioning calculations.
    /// </summary>
    /// <param name="element">The positioner element reference.</param>
    internal void SetPositionerElement(ElementReference? element)
    {
        positionerElement = element;
    }

    /// <summary>
    /// Stores the popup element reference and registers it with JavaScript interop.
    /// </summary>
    /// <param name="element">The popup element reference.</param>
    internal void SetPopupElement(ElementReference? element)
    {
        popupElement = element;

        if (hasRendered && element.HasValue)
        {
            _ = SetPopupElementJsAsync(element.Value);
        }
    }

    /// <summary>
    /// Gets the current open state of the tooltip.
    /// </summary>
    internal bool GetOpen() => context.Open;

    /// <summary>
    /// Gets whether the tooltip is currently mounted in the DOM.
    /// </summary>
    internal bool GetMounted() => transition.IsMounted;

    /// <summary>
    /// Gets the current payload value from the active trigger.
    /// </summary>
    internal object? GetPayload() => payload;

    /// <summary>
    /// Gets the element reference of the currently active trigger.
    /// </summary>
    internal ElementReference? GetTriggerElement()
    {
        if (activeTriggerId is not null && triggerElements.TryGetValue(activeTriggerId, out var element))
        {
            return element;
        }

        // Try to get from handle if available
        if (Handle is not null && activeTriggerId is not null)
        {
            var handleElement = GetTriggerElementFromHandle(activeTriggerId);
            if (handleElement.HasValue)
            {
                return handleElement;
            }
        }

        return triggerElements.Values.FirstOrDefault();
    }

    private ElementReference? GetTriggerElementById(string triggerId)
    {
        if (triggerElements.TryGetValue(triggerId, out var element))
        {
            return element;
        }

        return GetTriggerElementFromHandle(triggerId);
    }

    private async Task InitializeJsAsync()
    {
        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync("initializeRoot", rootId, dotNetRef);

            var triggerElement = GetTriggerElement();
            if (activeTriggerId is not null && triggerElement.HasValue)
            {
                await module.InvokeVoidAsync("setTriggerElement", rootId, activeTriggerId, triggerElement.Value);
            }

            if (popupElement.HasValue)
            {
                await module.InvokeVoidAsync("setPopupElement", rootId, popupElement.Value);
            }

            if (state.Open)
            {
                await module.InvokeVoidAsync("setRootOpen", rootId, true, activeTriggerId);
            }
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task RegisterDelayGroupMemberAsync()
    {
        if (DelayGroupContext?.HasProvider != true)
        {
            return;
        }

        delayGroupCallback = new DelayGroupMemberCallback(async _ =>
        {
            await InvokeAsync(async () =>
            {
                try
                {
                    await SetOpenAsync(false, TooltipOpenChangeReason.None, null);
                }
                catch (Exception ex)
                {
                    await DispatchExceptionAsync(ex);
                }
            });
        }, HandleDelayGroupMemberInstantPhaseChanged);
        delayGroupCallbackRef = DotNetObjectReference.Create(delayGroupCallback);
        await DelayGroupContext.RegisterMemberAsync(rootId, delayGroupCallbackRef);
    }

    private async Task SetTriggerElementJsAsync(string triggerId, ElementReference element)
    {
        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync("setTriggerElement", rootId, triggerId, element);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task SetPopupElementJsAsync(ElementReference element)
    {
        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync("setPopupElement", rootId, element);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private void ApplyOpenParameterChange(bool nextOpen)
    {
        var previousOpen = state.Open;

        openChangeReason = TooltipOpenChangeReason.None;
        context.OpenChangeReason = openChangeReason;
        instantType = TooltipInstantType.None;
        previousInstantType = null;

        if (nextOpen)
        {
            if (!previousOpen || !transition.IsMounted)
            {
                transition.BeginOpen();
            }

            if (!previousOpen && DelayGroupContext is not null)
            {
                QueueDelayGroupOpenStateSync(true);
            }
        }
        else
        {
            preventUnmountOnClose = false;

            if (previousOpen)
            {
                transition.BeginClose();
            }

            if (previousOpen && DelayGroupContext is not null)
            {
                QueueDelayGroupOpenStateSync(false);
            }
        }

        state = new TooltipRootState(nextOpen);
        context.Open = nextOpen;
        context.InstantType = instantType;
        context.TransitionStatus = transition.TransitionStatus;
        context.Mounted = transition.IsMounted;
    }

    private void CompleteOpenParameterChange(bool nextOpen)
    {
        if (nextOpen && activeTriggerId is null)
        {
            payload = null;
            context.Payload = null;
        }

        ApplyInstantPhaseOverride();
        SyncHandleState(nextOpen, activeTriggerId);

        if (hasRendered)
        {
            rootOpenToSyncAfterRender = nextOpen;
            syncRootOpenAfterRender = true;
            syncTriggerAttributesAfterRender = true;
        }

        context.NotifyStateChanged();
    }

    private async Task SyncOpenStateToJsAsync(bool nextOpen, bool syncRootOpen)
    {
        try
        {
            var module = await ModuleTask.Value;

            if (nextOpen && activeTriggerId is not null)
            {
                var triggerElement = GetTriggerElement();
                if (triggerElement.HasValue)
                {
                    await module.InvokeVoidAsync("setTriggerElement", rootId, activeTriggerId, triggerElement.Value);
                }
            }

            if (nextOpen && TrackCursorAxis != TrackCursorAxis.None)
            {
                var axis = TrackCursorAxis switch
                {
                    TrackCursorAxis.X => "x",
                    TrackCursorAxis.Y => "y",
                    TrackCursorAxis.Both => "both",
                    _ => "none"
                };
                var virtualId = await module.InvokeAsync<string?>("initializeCursorTracking", rootId, axis);
                context.VirtualAnchorId = virtualId;
            }
            else if (!nextOpen)
            {
                await module.InvokeVoidAsync("disposeCursorTracking", rootId);
                context.VirtualAnchorId = null;
            }

            if (syncRootOpen)
            {
                await module.InvokeVoidAsync("setRootOpen", rootId, nextOpen, activeTriggerId);
            }
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task SyncDelayGroupOpenStateAsync(bool nextOpen)
    {
        if (DelayGroupContext is null)
        {
            return;
        }

        try
        {
            if (nextOpen)
            {
                await DelayGroupContext.NotifyMemberOpenedAsync(rootId);
            }
            else
            {
                await DelayGroupContext.NotifyMemberClosedAsync(rootId);
            }
        }
        catch (Exception ex)
        {
            _ = ex;
        }
    }

    private async Task SyncTriggerAttributesAsync()
    {
        if (moduleTask?.IsValueCreated != true)
        {
            return;
        }

        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync("syncTriggerOpenAttributes", rootId, state.Open, activeTriggerId);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task SetOpenWithExceptionHandlingAsync(bool nextOpen, TooltipOpenChangeReason reason, string? triggerId)
    {
        try
        {
            await SetOpenAsync(nextOpen, reason, triggerId);
        }
        catch (Exception ex)
        {
            await DispatchExceptionAsync(ex);
        }
    }

    private void ForceUnmount()
    {
        transition.ForceUnmount();
        context.Mounted = false;
        context.TransitionStatus = transition.TransitionStatus;
        activeTriggerId = null;
        context.ActiveTriggerId = null;
        payload = null;
        context.Payload = null;
        RefreshCascadingContext();
        _ = InvokeOpenChangeCompleteAsync(false);
        StateHasChanged();
    }

    private void TrySetImplicitActiveTrigger()
    {
        if (state.Open && activeTriggerId is null && triggerElements.Count == 1)
        {
            var entry = triggerElements.First();
            SetActiveTrigger(entry.Key);
        }
    }

    private void SetActiveTrigger(string triggerId)
    {
        activeTriggerId = triggerId;
        context.ActiveTriggerId = triggerId;

        if (triggerPayloads.TryGetValue(triggerId, out var triggerPayload))
        {
            payload = triggerPayload;
        }
        else
        {
            payload = GetPayloadFromHandle(triggerId);
        }

        context.Payload = payload;
    }

    private void RefreshCascadingContext()
    {
        context.Open = state.Open;
        context.Mounted = transition.IsMounted;
        context.Disabled = Disabled;
        context.OpenChangeReason = openChangeReason;
        context.TransitionStatus = transition.TransitionStatus;
        context.InstantType = instantType;
        context.TrackCursorAxis = TrackCursorAxis;
        context.DisableHoverablePopup = DisableHoverablePopup;
        context.IsDelayGroupInstantPhase = DelayGroupContext?.IsInstantPhase == true;
        context.ActiveTriggerId = activeTriggerId;
        context.Payload = payload;
    }

    private void ApplyInstantPhaseOverride()
    {
        var isEnding = transition.TransitionStatus == TransitionStatus.Ending;
        var isClosingBySibling = isEnding && openChangeReason == TooltipOpenChangeReason.None;
        var isInInstantPhaseAndNotEnding = !isEnding && (DelayGroupContext?.IsInstantPhase == true || ProviderContext?.IsInInstantPhase() == true);

        if (isClosingBySibling || isInInstantPhaseAndNotEnding)
        {
            if (instantType != TooltipInstantType.Delay)
            {
                previousInstantType = instantType;
            }
            instantType = TooltipInstantType.Delay;
            context.InstantType = instantType;
        }
        else if (previousInstantType.HasValue)
        {
            instantType = previousInstantType.Value;
            previousInstantType = null;
            context.InstantType = instantType;
        }
    }

    private void HandleDelayGroupStateChanged()
    {
        context.IsDelayGroupInstantPhase = DelayGroupContext?.IsInstantPhase == true;
        context.NotifyStateChanged();
        _ = InvokeAsync(StateHasChanged);
    }

    private void QueueDelayGroupOpenStateSync(bool nextOpen)
    {
        delayGroupOpenToSyncAfterRender = nextOpen;
        syncDelayGroupAfterRender = true;
    }

    private void HandleDelayGroupMemberInstantPhaseChanged(bool value)
    {
        context.IsDelayGroupInstantPhase = value || DelayGroupContext?.IsInstantPhase == true;
        context.NotifyStateChanged();
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task InvokeOpenChangeCompleteAsync(bool open)
    {
        try
        {
            await OnOpenChangeComplete.InvokeAsync(open);
        }
        catch (Exception ex)
        {
            await DispatchExceptionAsync(ex);
        }
    }

    private void SubscribeToHandle()
    {
        if (Handle is null)
        {
            return;
        }

        subscribedHandle = Handle;
        Handle.Subscribe(this);
    }

    private void UnsubscribeFromHandle()
    {
        if (subscribedHandle is null)
        {
            return;
        }

        subscribedHandle.Unsubscribe(this);
        subscribedHandle = null;
    }

    private void SyncHandleState(bool open, string? triggerId)
    {
        Handle?.SyncState(open, triggerId, payload);
    }

    private object? GetPayloadFromHandle(string triggerId)
    {
        return Handle?.GetTriggerPayloadAsObject(triggerId);
    }

    private ElementReference? GetTriggerElementFromHandle(string triggerId)
    {
        return Handle?.GetTriggerElement(triggerId);
    }
}
