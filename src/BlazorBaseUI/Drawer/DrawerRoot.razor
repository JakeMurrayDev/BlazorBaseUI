@using BlazorBaseUI.Dialog

<CascadingValue TValue="DrawerRootContext" Value="context" IsFixed="true">
    <DialogRoot Open="Open"
                DefaultOpen="DefaultOpen"
                Modal="Modal.ToDialogModalMode()"
                ActionsRef="dialogActions"
                Handle="Handle"
                OpenChanged="HandleDialogOpenChangedAsync"
                OnOpenChange="HandleDialogOpenChangeAsync"
                OnOpenChangeComplete="OnOpenChangeComplete"
                DisablePointerDismissal="DisablePointerDismissal"
                TriggerId="TriggerId"
                DefaultTriggerId="DefaultTriggerId">
        <ChildContent Context="dialogPayload">
            <DrawerRootReporter />
            @if (ChildContent is not null)
            {
                @ChildContent(new DrawerRootPayloadContext(dialogPayload.Payload))
            }
        </ChildContent>
    </DialogRoot>
</CascadingValue>

@code {
    private readonly string rootId = Guid.NewGuid().ToIdString();
    private readonly DialogRootActions dialogActions = new();

    private DrawerSnapPoint? activeSnapPoint;
    private int popupHeight;
    private int frontmostHeight;
    private int nestedDrawerCount;
    private bool hasNestedDrawer;
    private bool nestedSwiping;
    private double nestedSwipeProgress;
    private bool hasSnapPointParameter;
    private bool hasDefaultSnapPointParameter;
    private DrawerRootContext context = null!;

    private bool IsSnapPointControlled => hasSnapPointParameter;

    private DrawerSnapPoint? ResolvedDefaultSnapPoint => hasDefaultSnapPointParameter ? DefaultSnapPoint : (SnapPoints is { Count: > 0 } ? SnapPoints[0] : (DrawerSnapPoint?)null);

    [CascadingParameter]
    private DrawerRootContext? ParentDrawerContext { get; set; }

    /// <summary>
    /// Gets or sets whether the drawer is currently open.
    /// When set, the component operates in controlled mode.
    /// </summary>
    [Parameter]
    public bool? Open { get; set; }

    /// <summary>
    /// Determines whether the drawer is initially open.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool DefaultOpen { get; set; }

    /// <summary>
    /// Gets or sets the modal behavior of the drawer.
    /// Defaults to <see cref="DrawerModalMode.True"/>.
    /// </summary>
    [Parameter]
    public DrawerModalMode Modal { get; set; } = DrawerModalMode.True;

    /// <summary>
    /// Gets or sets a reference to imperative actions for controlling the drawer programmatically.
    /// </summary>
    [Parameter]
    public DrawerRootActions? ActionsRef { get; set; }

    /// <summary>
    /// Gets or sets a handle to associate the drawer with external triggers.
    /// </summary>
    [Parameter]
    public IDialogHandle? Handle { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the open state changes, for two-way binding.
    /// </summary>
    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the drawer is opened or closed.
    /// </summary>
    [Parameter]
    public EventCallback<DrawerOpenChangeEventArgs> OnOpenChange { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked after animations complete when the drawer is opened or closed.
    /// </summary>
    [Parameter]
    public EventCallback<bool> OnOpenChangeComplete { get; set; }

    /// <summary>
    /// Determines whether pointer-based dismissal is disabled.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool DisablePointerDismissal { get; set; }

    /// <summary>
    /// Gets or sets the ID of the trigger that the drawer is associated with.
    /// </summary>
    [Parameter]
    public string? TriggerId { get; set; }

    /// <summary>
    /// Gets or sets the ID of the trigger that the drawer is initially associated with.
    /// </summary>
    [Parameter]
    public string? DefaultTriggerId { get; set; }

    /// <summary>
    /// Gets or sets the swipe direction used to dismiss the drawer.
    /// Defaults to <see cref="DrawerSwipeDirection.Down"/>.
    /// </summary>
    [Parameter]
    public DrawerSwipeDirection SwipeDirection { get; set; } = DrawerSwipeDirection.Down;

    /// <summary>
    /// Gets or sets whether velocity-based snap skipping is disabled.
    /// </summary>
    [Parameter]
    public bool SnapToSequentialPoints { get; set; }

    /// <summary>
    /// Gets or sets the snap points used to size and position the drawer.
    /// </summary>
    [Parameter]
    public IReadOnlyList<DrawerSnapPoint>? SnapPoints { get; set; }

    /// <summary>
    /// Gets or sets the currently active snap point.
    /// </summary>
    [Parameter]
    public DrawerSnapPoint? SnapPoint { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the active snap point changes.
    /// </summary>
    [Parameter]
    public EventCallback<DrawerSnapPoint?> SnapPointChanged { get; set; }

    /// <summary>
    /// Gets or sets the initial snap point value when uncontrolled.
    /// </summary>
    [Parameter]
    public DrawerSnapPoint? DefaultSnapPoint { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the drawer snap point changes.
    /// </summary>
    [Parameter]
    public EventCallback<DrawerSnapPointChangeEventArgs> OnSnapPointChange { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment<DrawerRootPayloadContext>? ChildContent { get; set; }

    /// <inheritdoc />
    public override Task SetParametersAsync(ParameterView parameters)
    {
        hasSnapPointParameter = parameters.TryGetValue<DrawerSnapPoint?>(nameof(SnapPoint), out _);
        hasDefaultSnapPointParameter = parameters.TryGetValue<DrawerSnapPoint?>(nameof(DefaultSnapPoint), out _);

        return base.SetParametersAsync(parameters);
    }

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        activeSnapPoint = IsSnapPointControlled ? SnapPoint : ResolvedDefaultSnapPoint;
        popupHeight = 0;
        frontmostHeight = 0;

        context = new DrawerRootContext
        {
            RootId = rootId,
            SwipeDirection = SwipeDirection,
            SnapToSequentialPoints = SnapToSequentialPoints,
            SnapPoints = SnapPoints,
            ActiveSnapPoint = activeSnapPoint,
            PopupHeight = popupHeight,
            FrontmostHeight = frontmostHeight,
            HasNestedDrawer = hasNestedDrawer,
            NestedDrawerCount = nestedDrawerCount,
            NestedSwiping = nestedSwiping,
            NestedSwipeProgress = nestedSwipeProgress,
            SetActiveSnapPointAsync = SetActiveSnapPointAsync,
            OnPopupHeightChange = OnPopupHeightChange,
            OnNestedDrawerPresenceChange = OnNestedDrawerPresenceChange,
            OnNestedFrontmostHeightChange = OnNestedFrontmostHeightChange,
            OnNestedSwipingChange = OnNestedSwipingChange,
            OnNestedSwipeProgressChange = OnNestedSwipeProgressChange,
            NotifyParentFrontmostHeight = ParentDrawerContext?.OnNestedFrontmostHeightChange,
            NotifyParentSwipingChange = ParentDrawerContext?.OnNestedSwipingChange,
            NotifyParentSwipeProgressChange = ParentDrawerContext?.OnNestedSwipeProgressChange,
            NotifyParentHasNestedDrawer = ParentDrawerContext?.OnNestedDrawerPresenceChange
        };

        SyncActions();
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        if (IsSnapPointControlled)
        {
            activeSnapPoint = SnapPoint;
        }
        else if (SnapPoints is { Count: > 0 } && (activeSnapPoint is null || !SnapPoints.Contains(activeSnapPoint.Value)))
        {
            activeSnapPoint = ResolvedDefaultSnapPoint;
        }

        context.SwipeDirection = SwipeDirection;
        context.SnapToSequentialPoints = SnapToSequentialPoints;
        context.SnapPoints = SnapPoints;
        context.ActiveSnapPoint = activeSnapPoint;
        context.PopupHeight = popupHeight;
        context.FrontmostHeight = frontmostHeight;
        context.HasNestedDrawer = hasNestedDrawer;
        context.NestedDrawerCount = nestedDrawerCount;
        context.NestedSwiping = nestedSwiping;
        context.NestedSwipeProgress = nestedSwipeProgress;
        context.NotifyParentFrontmostHeight = ParentDrawerContext?.OnNestedFrontmostHeightChange;
        context.NotifyParentSwipingChange = ParentDrawerContext?.OnNestedSwipingChange;
        context.NotifyParentSwipeProgressChange = ParentDrawerContext?.OnNestedSwipeProgressChange;
        context.NotifyParentHasNestedDrawer = ParentDrawerContext?.OnNestedDrawerPresenceChange;
        context.NotifyStateChanged();

        SyncActions();
    }

    private async Task HandleDialogOpenChangeAsync(DialogOpenChangeEventArgs args)
    {
        var drawerArgs = new DrawerOpenChangeEventArgs(args.Open, args.Reason.ToDrawerReason());
        await OnOpenChange.InvokeAsync(drawerArgs);

        if (drawerArgs.IsCanceled)
        {
            args.Cancel();
            return;
        }

        if (drawerArgs.PreventUnmount)
        {
            args.PreventUnmountOnClose();
        }

        if (!args.Open && SnapPoints is { Count: > 0 })
        {
            await SetActiveSnapPointAsync(ResolvedDefaultSnapPoint, drawerArgs.Reason);
        }
    }

    private async Task HandleDialogOpenChangedAsync(bool open)
    {
        await OpenChanged.InvokeAsync(open);
    }

    private void SyncActions()
    {
        if (ActionsRef is null)
        {
            return;
        }

        ActionsRef.Close = () => dialogActions.Close?.Invoke();
        ActionsRef.Unmount = () => dialogActions.Unmount?.Invoke();
    }

    private async Task SetActiveSnapPointAsync(DrawerSnapPoint? nextSnapPoint, DrawerOpenChangeReason reason)
    {
        var args = new DrawerSnapPointChangeEventArgs(nextSnapPoint, reason);
        await OnSnapPointChange.InvokeAsync(args);

        if (args.IsCanceled)
        {
            return;
        }

        if (!IsSnapPointControlled)
        {
            activeSnapPoint = nextSnapPoint;
        }

        context.ActiveSnapPoint = nextSnapPoint;
        context.NotifyStateChanged();
        await SnapPointChanged.InvokeAsync(nextSnapPoint);
        StateHasChanged();
    }

    private void OnPopupHeightChange(int height)
    {
        popupHeight = Math.Max(0, height);

        if (!hasNestedDrawer && popupHeight > 0)
        {
            frontmostHeight = popupHeight;
        }

        context.PopupHeight = popupHeight;
        context.FrontmostHeight = frontmostHeight;
        context.NotifyStateChanged();
        StateHasChanged();
    }

    private void OnNestedFrontmostHeightChange(int height)
    {
        if (height > 0)
        {
            frontmostHeight = height;
        }
        else if (popupHeight > 0)
        {
            frontmostHeight = popupHeight;
        }
        else
        {
            frontmostHeight = 0;
        }

        context.FrontmostHeight = frontmostHeight;
        context.NotifyStateChanged();
        StateHasChanged();
    }

    private void OnNestedDrawerPresenceChange(bool present)
    {
        var nextNestedDrawerCount = present
            ? nestedDrawerCount + 1
            : Math.Max(0, nestedDrawerCount - 1);

        if (nestedDrawerCount == nextNestedDrawerCount)
        {
            return;
        }

        nestedDrawerCount = nextNestedDrawerCount;
        hasNestedDrawer = nestedDrawerCount > 0;
        context.HasNestedDrawer = hasNestedDrawer;
        context.NestedDrawerCount = nestedDrawerCount;
        context.NotifyStateChanged();
        StateHasChanged();
    }

    private void OnNestedSwipingChange(bool swiping)
    {
        if (nestedSwiping == swiping)
        {
            return;
        }

        nestedSwiping = swiping;
        context.NestedSwiping = nestedSwiping;
        context.NotifyStateChanged();
        StateHasChanged();
    }

    private void OnNestedSwipeProgressChange(double progress)
    {
        var nextProgress = double.IsFinite(progress) ? progress : 0;
        if (Math.Abs(nestedSwipeProgress - nextProgress) < double.Epsilon)
        {
            return;
        }

        nestedSwipeProgress = nextProgress;
        context.NestedSwipeProgress = nestedSwipeProgress;
        // Nested swipe progress is high-frequency; descendants consume the context notification without forcing a root rerender per frame.
        context.NotifyStateChanged();
    }
}
