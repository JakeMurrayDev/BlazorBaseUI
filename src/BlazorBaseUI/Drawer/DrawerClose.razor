@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using BlazorBaseUI.Dialog

@implements IAsyncDisposable

<RenderElement TState="DrawerCloseState"
               Tag="button"
               State="state"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="ChildContent"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private const string JsModulePath = "./_content/BlazorBaseUI/blazor-baseui-button.min.js";

    private readonly Lazy<Task<IJSObjectReference>> moduleTask;

    private bool hasRendered;
    private bool previousDisabled;
    private bool previousNativeButton;
    private bool previousFocusableWhenDisabled;
    private DrawerCloseState state;
    private RenderElement<DrawerCloseState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private ElementReference? previousElement;

    private bool NeedsJsInterop => !NativeButton || Disabled || FocusableWhenDisabled;

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = null!;

    [CascadingParameter]
    private DialogRootContext? Context { get; set; }

    /// <summary>
    /// Gets or sets a custom render fragment that replaces the default element.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<DrawerCloseState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets a function that returns a CSS class based on the component's state.
    /// </summary>
    [Parameter]
    public Func<DrawerCloseState, string>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets a function that returns an inline style based on the component's state.
    /// </summary>
    [Parameter]
    public Func<DrawerCloseState, string>? StyleValue { get; set; }

    /// <summary>
    /// Determines whether the close button is disabled.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Determines whether the component renders a native <c>button</c> element when replacing it via <see cref="Render"/>.
    /// </summary>
    [Parameter]
    public bool NativeButton { get; set; } = true;

    /// <summary>
    /// Determines whether the button remains focusable when disabled.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool FocusableWhenDisabled { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    public DrawerClose()
    {
        moduleTask = new Lazy<Task<IJSObjectReference>>(() =>
            JSRuntime.InvokeAsync<IJSObjectReference>("import", JsModulePath).AsTask());
    }

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        if (Context is null)
        {
            throw new InvalidOperationException("DrawerClose must be used within a DrawerRoot.");
        }

        state = new DrawerCloseState(Disabled);
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        state = new DrawerCloseState(Disabled);
        BuildComponentAttributes();

        if (!hasRendered)
        {
            return;
        }

        var stateChanged = Disabled != previousDisabled
            || NativeButton != previousNativeButton
            || FocusableWhenDisabled != previousFocusableWhenDisabled;

        if (!stateChanged)
        {
            return;
        }

        var previousNeedsJs = !previousNativeButton || previousDisabled || previousFocusableWhenDisabled;
        var currentNeedsJs = NeedsJsInterop;
        previousDisabled = Disabled;
        previousNativeButton = NativeButton;
        previousFocusableWhenDisabled = FocusableWhenDisabled;

        if (currentNeedsJs)
        {
            _ = SyncJsAsync(dispose: false);
        }
        else if (previousNeedsJs)
        {
            _ = SyncJsAsync(dispose: true);
        }
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Element.HasValue)
        {
            previousElement = Element;
        }

        if (!firstRender)
        {
            return;
        }

        hasRendered = true;
        previousDisabled = Disabled;
        previousNativeButton = NativeButton;
        previousFocusableWhenDisabled = FocusableWhenDisabled;

        if (NeedsJsInterop)
        {
            await SyncJsAsync(dispose: false);
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (moduleTask.IsValueCreated)
        {
            try
            {
                var module = await moduleTask.Value;
                try
                {
                    if (previousElement.HasValue)
                    {
                        await module.InvokeVoidAsync("sync", previousElement.Value, false, false, false, true);
                    }
                }
                finally
                {
                    await module.DisposeAsync();
                }
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex;
            }
        }
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();

        if (NativeButton)
        {
            AccessibilityUtilities.ApplyNativeButtonAttributes(attrs, Disabled, FocusableWhenDisabled);
        }
        else
        {
            AccessibilityUtilities.ApplyButtonAttributes(attrs, Disabled, FocusableWhenDisabled);
        }

        attrs["data-disabled"] = Disabled;
        attrs["onclick"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleClickAsync);

        componentAttributes = attrs;
    }

    private async Task HandleClickAsync(MouseEventArgs e)
    {
        if (Disabled || Context is null || !Context.GetOpen())
        {
            return;
        }

        await Context.SetOpenAsync(false, DialogOpenChangeReason.ClosePress);
        await EventUtilities.InvokeOnClickAsync(AdditionalAttributes, e);
    }

    private async Task SyncJsAsync(bool dispose)
    {
        if (!Element.HasValue)
        {
            return;
        }

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("sync", Element.Value, Disabled, FocusableWhenDisabled, NativeButton, dispose);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }
    }
}
