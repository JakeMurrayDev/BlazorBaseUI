@using Microsoft.JSInterop

@implements IDisposable
@implements IAsyncDisposable

@inject IJSRuntime JSRuntime

<RenderElement TState="DrawerIndentState"
               Tag="div"
               State="state"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="computedStyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="ChildContent"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private const string ModulePath = "./_content/BlazorBaseUI/blazor-baseui-drawer.min.js";

    private Lazy<Task<IJSObjectReference>>? moduleTask;
    private DrawerIndentState state;
    private RenderElement<DrawerIndentState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private Func<DrawerIndentState, string>? computedStyleValue;
    private ElementReference? previousElement;
    private ElementReference? elementForDisposal;

    private Lazy<Task<IJSObjectReference>> ModuleTask => moduleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>("import", ModulePath).AsTask());

    [CascadingParameter]
    private DrawerProviderContext? ProviderContext { get; set; }

    /// <summary>
    /// Gets or sets a custom render fragment that replaces the default element.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<DrawerIndentState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets a function that returns a CSS class based on the component's state.
    /// </summary>
    [Parameter]
    public Func<DrawerIndentState, string>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets a function that returns an inline style based on the component's state.
    /// </summary>
    [Parameter]
    public Func<DrawerIndentState, string>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        if (ProviderContext is not null)
        {
            ProviderContext.StateChanged += OnProviderStateChanged;
        }

        state = new DrawerIndentState(ProviderContext?.Active ?? false);
        BuildComponentAttributes();
        UpdateComputedStyleValue();
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        state = new DrawerIndentState(ProviderContext?.Active ?? false);
        BuildComponentAttributes();
        UpdateComputedStyleValue();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var currentElement = Element;
        if (!Nullable.Equals(previousElement, currentElement))
        {
            previousElement = currentElement;
            if (currentElement.HasValue)
            {
                elementForDisposal = currentElement;
                await InitializeIndentJsAsync(currentElement.Value);
            }
        }
    }

    /// <inheritdoc />
    public void Dispose()
    {
        if (ProviderContext is not null)
        {
            ProviderContext.StateChanged -= OnProviderStateChanged;
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (moduleTask?.IsValueCreated == true)
        {
            try
            {
                var module = await ModuleTask.Value;
                try
                {
                    if (elementForDisposal.HasValue)
                    {
                        await module.InvokeVoidAsync("disposeIndent", elementForDisposal.Value);
                    }
                }
                finally
                {
                    await module.DisposeAsync();
                }
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex;
            }
        }
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();

        if (ProviderContext?.Active == true)
        {
            attrs["data-active"] = true;
        }
        else
        {
            attrs["data-inactive"] = true;
        }

        componentAttributes = attrs;
    }

    private void UpdateComputedStyleValue()
    {
        computedStyleValue = s =>
        {
            var height = ProviderContext?.FrontmostHeight > 0
                ? $" --drawer-height: {ProviderContext.FrontmostHeight}px;"
                : string.Empty;
            var baseStyle = $"--drawer-swipe-progress: {ProviderContext?.SwipeProgress ?? 0};{height}";
            var userStyle = StyleValue?.Invoke(s);
            return string.IsNullOrEmpty(userStyle) ? baseStyle : $"{baseStyle} {userStyle}";
        };
    }

    private void OnProviderStateChanged()
    {
        _ = InvokeAsync(() =>
        {
            state = new DrawerIndentState(ProviderContext?.Active ?? false);
            BuildComponentAttributes();
            UpdateComputedStyleValue();
            StateHasChanged();
        });
    }

    private async Task InitializeIndentJsAsync(ElementReference element)
    {
        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync("initializeIndent", element);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }
    }
}
