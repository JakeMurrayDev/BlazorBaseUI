@using Microsoft.JSInterop
@using BlazorBaseUI.Dialog
@using BlazorBaseUI.FloatingFocusManager

@implements IAsyncDisposable

@inject IJSRuntime JSRuntime

<RenderElement TState="DrawerPopupState"
               Tag="div"
               Enabled="shouldRender"
               State="state"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="computedStyleValue"
               ComponentAttributes="componentAttributes"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference">
    <FloatingFocusManager Modal="@(Context is not null && Context.Modal != DialogModalMode.False)"
                          Disabled="@(Context is null || !Context.GetMounted())"
                          InitialFocus="@ComputeInitialFocus()"
                          ReturnFocus="@ComputeReturnFocus()"
                          CloseOnFocusOut="@(Context is not null && !Context.DisablePointerDismissal)"
                          RestoreFocusMode="popup"
                          InteractionType="@(Context?.InteractionType)">
        @ChildContent
    </FloatingFocusManager>
</RenderElement>

@code {
    private const string DialogModulePath = "./_content/BlazorBaseUI/blazor-baseui-dialog.min.js";
    private const string DrawerModulePath = "./_content/BlazorBaseUI/blazor-baseui-drawer.min.js";

    private Lazy<Task<IJSObjectReference>>? dialogModuleTask;
    private Lazy<Task<IJSObjectReference>>? drawerModuleTask;
    private DotNetObjectReference<DrawerPopup>? dotNetRef;
    private readonly string popupId = Guid.NewGuid().ToIdString();
    private bool hasRendered;
    private bool shouldRender;
    private bool popupInitialized;
    private DrawerPopupState state;
    private RenderElement<DrawerPopupState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private Func<DrawerPopupState, string>? computedStyleValue;
    private ElementReference? previousElement;
    private FocusTarget? previousInitialFocus;
    private FocusTarget? previousFinalFocus;
    private int? lastNotifiedParentFrontmostHeight;

    private Lazy<Task<IJSObjectReference>> DialogModuleTask => dialogModuleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>("import", DialogModulePath).AsTask());

    private Lazy<Task<IJSObjectReference>> DrawerModuleTask => drawerModuleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>("import", DrawerModulePath).AsTask());

    [CascadingParameter]
    private DialogRootContext? Context { get; set; }

    [CascadingParameter]
    private DialogPortalContext? PortalContext { get; set; }

    [CascadingParameter]
    private DrawerRootContext? DrawerContext { get; set; }

    [CascadingParameter]
    private DrawerViewportContext? ViewportContext { get; set; }

    /// <summary>
    /// Gets or sets a custom render fragment that replaces the default element.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<DrawerPopupState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets a function that returns a CSS class based on the component's state.
    /// </summary>
    [Parameter]
    public Func<DrawerPopupState, string>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets a function that returns an inline style based on the component's state.
    /// </summary>
    [Parameter]
    public Func<DrawerPopupState, string>? StyleValue { get; set; }

    /// <summary>
    /// Gets or sets the focus target when the drawer is opened.
    /// </summary>
    [Parameter]
    public FocusTarget? InitialFocus { get; set; }

    /// <summary>
    /// Gets or sets the focus target when the drawer is closed.
    /// </summary>
    [Parameter]
    public FocusTarget? FinalFocus { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        if (Context is null)
        {
            throw new InvalidOperationException("DrawerPopup must be used within a DrawerRoot.");
        }

        if (PortalContext is null)
        {
            throw new InvalidOperationException("DrawerPopup must be used within a DrawerPortal.");
        }

        if (DrawerContext is null)
        {
            throw new InvalidOperationException("DrawerPopup must be used within a DrawerRoot.");
        }

        Context.SetPopupId(popupId);
        SubscribeViewportContext();
        state = BuildState();
        UpdateShouldRender();
        UpdateComputedStyleValue();
        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        state = BuildState();
        UpdateShouldRender();
        UpdateComputedStyleValue();
        BuildComponentAttributes();
        NotifyParentFrontmostHeight();

        if (hasRendered)
        {
            if (!Equals(InitialFocus, previousInitialFocus))
            {
                previousInitialFocus = InitialFocus;
                var (mode, element) = ResolveFocusTarget(InitialFocus);
                _ = SetInitialFocusElementAsync(mode, element);
            }

            if (!Equals(FinalFocus, previousFinalFocus))
            {
                previousFinalFocus = FinalFocus;
                var (mode, element) = ResolveFocusTarget(FinalFocus);
                _ = SetFinalFocusElementAsync(mode, element);
            }

            _ = UpdateDrawerPopupJsAsync();
        }
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            hasRendered = true;
            dotNetRef = DotNetObjectReference.Create(this);
        }

        var currentElement = Element;
        var elementChanged = !Nullable.Equals(previousElement, currentElement);
        if (elementChanged)
        {
            if (popupInitialized)
            {
                await DisposePopupJsRegistrationsAsync();
                popupInitialized = false;
            }

            previousElement = currentElement;
            Context?.SetPopupElement(currentElement);
        }

        if (!currentElement.HasValue || Context is null || popupInitialized)
        {
            return;
        }

        await InitializePopupJsRegistrationsAsync(currentElement.Value);
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        UnsubscribeViewportContext();
        DrawerContext?.NotifyParentFrontmostHeight?.Invoke(0);

        await DisposePopupJsRegistrationsAsync(disposeModules: true);

        Context?.SetPopupId(null);
        dotNetRef?.Dispose();
    }

    /// <summary>
    /// Receives popup height measurements from JavaScript.
    /// </summary>
    [JSInvokable]
    public void OnPopupHeightChanged(int height)
    {
        DrawerContext?.OnPopupHeightChange(height);
    }

    private async Task InitializePopupJsRegistrationsAsync(ElementReference element)
    {
        if (Context is null)
        {
            return;
        }

        var (initialMode, initialElement) = ResolveFocusTarget(InitialFocus);
        var (finalMode, finalElement) = ResolveFocusTarget(FinalFocus);

        try
        {
            var dialogModule = await DialogModuleTask.Value;
            await dialogModule.InvokeVoidAsync(
                "initializePopup",
                Context.RootId,
                element,
                Context.Modal.ToDataAttributeString(),
                initialMode,
                initialElement,
                finalMode,
                finalElement);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }

        await InitializeDrawerPopupJsAsync(element);
        await ApplyDeferredInitialFocusAsync(initialMode);
        previousInitialFocus = InitialFocus;
        previousFinalFocus = FinalFocus;
        popupInitialized = true;
    }

    private async Task DisposePopupJsRegistrationsAsync(bool disposeModules = false)
    {
        if (Context is null)
        {
            return;
        }

        if (drawerModuleTask?.IsValueCreated == true && hasRendered)
        {
            try
            {
                var module = await DrawerModuleTask.Value;
                try
                {
                    await module.InvokeVoidAsync("disposePopup", Context.RootId);
                }
                finally
                {
                    if (disposeModules)
                    {
                        await module.DisposeAsync();
                    }
                }
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex;
            }
        }

        if (dialogModuleTask?.IsValueCreated == true && hasRendered)
        {
            try
            {
                var module = await DialogModuleTask.Value;
                try
                {
                    await module.InvokeVoidAsync("disposePopup", Context.RootId);
                }
                finally
                {
                    if (disposeModules)
                    {
                        await module.DisposeAsync();
                    }
                }
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex;
            }
        }

        popupInitialized = false;
    }

    private void UpdateShouldRender()
    {
        if (Context is null)
        {
            shouldRender = false;
            return;
        }

        var keepMounted = PortalContext?.KeepMounted ?? false;
        shouldRender = keepMounted || Context.Mounted;
    }

    private void UpdateComputedStyleValue()
    {
        computedStyleValue = s =>
        {
            var nestedDrawers = DrawerContext?.NestedDrawerCount ?? 0;
            var height = DrawerContext?.PopupHeight > 0 && DrawerContext.HasNestedDrawer
                ? $" --drawer-height: {DrawerContext.PopupHeight}px;"
                : string.Empty;
            var frontmostHeight = DrawerContext?.FrontmostHeight > 0
                ? $" --drawer-frontmost-height: {DrawerContext.FrontmostHeight}px;"
                : string.Empty;
            var strength = ViewportContext?.SwipeStrength;
            var swipeStrength = strength.HasValue && double.IsFinite(strength.Value) && strength.Value > 0
                ? strength.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)
                : "1";
            var baseStyle = $"--drawer-swipe-progress: 0; --nested-drawers: {nestedDrawers}; --drawer-snap-point-offset: 0px; --drawer-swipe-strength: {swipeStrength};{height}{frontmostHeight}";
            var userStyle = StyleValue?.Invoke(s);
            return string.IsNullOrEmpty(userStyle) ? baseStyle : $"{baseStyle} {userStyle}";
        };
    }

    private void BuildComponentAttributes()
    {
        if (Context is null || DrawerContext is null)
        {
            return;
        }

        var attrs = new Dictionary<string, object>
        {
            ["id"] = popupId,
            ["role"] = Context.Role.ToRoleString(),
            ["tabindex"] = "-1",
            ["data-blazor-base-ui-focusable"] = true,
            ["data-open"] = Context.Open,
            ["data-closed"] = !Context.Open
        };

        var swipeDirection = DrawerContext.SwipeDirection.ToDataAttributeString();
        if (swipeDirection is not null)
        {
            attrs["data-swipe-direction"] = swipeDirection;
        }

        if (Context.Modal != DialogModalMode.False)
        {
            attrs["aria-modal"] = "true";
        }

        if (!string.IsNullOrEmpty(Context.TitleId))
        {
            attrs["aria-labelledby"] = Context.TitleId;
        }

        if (!string.IsNullOrEmpty(Context.DescriptionId))
        {
            attrs["aria-describedby"] = Context.DescriptionId;
        }

        if (DrawerContext.ActiveSnapPoint is { } snapPoint && snapPoint.IsNumber && snapPoint.NumberValue == 1)
        {
            attrs["data-expanded"] = true;
        }

        if (DrawerContext.HasNestedDrawer)
        {
            attrs["data-nested-drawer-open"] = true;
        }

        if (DrawerContext.NestedSwiping)
        {
            attrs["data-nested-drawer-swiping"] = true;
        }

        if (ViewportContext?.Swiping == true)
        {
            attrs["data-swiping"] = true;
        }

        TransitionAttributeHelper.ApplyTransitionStyleAttributes(attrs, Context.TransitionStatus);

        var keepMounted = PortalContext?.KeepMounted ?? false;
        var isHidden = keepMounted && !Context.Open && (Context.TransitionStatus == TransitionStatus.Undefined || Context.TransitionStatus == TransitionStatus.Idle);
        if (isHidden)
        {
            attrs["hidden"] = true;
        }

        componentAttributes = attrs;
    }

    private DrawerPopupState BuildState()
    {
        if (Context is null || DrawerContext is null)
        {
            return default;
        }

        var expanded = DrawerContext.ActiveSnapPoint is { } snapPoint && snapPoint.IsNumber && snapPoint.NumberValue == 1;
        return new DrawerPopupState(
            Context.Open,
            Context.TransitionStatus,
            expanded,
            Context.Nested,
            DrawerContext.HasNestedDrawer,
            DrawerContext.NestedSwiping,
            DrawerContext.SwipeDirection,
            ViewportContext?.Swiping ?? false);
    }

    private void SubscribeViewportContext()
    {
        if (ViewportContext is not null)
        {
            ViewportContext.StateChanged += OnViewportContextStateChanged;
        }
    }

    private void UnsubscribeViewportContext()
    {
        if (ViewportContext is not null)
        {
            ViewportContext.StateChanged -= OnViewportContextStateChanged;
        }
    }

    private void OnViewportContextStateChanged()
    {
        _ = InvokeAsync(() =>
        {
            state = BuildState();
            UpdateComputedStyleValue();
            BuildComponentAttributes();
            StateHasChanged();
        });
    }

    private void NotifyParentFrontmostHeight()
    {
        if (Context is null || DrawerContext?.NotifyParentFrontmostHeight is null)
        {
            return;
        }

        var nextHeight = Context.Open ? DrawerContext.FrontmostHeight : 0;
        if (lastNotifiedParentFrontmostHeight == nextHeight)
        {
            return;
        }

        lastNotifiedParentFrontmostHeight = nextHeight;
        DrawerContext.NotifyParentFrontmostHeight(nextHeight);
    }

    private async Task InitializeDrawerPopupJsAsync(ElementReference element)
    {
        if (Context is null || DrawerContext is null || dotNetRef is null)
        {
            return;
        }

        try
        {
            var module = await DrawerModuleTask.Value;
            await module.InvokeVoidAsync(
                "initializePopup",
                Context.RootId,
                element,
                dotNetRef,
                DrawerContext.SwipeDirection.ToDataAttributeString());
            await UpdateDrawerPopupJsAsync();
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }
    }

    private async Task UpdateDrawerPopupJsAsync()
    {
        if (Context is null || DrawerContext is null)
        {
            return;
        }

        try
        {
            var module = await DrawerModuleTask.Value;
            await module.InvokeVoidAsync(
                "updatePopup",
                Context.RootId,
                Context.Open,
                Context.Mounted,
                DrawerContext.SwipeDirection.ToDataAttributeString(),
                DrawerContext.SnapPoints?.Select(static point => point.ToString()).ToArray(),
                DrawerContext.ActiveSnapPoint?.ToString(),
                DrawerContext.FrontmostHeight);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }
    }

    private async Task SetInitialFocusElementAsync(string? mode, ElementReference? element)
    {
        if (Context is null)
        {
            return;
        }

        try
        {
            var module = await DialogModuleTask.Value;
            await module.InvokeVoidAsync("setInitialFocusElement", Context.RootId, mode, element);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }
    }

    private async Task ApplyDeferredInitialFocusAsync(string? initialMode)
    {
        if (InitialFocus is not FocusTarget.Callback || initialMode == "element")
        {
            return;
        }

        for (var attempt = 0; attempt < 5; attempt++)
        {
            await Task.Delay(16);

            var (mode, element) = ResolveFocusTarget(InitialFocus);
            if (mode == "element" && element.HasValue)
            {
                await SetInitialFocusElementAsync(mode, element);
                return;
            }

            if (mode is not null && mode != "element")
            {
                await SetInitialFocusElementAsync(mode, element);
                return;
            }
        }
    }

    private async Task SetFinalFocusElementAsync(string? mode, ElementReference? element)
    {
        if (Context is null)
        {
            return;
        }

        try
        {
            var module = await DialogModuleTask.Value;
            await module.InvokeVoidAsync("setFinalFocusElement", Context.RootId, mode, element);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }
    }

    private (string? Mode, ElementReference? Element) ResolveFocusTarget(FocusTarget? target)
    {
        return target switch
        {
            null => (null, null),
            FocusTarget.None => ("none", null),
            FocusTarget.Default => ("default", null),
            FocusTarget.Element e => ("element", e.Ref),
            FocusTarget.Callback cb => ResolveFocusCallback(cb),
            _ => (null, null)
        };
    }

    private (string? Mode, ElementReference? Element) ResolveFocusCallback(FocusTarget.Callback cb)
    {
        var interactionType = Context?.InteractionType ?? string.Empty;
        var result = cb.Fn(interactionType);
        return result.HasValue ? ("element", result.Value) : ("default", null);
    }

    private bool ComputeInitialFocus()
    {
        return InitialFocus is not FocusTarget.None;
    }

    private bool ComputeReturnFocus()
    {
        return FinalFocus is not FocusTarget.None;
    }
}
