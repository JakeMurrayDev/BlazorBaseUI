@using Microsoft.JSInterop

@typeparam TValue

@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<RenderElement TState="TabsIndicatorState"
               Tag="span"
               State="state"
               Enabled="ShouldRenderIndicator"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="computedStyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="ChildContent"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />
@if (ShouldRenderIndicator && RenderBeforeHydration)
{
    <script>@((MarkupString)PrehydrationScript)</script>
}

@code {
    private const string JsModulePath = "./_content/BlazorBaseUI/blazor-baseui-tabs.js";
    private const string PrehydrationScript = "!function(){const t=document.currentScript.previousElementSibling;if(!t)return;const e=t.closest('[role=\"tablist\"]');if(!e)return;const i=e.querySelector('[data-active]');if(!i)return;if(i.offsetWidth===0||e.offsetWidth===0)return;let o=0,n=0,h=0,l=0,r=0,f=0;function s(t){const e=getComputedStyle(t);let i=parseFloat(e.width)||0,o=parseFloat(e.height)||0;if(Math.round(i)!==t.offsetWidth||Math.round(o)!==t.offsetHeight){i=t.offsetWidth;o=t.offsetHeight}return{width:i,height:o}}const c=s(i),u=s(e),a=i.getBoundingClientRect(),g=e.getBoundingClientRect(),p=u.width>0?g.width/u.width:1,b=u.height>0?g.height/u.height:1;if(Math.abs(p)>Number.EPSILON&&Math.abs(b)>Number.EPSILON){o=(a.left-g.left)/p+e.scrollLeft-e.clientLeft;h=(a.top-g.top)/b+e.scrollTop-e.clientTop}else{o=i.offsetLeft;h=i.offsetTop}r=c.width;f=c.height;n=e.scrollWidth-o-r;l=e.scrollHeight-h-f;function d(e,i){t.style.setProperty('--active-tab-'+e,i+'px')}d('left',o);d('right',n);d('top',h);d('bottom',l);d('width',r);d('height',f);if(r>0&&f>0)t.removeAttribute('hidden')}();";

    private readonly Lazy<Task<IJSObjectReference>> moduleTask;

    private bool hasRendered;
    private bool isObserving;
    private DotNetObjectReference<TabsIndicator<TValue>>? dotNetRef;
    private IndicatorPositionResult? currentPosition;
    private TabsIndicatorState state = TabsIndicatorState.Default;
    private RenderElement<TabsIndicatorState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private Func<TabsIndicatorState, string?>? computedStyleValue;

    private Orientation Orientation => RootContext?.Orientation ?? Orientation.Horizontal;

    private ActivationDirection ActivationDirection => RootContext?.ActivationDirection ?? ActivationDirection.None;

    private bool HasValidPosition => currentPosition is not null && currentPosition.Width > 0 && currentPosition.Height > 0;

    private bool ShouldRenderIndicator => RootContext is not null && RootContext.Value is not null;

    private TabPosition? ActiveTabPosition => currentPosition is not null
        ? new TabPosition(currentPosition.Left, currentPosition.Right, currentPosition.Top, currentPosition.Bottom)
        : null;

    private TabSize? ActiveTabSize => currentPosition is not null
        ? new TabSize(currentPosition.Width, currentPosition.Height)
        : null;

    [CascadingParameter]
    private ITabsRootContext<TValue>? RootContext { get; set; }

    [CascadingParameter]
    private ITabsListContext? ListContext { get; set; }

    /// <summary>
    /// Determines whether the indicator should emit pre-hydration support markup.
    /// This minimizes the time that the indicator is hidden during server-side hydration.
    /// </summary>
    [Parameter]
    public bool RenderBeforeHydration { get; set; }

    /// <summary>
    /// Allows you to replace the component's HTML element
    /// with a different tag, or compose it with another component.
    /// Accepts a function that returns the element to render.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<TabsIndicatorState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on the component state.
    /// </summary>
    [Parameter]
    public Func<TabsIndicatorState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on the component state.
    /// </summary>
    [Parameter]
    public Func<TabsIndicatorState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    public TabsIndicator()
    {
        moduleTask = new Lazy<Task<IJSObjectReference>>(() =>
            JSRuntime.InvokeAsync<IJSObjectReference>("import", JsModulePath).AsTask());
    }

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        computedStyleValue = s =>
        {
            var userStyle = StyleValue?.Invoke(s);
            var positionStyle = BuildPositionStyle();
            return CombineStyles(userStyle, positionStyle);
        };
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        state = new TabsIndicatorState(Orientation, ActivationDirection, ActiveTabPosition, ActiveTabSize);
        BuildComponentAttributes();

        if (hasRendered)
        {
            _ = UpdateIndicatorPositionAndRerenderAsync();
        }
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            hasRendered = true;
            dotNetRef = DotNetObjectReference.Create(this);
            await UpdateIndicatorPositionAsync();
            await StartObservingAsync();
            StateHasChanged();
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        await StopObservingAsync();
        dotNetRef?.Dispose();

        if (moduleTask.IsValueCreated && Element.HasValue)
        {
            try
            {
                var module = await moduleTask.Value;
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }
    }

    /// <summary>
    /// Handles resize events to recalculate the indicator position. Called from JavaScript interop.
    /// </summary>
    [JSInvokable]
    public async Task OnResizeAsync()
    {
        await UpdateIndicatorPositionAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();

        attrs["role"] = "presentation";

        if (!HasValidPosition)
        {
            attrs["hidden"] = true;
        }

        attrs["data-activation-direction"] = ActivationDirection.ToDataAttributeString();
        attrs["data-orientation"] = Orientation.ToDataAttributeString() ?? "horizontal";

        componentAttributes = attrs;
    }

    private async Task UpdateIndicatorPositionAndRerenderAsync()
    {
        await UpdateIndicatorPositionAsync();
        await InvokeAsync(StateHasChanged);
    }

    private string? BuildPositionStyle()
    {
        if (!HasValidPosition || currentPosition is null)
        {
            return null;
        }

        return string.Create(System.Globalization.CultureInfo.InvariantCulture,
            $"--active-tab-left:{currentPosition.Left}px;" +
            $"--active-tab-right:{currentPosition.Right}px;" +
            $"--active-tab-top:{currentPosition.Top}px;" +
            $"--active-tab-bottom:{currentPosition.Bottom}px;" +
            $"--active-tab-width:{currentPosition.Width}px;" +
            $"--active-tab-height:{currentPosition.Height}px;");
    }

    private static string? CombineStyles(string? style1, string? style2)
    {
        if (string.IsNullOrEmpty(style1) && string.IsNullOrEmpty(style2))
        {
            return null;
        }

        if (string.IsNullOrEmpty(style1))
        {
            return style2;
        }

        if (string.IsNullOrEmpty(style2))
        {
            return style1;
        }

        var s1 = style1.TrimEnd();
        if (!s1.EndsWith(';'))
        {
            s1 += ";";
        }

        return s1 + style2;
    }

    private async Task UpdateIndicatorPositionAsync()
    {
        if (!hasRendered || RootContext is null || ListContext?.TabsListElement is null)
        {
            currentPosition = null;
            state = new TabsIndicatorState(Orientation, ActivationDirection, null, null);
            BuildComponentAttributes();
            return;
        }

        var activeValue = RootContext.Value;
        if (activeValue is null)
        {
            currentPosition = null;
            state = new TabsIndicatorState(Orientation, ActivationDirection, null, null);
            BuildComponentAttributes();
            return;
        }

        var activeTabElement = RootContext.GetTabElementByValue(activeValue);
        if (activeTabElement is null || !activeTabElement.HasValue)
        {
            currentPosition = null;
            state = new TabsIndicatorState(Orientation, ActivationDirection, null, null);
            BuildComponentAttributes();
            return;
        }

        var listElement = ListContext.TabsListElement;
        if (!listElement.HasValue)
        {
            currentPosition = null;
            state = new TabsIndicatorState(Orientation, ActivationDirection, null, null);
            BuildComponentAttributes();
            return;
        }

        try
        {
            var module = await moduleTask.Value;
            currentPosition = await module.InvokeAsync<IndicatorPositionResult>(
                "getIndicatorPosition",
                listElement.Value,
                activeTabElement.Value);
            state = new TabsIndicatorState(Orientation, ActivationDirection, ActiveTabPosition, ActiveTabSize);
            BuildComponentAttributes();
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            currentPosition = null;
            state = new TabsIndicatorState(Orientation, ActivationDirection, null, null);
            BuildComponentAttributes();
        }
    }

    private async Task StartObservingAsync()
    {
        if (isObserving || ListContext?.TabsListElement is null || !ListContext.TabsListElement.HasValue)
        {
            return;
        }

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("observeResize", ListContext.TabsListElement.Value, dotNetRef);
            isObserving = true;
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task StopObservingAsync()
    {
        if (!isObserving || !moduleTask.IsValueCreated || ListContext?.TabsListElement is null || !ListContext.TabsListElement.HasValue)
        {
            return;
        }

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("unobserveResize", ListContext.TabsListElement.Value, dotNetRef);
            isObserving = false;
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private sealed record IndicatorPositionResult(
        double Left,
        double Right,
        double Top,
        double Bottom,
        double Width,
        double Height);
}
