@using Microsoft.JSInterop

@typeparam TValue

@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<RenderElement TState="TabsPanelState"
               Tag="div"
               State="state"
               Enabled="isMounted || KeepMounted"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="ChildContent"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private const string JsModulePath = "./_content/BlazorBaseUI/blazor-baseui-tabs.js";

    private readonly Lazy<Task<IJSObjectReference>> moduleTask;

    private TValue previousValue = default!;
    private string? defaultId;
    private string panelId = null!;
    private bool previousOpen;
    private bool isMounted;
    private Orientation previousOrientation;
    private ActivationDirection previousActivationDirection;
    private TransitionStatus transitionStatus = TransitionStatus.Undefined;
    private DotNetObjectReference<TabsPanel<TValue>>? dotNetRef;
    private ElementReference? capturedElement;
    private TabsPanelState state = TabsPanelState.Default;
    private RenderElement<TabsPanelState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private bool isRegistered;

    private bool IsOpen
    {
        get
        {
            if (RootContext is null)
            {
                return false;
            }

            return EqualityComparer<TValue>.Default.Equals(RootContext.Value, Value);
        }
    }

    private bool IsHidden => !isMounted;

    private Orientation Orientation => RootContext?.Orientation ?? Orientation.Horizontal;

    private ActivationDirection ActivationDirection => RootContext?.ActivationDirection ?? ActivationDirection.None;

    private string ResolvedId => AttributeUtilities.GetIdOrDefault(AdditionalAttributes, () => defaultId ??= Guid.NewGuid().ToIdString());

    [CascadingParameter]
    private ITabsRootContext<TValue>? RootContext { get; set; }

    /// <summary>
    /// Gets or sets the value of the tab panel.
    /// It will be shown when the <see cref="TabsTab{TValue}"/> with the corresponding value is active.
    /// </summary>
    [Parameter, EditorRequired]
    public TValue Value { get; set; } = default!;

    /// <summary>
    /// Determines whether to keep the HTML element in the DOM while the panel is hidden.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool KeepMounted { get; set; }

    /// <summary>
    /// Allows you to replace the component's HTML element
    /// with a different tag, or compose it with another component.
    /// Accepts a function that returns the element to render.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<TabsPanelState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on the component state.
    /// </summary>
    [Parameter]
    public Func<TabsPanelState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on the component state.
    /// </summary>
    [Parameter]
    public Func<TabsPanelState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    public TabsPanel()
    {
        moduleTask = new Lazy<Task<IJSObjectReference>>(() =>
            JSRuntime.InvokeAsync<IJSObjectReference>("import", JsModulePath).AsTask());
    }

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        if (RootContext is null)
        {
            throw new InvalidOperationException("TabsPanel must be used within a TabsRoot component.");
        }

        panelId = ResolvedId;
        previousValue = Value;
        previousOpen = IsOpen;
        isMounted = previousOpen;
        previousOrientation = Orientation;
        previousActivationDirection = ActivationDirection;
        RootContext.RegisterPanelInfo(Value, panelId);
        state = new TabsPanelState(IsHidden, previousOrientation, previousActivationDirection, transitionStatus);
        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        var newId = ResolvedId;
        var valueChanged = !EqualityComparer<TValue>.Default.Equals(previousValue, Value);
        if (newId != panelId || valueChanged)
        {
            if (isRegistered)
            {
                RootContext?.UnregisterPanel(previousValue, panelId);
            }

            RootContext?.UnregisterPanelInfo(previousValue, panelId);
            panelId = newId;
            previousValue = Value;
            isRegistered = false;
            RootContext?.RegisterPanelInfo(Value, panelId);
        }

        var currentOpen = IsOpen;
        var currentOrientation = Orientation;
        var currentActivationDirection = ActivationDirection;

        if (currentOpen != previousOpen)
        {
            transitionStatus = currentOpen ? TransitionStatus.Starting : TransitionStatus.Ending;

            if (currentOpen)
            {
                isMounted = true;
            }
        }

        var currentHidden = IsHidden;

        if (currentOpen != previousOpen ||
            currentHidden != state.Hidden ||
            currentOrientation != previousOrientation ||
            currentActivationDirection != previousActivationDirection ||
            state.TransitionStatus != transitionStatus)
        {
            state = new TabsPanelState(
                currentHidden,
                currentOrientation,
                currentActivationDirection,
                transitionStatus);
            previousOpen = currentOpen;
            previousOrientation = currentOrientation;
            previousActivationDirection = currentActivationDirection;
        }

        RootContext?.RegisterPanelInfo(Value, panelId);

        var shouldBeRegistered = isMounted || KeepMounted;

        if (shouldBeRegistered && !isRegistered)
        {
            RootContext?.RegisterPanel(Value, panelId);
            isRegistered = true;
        }
        else if (!shouldBeRegistered && isRegistered)
        {
            RootContext?.UnregisterPanel(Value, panelId);
            isRegistered = false;
        }

        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (transitionStatus is not (TransitionStatus.Starting or TransitionStatus.Ending) || !Element.HasValue)
        {
            return;
        }

        try
        {
            dotNetRef ??= DotNetObjectReference.Create(this);
            var element = Element.Value;
            capturedElement = element;
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync(
                "startPanelTransition",
                element,
                dotNetRef,
                transitionStatus == TransitionStatus.Starting);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (isRegistered)
        {
            RootContext?.UnregisterPanel(Value, panelId);
            isRegistered = false;
        }

        RootContext?.UnregisterPanelInfo(Value, panelId);

        if (moduleTask.IsValueCreated)
        {
            try
            {
                var module = await moduleTask.Value;
                if (capturedElement.HasValue)
                {
                    await module.InvokeVoidAsync("disposePanel", capturedElement.Value);
                }

                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }

        dotNetRef?.Dispose();
    }

    /// <summary>
    /// Handles the end of the panel starting-style frame. Called from JavaScript interop.
    /// </summary>
    [JSInvokable]
    public void OnPanelStartingStyleApplied()
    {
        if (transitionStatus != TransitionStatus.Starting)
        {
            return;
        }

        transitionStatus = TransitionStatus.Undefined;
        state = state with { Hidden = IsHidden, TransitionStatus = transitionStatus };
        BuildComponentAttributes();
        StateHasChanged();
    }

    /// <summary>
    /// Handles the end of a panel exit transition. Called from JavaScript interop.
    /// </summary>
    [JSInvokable]
    public void OnPanelTransitionEnded()
    {
        if (transitionStatus != TransitionStatus.Ending)
        {
            return;
        }

        transitionStatus = TransitionStatus.Undefined;

        if (!IsOpen)
        {
            isMounted = false;
            if (!KeepMounted && isRegistered)
            {
                RootContext?.UnregisterPanel(Value, panelId);
                isRegistered = false;
            }
        }

        state = state with { Hidden = IsHidden, TransitionStatus = transitionStatus };
        BuildComponentAttributes();
        StateHasChanged();
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();
        var isHidden = IsHidden;
        var isOpen = IsOpen;
        var tabId = RootContext?.GetTabIdByPanelValue(Value);
        var orientationValue = Orientation.ToDataAttributeString();

        attrs["id"] = panelId;
        attrs["role"] = "tabpanel";
        attrs["tabindex"] = isOpen ? 0 : -1;
        attrs["data-index"] = RootContext?.GetPanelIndexByValue(Value) ?? 0;

        if (isHidden)
        {
            attrs["hidden"] = true;
        }

        if (!isOpen)
        {
            attrs["inert"] = true;
        }

        if (tabId is not null)
        {
            attrs["aria-labelledby"] = tabId;
        }

        if (orientationValue is not null)
        {
            attrs["data-orientation"] = orientationValue;
        }

        attrs["data-activation-direction"] = ActivationDirection.ToDataAttributeString();
        attrs["data-hidden"] = isHidden;
        TransitionAttributeHelper.ApplyTransitionStyleAttributes(attrs, state.TransitionStatus);

        componentAttributes = attrs;
    }
}
