@using Microsoft.JSInterop
@using System.Text.Json

@implements IAsyncDisposable

@inject IJSRuntime JS

<CascadingValue Value="context" IsFixed="true">
    @ChildContent
</CascadingValue>

@code {
    private readonly Lazy<Task<IJSObjectReference>> moduleTask;
    private FloatingDelayGroupContext context = null!;
    private DotNetObjectReference<FloatingDelayGroup>? dotNetRef;
    private string? groupId;
    private bool disposed;
    private int previousOpenDelayMs;
    private int previousCloseDelayMs;
    private int previousTimeoutMs;

    public FloatingDelayGroup()
    {
        moduleTask = new(() => JS.InvokeAsync<IJSObjectReference>(
            "import", "./_content/BlazorBaseUI/blazor-baseui-floating.min.js").AsTask());
    }

    /// <summary>
    /// The child content to render within the delay group context.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// The open delay in milliseconds for group members.
    /// </summary>
    [Parameter]
    public int OpenDelayMs { get; set; }

    /// <summary>
    /// The close delay in milliseconds for group members.
    /// </summary>
    [Parameter]
    public int CloseDelayMs { get; set; }

    /// <summary>
    /// How long the instant phase persists (in milliseconds) after the close delay completes.
    /// </summary>
    [Parameter]
    public int TimeoutMs { get; set; }

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        context = new FloatingDelayGroupContext
        {
            HasProvider = true,
            GetDelay = () => context.IsInstantPhase
                ? (0, CloseDelayMs)
                : (OpenDelayMs, CloseDelayMs),
            RegisterMemberAsync = RegisterMemberAsync,
            UnregisterMemberAsync = UnregisterMemberAsync,
            NotifyMemberOpenedAsync = NotifyMemberOpenedAsync,
            NotifyMemberClosedAsync = NotifyMemberClosedAsync
        };
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !disposed)
        {
            try
            {
                dotNetRef = DotNetObjectReference.Create(this);

                var module = await moduleTask.Value;
                if (disposed)
                {
                    return;
                }

                var result = await module.InvokeAsync<JsonElement>("createDelayGroup", new
                {
                    delay = new { open = OpenDelayMs, close = CloseDelayMs },
                    timeoutMs = TimeoutMs,
                    setIsInstantPhaseRef = dotNetRef
                });
                groupId = result.GetProperty("groupId").GetString();
                context.GroupId = groupId ?? string.Empty;

                previousOpenDelayMs = OpenDelayMs;
                previousCloseDelayMs = CloseDelayMs;
                previousTimeoutMs = TimeoutMs;
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
            {
                _ = ex;
            }
        }
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        if (disposed || groupId is null) return;

        var openDelayChanged = OpenDelayMs != previousOpenDelayMs;
        var closeDelayChanged = CloseDelayMs != previousCloseDelayMs;
        var timeoutChanged = TimeoutMs != previousTimeoutMs;

        if (openDelayChanged || closeDelayChanged || timeoutChanged)
        {
            previousOpenDelayMs = OpenDelayMs;
            previousCloseDelayMs = CloseDelayMs;
            previousTimeoutMs = TimeoutMs;

            _ = UpdateDelayGroupOptionsAsync();
        }
    }

    public async ValueTask DisposeAsync()
    {
        disposed = true;

        if (groupId is not null && moduleTask.IsValueCreated)
        {
            try
            {
                var module = await moduleTask.Value;
                await module.InvokeVoidAsync("disposeDelayGroup", groupId);
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
            {
                _ = ex;
            }
        }

        dotNetRef?.Dispose();

        if (moduleTask.IsValueCreated)
        {
            try
            {
                var module = await moduleTask.Value;
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
            {
                _ = ex;
            }
        }
    }

    /// <summary>
    /// Invoked by JS when the instant phase state changes.
    /// </summary>
    [JSInvokable]
    public void SetIsInstantPhase(bool value)
    {
        if (disposed)
        {
            return;
        }

        if (context.IsInstantPhase == value)
        {
            return;
        }

        context.IsInstantPhase = value;
        context.NotifyStateChanged();
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task UpdateDelayGroupOptionsAsync()
    {
        if (disposed || groupId is null) return;

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("updateDelayGroupOptions", groupId, new
            {
                delay = new { open = OpenDelayMs, close = CloseDelayMs },
                timeoutMs = TimeoutMs
            });
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex;
        }
    }

    private async Task RegisterMemberAsync(
        string interactionId,
        DotNetObjectReference<DelayGroupMemberCallback> closeMemberRef)
    {
        if (disposed || groupId is null || dotNetRef is null) return;

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("registerDelayGroupMember", groupId, interactionId, new
            {
                setIsInstantPhase = dotNetRef,
                closeMember = closeMemberRef
            });
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex;
        }
    }

    private async Task UnregisterMemberAsync(string interactionId)
    {
        if (disposed || groupId is null) return;

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("unregisterDelayGroupMember", groupId, interactionId);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex;
        }
    }

    private async Task NotifyMemberOpenedAsync(string interactionId)
    {
        if (disposed || groupId is null) return;

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("notifyDelayGroupMemberOpened", groupId, interactionId);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex;
        }
    }

    private async Task NotifyMemberClosedAsync(string interactionId)
    {
        if (disposed || groupId is null) return;

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("notifyDelayGroupMemberClosed", groupId, interactionId);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException or ObjectDisposedException)
        {
            _ = ex;
        }
    }

}
