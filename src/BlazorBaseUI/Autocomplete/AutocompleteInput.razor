@using BlazorBaseUI.Field
@using BlazorBaseUI.Utilities.LabelableProvider
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop

@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<RenderElement TState="AutocompleteInputState"
               Tag="input"
               State="state"
               Enabled="RootContext is not null"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private const string ModulePath = "./_content/BlazorBaseUI/blazor-baseui-autocomplete.min.js";

    private AutocompleteInputState state;
    private RenderElement<AutocompleteInputState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private Lazy<Task<IJSObjectReference>>? moduleTask;
    private ElementReference? previousElement;
    private bool? previousIsInsidePopup;
    private bool subscribed;

    private Task<IJSObjectReference> ModuleTask => (moduleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>("import", ModulePath).AsTask())).Value;

    private bool IsInsidePopup => PositionerContext is not null || RootContext?.Inline == true;

    [CascadingParameter]
    private IAutocompleteRootContext? RootContext { get; set; }

    [CascadingParameter]
    private AutocompletePositionerContext? PositionerContext { get; set; }

    [CascadingParameter]
    private FieldRootContext? FieldContext { get; set; }

    [CascadingParameter]
    private LabelableContext? LabelableContext { get; set; }

    /// <summary>
    /// Determines whether the component should ignore user interaction.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets the input id.
    /// </summary>
    [Parameter]
    public string? Id { get; set; }

    /// <summary>
    /// Allows replacing or composing the rendered element.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<AutocompleteInputState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on component state.
    /// </summary>
    [Parameter]
    public Func<AutocompleteInputState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on component state.
    /// </summary>
    [Parameter]
    public Func<AutocompleteInputState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Gets or sets additional element attributes.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets the associated element reference.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        if (RootContext is not null)
        {
            RootContext.StateChanged += OnRootStateChanged;
            subscribed = true;
        }

        BuildStateAndAttributes();
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        if (RootContext is not null)
        {
            RootContext.InputInsidePopup = IsInsidePopup;
            RootContext.InputOwnsFormValue = !IsInsidePopup;
        }

        BuildStateAndAttributes();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var current = Element;
        var isInsidePopup = IsInsidePopup;
        if (RootContext is not null && (!Nullable.Equals(previousElement, current) || previousIsInsidePopup != isInsidePopup))
        {
            previousElement = current;
            previousIsInsidePopup = isInsidePopup;
            RootContext.SetInputElement(current);

            if (current.HasValue)
            {
                try
                {
                    var module = await ModuleTask;
                    await module.InvokeVoidAsync("setInputElement", RootContext.RootId, current.Value, isInsidePopup);
                }
                catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
                {
                    _ = ex;
                }
            }
        }

        await SyncInlineSelectionAsync(current);
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (subscribed && RootContext is not null)
        {
            RootContext.StateChanged -= OnRootStateChanged;
        }

        RootContext?.SetInputElement(null);

        if (moduleTask?.IsValueCreated == true)
        {
            try
            {
                var module = await ModuleTask;
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex;
            }
        }
    }

    private void OnRootStateChanged()
    {
        BuildStateAndAttributes();
        InvokeAsync(StateHasChanged);
    }

    private async Task SyncInlineSelectionAsync(ElementReference? current)
    {
        if (RootContext is null ||
            !current.HasValue ||
            RootContext.Mode is not (AutocompleteMode.Inline or AutocompleteMode.Both))
        {
            return;
        }

        var typedValue = RootContext.GetTypedInputValue();
        var inputValue = RootContext.GetInputValue();
        if (inputValue.Length <= typedValue.Length ||
            !inputValue.StartsWith(typedValue, StringComparison.CurrentCultureIgnoreCase))
        {
            return;
        }

        try
        {
            var module = await ModuleTask;
            await module.InvokeVoidAsync("syncInputSelection", current.Value, typedValue, inputValue);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }
    }

    private void BuildStateAndAttributes()
    {
        var open = RootContext?.Mounted == true && RootContext.OpenChangeReason != AutocompleteChangeReason.ClosePress
            ? RootContext.Mounted && (RootContext.PopupElement.HasValue || RootContext.Inline || RootContext.OpenChangeReason != AutocompleteChangeReason.None)
            : RootContext?.Mounted == true;
        open = RootContext?.OpenChangeReason == AutocompleteChangeReason.None
            ? RootContext?.Mounted == true
            : open;

        var disabled = Disabled || (RootContext?.Disabled ?? false) || (FieldContext?.Disabled ?? false);
        var fieldState = IsInsidePopup ? FieldRootState.Default : RootContext?.FieldState ?? FieldRootState.Default;
        state = AutocompleteInputState.FromFieldState(
            fieldState,
            RootContext?.Mounted == true,
            disabled,
            RootContext?.ReadOnly == true,
            RootContext?.PopupSide,
            RootContext?.ListEmpty == true);

        var attrs = new Dictionary<string, object>
        {
            ["type"] = "text",
            ["value"] = RootContext?.GetInputValue() ?? string.Empty,
            ["autocomplete"] = "off",
            ["spellcheck"] = "false",
            ["autocorrect"] = "off",
            ["autocapitalize"] = "none",
            ["role"] = "combobox",
            ["aria-autocomplete"] = ToAutocompleteAttribute(RootContext?.Mode ?? AutocompleteMode.List)
        };

        if (RootContext?.Inline != true)
        {
            attrs["aria-expanded"] = RootContext?.Mounted == true ? "true" : "false";
            attrs["aria-haspopup"] = RootContext?.Grid == true ? "grid" : "listbox";

            if (RootContext?.Mounted == true && RootContext.ListId is not null)
            {
                attrs["aria-controls"] = RootContext.ListId;
            }
        }

        if (RootContext?.ActiveIndex >= 0 && RootContext.ListId is not null)
        {
            attrs["aria-activedescendant"] = $"{RootContext.RootId}-{RootContext.ActiveIndex}";
        }

        if (RootContext?.ReadOnly == true)
        {
            attrs["aria-readonly"] = "true";
            attrs["readonly"] = "readonly";
            attrs["data-readonly"] = "true";
        }

        if (RootContext?.Required == true)
        {
            attrs["aria-required"] = "true";
            attrs["required"] = "required";
        }

        if (disabled)
        {
            attrs["disabled"] = "disabled";
            attrs["data-disabled"] = "true";
        }

        var id = Id ?? (!IsInsidePopup ? RootContext?.RootId : null);
        if (!string.IsNullOrEmpty(id))
        {
            attrs["id"] = id;
            LabelableContext?.SetControlId(id);
        }

        if (RootContext?.InputOwnsFormValue == true && !string.IsNullOrEmpty(RootContext.Name))
        {
            attrs["name"] = RootContext.Name;
        }

        if (!string.IsNullOrEmpty(RootContext?.Form))
        {
            attrs["form"] = RootContext.Form;
        }

        var labelledBy = AccessibilityUtilities.ResolveAriaLabelledBy(LabelableContext?.LabelId, RootContext?.LabelId);
        if (!string.IsNullOrEmpty(labelledBy))
        {
            attrs["aria-labelledby"] = labelledBy;
        }

        ApplyFieldDataAttributes(attrs, fieldState);
        ApplyPopupDataAttributes(attrs);

        attrs["oninput"] = EventCallback.Factory.Create<ChangeEventArgs>(this, HandleInputAsync);
        attrs["onfocus"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleFocusAsync);
        attrs["onblur"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleBlurAsync);
        attrs["onmousedown"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleMouseDownAsync);
        attrs["onkeydown"] = EventCallback.Factory.Create<KeyboardEventArgs>(this, HandleKeyDownAsync);

        componentAttributes = attrs;
    }

    private async Task HandleInputAsync(ChangeEventArgs e)
    {
        if (RootContext is null || state.Disabled || RootContext.ReadOnly)
        {
            return;
        }

        await RootContext.SetInputValueAsync(Convert.ToString(e.Value) ?? string.Empty, AutocompleteChangeReason.InputChange);
    }

    private async Task HandleFocusAsync(FocusEventArgs e)
    {
        FieldContext?.SetFocused(true);
        await EventUtilities.InvokeOnFocusAsync(AdditionalAttributes, e);
    }

    private async Task HandleBlurAsync(FocusEventArgs e)
    {
        FieldContext?.SetTouched(true);
        FieldContext?.SetFocused(false);
        await EventUtilities.InvokeOnBlurAsync(AdditionalAttributes, e);
    }

    private async Task HandleMouseDownAsync(MouseEventArgs e)
    {
        if (RootContext is null || state.Disabled || RootContext.ReadOnly || !RootContext.OpenOnInputClick)
        {
            return;
        }

        await RootContext.SetOpenAsync(true, AutocompleteChangeReason.InputChange);
    }

    private Task HandleKeyDownAsync(KeyboardEventArgs e)
    {
        return EventUtilities.InvokeOnKeyDownAsync(AdditionalAttributes, e);
    }

    private void ApplyPopupDataAttributes(Dictionary<string, object> attrs)
    {
        if (RootContext?.Mounted == true)
        {
            attrs["data-popup-open"] = true;
        }

        if (RootContext?.PopupSide is { } side)
        {
            attrs["data-popup-side"] = side.ToDataAttributeString()!;
        }

        if (RootContext?.ListEmpty == true)
        {
            attrs["data-list-empty"] = true;
        }
    }

    private static void ApplyFieldDataAttributes(Dictionary<string, object> attrs, FieldRootState fieldState)
    {
        attrs["data-valid"] = fieldState.Valid == true;
        attrs["data-invalid"] = fieldState.Valid == false;
        attrs["data-touched"] = fieldState.Touched;
        attrs["data-dirty"] = fieldState.Dirty;
        attrs["data-filled"] = fieldState.Filled;
        attrs["data-focused"] = fieldState.Focused;
    }

    private static string ToAutocompleteAttribute(AutocompleteMode mode)
    {
        return mode switch
        {
            AutocompleteMode.Both => "both",
            AutocompleteMode.Inline => "inline",
            AutocompleteMode.None => "none",
            _ => "list"
        };
    }
}
