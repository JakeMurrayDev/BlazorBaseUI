@using Microsoft.JSInterop
@using System.Linq
@using BlazorBaseUI.FloatingTree
@using BlazorBaseUI.FocusGuard
@using BlazorBaseUI.Portal

@implements IAsyncDisposable

@inject IJSRuntime JS

@if (ShouldRenderGuards)
{
    <FocusGuard OnFocus="HandleBeforeGuardFocus" data-blazor-base-ui-focus-guard-type="inside" @ref="beforeGuardRef" />
}
@ChildContent
@if (ShouldRenderGuards)
{
    <FocusGuard OnFocus="HandleAfterGuardFocus" data-blazor-base-ui-focus-guard-type="inside" @ref="afterGuardRef" />
}

@code {
    private readonly Lazy<Task<IJSObjectReference>> moduleTask;
    private DotNetObjectReference<FloatingFocusManager>? dotNetRef;
    private string? managerId;
    private bool wasOpen;
    private bool previousModal = true;
    private bool previousReturnFocus = true;
    private bool previousCloseOnFocusOut = true;
    private IReadOnlyList<ElementReference>? previousInsideElements;
    private IReadOnlyList<FocusManagerOrderItem>? previousOrder;
    private bool previousDisabled;
    private FocusGuard? beforeGuardRef;
    private FocusGuard? afterGuardRef;

    public FloatingFocusManager()
    {
        moduleTask = new(() => JS.InvokeAsync<IJSObjectReference>(
            "import", "./_content/BlazorBaseUI/blazor-baseui-floating.js").AsTask());
    }

    private bool ShouldRenderGuards => !Disabled && (Modal || PortalContext is not null);

    /// <summary>
    /// The floating root context providing open state and element references.
    /// </summary>
    [CascadingParameter]
    private IFloatingRootContext? RootContext { get; set; }

    /// <summary>
    /// The node context from an ancestor <see cref="FloatingNode"/>.
    /// </summary>
    [CascadingParameter]
    private FloatingNodeContext? NodeContext { get; set; }

    /// <summary>
    /// The portal context from an ancestor <see cref="FloatingPortal"/>.
    /// </summary>
    [CascadingParameter]
    private FloatingPortalContext? PortalContext { get; set; }

    /// <summary>
    /// The child content to render.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Whether focus is fully trapped (modal) or allows outside focus (non-modal).
    /// </summary>
    [Parameter]
    public bool Modal { get; set; } = true;

    /// <summary>
    /// Whether to move focus to the first tabbable element on open.
    /// </summary>
    [Parameter]
    public bool InitialFocus { get; set; } = true;

    /// <summary>
    /// CSS selector for initial focus target (alternative to <see cref="InitialFocus"/>).
    /// </summary>
    [Parameter]
    public string? InitialFocusSelector { get; set; }

    /// <summary>
    /// Whether to return focus to the trigger element on close.
    /// </summary>
    [Parameter]
    public bool ReturnFocus { get; set; } = true;

    /// <summary>
    /// An optional element to return focus to on close, overriding the previously focused element.
    /// </summary>
    [Parameter]
    public ElementReference? ReturnFocusElement { get; set; }

    /// <summary>
    /// Whether to restore focus when the currently focused element is removed from the DOM.
    /// </summary>
    [Parameter]
    public bool RestoreFocus { get; set; }

    /// <summary>
    /// Restore focus mode: <c>null</c> for nearest tabbable, or <c>"popup"</c> for the popup container.
    /// </summary>
    [Parameter]
    public string? RestoreFocusMode { get; set; }

    /// <summary>
    /// Whether to close the floating element when focus moves outside (non-modal only).
    /// </summary>
    [Parameter]
    public bool CloseOnFocusOut { get; set; } = true;

    /// <summary>
    /// The interaction type that opened the popup (e.g. "click", "touch", "keyboard").
    /// </summary>
    [Parameter]
    public string? InteractionType { get; set; }

    /// <summary>
    /// A callback that dynamically determines whether initial focus should be applied.
    /// Receives the current <see cref="InteractionType"/> and returns <c>true</c> to focus or <c>false</c> to skip.
    /// When set, this takes precedence over the static <see cref="InitialFocus"/> parameter.
    /// </summary>
    [Parameter]
    public Func<string?, bool>? InitialFocusCallback { get; set; }

    /// <summary>
    /// A callback that dynamically determines whether return focus should be applied on close.
    /// Receives the current <see cref="InteractionType"/> and returns <c>true</c> to return focus or <c>false</c> to skip.
    /// When set, this takes precedence over the static <see cref="ReturnFocus"/> parameter.
    /// </summary>
    [Parameter]
    public Func<string?, bool>? ReturnFocusCallback { get; set; }

    /// <summary>
    /// Whether the focus manager is disabled (no focus management applied).
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// The tab cycling order for focus management.
    /// Controls which elements are included when Tab cycles through the floating scope.
    /// </summary>
    [Parameter]
    public IReadOnlyList<FocusManagerOrderItem>? Order { get; set; } = [FocusManagerOrderItem.Content];

    /// <summary>
    /// Additional element references that should be considered "inside" the floating element
    /// for focus-out detection. Useful for portaled content.
    /// </summary>
    [Parameter]
    public IReadOnlyList<ElementReference>? InsideElements { get; set; }

    /// <summary>
    /// An element to focus when Tab reaches the end of the floating element's tabbable list
    /// (non-modal only). When null, standard wrap-around behavior applies.
    /// </summary>
    [Parameter]
    public ElementReference? NextFocusableElement { get; set; }

    /// <summary>
    /// An element to focus when Shift+Tab reaches the start of the floating element's tabbable list.
    /// When null, standard wrap-around behavior applies.
    /// </summary>
    [Parameter]
    public ElementReference? PreviousFocusableElement { get; set; }

    /// <summary>
    /// A callback that returns additional elements to consider "inside" the floating element
    /// for focus-out detection. Called on mount and during parameter updates.
    /// </summary>
    [Parameter]
    public Func<IReadOnlyList<ElementReference>>? GetInsideElements { get; set; }

    /// <summary>
    /// An external floating tree context to use when the standard cascading one is unavailable.
    /// </summary>
    [Parameter]
    public FloatingTreeContext? ExternalTree { get; set; }

    /// <summary>
    /// Gets the element reference of the focus guard rendered before the content.
    /// Useful for programmatic focus of the popup.
    /// </summary>
    public ElementReference? BeforeContentFocusGuardElement => beforeGuardRef?.Element;

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Disabled || RootContext is null) return;

        var isOpen = RootContext.GetOpen();

        if (isOpen && !wasOpen)
        {
            await CreateManagerAsync();
        }
        else if (!isOpen && wasOpen)
        {
            string? closeInteractionType = null;
            if (ReturnFocusCallback is not null && managerId is not null)
            {
                try
                {
                    var module = await moduleTask.Value;
                    closeInteractionType = await module.InvokeAsync<string>(
                        "getLastInteractionType", managerId);
                }
                catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
                {
                    _ = ex;
                }
            }

            var resolvedReturnFocus = ReturnFocusCallback is not null
                ? ReturnFocusCallback(closeInteractionType)
                : true;
            await DisposeManagerAsync(shouldReturnFocus: resolvedReturnFocus);
        }

        wasOpen = isOpen;
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        var disabledChanged = Disabled != previousDisabled;
        previousDisabled = Disabled;

        if (disabledChanged && RootContext is not null && RootContext.GetOpen())
        {
            if (Disabled && managerId is not null)
            {
                _ = DisposeManagerAsync(shouldReturnFocus: false);
                ClearPortalContext();
                wasOpen = false;
                return;
            }
            else if (!Disabled)
            {
                wasOpen = false;
            }
        }

        if (managerId is null) return;

        var modalChanged = Modal != previousModal;
        var returnFocusChanged = ReturnFocus != previousReturnFocus;
        var closeOnFocusOutChanged = CloseOnFocusOut != previousCloseOnFocusOut;
        var insideElementsChanged = !ReferenceEquals(InsideElements, previousInsideElements);
        var orderChanged = !ReferenceEquals(Order, previousOrder);

        if (modalChanged || returnFocusChanged || closeOnFocusOutChanged || insideElementsChanged || orderChanged)
        {
            previousModal = Modal;
            previousReturnFocus = ReturnFocus;
            previousCloseOnFocusOut = CloseOnFocusOut;
            previousInsideElements = InsideElements;
            previousOrder = Order;

            _ = UpdateManagerAsync(modalChanged, returnFocusChanged, closeOnFocusOutChanged, insideElementsChanged, orderChanged);
            SyncPortalContext(open: true);
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        await DisposeManagerAsync(shouldReturnFocus: false);
        ClearPortalContext();

        dotNetRef?.Dispose();

        if (moduleTask.IsValueCreated)
        {
            try
            {
                var module = await moduleTask.Value;
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }
    }

    /// <summary>
    /// Invoked by JS when focus leaves the floating element and the element should close.
    /// </summary>
    [JSInvokable]
    public async Task OnClose()
    {
        if (RootContext is not null)
        {
            await RootContext.SetOpenAsync(false, "focus-out");
        }
    }

    private async Task CreateManagerAsync()
    {
        var popupElement = RootContext!.GetPopupElement();
        if (popupElement is null) return;

        dotNetRef ??= DotNetObjectReference.Create(this);

        try
        {
            var module = await moduleTask.Value;
            var resolvedInitialFocus = InitialFocusCallback is not null
                ? InitialFocusCallback(InteractionType)
                : InitialFocus;

            managerId = await module.InvokeAsync<string>("createFloatingFocusManager", new
            {
                floatingElement = popupElement.Value,
                triggerElement = RootContext.GetTriggerElement(),
                modal = Modal,
                initialFocus = resolvedInitialFocus,
                initialFocusSelector = InitialFocusSelector,
                returnFocus = ReturnFocus,
                returnFocusElement = ReturnFocusElement,
                restoreFocus = RestoreFocus,
                restoreFocusMode = RestoreFocusMode,
                closeOnFocusOut = CloseOnFocusOut,
                interactionType = InteractionType ?? string.Empty,
                dotNetRef = dotNetRef,
                treeId = NodeContext?.TreeId ?? ExternalTree?.TreeId,
                nodeId = NodeContext?.NodeId,
                order = Order?.Select(o => o.ToJsString()).ToArray(),
                insideElements = MergeInsideElements(),
                nextFocusableElement = NextFocusableElement,
                previousFocusableElement = PreviousFocusableElement,
                beforeGuardElement = beforeGuardRef?.Element,
                afterGuardElement = afterGuardRef?.Element,
                portalNode = PortalContext?.PortalNode,
                beforeOutsideGuard = PortalContext?.BeforeOutsideGuard,
                afterOutsideGuard = PortalContext?.AfterOutsideGuard
            });

            previousModal = Modal;
            previousReturnFocus = ReturnFocus;
            previousCloseOnFocusOut = CloseOnFocusOut;
            previousInsideElements = InsideElements;
            previousOrder = Order;

            SyncPortalContext(open: true);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }
    }

    private async Task UpdateManagerAsync(bool modalChanged, bool returnFocusChanged,
        bool closeOnFocusOutChanged, bool insideElementsChanged, bool orderChanged)
    {
        if (managerId is null) return;

        try
        {
            var module = await moduleTask.Value;
            var options = new Dictionary<string, object?>();

            if (modalChanged) options["modal"] = Modal;
            if (returnFocusChanged) options["returnFocus"] = ReturnFocus;
            if (closeOnFocusOutChanged) options["closeOnFocusOut"] = CloseOnFocusOut;
            if (insideElementsChanged) options["insideElements"] = MergeInsideElements();
            if (orderChanged) options["order"] = Order?.Select(o => o.ToJsString()).ToArray();

            await module.InvokeVoidAsync("updateFloatingFocusManager", managerId, options);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }
    }

    private IReadOnlyList<ElementReference> MergeInsideElements()
    {
        var baseElements = InsideElements ?? (IReadOnlyList<ElementReference>)Array.Empty<ElementReference>();
        var extraElements = GetInsideElements?.Invoke();
        if (extraElements is null || extraElements.Count == 0)
        {
            return baseElements;
        }

        return baseElements.Concat(extraElements).ToArray();
    }

    private async Task HandleBeforeGuardFocus()
    {
        if (managerId is null) return;

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("handleFocusGuardFocus", managerId, "before");
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }
    }

    private async Task HandleAfterGuardFocus()
    {
        if (managerId is null) return;

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("handleFocusGuardFocus", managerId, "after");
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }
    }

    private async Task DisposeManagerAsync(bool shouldReturnFocus)
    {
        if (managerId is null) return;

        try
        {
            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("disposeFloatingFocusManager", managerId, shouldReturnFocus);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }

        ClearPortalContext();
        managerId = null;
    }

    private void SyncPortalContext(bool open)
    {
        if (PortalContext is null) return;

        PortalContext.FocusManagerState = new FocusManagerState
        {
            Modal = Modal,
            CloseOnFocusOut = CloseOnFocusOut,
            Open = open,
            OnOpenChangeAsync = RootContext is not null
                ? (o, reason) => RootContext.SetOpenAsync(o, reason)
                : null,
            DomReference = RootContext?.GetTriggerElement()
        };

        PortalContext.BeforeInsideGuard = beforeGuardRef?.Element;
        PortalContext.AfterInsideGuard = afterGuardRef?.Element;
    }

    private void ClearPortalContext()
    {
        if (PortalContext is null) return;
        PortalContext.FocusManagerState = null;
        PortalContext.BeforeInsideGuard = null;
        PortalContext.AfterInsideGuard = null;
    }
}
