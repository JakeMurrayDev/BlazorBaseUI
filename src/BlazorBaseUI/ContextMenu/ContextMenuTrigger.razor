@using BlazorBaseUI.Menu
@using BlazorBaseUI.Utilities
@using Microsoft.JSInterop

@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<RenderElement TState="ContextMenuTriggerState"
               Tag="div"
               State="state"
               Enabled="RootContext is not null"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="CombinedStyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="ChildContent"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private const string ModulePath = "./_content/BlazorBaseUI/blazor-baseui-context-menu.js";

    private Lazy<Task<IJSObjectReference>>? moduleTask;
    private bool hasRendered;
    private bool previousDisabled;
    private ContextMenuTriggerState state;
    private RenderElement<ContextMenuTriggerState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private DotNetObjectReference<ContextMenuTrigger>? dotNetRef;

    private Lazy<Task<IJSObjectReference>> ModuleTask => moduleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>(
            "import", ModulePath).AsTask());

    private Func<ContextMenuTriggerState, string?> CombinedStyleValue => state =>
    {
        var userStyle = StyleValue?.Invoke(state);
        if (string.IsNullOrEmpty(userStyle))
            return "-webkit-touch-callout: none";
        return $"-webkit-touch-callout: none; {userStyle}";
    };

    private bool CurrentDisabled => Disabled || (RootContext?.Disabled ?? false);

    [CascadingParameter]
    private MenuRootContext? RootContext { get; set; }

    [CascadingParameter]
    private ContextMenuRootContext? ContextMenuContext { get; set; }

    /// <summary>
    /// Determines whether the component should ignore user interaction.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets the id attribute of the trigger element.
    /// </summary>
    [Parameter]
    public string? Id { get; set; }

    /// <summary>
    /// Allows you to replace the component's HTML element
    /// with a different tag, or compose it with another component.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<ContextMenuTriggerState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on the component state.
    /// </summary>
    [Parameter]
    public Func<ContextMenuTriggerState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on the component state.
    /// </summary>
    [Parameter]
    public Func<ContextMenuTriggerState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        var open = RootContext?.GetOpen() ?? false;
        var disabled = CurrentDisabled;
        state = new ContextMenuTriggerState(open);
        BuildComponentAttributes();

        if (hasRendered && disabled != previousDisabled)
        {
            previousDisabled = disabled;
            _ = UpdateJsDisabledAsync(disabled);
        }
        else
        {
            previousDisabled = disabled;
        }
    }

    /// <inheritdoc />
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            hasRendered = true;

            var virtualAnchor = ContextMenuContext?.GetVirtualAnchorElement();
            if (virtualAnchor.HasValue)
            {
                RootContext?.SetTriggerElement(virtualAnchor);
            }

            _ = InitializeJsAsync();
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (moduleTask?.IsValueCreated == true && hasRendered && ContextMenuContext is not null)
        {
            try
            {
                var module = await ModuleTask.Value;
                await module.InvokeVoidAsync("disposeContextMenu", ContextMenuContext.RootId);
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }

        dotNetRef?.Dispose();
    }

    /// <summary>
    /// Invoked from JavaScript when a context menu event occurs on the trigger.
    /// </summary>
    [JSInvokable]
    public async Task OnContextMenu(double x, double y, bool isTouchEvent)
    {
        if (state.Open || CurrentDisabled || RootContext is null)
        {
            return;
        }

        await RootContext.SetOpenFromTriggerAsync(
            true,
            MenuOpenChangeReason.TriggerPress,
            null,
            null,
            isTouchEvent ? "touch" : "mouse",
            false);

        state = new ContextMenuTriggerState(RootContext.GetOpen());
        BuildComponentAttributes();
        StateHasChanged();
    }

    /// <summary>
    /// Invoked from JavaScript when a mouseup cancel occurs.
    /// </summary>
    [JSInvokable]
    public async Task OnCancelOpen()
    {
        if (RootContext is null)
        {
            return;
        }

        await RootContext.SetOpenAsync(false, MenuOpenChangeReason.CancelOpen, null);

        state = new ContextMenuTriggerState(RootContext.GetOpen());
        BuildComponentAttributes();
        StateHasChanged();
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();
        var open = RootContext?.GetOpen() ?? false;
        var disabled = CurrentDisabled;

        if (Id is not null)
        {
            attrs["id"] = Id;
        }

        if (open)
        {
            attrs["data-popup-open"] = true;
            attrs["data-pressed"] = true;
        }

        if (disabled)
        {
            attrs["data-disabled"] = true;
        }

        componentAttributes = attrs;
    }

    private async Task InitializeJsAsync()
    {
        if (!Element.HasValue || ContextMenuContext is null)
        {
            return;
        }

        var element = Element;
        var virtualAnchor = ContextMenuContext.GetVirtualAnchorElement();
        if (!element.HasValue || !virtualAnchor.HasValue)
        {
            return;
        }

        try
        {
            dotNetRef = DotNetObjectReference.Create(this);
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync(
                "initializeContextMenu",
                ContextMenuContext.RootId,
                element.Value,
                virtualAnchor.Value,
                dotNetRef,
                CurrentDisabled);

            ContextMenuContext.RegisterBackdropElement = async (element) =>
            {
                try
                {
                    var mod = await ModuleTask.Value;
                    await mod.InvokeVoidAsync("setBackdropElement", ContextMenuContext.RootId, element);
                }
                catch (Exception ex2) when (ex2 is JSDisconnectedException or TaskCanceledException)
                {
                    _ = ex2; // Expected during circuit disconnect - safe to ignore.
                }
            };

            ContextMenuContext.RegisterPositionerElement = async (element) =>
            {
                try
                {
                    var mod = await ModuleTask.Value;
                    await mod.InvokeVoidAsync("setPositionerElement", ContextMenuContext.RootId, element);
                }
                catch (Exception ex2) when (ex2 is JSDisconnectedException or TaskCanceledException)
                {
                    _ = ex2; // Expected during circuit disconnect - safe to ignore.
                }
            };

            if (ContextMenuContext.PositionerElement.HasValue)
            {
                await ContextMenuContext.RegisterPositionerElement(ContextMenuContext.PositionerElement.Value);
            }
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task UpdateJsDisabledAsync(bool disabled)
    {
        if (ContextMenuContext is null)
        {
            return;
        }

        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync("setContextMenuDisabled", ContextMenuContext.RootId, disabled);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }
}
