@using BlazorBaseUI.Form
@using BlazorBaseUI.Utilities.LabelableProvider
@using Microsoft.AspNetCore.Components.Forms

@implements IFieldStateSubscriber
@implements IDisposable

@if (mounted)
{
    <RenderElement TState="FieldErrorState"
                   Tag="div"
                   State="state"
                   Render="Render"
                   ClassValue="ClassValue"
                   StyleValue="StyleValue"
                   ComponentAttributes="componentAttributes"
                   @attributes="AdditionalAttributes"
                   @ref="renderElementReference">
        @RenderErrorContent()
    </RenderElement>
}

@code {
    private string? defaultId;
    private bool rendered;
    private bool mounted;
    private bool messageIdRegistered;
    private string? registeredMessageId;
    private FieldTransitionStatus? transitionStatus;
    private FieldRootState fieldState;
    private FieldErrorState state;
    private RenderElement<FieldErrorState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private string[] lastRenderedErrors = [];

    private FieldRootState FieldState => FieldContext?.State ?? FieldRootState.Default;

    private string? FieldName => FieldContext?.Name;

    private string ResolvedId => AttributeUtilities.GetIdOrDefault(AdditionalAttributes, () => defaultId ??= Guid.NewGuid().ToIdString());

    [CascadingParameter]
    private FieldRootContext? FieldContext { get; set; }

    [CascadingParameter]
    private LabelableContext? LabelableContext { get; set; }

    [CascadingParameter]
    private EditContext? EditContext { get; set; }

    [CascadingParameter]
    private FormContext? FormContext { get; set; }

    /// <summary>
    /// Determines whether to show the error message.
    /// When <see langword="true"/>, the error is always shown, letting external libraries control visibility.
    /// </summary>
    [Parameter]
    public bool? Match { get; set; }

    /// <summary>
    /// Gets or sets a validity state name to match against the field's validity.
    /// Supported values: <c>badInput</c>, <c>customError</c>, <c>patternMismatch</c>,
    /// <c>rangeOverflow</c>, <c>rangeUnderflow</c>, <c>stepMismatch</c>, <c>tooLong</c>,
    /// <c>tooShort</c>, <c>typeMismatch</c>, <c>valueMissing</c>.
    /// </summary>
    [Parameter]
    public string? MatchValidity { get; set; }

    /// <summary>
    /// Allows you to replace the component's HTML element
    /// with a different tag, or compose it with another component.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<FieldErrorState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets a function that returns a CSS class based on the component's state.
    /// </summary>
    [Parameter]
    public Func<FieldErrorState, string>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets a function that returns a CSS style based on the component's state.
    /// </summary>
    [Parameter]
    public Func<FieldErrorState, string>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        FieldContext?.Subscribe(this);
        UpdateRenderState(ShouldRenderError(), initialRender: true);
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        UpdateRenderState(ShouldRenderError(), initialRender: false);
    }

    /// <inheritdoc />
    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (transitionStatus == FieldTransitionStatus.Starting)
        {
            transitionStatus = null;
            RebuildState();
            StateHasChanged();
        }
        else if (transitionStatus == FieldTransitionStatus.Ending)
        {
            mounted = false;
            transitionStatus = null;
            RebuildState();
            StateHasChanged();
        }

        return Task.CompletedTask;
    }

    /// <inheritdoc />
    public void Dispose()
    {
        FieldContext?.Unsubscribe(this);
        SetMessageIdRegistered(false);
    }

    /// <inheritdoc />
    void IFieldStateSubscriber.NotifyStateChanged()
    {
        UpdateRenderState(ShouldRenderError(), initialRender: false);
        _ = InvokeAsync(StateHasChanged);
    }

    private void UpdateRenderState(bool nextRendered, bool initialRender)
    {
        fieldState = FieldState;

        if (nextRendered)
        {
            lastRenderedErrors = GetCurrentErrorMessages();
        }

        if (initialRender)
        {
            rendered = nextRendered;
            mounted = nextRendered;
        }
        else if (nextRendered && !rendered)
        {
            mounted = true;
            transitionStatus = FieldTransitionStatus.Starting;
        }
        else if (!nextRendered && rendered)
        {
            transitionStatus = FieldTransitionStatus.Ending;
        }

        rendered = nextRendered;
        SetMessageIdRegistered(rendered);
        RebuildState();
    }

    private void RebuildState()
    {
        state = FieldErrorState.FromFieldState(fieldState, transitionStatus);
        BuildComponentAttributes();
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>
        {
            ["id"] = ResolvedId
        };

        FieldAttributeUtilities.AddFieldStateAttributes(attrs, fieldState);

        if (transitionStatus == FieldTransitionStatus.Starting)
            attrs["data-starting-style"] = true;
        else if (transitionStatus == FieldTransitionStatus.Ending)
            attrs["data-ending-style"] = true;

        componentAttributes = attrs;
    }

    private void SetMessageIdRegistered(bool register)
    {
        var currentId = ResolvedId;
        if (messageIdRegistered && registeredMessageId != currentId)
        {
            if (registeredMessageId is not null)
                LabelableContext?.UpdateMessageIds.Invoke(registeredMessageId, false);

            registeredMessageId = null;
            messageIdRegistered = false;
        }

        if (messageIdRegistered == register)
            return;

        LabelableContext?.UpdateMessageIds.Invoke(currentId, register);
        registeredMessageId = register ? currentId : null;
        messageIdRegistered = register;
    }

    private bool ShouldRenderError()
    {
        if (Match == true)
            return true;

        if (MatchValidity is not null)
            return MatchValidityState(MatchValidity);

        if (HasFormError())
            return true;

        var validityData = FieldContext?.ValidityData ?? FieldValidityData.Default;
        return validityData.State.Valid == false;
    }

    private bool MatchValidityState(string validity)
    {
        var validityData = FieldContext?.ValidityData ?? FieldValidityData.Default;
        return validity.ToLowerInvariant() switch
        {
            "badinput" => validityData.State.BadInput,
            "customerror" => validityData.State.CustomError,
            "patternmismatch" => validityData.State.PatternMismatch,
            "rangeoverflow" => validityData.State.RangeOverflow,
            "rangeunderflow" => validityData.State.RangeUnderflow,
            "stepmismatch" => validityData.State.StepMismatch,
            "toolong" => validityData.State.TooLong,
            "tooshort" => validityData.State.TooShort,
            "typemismatch" => validityData.State.TypeMismatch,
            "valuemissing" => validityData.State.ValueMissing,
            _ => false
        };
    }

    private bool HasFormError() => GetFormErrors().Length > 0;

    private string[] GetFormErrors()
    {
        if (FieldName is null)
            return [];

        if (FormContext is not null)
        {
            var formErrors = FormContext.GetErrors(FieldName);
            if (formErrors.Length > 0)
                return formErrors;
        }

        if (EditContext is not null)
        {
            var fieldIdentifier = EditContext.Field(FieldName);
            var editContextErrors = EditContext.GetValidationMessages(fieldIdentifier).ToArray();
            if (editContextErrors.Length > 0)
                return editContextErrors;
        }

        return [];
    }

    private string[] GetCurrentErrorMessages()
    {
        var validityData = FieldContext?.ValidityData ?? FieldValidityData.Default;
        var formErrors = GetFormErrors();
        var hasSpecificMatch = MatchValidity is not null;

        if (!hasSpecificMatch && formErrors.Length > 0)
            return formErrors;

        if (validityData.Errors.Length > 1)
            return validityData.Errors;

        return string.IsNullOrEmpty(validityData.Error) ? [] : [validityData.Error];
    }

    private RenderFragment RenderErrorContent() => builder =>
    {
        if (ChildContent is not null)
        {
            builder.AddContent(0, ChildContent);
            return;
        }

        var errors = rendered ? GetCurrentErrorMessages() : lastRenderedErrors;

        if (errors.Length > 1)
        {
            builder.OpenElement(1, "ul");
            for (var i = 0; i < errors.Length; i++)
            {
                builder.OpenElement(2, "li");
                builder.AddContent(3, errors[i]);
                builder.CloseElement();
            }
            builder.CloseElement();
        }
        else if (errors.Length == 1)
        {
            builder.AddContent(4, errors[0]);
        }
    };
}
