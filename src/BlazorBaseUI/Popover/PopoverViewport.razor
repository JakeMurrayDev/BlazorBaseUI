@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<RenderElement TState="PopoverViewportState"
               Tag="div"
               Enabled="RootContext is not null"
               State="state"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="ChildContent"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private Lazy<Task<IJSObjectReference>>? moduleTask;
    private bool hasRendered;
    private string? activationDirection;
    private bool transitioning;
    private PopoverViewportState state;
    private RenderElement<PopoverViewportState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private DotNetObjectReference<PopoverViewport>? dotNetRef;

    private Lazy<Task<IJSObjectReference>> ModuleTask => moduleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>(
            "import", "./_content/BlazorBaseUI/blazor-baseui-popover.js").AsTask());

    [CascadingParameter]
    private PopoverRootContext? RootContext { get; set; }

    [CascadingParameter]
    private PopoverPositionerContext? PositionerContext { get; set; }

    /// <summary>
    /// Gets or sets a custom render template for the viewport element.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<PopoverViewportState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets a function that returns CSS class names based on the current state.
    /// </summary>
    [Parameter]
    public Func<PopoverViewportState, string>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets a function that returns inline styles based on the current state.
    /// </summary>
    [Parameter]
    public Func<PopoverViewportState, string>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        RootContext?.SetHasViewport(true);
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        state = new PopoverViewportState(activationDirection, transitioning);
        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            hasRendered = true;
            dotNetRef = DotNetObjectReference.Create(this);

            if (RootContext is not null && Element.HasValue)
            {
                try
                {
                    var module = await ModuleTask.Value;
                    await module.InvokeVoidAsync("initializeViewport", RootContext.RootId, Element.Value, dotNetRef);

                    var side = PositionerContext?.Side ?? Side.Bottom;
                    var direction = RootContext.Direction ?? "ltr";
                    await module.InvokeVoidAsync("initializeAutoResize", RootContext.RootId, side.ToDataAttributeString(), direction);
                }
                catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
                {
                }
            }
        }
    }

    /// <summary>
    /// Called from JavaScript when a viewport content transition starts.
    /// </summary>
    [JSInvokable]
    public void OnViewportTransitionStart(string direction)
    {
        activationDirection = direction;
        transitioning = true;
        state = new PopoverViewportState(activationDirection, transitioning);
        BuildComponentAttributes();
        StateHasChanged();
    }

    /// <summary>
    /// Called from JavaScript when a viewport content transition ends.
    /// </summary>
    [JSInvokable]
    public void OnViewportTransitionEnd()
    {
        activationDirection = null;
        transitioning = false;
        RootContext?.SetInstantType(InstantType.TriggerChange);
        state = new PopoverViewportState(activationDirection, transitioning);
        BuildComponentAttributes();
        StateHasChanged();
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();

        if (!string.IsNullOrEmpty(state.ActivationDirection))
        {
            attrs["data-activation-direction"] = state.ActivationDirection;
        }

        attrs["data-transitioning"] = state.Transitioning;
        attrs["data-current"] = true;

        componentAttributes = attrs;
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        RootContext?.SetHasViewport(false);

        if (moduleTask?.IsValueCreated == true && hasRendered && RootContext is not null)
        {
            try
            {
                var module = await ModuleTask.Value;
                await module.InvokeVoidAsync("disposeAutoResize", RootContext.RootId);
                await module.InvokeVoidAsync("disposeViewport", RootContext.RootId);
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
            }
        }

        dotNetRef?.Dispose();
    }
}
