@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop

@typeparam TPayload

@implements IAsyncDisposable

@inject IJSRuntime JSRuntime

<RenderElement TState="PopoverTriggerState"
               Tag="button"
               Enabled="RootContext is not null || HasHandle"
               State="state"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="ChildContent"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private Lazy<Task<IJSObjectReference>>? moduleTask;
    private bool hasRendered;
    private bool hoverInitialized;
    private string? hoverRootId;
    private string triggerId = null!;
    private string lastPointerType = string.Empty;
    private OpenChangeReason lastOpenReason;
    private PopoverTriggerState state;
    private PopoverHandle<TPayload>? registeredHandle;
    private RenderElement<PopoverTriggerState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private ElementReference? previousElement;

    private Lazy<Task<IJSObjectReference>> ModuleTask => moduleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>(
            "import", "./_content/BlazorBaseUI/blazor-baseui-popover.js").AsTask());

    private bool HasHandle => Handle is not null;

    private bool HasRootContext => RootContext is not null;

    [CascadingParameter]
    private PopoverRootContext? RootContext { get; set; }

    /// <summary>
    /// Gets or sets a custom render template for the trigger element.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<PopoverTriggerState>>? Render { get; set; }

    /// <summary>
    /// Determines whether the trigger is currently disabled.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Determines whether the component renders a native <c>&lt;button&gt;</c> element when replacing it via the <see cref="Render"/> prop.
    /// Set to <see langword="false"/> if the rendered element is not a button (e.g. a <c>&lt;div&gt;</c>).
    /// Defaults to <see langword="true"/>.
    /// </summary>
    [Parameter]
    public bool NativeButton { get; set; } = true;

    /// <summary>
    /// Determines whether the popover should also open when the trigger is hovered.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool OpenOnHover { get; set; }

    /// <summary>
    /// Gets or sets how long to wait, in milliseconds, before the popover may be opened on hover.
    /// Requires the <see cref="OpenOnHover"/> prop.
    /// Defaults to <c>300</c>.
    /// </summary>
    [Parameter]
    public int Delay { get; set; } = 300;

    /// <summary>
    /// Gets or sets how long to wait, in milliseconds, before closing the popover that was opened on hover.
    /// Requires the <see cref="OpenOnHover"/> prop.
    /// Defaults to <c>0</c>.
    /// </summary>
    [Parameter]
    public int CloseDelay { get; set; }

    /// <summary>
    /// Gets or sets the ID of the trigger. In addition to being forwarded to the rendered element,
    /// it is also used to specify the active trigger for the popover in controlled mode.
    /// </summary>
    [Parameter]
    public string? Id { get; set; }

    /// <summary>
    /// Gets or sets the handle to associate the trigger with a popover.
    /// </summary>
    [Parameter]
    public PopoverHandle<TPayload>? Handle { get; set; }

    /// <summary>
    /// Gets or sets the payload to pass to the popover when it is opened by this trigger.
    /// </summary>
    [Parameter]
    public TPayload? Payload { get; set; }

    /// <summary>
    /// Gets or sets a function that returns CSS class names based on the current state.
    /// </summary>
    [Parameter]
    public Func<PopoverTriggerState, string>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets a function that returns inline styles based on the current state.
    /// </summary>
    [Parameter]
    public Func<PopoverTriggerState, string>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        triggerId = Id ?? Guid.NewGuid().ToIdString();
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        // Handle Id change - unregister old trigger ID
        if (Id is not null && Id != triggerId)
        {
            UnregisterFromCurrentStore(triggerId);
            triggerId = Id;
        }

        // Handle change of handle parameter
        if (Handle != registeredHandle)
        {
            registeredHandle?.UnregisterTrigger(triggerId);
            registeredHandle = Handle;
            Handle?.RegisterTrigger(triggerId, Element, Payload);
        }
        else if (HasHandle)
        {
            // Update payload on existing handle
            Handle!.UpdateTriggerPayload(triggerId, Payload);
        }

        var open = IsOpenedByThisTrigger();
        state = new PopoverTriggerState(open, Disabled);
        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            hasRendered = true;

            if (HasHandle)
            {
                Handle!.RegisterTrigger(triggerId, Element, Payload);
                registeredHandle = Handle;
            }
            else
            {
                RootContext?.SetTriggerElement(Element);
            }

            if (OpenOnHover && !hoverInitialized)
            {
                _ = InitializeHoverInteractionAsync();
            }
        }

        var currentElement = Element;
        if (!Nullable.Equals(previousElement, currentElement))
        {
            previousElement = currentElement;
            OnElementChanged();
        }
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();

        if (!NativeButton)
        {
            attrs["role"] = "button";
            if (Disabled)
            {
                attrs["aria-disabled"] = "true";
            }
        }
        else
        {
            attrs["type"] = "button";
            if (Disabled)
            {
                attrs["disabled"] = true;
            }
        }

        attrs["aria-haspopup"] = "dialog";

        var open = IsOpenedByThisTrigger();
        attrs["aria-expanded"] = open ? "true" : "false";
        attrs["id"] = triggerId;

        attrs["data-popup-open"] = open;

        var openReason = HasHandle ? lastOpenReason : (RootContext?.OpenChangeReason ?? OpenChangeReason.TriggerPress);
        attrs["data-pressed"] = open && openReason == OpenChangeReason.TriggerPress;
        attrs["data-base-ui-click-trigger"] = true;

        attrs["onpointerdown"] = EventCallback.Factory.Create<PointerEventArgs>(this, HandlePointerDownAsync);
        attrs["onclick"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleClickAsync);

        componentAttributes = attrs;
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        UnregisterFromCurrentStore(triggerId);

        if (moduleTask?.IsValueCreated == true && hasRendered && hoverInitialized && hoverRootId is not null)
        {
            try
            {
                var module = await ModuleTask.Value;
                await module.InvokeVoidAsync("disposeHoverInteraction", hoverRootId);
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
            }
        }

        hoverDotNetRef?.Dispose();
    }

    private void OnElementChanged()
    {
        if (HasHandle)
        {
            Handle!.UpdateTriggerElement(triggerId, Element);
        }
        else
        {
            RootContext?.SetTriggerElement(Element);
        }
    }

    private void UnregisterFromCurrentStore(string id)
    {
        if (registeredHandle is not null)
        {
            registeredHandle.UnregisterTrigger(id);
        }
    }

    private bool IsOpenedByThisTrigger()
    {
        // Check handle state first if using detached trigger pattern
        if (HasHandle)
        {
            var isOpen = Handle!.IsOpen;
            if (!isOpen)
            {
                return false;
            }
            var activeId = Handle.ActiveTriggerId;
            return activeId == triggerId || (activeId is null && isOpen);
        }

        // Fall back to root context
        if (RootContext is null)
        {
            return false;
        }

        var rootOpen = RootContext.GetOpen();
        if (!rootOpen)
        {
            return false;
        }

        var activeTriggerId = RootContext.ActiveTriggerId;
        return activeTriggerId == triggerId || (activeTriggerId is null && rootOpen);
    }

    private Task HandlePointerDownAsync(PointerEventArgs e)
    {
        lastPointerType = e.PointerType ?? string.Empty;
        return Task.CompletedTask;
    }

    private async Task HandleClickAsync(MouseEventArgs e)
    {
        if (Disabled || (!HasRootContext && !HasHandle))
        {
            return;
        }

        var nextOpen = !IsOpenedByThisTrigger();

        // Patient click protection: when the popover was recently hover-opened,
        // suppress the first click that would close it (the click "sticks" the
        // popover open instead). Only applies to root-context triggers.
        if (!nextOpen && HasRootContext && OpenOnHover)
        {
            try
            {
                var module = await ModuleTask.Value;
                var stuck = await module.InvokeAsync<bool>("consumeStickIfOpen", RootContext!.RootId);
                if (stuck)
                {
                    await EventUtilities.InvokeOnClickAsync(AdditionalAttributes, e);
                    return;
                }
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
            }
        }

        // Detect interaction type on both open and close
        string? detectedInteractionType = e.Detail == 0 ? "keyboard" : lastPointerType;
        lastPointerType = string.Empty;

        await RequestOpenAsync(nextOpen, OpenChangeReason.TriggerPress, detectedInteractionType);
        await EventUtilities.InvokeOnClickAsync(AdditionalAttributes, e);
    }

    private DotNetObjectReference<PopoverTypedTrigger<TPayload>>? hoverDotNetRef;

    private async Task InitializeHoverInteractionAsync()
    {
        if (!Element.HasValue)
        {
            return;
        }

        if (HasHandle)
        {
            // Handle-based trigger: use trigger-level hover ID and dotnet ref
            try
            {
                var module = await ModuleTask.Value;
                hoverDotNetRef = DotNetObjectReference.Create(this);
                var hoverId = $"hover-{triggerId}";
                await module.InvokeVoidAsync("initializeHoverInteraction", hoverId, Element.Value, Delay, CloseDelay, hoverDotNetRef);
                hoverInitialized = true;
                hoverRootId = hoverId;
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
            }
        }
        else
        {
            if (RootContext is null)
            {
                return;
            }

            try
            {
                var module = await ModuleTask.Value;
                await module.InvokeVoidAsync("initializeHoverInteraction", RootContext.RootId, Element.Value, Delay, CloseDelay);
                hoverInitialized = true;
                hoverRootId = RootContext.RootId;
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
            }
        }
    }

    /// <summary>
    /// Handles a hover open event from JavaScript interop for handle-based triggers.
    /// </summary>
    [JSInvokable]
    public Task OnHoverOpen()
    {
        if (HasHandle)
        {
            Handle!.RequestOpen(triggerId, OpenChangeReason.TriggerHover);
        }
        return Task.CompletedTask;
    }

    /// <summary>
    /// Handles a hover close event from JavaScript interop for handle-based triggers.
    /// </summary>
    [JSInvokable]
    public Task OnHoverClose()
    {
        if (HasHandle)
        {
            Handle!.RequestClose(OpenChangeReason.TriggerHover);
        }
        return Task.CompletedTask;
    }

    private Task RequestOpenAsync(bool open, OpenChangeReason reason, string? requestInteractionType = null)
    {
        if (HasHandle)
        {
            if (open)
            {
                lastOpenReason = reason;
                Handle!.RequestOpen(triggerId, reason, requestInteractionType);
            }
            else
            {
                Handle!.RequestClose(reason, requestInteractionType);
            }
            return Task.CompletedTask;
        }

        if (RootContext is not null)
        {
            if (requestInteractionType is not null)
            {
                RootContext.SetInteractionType(requestInteractionType);
            }

            return RootContext.SetOpenAsync(open, reason, open ? Payload : null, triggerId);
        }

        return Task.CompletedTask;
    }
}
