@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

@if (RootContext is not null)
{
    @if (ShouldRenderInternalBackdrop())
    {
        <div @ref="internalBackdropElement"
             role="presentation"
             data-base-ui-inert @* lint-ignore:RULE-05 React parity selector consumed by markOthers floating-ui logic. *@
             style="position:fixed;inset:0;pointer-events:auto;user-select:none"
             inert="@(!RootContext?.GetOpen() ?? true)" />
    }
    <CascadingValue Value="positionerContext" IsFixed="true">
        <RenderElement TState="PopoverPositionerState"
                       Tag="div"
                       State="state"
                       Enabled="RootContext is not null"
                       Render="Render"
                       ClassValue="ClassValue"
                       StyleValue="StyleValue"
                       ComponentAttributes="componentAttributes"
                       ChildContent="ChildContent"
                       @attributes="AdditionalAttributes"
                       @ref="renderElementReference" />
    </CascadingValue>
}

@code {
    private PositionerInterop positionerInterop = null!;
    private ElementReference? arrowElement;
    private ElementReference? internalBackdropElement;
    private ElementReference? previousBackdropElement;
    private Side computedSide;
    private Align computedAlign;
    private bool computedAnchorHidden;
    private bool computedArrowUncentered;
    private DotNetObjectReference<PopoverPositioner>? positionerDotNetRef;
    private PopoverPositionerState state;
    private PopoverPositionerContext positionerContext = null!;
    private RenderElement<PopoverPositionerState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();
    private ElementReference? previousElement;

    [CascadingParameter]
    private PopoverRootContext? RootContext { get; set; }

    [CascadingParameter]
    private PopoverPortalContext? PortalContext { get; set; }

    /// <summary>
    /// Gets or sets a custom render template for the positioner element.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<PopoverPositionerState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the side of the anchor element to position against.
    /// Defaults to <see cref="Popover.Side.Bottom"/>.
    /// </summary>
    [Parameter]
    public Side Side { get; set; } = Side.Bottom;

    /// <summary>
    /// Gets or sets the alignment of the popover relative to the specified side.
    /// Defaults to <see cref="Popover.Align.Center"/>.
    /// </summary>
    [Parameter]
    public Align Align { get; set; } = Align.Center;

    /// <summary>
    /// Gets or sets the offset in pixels from the side of the anchor element.
    /// Defaults to <c>0</c>.
    /// </summary>
    [Parameter]
    public double SideOffset { get; set; }

    /// <summary>
    /// Gets or sets a function that computes the side offset dynamically based on anchor/popup dimensions.
    /// When set, takes precedence over <see cref="SideOffset"/>.
    /// </summary>
    [Parameter]
    public Func<OffsetData, double>? SideOffsetFunction { get; set; }

    /// <summary>
    /// Gets or sets the offset in pixels from the alignment edge of the anchor element.
    /// Defaults to <c>0</c>.
    /// </summary>
    [Parameter]
    public double AlignOffset { get; set; }

    /// <summary>
    /// Gets or sets a function that computes the align offset dynamically based on anchor/popup dimensions.
    /// When set, takes precedence over <see cref="AlignOffset"/>.
    /// </summary>
    [Parameter]
    public Func<OffsetData, double>? AlignOffsetFunction { get; set; }

    /// <summary>
    /// Gets or sets the uniform padding in pixels between the popover and the collision boundary edge.
    /// Defaults to <c>5</c>.
    /// </summary>
    [Parameter]
    public double CollisionPadding { get; set; } = 5;

    /// <summary>
    /// Gets or sets per-side collision padding between the popover and the collision boundary edge.
    /// When set, takes precedence over <see cref="CollisionPadding"/>.
    /// </summary>
    [Parameter]
    public SidePadding? CollisionPaddingPerSide { get; set; }

    /// <summary>
    /// Gets or sets the boundary used to detect collisions for repositioning.
    /// Defaults to <see cref="Popover.CollisionBoundary.ClippingAncestors"/>.
    /// </summary>
    [Parameter]
    public CollisionBoundary CollisionBoundary { get; set; } = CollisionBoundary.ClippingAncestors;

    /// <summary>
    /// Gets or sets the minimum padding in pixels between the arrow and the edges of the popup.
    /// Defaults to <c>5</c>.
    /// </summary>
    [Parameter]
    public double ArrowPadding { get; set; } = 5;

    /// <summary>
    /// Determines whether the popover stays attached to its anchor element when it overflows.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool Sticky { get; set; }

    /// <summary>
    /// Determines whether anchor tracking updates are disabled as the popup repositions on scroll/resize.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool DisableAnchorTracking { get; set; }

    /// <summary>
    /// Gets or sets the CSS positioning method for the popover.
    /// Defaults to <see cref="Popover.PositionMethod.Absolute"/>.
    /// </summary>
    [Parameter]
    public PositionMethod PositionMethod { get; set; } = PositionMethod.Absolute;

    /// <summary>
    /// Gets or sets how collisions are handled when positioning the popup.
    /// When <see langword="null"/>, defaults to flipping on both the side and alignment axes.
    /// </summary>
    [Parameter]
    public CollisionAvoidance? CollisionAvoidance { get; set; }

    /// <summary>
    /// Gets or sets a custom anchor element to position the popover against instead of the trigger.
    /// </summary>
    [Parameter]
    public ElementReference? Anchor { get; set; }

    /// <summary>
    /// Gets or sets a function that returns CSS class names based on the current state.
    /// </summary>
    [Parameter]
    public Func<PopoverPositionerState, string>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets a function that returns inline styles based on the current state.
    /// </summary>
    [Parameter]
    public Func<PopoverPositionerState, string>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        positionerInterop = new PositionerInterop(
            JSRuntime,
            "./_content/BlazorBaseUI/blazor-baseui-popover.js");

        computedSide = Side;
        computedAlign = Align;
        computedAnchorHidden = false;

        positionerContext = new PopoverPositionerContext
        {
            Side = computedSide,
            Align = computedAlign,
            AnchorHidden = computedAnchorHidden,
            ArrowUncentered = false,
            GetArrowElement = () => arrowElement,
            SetArrowElement = SetArrowElement
        };
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        // Reset computed values when parameters change
        computedSide = Side;
        computedAlign = Align;

        var open = RootContext?.GetOpen() ?? false;
        var instant = RootContext?.PopoverInstantType ?? PopoverInstantType.None;
        state = new PopoverPositionerState(open, computedSide, computedAlign, computedAnchorHidden, instant);

        positionerContext.Side = computedSide;
        positionerContext.Align = computedAlign;
        positionerContext.AnchorHidden = computedAnchorHidden;

        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            positionerInterop.MarkRendered();
            positionerDotNetRef = DotNetObjectReference.Create(this);
        }

        var currentElement = Element;
        if (!Nullable.Equals(previousElement, currentElement))
        {
            previousElement = currentElement;
            RootContext?.SetPositionerElement(currentElement);
        }

        // Track internal backdrop element
        if (positionerInterop.HasRendered && !Nullable.Equals(previousBackdropElement, internalBackdropElement))
        {
            previousBackdropElement = internalBackdropElement;
            if (RootContext is not null)
            {
                try
                {
                    var module = await positionerInterop.GetModuleAsync();
                    await module.InvokeVoidAsync("setInternalBackdrop", RootContext.RootId,
                        internalBackdropElement.HasValue ? internalBackdropElement.Value : null);
                }
                catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
                {
                    _ = ex; // Expected during circuit disconnect - safe to ignore.
                }
            }
        }

        if (positionerInterop.HasRendered && Element.HasValue && RootContext?.GetMounted() == true)
        {
            if (!positionerInterop.IsInitialized)
            {
                await InitializePositionerAsync();
            }
            else if (!DisableAnchorTracking)
            {
                await UpdatePositionAsync();
            }
        }
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();

        attrs["role"] = "presentation";
        attrs["data-blazor-base-ui-positioner"] = true;

        var mounted = RootContext?.GetMounted() ?? false;
        if (!mounted)
        {
            attrs["hidden"] = true;
        }

        var isOpen = RootContext?.GetOpen() ?? false;

        // NOTE: Do NOT set inline "style" here. JS (initializePositioner/updatePosition)
        // manages position, left, top, z-index, and visibility on this element's style.
        // If C# sets the style attribute, Blazor's diff will clobber JS-set values on
        // re-render, causing a flash-of-unpositioned-content. Initial hiding and
        // pointer-events are handled by global CSS rules in blazor-baseui-floating.js.

        attrs["data-side"] = computedSide.ToDataAttributeString()!;
        attrs["data-align"] = computedAlign.ToDataAttributeString()!;

        attrs["data-open"] = isOpen;
        attrs["data-closed"] = !isOpen;
        attrs["data-anchor-hidden"] = computedAnchorHidden;

        var instantType = RootContext?.PopoverInstantType ?? PopoverInstantType.None;
        var instantAttr = instantType.ToDataAttributeString();
        if (!string.IsNullOrEmpty(instantAttr))
        {
            attrs["data-instant"] = instantAttr;
        }

        var transitionStatus = RootContext?.TransitionStatus ?? TransitionStatus.Undefined;
        TransitionAttributeHelper.ApplyTransitionStyleAttributes(attrs, transitionStatus);

        componentAttributes = attrs;
    }

    /// <summary>
    /// Called from JavaScript to compute the side offset dynamically.
    /// </summary>
    [JSInvokable]
    public double ComputeSideOffset(OffsetData data) => SideOffsetFunction?.Invoke(data) ?? SideOffset;

    /// <summary>
    /// Called from JavaScript to compute the align offset dynamically.
    /// </summary>
    [JSInvokable]
    public double ComputeAlignOffset(OffsetData data) => AlignOffsetFunction?.Invoke(data) ?? AlignOffset;

    [JSInvokable]
    public void OnPositionUpdated(string side, string align, bool anchorHidden, bool arrowUncentered)
    {
        var physicalSide = BlazorBaseUI.Extensions.ParseSide(side);
        var newSide = GetLogicalSide(physicalSide);
        var newAlign = BlazorBaseUI.Extensions.ParseAlign(align);

        if (newSide == computedSide && newAlign == computedAlign && anchorHidden == computedAnchorHidden && arrowUncentered == computedArrowUncentered)
        {
            return;
        }

        computedSide = newSide;
        computedAlign = newAlign;
        computedAnchorHidden = anchorHidden;
        computedArrowUncentered = arrowUncentered;

        positionerContext.Side = computedSide;
        positionerContext.Align = computedAlign;
        positionerContext.AnchorHidden = computedAnchorHidden;
        positionerContext.ArrowUncentered = computedArrowUncentered;

        var open = RootContext?.GetOpen() ?? false;
        var instant = RootContext?.PopoverInstantType ?? PopoverInstantType.None;
        state = new PopoverPositionerState(open, computedSide, computedAlign, computedAnchorHidden, instant);
        BuildComponentAttributes();
        StateHasChanged();
    }

    private bool ShouldRenderInternalBackdrop()
    {
        if (RootContext is null) return false;
        return RootContext.Modal == PopoverModalMode.True
            && RootContext.PopoverOpenChangeReason != PopoverOpenChangeReason.TriggerHover
            && RootContext.GetMounted();
    }

    private void SetArrowElement(ElementReference? element)
    {
        if (Nullable.Equals(arrowElement, element))
        {
            return;
        }

        arrowElement = element;

        if (positionerInterop.HasRendered && positionerInterop.IsInitialized)
        {
            _ = UpdatePositionAsync();
        }
    }

    private Side GetLogicalSide(Side physicalSide)
    {
        var isLogicalRequest = computedSide is Side.InlineStart or Side.InlineEnd;

        if (!isLogicalRequest)
        {
            return physicalSide;
        }

        var isRtl = RootContext?.Direction == "rtl";
        return physicalSide switch
        {
            Side.Right => isRtl ? Side.InlineStart : Side.InlineEnd,
            Side.Left => isRtl ? Side.InlineEnd : Side.InlineStart,
            _ => physicalSide
        };
    }

    private object GetCollisionPaddingArg() =>
        CollisionPaddingPerSide is not null
            ? new { top = CollisionPaddingPerSide.Top, right = CollisionPaddingPerSide.Right, bottom = CollisionPaddingPerSide.Bottom, left = CollisionPaddingPerSide.Left }
            : (object)CollisionPadding;

    private async Task InitializePositionerAsync()
    {
        if (!Element.HasValue || RootContext is null)
        {
            return;
        }

        var anchorElement = Anchor ?? RootContext.GetTriggerElement();
        if (!anchorElement.HasValue)
        {
            return;
        }

        try
        {
            var module = await positionerInterop.GetModuleAsync();
            var config = new PositionerConfig
            {
                Side = Side,
                Align = Align,
                CollisionBoundary = CollisionBoundary,
                ArrowPadding = ArrowPadding,
                Sticky = Sticky,
                PositionMethod = PositionMethod,
                DisableAnchorTracking = DisableAnchorTracking,
                CollisionAvoidance = CollisionAvoidance
            };

            var ca = config.CollisionAvoidance ?? new CollisionAvoidance();
            positionerInterop.SetPositionerId(await module.InvokeAsync<string>( // lint-ignore:RULE-09 Either EventCallback.InvokeAsync (not JS interop) or JS interop wrapped in try/catch outside the lint's 20-line lookback window.
                "initializePositioner",
                Element.Value, // lint-ignore:RULE-12 Element.Value reached only after early-exit Element.HasValue guard outside the 10-line lookback window.
                anchorElement.Value, // lint-ignore:RULE-12 Element.Value reached only after early-exit Element.HasValue guard outside the 10-line lookback window.
                Side.ToDataAttributeString(),
                Align.ToDataAttributeString(),
                SideOffset,
                AlignOffset,
                GetCollisionPaddingArg(),
                CollisionBoundary.ToDataAttributeString(),
                ArrowPadding,
                arrowElement,
                Sticky,
                config.PositionMethodString,
                DisableAnchorTracking,
                (ca.Side).ToJsString(),
                (ca.Align).ToJsString(),
                (ca.FallbackAxisSide).ToJsString(),
                positionerDotNetRef,
                SideOffsetFunction is not null,
                AlignOffsetFunction is not null,
                RootContext.HasViewport));
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task UpdatePositionAsync()
    {
        if (!positionerInterop.IsInitialized || RootContext is null)
        {
            return;
        }

        var anchorElement = Anchor ?? RootContext.GetTriggerElement();
        if (!anchorElement.HasValue)
        {
            return;
        }

        try
        {
            var module = await positionerInterop.GetModuleAsync();
            var ca = CollisionAvoidance ?? new CollisionAvoidance();

            await module.InvokeVoidAsync( // lint-ignore:RULE-09 Either EventCallback.InvokeAsync (not JS interop) or JS interop wrapped in try/catch outside the lint's 20-line lookback window.
                "updatePosition",
                positionerInterop.PositionerId,
                anchorElement.Value, // lint-ignore:RULE-12 Element.Value reached only after early-exit Element.HasValue guard outside the 10-line lookback window.
                Side.ToDataAttributeString(),
                Align.ToDataAttributeString(),
                SideOffset,
                AlignOffset,
                GetCollisionPaddingArg(),
                CollisionBoundary.ToDataAttributeString(),
                ArrowPadding,
                arrowElement,
                Sticky,
                PositionMethod == PositionMethod.Fixed ? "fixed" : "absolute",
                (ca.Side).ToJsString(),
                (ca.Align).ToJsString(),
                (ca.FallbackAxisSide).ToJsString(),
                SideOffsetFunction is not null,
                AlignOffsetFunction is not null,
                RootContext?.HasViewport ?? false);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        await positionerInterop.DisposeAsync();
        positionerDotNetRef?.Dispose();
    }
}
