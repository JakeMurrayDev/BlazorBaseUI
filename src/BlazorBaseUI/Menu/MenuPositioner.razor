@using Microsoft.JSInterop
@using BlazorBaseUI.ContextMenu

@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<CascadingValue TValue="MenuPositionerContext" Value="positionerContext" IsFixed="true">
    <RenderElement TState="MenuPositionerState"
                   Tag="div"
                   State="state"
                   Enabled="RootContext is not null"
                   Render="Render"
                   ClassValue="ClassValue"
                   StyleValue="StyleValue"
                   ComponentAttributes="componentAttributes"
                   ChildContent="ChildContent"
                   @attributes="AdditionalAttributes"
                   @ref="renderElementReference" />
</CascadingValue>

@code {
    private Lazy<Task<IJSObjectReference>>? moduleTask;
    private bool hasRendered;
    private ElementReference? arrowElement;
    private string? positionerId;
    private Side computedSide;
    private Align computedAlign;
    private int effectiveSideOffset;
    private int effectiveAlignOffset;
    private int effectiveArrowPadding;
    private PositionMethod effectivePositionMethod;
    private bool shiftCrossAxis;
    private bool computedAnchorHidden;
    private DotNetObjectReference<MenuPositioner>? positionerDotNetRef;
    private MenuPositionerState state;
    private MenuPositionerContext positionerContext = null!;
    private RenderElement<MenuPositionerState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();

    private Lazy<Task<IJSObjectReference>> ModuleTask => moduleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>(
            "import", "./_content/BlazorBaseUI/blazor-baseui-menu.js").AsTask());

    [CascadingParameter]
    private MenuRootContext? RootContext { get; set; }

    [CascadingParameter]
    private ContextMenuRootContext? ContextMenuContext { get; set; }

    /// <summary>
    /// Gets or sets which side of the anchor element to align the popup against.
    /// May automatically change to avoid collisions.
    /// </summary>
    [Parameter]
    public Side? Side { get; set; }

    /// <summary>
    /// Gets or sets how to align the popup relative to the specified side.
    /// </summary>
    [Parameter]
    public Align? Align { get; set; }

    /// <summary>
    /// Gets or sets the distance between the anchor and the popup in pixels.
    /// </summary>
    [Parameter]
    public int SideOffset { get; set; }

    /// <summary>
    /// Gets or sets additional offset along the alignment axis in pixels.
    /// </summary>
    [Parameter]
    public int AlignOffset { get; set; }

    /// <summary>
    /// Gets or sets additional space to maintain from the edge of the collision boundary.
    /// </summary>
    [Parameter]
    public int CollisionPadding { get; set; } = 5;

    /// <summary>
    /// Gets or sets an element or rectangle that delimits the area the popup is confined to.
    /// </summary>
    [Parameter]
    public CollisionBoundary CollisionBoundary { get; set; } = CollisionBoundary.ClippingAncestors;

    /// <summary>
    /// Gets or sets how to handle collisions when positioning the popup.
    /// When <see langword="null"/>, defaults to flipping on the side axis and shifting on the alignment axis.
    /// </summary>
    [Parameter]
    public CollisionAvoidance? CollisionAvoidance { get; set; }

    /// <summary>
    /// Gets or sets the minimum distance to maintain between the arrow and the edges of the popup.
    /// </summary>
    [Parameter]
    public int ArrowPadding { get; set; } = 5;

    /// <summary>
    /// Determines whether the popup is maintained in the viewport after the anchor element is scrolled out of view.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool Sticky { get; set; }

    /// <summary>
    /// Determines whether the popup is prevented from tracking any layout shift of its positioning anchor.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool DisableAnchorTracking { get; set; }

    /// <summary>
    /// Gets or sets which CSS <c>position</c> property to use.
    /// </summary>
    [Parameter]
    public PositionMethod PositionMethod { get; set; } = PositionMethod.Absolute;

    /// <summary>
    /// Gets or sets an element to position the popup against.
    /// By default, the popup will be positioned against the trigger.
    /// </summary>
    [Parameter]
    public ElementReference? Anchor { get; set; }

    /// <summary>
    /// Allows you to replace the component's HTML element
    /// with a different tag, or compose it with another component.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<MenuPositionerState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on the component state.
    /// </summary>
    [Parameter]
    public Func<MenuPositionerState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on the component state.
    /// </summary>
    [Parameter]
    public Func<MenuPositionerState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        positionerContext = new MenuPositionerContext
        {
            Side = Side ?? BlazorBaseUI.Side.Bottom,
            Align = Align ?? BlazorBaseUI.Align.Center,
            GetArrowElement = () => arrowElement,
            SetArrowElement = SetArrowElement
        };
        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        var open = RootContext?.GetOpen() ?? false;
        var parentType = RootContext?.ParentType ?? MenuParentType.None;
        var nested = parentType == MenuParentType.Menu;
        var isContextMenu = parentType == MenuParentType.ContextMenu;
        var isMenubar = parentType == MenuParentType.Menubar;
        var instant = RootContext?.MenuInstantType ?? MenuInstantType.None;

        // Resolve Side default per parent type (React: useAnchorPositioning defaults to 'bottom')
        var resolvedSide = Side ?? (nested ? BlazorBaseUI.Side.InlineEnd : BlazorBaseUI.Side.Bottom);

        // Resolve Align default per parent type (React: useAnchorPositioning defaults to 'center')
        var resolvedAlign = Align ?? ((isContextMenu || nested || isMenubar)
            ? BlazorBaseUI.Align.Start
            : BlazorBaseUI.Align.Center);

        // Effective positioning values (may be overridden by parent type)
        effectiveSideOffset = SideOffset;
        effectiveAlignOffset = AlignOffset;
        effectiveArrowPadding = ArrowPadding;
        effectivePositionMethod = PositionMethod;
        shiftCrossAxis = false;

        if (isContextMenu)
        {
            effectivePositionMethod = ContextMenuContext is not null ? PositionMethod.Fixed : PositionMethod;
            effectiveArrowPadding = 0;
            shiftCrossAxis = CollisionAvoidance?.Side != CollisionAvoidanceSideMode.Flip;

            // Context-menu offset adjustments when side is unspecified and align isn't center
            if (Side is null && resolvedAlign != BlazorBaseUI.Align.Center)
            {
                if (AlignOffset == 0) effectiveAlignOffset = 2;
                if (SideOffset == 0) effectiveSideOffset = -5;
            }
        }

        computedSide = resolvedSide;
        computedAlign = resolvedAlign;

        state = new MenuPositionerState(open, computedSide, computedAlign, computedAnchorHidden, nested, instant);

        positionerContext.Side = computedSide;
        positionerContext.Align = computedAlign;

        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            hasRendered = true;
            positionerDotNetRef = DotNetObjectReference.Create(this);
            RootContext?.SetPositionerElement(Element);
        }

        if (hasRendered && Element.HasValue && RootContext?.GetMounted() == true)
        {
            if (string.IsNullOrEmpty(positionerId))
            {
                await InitializePositionerAsync();
            }
            else if (!DisableAnchorTracking)
            {
                await UpdatePositionAsync();
            }
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (moduleTask?.IsValueCreated == true && hasRendered && !string.IsNullOrEmpty(positionerId))
        {
            try
            {
                var module = await ModuleTask.Value;
                await module.InvokeVoidAsync("disposePositioner", positionerId);
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }

        positionerDotNetRef?.Dispose();
    }

    [JSInvokable]
    public void OnPositionUpdated(string side, string align, bool anchorHidden)
    {
        var physicalSide = Extensions.ParseSide(side);
        var newSide = GetLogicalSide(physicalSide);
        var newAlign = Extensions.ParseAlign(align);

        if (newSide == computedSide && newAlign == computedAlign && anchorHidden == computedAnchorHidden)
        {
            return;
        }

        computedSide = newSide;
        computedAlign = newAlign;
        computedAnchorHidden = anchorHidden;

        positionerContext.Side = computedSide;
        positionerContext.Align = computedAlign;
        positionerContext.AnchorHidden = computedAnchorHidden;

        var open = RootContext?.GetOpen() ?? false;
        var nested = RootContext?.ParentType == MenuParentType.Menu;
        var instant = RootContext?.MenuInstantType ?? MenuInstantType.None;
        state = new MenuPositionerState(open, computedSide, computedAlign, computedAnchorHidden, nested, instant);
        BuildComponentAttributes();
        StateHasChanged();
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();
        var open = RootContext?.GetOpen() ?? false;
        var mounted = RootContext?.GetMounted() ?? false;
        var instantType = RootContext?.MenuInstantType ?? MenuInstantType.None;
        var nested = RootContext?.ParentType == MenuParentType.Menu;
        var transitionStatus = RootContext?.TransitionStatus ?? TransitionStatus.Undefined;

        attrs["role"] = "presentation";

        if (!mounted)
        {
            attrs["hidden"] = true;
        }

        // NOTE: Do NOT set inline "style" here. JS (initializePositioner/updatePosition)
        // manages position, left, top, z-index, and visibility on this element's style.
        // pointer-events are handled by global CSS rules in blazor-baseui-floating.js.

        attrs["data-side"] = computedSide.ToDataAttributeString()!;
        attrs["data-align"] = computedAlign.ToDataAttributeString()!;

        attrs["data-open"] = open;
        attrs["data-closed"] = !open;
        attrs["data-anchor-hidden"] = computedAnchorHidden;

        if (nested)
        {
            attrs["data-nested"] = true;
        }

        var instantAttr = instantType.ToDataAttributeString();
        if (!string.IsNullOrEmpty(instantAttr))
        {
            attrs["data-instant"] = instantAttr;
        }

        attrs["data-starting-style"] = transitionStatus == TransitionStatus.Starting;

        componentAttributes = attrs;
    }

    private BlazorBaseUI.Side GetLogicalSide(BlazorBaseUI.Side physicalSide)
    {
        var isLogicalRequest = computedSide is BlazorBaseUI.Side.InlineStart or BlazorBaseUI.Side.InlineEnd;

        if (!isLogicalRequest)
        {
            return physicalSide;
        }

        var isRtl = RootContext?.Direction == "rtl";
        return physicalSide switch
        {
            BlazorBaseUI.Side.Right => isRtl ? BlazorBaseUI.Side.InlineStart : BlazorBaseUI.Side.InlineEnd,
            BlazorBaseUI.Side.Left => isRtl ? BlazorBaseUI.Side.InlineEnd : BlazorBaseUI.Side.InlineStart,
            _ => physicalSide
        };
    }

    private void SetArrowElement(ElementReference? element)
    {
        if (Nullable.Equals(arrowElement, element))
        {
            return;
        }

        arrowElement = element;

        if (hasRendered && !string.IsNullOrEmpty(positionerId))
        {
            _ = UpdatePositionAsync();
        }
    }

    private async Task InitializePositionerAsync()
    {
        if (!Element.HasValue || RootContext is null)
        {
            return;
        }

        var anchorElement = Anchor ?? RootContext.GetTriggerElement();
        if (!anchorElement.HasValue)
        {
            return;
        }

        var nested = RootContext.ParentType == MenuParentType.Menu;

        try
        {
            var module = await ModuleTask.Value;
            var (caSide, caAlign, caFallback) = GetCollisionAvoidanceStrings(nested);
            var hasViewport = RootContext.HasViewport;
            positionerId = await module.InvokeAsync<string>(
                "initializePositioner",
                Element.Value,
                anchorElement.Value,
                computedSide.ToDataAttributeString(),
                computedAlign.ToDataAttributeString(),
                effectiveSideOffset,
                effectiveAlignOffset,
                CollisionPadding,
                CollisionBoundary.ToDataAttributeString(),
                effectiveArrowPadding,
                arrowElement,
                Sticky,
                effectivePositionMethod == PositionMethod.Fixed ? "fixed" : "absolute",
                DisableAnchorTracking,
                caSide, caAlign, caFallback,
                positionerDotNetRef,
                hasViewport,
                shiftCrossAxis);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task UpdatePositionAsync()
    {
        if (string.IsNullOrEmpty(positionerId) || RootContext is null)
        {
            return;
        }

        var anchorElement = Anchor ?? RootContext.GetTriggerElement();
        if (!anchorElement.HasValue)
        {
            return;
        }

        var nested = RootContext.ParentType == MenuParentType.Menu;
        var (caSide, caAlign, caFallback) = GetCollisionAvoidanceStrings(nested);

        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync(
                "updatePosition",
                positionerId,
                anchorElement.Value,
                computedSide.ToDataAttributeString(),
                computedAlign.ToDataAttributeString(),
                effectiveSideOffset,
                effectiveAlignOffset,
                CollisionPadding,
                CollisionBoundary.ToDataAttributeString(),
                effectiveArrowPadding,
                arrowElement,
                Sticky,
                effectivePositionMethod == PositionMethod.Fixed ? "fixed" : "absolute",
                caSide, caAlign, caFallback,
                shiftCrossAxis);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private (string Side, string Align, string Fallback) GetCollisionAvoidanceStrings(bool nested) => (
        (CollisionAvoidance?.Side ?? CollisionAvoidanceSideMode.Flip).ToJsString(),
        (CollisionAvoidance?.Align ?? CollisionAvoidanceAlignMode.Flip).ToJsString(),
        (CollisionAvoidance?.FallbackAxisSide ?? (nested
            ? CollisionAvoidanceFallbackAxisSide.End
            : CollisionAvoidanceFallbackAxisSide.None)).ToJsString()
    );
}
