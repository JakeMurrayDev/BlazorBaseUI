@using BlazorBaseUI.MenuBar
@using BlazorBaseUI.Utilities
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop

@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<RenderElement TState="MenuTriggerState"
               Tag="button"
               State="state"
               Enabled="RootContext is not null || Handle is not null"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="ChildContent"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private Lazy<Task<IJSObjectReference>>? moduleTask;
    private bool hasRendered;
    private bool hoverInitialized;
    private string? hoverRootId;
    private string triggerId = null!;
    private string lastPointerType = string.Empty;
    private bool openedByPointerDown;
    private MenuTriggerState state;
    private RenderElement<MenuTriggerState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();

    private Lazy<Task<IJSObjectReference>> ModuleTask => moduleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>(
            "import", "./_content/BlazorBaseUI/blazor-baseui-menu.js").AsTask());

    private bool IsInMenuBar => MenuBarContext is not null;

    [CascadingParameter]
    private MenuRootContext? RootContext { get; set; }

    [CascadingParameter]
    private MenuBarRootContext? MenuBarContext { get; set; }

    /// <summary>
    /// Determines whether the component should ignore user interaction.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Determines whether the menu should also open when the trigger is hovered.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool OpenOnHover { get; set; }

    /// <summary>
    /// Gets or sets the delay in milliseconds before the menu may be opened on hover.
    /// Requires the <see cref="OpenOnHover"/> property.
    /// </summary>
    [Parameter]
    public int Delay { get; set; } = 100;

    /// <summary>
    /// Gets or sets the delay in milliseconds before closing the menu that was opened on hover.
    /// Requires the <see cref="OpenOnHover"/> property.
    /// When <see langword="null"/>, falls back to the <see cref="Delay"/> value.
    /// </summary>
    [Parameter]
    public int CloseDelay { get; set; }

    /// <summary>
    /// Gets or sets a handle to connect this trigger with a detached menu root.
    /// </summary>
    [Parameter]
    public IMenuHandle? Handle { get; set; }

    /// <summary>
    /// Allows you to replace the component's HTML element
    /// with a different tag, or compose it with another component.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<MenuTriggerState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on the component state.
    /// </summary>
    [Parameter]
    public Func<MenuTriggerState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on the component state.
    /// </summary>
    [Parameter]
    public Func<MenuTriggerState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        triggerId = Guid.NewGuid().ToIdString();
        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        var open = IsOpenedByThisTrigger();
        var disabled = Disabled || (RootContext?.Disabled ?? false) || (MenuBarContext?.Disabled ?? false);
        state = new MenuTriggerState(open, disabled);
        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            hasRendered = true;
            RootContext?.SetTriggerElement(Element);

            if (IsInMenuBar && Element.HasValue)
            {
                MenuBarContext!.RegisterItem(Element.Value);
            }

            if ((OpenOnHover || IsInMenuBar) && !hoverInitialized)
            {
                _ = InitializeHoverInteractionAsync();
            }
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (IsInMenuBar && Element.HasValue)
        {
            MenuBarContext!.UnregisterItem(Element.Value);
        }

        if (moduleTask?.IsValueCreated == true && hasRendered && hoverInitialized && hoverRootId is not null)
        {
            try
            {
                var module = await ModuleTask.Value;
                await module.InvokeVoidAsync("disposeHoverInteraction", hoverRootId);
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();
        var open = IsOpenedByThisTrigger();
        var disabled = state.Disabled;

        if (IsInMenuBar)
        {
            attrs["role"] = "menuitem";
            if (disabled)
            {
                attrs["aria-disabled"] = "true";
            }
        }

        attrs["type"] = "button";
        if (disabled)
        {
            attrs["disabled"] = true;
        }

        attrs["aria-haspopup"] = "menu";
        attrs["aria-expanded"] = open ? "true" : "false";

        var popupId = RootContext?.PopupId ?? Handle?.PopupId;
        if (open && !string.IsNullOrEmpty(popupId))
        {
            attrs["aria-controls"] = popupId;
        }

        attrs["id"] = triggerId;

        if (open)
        {
            attrs["data-popup-open"] = true;
            attrs["data-pressed"] = true;
        }

        attrs["onpointerdown"] = EventCallback.Factory.Create<PointerEventArgs>(this, HandlePointerDownAsync);
        attrs["onclick"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleClickAsync);
        attrs["onkeydown"] = EventCallback.Factory.Create<KeyboardEventArgs>(this, HandleKeyDownAsync);

        if (IsInMenuBar)
        {
            attrs["onmouseenter"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleMouseEnterAsync);
            attrs["onfocus"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleFocusAsync);
        }

        componentAttributes = attrs;
    }

    private bool IsOpenedByThisTrigger()
    {
        if (RootContext is null)
        {
            return false;
        }

        return RootContext.GetOpen();
    }

    private async Task HandlePointerDownAsync(PointerEventArgs e)
    {
        lastPointerType = InteractionTypeDetector.FromPointerEvent(e);

        if (state.Disabled || RootContext is null)
        {
            return;
        }

        var currentlyOpen = IsOpenedByThisTrigger();

        // In menubar, when already open, close on click (not pointerdown).
        if (currentlyOpen && IsInMenuBar)
        {
            return;
        }

        // Patient click protection: when menu was recently hover-opened,
        // suppress the press that would close it (500ms threshold).
        if (currentlyOpen && OpenOnHover)
        {
            try
            {
                var module = await ModuleTask.Value;
                var stuck = await module.InvokeAsync<bool>("consumeStickIfOpen", RootContext.RootId);
                if (stuck)
                {
                    return;
                }
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex;
            }
        }

        var nextOpen = !currentlyOpen;

        if (nextOpen)
        {
            RootContext.SetInteractionType?.Invoke(InteractionTypeDetector.FromPointerEvent(e));
        }

        openedByPointerDown = nextOpen;

        await RootContext.SetOpenAsync(nextOpen, MenuOpenChangeReason.TriggerPress, null);

        state = new MenuTriggerState(IsOpenedByThisTrigger(), state.Disabled);
        BuildComponentAttributes();

        // Arm click-and-drag: after 200ms, mouseup on a menu item activates it.
        if (nextOpen)
        {
            try
            {
                var module = await ModuleTask.Value;
                await module.InvokeVoidAsync("armMouseUpTrigger", RootContext.RootId);
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex;
            }
        }
    }

    private async Task HandleClickAsync(MouseEventArgs e)
    {
        if (state.Disabled || RootContext is null)
        {
            await EventUtilities.InvokeOnClickAsync(AdditionalAttributes, e);
            return;
        }

        // Suppress the click that follows a pointerdown-triggered open/close.
        if (openedByPointerDown)
        {
            openedByPointerDown = false;
            await EventUtilities.InvokeOnClickAsync(AdditionalAttributes, e);
            return;
        }

        // Menubar close: when already open and pointerdown was skipped, close on click.
        if (IsInMenuBar && IsOpenedByThisTrigger())
        {
            await RootContext.SetOpenAsync(false, MenuOpenChangeReason.TriggerPress, null);

            state = new MenuTriggerState(IsOpenedByThisTrigger(), state.Disabled);
            BuildComponentAttributes();
        }

        lastPointerType = string.Empty;

        await EventUtilities.InvokeOnClickAsync(AdditionalAttributes, e);
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs e)
    {
        if (state.Disabled || RootContext is null)
        {
            return;
        }

        if (e.Key == "Enter" || e.Key == " ")
        {
            if (!IsOpenedByThisTrigger())
            {
                await RootContext.SetOpenAsync(true, MenuOpenChangeReason.TriggerPress, "keyboard");

                state = new MenuTriggerState(IsOpenedByThisTrigger(), state.Disabled);
                BuildComponentAttributes();
            }
        }
        else if (e.Key == "ArrowDown" || e.Key == "ArrowUp")
        {
            if (!IsOpenedByThisTrigger())
            {
                var highlightLast = e.Key == "ArrowUp";
                await RootContext.SetOpenAsync(true, MenuOpenChangeReason.TriggerPress, highlightLast ? "highlight-last" : "keyboard");

                state = new MenuTriggerState(IsOpenedByThisTrigger(), state.Disabled);
                BuildComponentAttributes();
            }
        }

        await EventUtilities.InvokeOnKeyDownAsync(AdditionalAttributes, e);
    }

    private async Task HandleMouseEnterAsync(MouseEventArgs e)
    {
        if (!state.Disabled && RootContext is not null && IsInMenuBar)
        {
            if (MenuBarContext!.GetHasSubmenuOpen() && !IsOpenedByThisTrigger())
            {
                await RootContext.SetOpenAsync(true, MenuOpenChangeReason.TriggerHover, null);

                state = new MenuTriggerState(IsOpenedByThisTrigger(), state.Disabled);
                BuildComponentAttributes();
            }
        }

        await EventUtilities.InvokeOnMouseEnterAsync(AdditionalAttributes, e);
    }

    private async Task HandleFocusAsync(FocusEventArgs e)
    {
        if (!state.Disabled && RootContext is not null && IsInMenuBar)
        {
            if (MenuBarContext!.GetHasSubmenuOpen() && !IsOpenedByThisTrigger())
            {
                await RootContext.SetOpenAsync(true, MenuOpenChangeReason.TriggerFocus, null);

                state = new MenuTriggerState(IsOpenedByThisTrigger(), state.Disabled);
                BuildComponentAttributes();
            }
        }

        await EventUtilities.InvokeOnFocusAsync(AdditionalAttributes, e);
    }

    private async Task InitializeHoverInteractionAsync()
    {
        if (RootContext is null || !Element.HasValue)
        {
            return;
        }

        try
        {
            var module = await ModuleTask.Value;
            var effectiveCloseDelay = CloseDelay > 0 ? CloseDelay : Delay;
            await module.InvokeVoidAsync("initializeHoverInteraction", RootContext.RootId, Element.Value, Delay, effectiveCloseDelay);
            hoverInitialized = true;
            hoverRootId = RootContext.RootId;
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }
}
