@using BlazorBaseUI.Utilities
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop

@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<RenderElement TState="MenuSubmenuTriggerState"
               Tag="div"
               State="state"
               Enabled="RootContext is not null"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="ChildContent"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private Lazy<Task<IJSObjectReference>>? moduleTask;
    private bool hasRendered;
    private bool hoverInitialized;
    private string? hoverRootId;
    private int itemIndex = -1;
    private string triggerId = null!;
    private MenuSubmenuTriggerState state;
    private RenderElement<MenuSubmenuTriggerState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();

    private Lazy<Task<IJSObjectReference>> ModuleTask => moduleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>(
            "import", "./_content/BlazorBaseUI/blazor-baseui-menu.js").AsTask());

    [CascadingParameter]
    private MenuRootContext? RootContext { get; set; }

    [CascadingParameter]
    private MenuSubmenuRootContext? SubmenuContext { get; set; }

    /// <summary>
    /// Determines whether the component should ignore user interaction.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Determines whether the submenu should also open when the trigger is hovered.
    /// Defaults to <see langword="true"/>.
    /// </summary>
    [Parameter]
    public bool OpenOnHover { get; set; } = true;

    /// <summary>
    /// Gets or sets the delay in milliseconds before the submenu may be opened on hover.
    /// Requires the <see cref="OpenOnHover"/> property.
    /// </summary>
    [Parameter]
    public int Delay { get; set; } = 100;

    /// <summary>
    /// Gets or sets the delay in milliseconds before closing the submenu that was opened on hover.
    /// Requires the <see cref="OpenOnHover"/> property.
    /// When <see langword="null"/>, falls back to the <see cref="Delay"/> value.
    /// </summary>
    [Parameter]
    public int CloseDelay { get; set; }

    /// <summary>
    /// Gets or sets the id attribute of the submenu trigger element.
    /// </summary>
    [Parameter]
    public string? Id { get; set; }

    /// <summary>
    /// Gets or sets the text label to use when the item is matched during keyboard text navigation.
    /// </summary>
    [Parameter]
    public string? Label { get; set; }

    /// <summary>
    /// Allows you to replace the component's HTML element
    /// with a different tag, or compose it with another component.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<MenuSubmenuTriggerState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on the component state.
    /// </summary>
    [Parameter]
    public Func<MenuSubmenuTriggerState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on the component state.
    /// </summary>
    [Parameter]
    public Func<MenuSubmenuTriggerState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        if (SubmenuContext is null)
        {
            throw new InvalidOperationException("MenuSubmenuTrigger must be placed inside a MenuSubmenuRoot.");
        }

        triggerId = Id ?? Guid.NewGuid().ToIdString();
        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        var open = RootContext?.GetOpen() ?? false;
        var highlighted = GetHighlighted();
        var disabled = Disabled || (RootContext?.Disabled ?? false);

        state = new MenuSubmenuTriggerState(
            Disabled: disabled,
            Highlighted: highlighted,
            Open: open);

        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            hasRendered = true;
            RootContext?.SetTriggerElement(Element);

            if (SubmenuContext?.ParentMenu?.RootId is not null && Element.HasValue)
            {
                _ = UpdateItemIndexAsync();
            }

            if (OpenOnHover && !hoverInitialized)
            {
                _ = InitializeHoverInteractionAsync();
            }
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        if (moduleTask?.IsValueCreated == true && hasRendered && hoverInitialized && hoverRootId is not null)
        {
            try
            {
                var module = await ModuleTask.Value;
                await module.InvokeVoidAsync("disposeHoverInteraction", hoverRootId);
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();

        attrs["role"] = "menuitem";
        attrs["id"] = triggerId;
        attrs["aria-haspopup"] = "menu";
        attrs["aria-expanded"] = state.Open ? "true" : "false";

        var popupId = RootContext?.PopupId;
        if (state.Open && !string.IsNullOrEmpty(popupId))
        {
            attrs["aria-controls"] = popupId;
        }

        attrs["onpointerdown"] = EventCallback.Factory.Create<PointerEventArgs>(this, HandlePointerDownAsync);
        attrs["onclick"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleClickAsync);
        attrs["onmouseenter"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleMouseEnterAsync);
        attrs["onfocusout"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleFocusOutAsync);

        if (state.Disabled)
        {
            attrs["aria-disabled"] = "true";
        }

        attrs["tabindex"] = state.Open || state.Highlighted ? 0 : -1;

        if (state.Open)
        {
            attrs["data-popup-open"] = true;
        }

        attrs["data-disabled"] = state.Disabled;
        attrs["data-highlighted"] = state.Highlighted;

        if (!string.IsNullOrEmpty(Label))
        {
            attrs["data-label"] = Label;
        }

        componentAttributes = attrs;
    }

    private bool GetHighlighted()
    {
        if (itemIndex < 0 || SubmenuContext?.ParentMenu is null)
        {
            return false;
        }

        return SubmenuContext.ParentMenu.ActiveIndex == itemIndex;
    }

    private Task HandleMouseEnterAsync(MouseEventArgs e)
    {
        if (itemIndex >= 0 && SubmenuContext?.ParentMenu is not null)
        {
            SubmenuContext.ParentMenu.ActiveIndex = itemIndex;
            state = new MenuSubmenuTriggerState(state.Disabled, Highlighted: true, state.Open);
            BuildComponentAttributes();
            StateHasChanged();
        }

        return Task.CompletedTask;
    }

    private Task HandleFocusOutAsync(FocusEventArgs e)
    {
        if (GetHighlighted() && SubmenuContext?.ParentMenu is not null)
        {
            SubmenuContext.ParentMenu.ActiveIndex = null;
        }

        return Task.CompletedTask;
    }

    private async Task UpdateItemIndexAsync()
    {
        try
        {
            var module = await ModuleTask.Value;
            itemIndex = await module.InvokeAsync<int>("getItemIndex",
                SubmenuContext!.ParentMenu!.RootId, Element!.Value);
            StateHasChanged();
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex;
        }
    }

    private async Task HandlePointerDownAsync(PointerEventArgs e)
    {
        if (!OpenOnHover && !state.Disabled && RootContext is not null)
        {
            var nextOpen = !RootContext.GetOpen();
            await RootContext.SetOpenAsync(nextOpen, MenuOpenChangeReason.TriggerPress, null);
            state = new MenuSubmenuTriggerState(state.Disabled, state.Highlighted, nextOpen);
            BuildComponentAttributes();
        }
    }

    private async Task HandleClickAsync(MouseEventArgs e)
    {
        if (state.Disabled || RootContext is null)
        {
            return;
        }

        await EventUtilities.InvokeOnClickAsync(AdditionalAttributes, e);
    }

    private async Task InitializeHoverInteractionAsync()
    {
        if (RootContext is null || !Element.HasValue)
        {
            return;
        }

        try
        {
            var module = await ModuleTask.Value;
            var effectiveCloseDelay = CloseDelay;
            await module.InvokeVoidAsync("initializeHoverInteraction", RootContext.RootId, Element.Value, Delay, effectiveCloseDelay);
            hoverInitialized = true;
            hoverRootId = RootContext.RootId;
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }
}
