@implements IDisposable

<RenderElement TState="MenuGroupLabelState"
               Tag="div"
               State="CachedState"
               Render="Render"
               ClassValue="ClassValue"
               StyleValue="StyleValue"
               ComponentAttributes="componentAttributes"
               ChildContent="ChildContent"
               @attributes="AdditionalAttributes"
               @ref="renderElementReference" />

@code {
    private static readonly MenuGroupLabelState CachedState = new();

    private string? defaultId;
    private string? lastRegisteredId;
    private bool hasRegisteredId;
    private RenderElement<MenuGroupLabelState>? renderElementReference;
    private Dictionary<string, object> componentAttributes = new();

    private string ResolvedId => AttributeUtilities.GetIdOrDefault(
        AdditionalAttributes, () => defaultId ??= Guid.NewGuid().ToIdString());

    [CascadingParameter]
    private IMenuGroupContext? GroupContext { get; set; }

    /// <summary>
    /// Allows you to replace the component's HTML element
    /// with a different tag, or compose it with another component.
    /// </summary>
    [Parameter]
    public RenderFragment<RenderProps<MenuGroupLabelState>>? Render { get; set; }

    /// <summary>
    /// Gets or sets the CSS class function based on the component state.
    /// </summary>
    [Parameter]
    public Func<MenuGroupLabelState, string?>? ClassValue { get; set; }

    /// <summary>
    /// Gets or sets the inline style function based on the component state.
    /// </summary>
    [Parameter]
    public Func<MenuGroupLabelState, string?>? StyleValue { get; set; }

    /// <summary>
    /// Defines the child components of this instance.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Gets or sets a collection of additional attributes that will be applied to the created element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    /// <summary>
    /// Gets or sets the associated <see cref="ElementReference"/>.
    /// </summary>
    public ElementReference? Element => renderElementReference?.Element;

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        var currentId = ResolvedId;
        if (hasRegisteredId && currentId != lastRegisteredId)
        {
            lastRegisteredId = currentId;
            GroupContext?.SetLabelId(currentId);
        }

        BuildComponentAttributes();
    }

    /// <inheritdoc />
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && !hasRegisteredId)
        {
            lastRegisteredId = ResolvedId;
            GroupContext?.SetLabelId(lastRegisteredId);
            hasRegisteredId = true;
        }
    }

    /// <inheritdoc />
    public void Dispose()
    {
        if (hasRegisteredId)
        {
            GroupContext?.SetLabelId(null);
        }
    }

    private void BuildComponentAttributes()
    {
        var attrs = new Dictionary<string, object>();

        attrs["id"] = ResolvedId;
        attrs["role"] = "presentation";

        componentAttributes = attrs;
    }
}
