@using BlazorBaseUI.ContextMenu
@using BlazorBaseUI.DirectionProvider
@using BlazorBaseUI.MenuBar
@using BlazorBaseUI.Utilities
@using Microsoft.JSInterop

@implements IAsyncDisposable
@implements IMenuHandleSubscriber
@inject IJSRuntime JSRuntime

<CascadingValue TValue="IFloatingRootContext" Value="context.FloatingRootContext" IsFixed="true">
    <CascadingValue TValue="MenuRootContext" Value="context" IsFixed="true">
        @ChildContent!(new MenuRootPayloadContext(activePayload))
    </CascadingValue>
</CascadingValue>

@code {
    private readonly string rootId = Guid.NewGuid().ToIdString();

    private Lazy<Task<IJSObjectReference>>? moduleTask;
    private bool hasRendered;
    private bool isOpen;
    private bool isMounted;
    private int? activeIndex;
    private ElementReference? triggerElement;
    private ElementReference? positionerElement;
    private ElementReference? popupElement;
    private MenuOpenChangeReason openChangeReason = MenuOpenChangeReason.None;
    private TransitionStatus transitionStatus = TransitionStatus.Undefined;
    private MenuInstantType instantType = MenuInstantType.None;
    private bool preventUnmountOnClose;
    private bool hasViewport;
    private MenuRootState state;
    private MenuRootContext context = null!;
    private DotNetObjectReference<MenuRoot>? dotNetRef;
    private string? activeTriggerId;
    private object? activePayload;
    private MenuModalMode previousModal;
    private MenuOrientation previousOrientation;
    private bool previousLoopFocus;
    private bool previousHighlightItemOnHover;

    private Lazy<Task<IJSObjectReference>> ModuleTask => moduleTask ??= new Lazy<Task<IJSObjectReference>>(() =>
        JSRuntime.InvokeAsync<IJSObjectReference>(
            "import", "./_content/BlazorBaseUI/blazor-baseui-menu.js").AsTask());

    private bool IsControlled => Open.HasValue;

    private bool CurrentOpen => IsControlled ? Open!.Value : isOpen;

    private MenuParentType ParentType =>
        ParentMenuContext is not null ? MenuParentType.Menu :
        ContextMenuContext is not null ? MenuParentType.ContextMenu :
        MenuBarContext is not null ? MenuParentType.Menubar :
        MenuParentType.None;

    [CascadingParameter]
    private MenuRootContext? ParentMenuContext { get; set; }

    [CascadingParameter]
    private MenuBarRootContext? MenuBarContext { get; set; }

    [CascadingParameter]
    private ContextMenuRootContext? ContextMenuContext { get; set; }

    [CascadingParameter]
    private DirectionProviderContext? DirectionContext { get; set; }

    /// <summary>
    /// Gets or sets whether the menu is currently open.
    /// </summary>
    [Parameter]
    public bool? Open { get; set; }

    /// <summary>
    /// Determines whether the menu is initially open.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool DefaultOpen { get; set; }

    /// <summary>
    /// Gets or sets the modal behavior of the menu when open.
    /// When <see cref="MenuModalMode.True"/>, user interaction is limited to the menu: page scroll is locked and pointer interactions on outside elements are disabled.
    /// </summary>
    [Parameter]
    public MenuModalMode Modal { get; set; } = MenuModalMode.True;

    /// <summary>
    /// Determines whether keyboard focus loops back to the first item when the end of the list is reached while using the arrow keys.
    /// Defaults to <see langword="true"/>.
    /// </summary>
    [Parameter]
    public bool LoopFocus { get; set; } = true;

    /// <summary>
    /// Gets or sets the visual orientation of the menu.
    /// Controls whether roving focus uses up/down or left/right arrow keys.
    /// </summary>
    [Parameter]
    public MenuOrientation Orientation { get; set; } = MenuOrientation.Vertical;

    /// <summary>
    /// Determines whether moving the pointer over items highlights them.
    /// Defaults to <see langword="true"/>.
    /// </summary>
    [Parameter]
    public bool HighlightItemOnHover { get; set; } = true;

    /// <summary>
    /// Determines whether the component should ignore user interaction.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Determines whether pressing the Escape key closes the parent menu in a submenu context.
    /// Defaults to <see langword="false"/>.
    /// </summary>
    [Parameter]
    public bool CloseParentOnEsc { get; set; }

    /// <summary>
    /// Gets or sets the ID of the trigger element that the menu should be associated with.
    /// Used for detached trigger patterns where multiple triggers share one menu.
    /// </summary>
    [Parameter]
    public string? TriggerId { get; set; }

    /// <summary>
    /// Gets or sets the default trigger ID when using uncontrolled trigger selection.
    /// </summary>
    [Parameter]
    public string? DefaultTriggerId { get; set; }

    /// <summary>
    /// Gets or sets a handle to connect this root with detached trigger components.
    /// </summary>
    [Parameter]
    public IMenuHandle? Handle { get; set; }

    /// <summary>
    /// Gets or sets a reference to imperative actions for controlling the menu programmatically.
    /// </summary>
    [Parameter]
    public MenuRootActions? ActionsRef { get; set; }

    /// <summary>
    /// Gets or sets the callback for two-way binding of the open state.
    /// </summary>
    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the menu is opened or closed.
    /// </summary>
    [Parameter]
    public EventCallback<MenuOpenChangeEventArgs> OnOpenChange { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked after any open/close transition animations complete.
    /// </summary>
    [Parameter]
    public EventCallback<bool> OnOpenChangeComplete { get; set; }

    /// <summary>
    /// Defines the child components of this instance with access to the payload context.
    /// </summary>
    [Parameter]
    public RenderFragment<MenuRootPayloadContext>? ChildContent { get; set; }

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        isOpen = DefaultOpen;
        isMounted = CurrentOpen;
        state = new MenuRootState(CurrentOpen);
        var effectiveDirection = DirectionContext?.Direction ?? Direction.Ltr;

        context = new MenuRootContext
        {
            RootId = rootId,
            PopupId = $"{rootId}-popup",
            Open = CurrentOpen,
            Mounted = isMounted,
            Disabled = Disabled,
            ParentType = ParentType,
            Orientation = Orientation,
            HighlightItemOnHover = HighlightItemOnHover,
            MenuOpenChangeReason = openChangeReason,
            TransitionStatus = transitionStatus,
            MenuInstantType = instantType,
            ActiveIndex = activeIndex,
            GetOpen = () => CurrentOpen,
            GetMounted = () => isMounted,
            GetTriggerElement = () => triggerElement,
            SetTriggerElement = SetTriggerElement,
            SetPositionerElement = SetPositionerElement,
            SetPopupElement = SetPopupElement,
            SetActiveIndex = SetActiveIndex,
            SetOpenAsync = SetOpenAsyncFromContext,
            EmitClose = EmitClose,
            Direction = effectiveDirection.ToAttributeString() ?? "ltr",
            TriggerId = TriggerId ?? DefaultTriggerId,
            GetPopupElement = () => popupElement,
            SetHasViewport = value => { hasViewport = value; context.HasViewport = value; },
            SetMenuInstantType = SetMenuInstantTypeValue,
            SetInteractionType = type => context.InteractionType = type
        };

        context.FloatingRootContext = new MenuFloatingRootContextAdapter(context);

        previousModal = Modal;
        previousOrientation = Orientation;
        previousLoopFocus = LoopFocus;
        previousHighlightItemOnHover = HighlightItemOnHover;

        if (ActionsRef is not null)
        {
            ActionsRef.Unmount = ForceUnmount;
            ActionsRef.Close = () => _ = SetOpenWithExceptionHandlingAsync(false, MenuOpenChangeReason.ImperativeAction);
        }

        Handle?.Subscribe(this);
        Handle?.SetPopupId(context.PopupId);
    }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        var currentOpen = CurrentOpen;
        if (state.Open != currentOpen)
        {
            state = new MenuRootState(currentOpen);
            if (currentOpen)
            {
                isMounted = true;
            }
            context.Open = currentOpen;
            context.Mounted = isMounted;
        }

        context.Disabled = Disabled;
        context.TriggerId = TriggerId ?? DefaultTriggerId;
        context.Orientation = Orientation;
        context.HighlightItemOnHover = HighlightItemOnHover;

        if (hasRendered &&
            (Modal != previousModal ||
             Orientation != previousOrientation ||
             LoopFocus != previousLoopFocus ||
             HighlightItemOnHover != previousHighlightItemOnHover))
        {
            previousModal = Modal;
            previousOrientation = Orientation;
            previousLoopFocus = LoopFocus;
            previousHighlightItemOnHover = HighlightItemOnHover;
            _ = UpdateRootJsAsync();
        }

        if (ActionsRef is not null)
        {
            ActionsRef.Unmount = ForceUnmount;
            ActionsRef.Close = () => _ = SetOpenWithExceptionHandlingAsync(false, MenuOpenChangeReason.ImperativeAction);
        }
    }

    /// <inheritdoc />
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            hasRendered = true;
            dotNetRef = DotNetObjectReference.Create(this);
            _ = InitializeJsAsync();
        }
    }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        Handle?.Unsubscribe(this);

        if (moduleTask?.IsValueCreated == true && hasRendered)
        {
            try
            {
                var module = await ModuleTask.Value;
                await module.InvokeVoidAsync("disposeRoot", rootId);
                await module.DisposeAsync();
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }

        dotNetRef?.Dispose();
    }

    /// <summary>
    /// Invoked from JavaScript when a click occurs outside the menu.
    /// </summary>
    [JSInvokable]
    public async Task OnOutsidePress()
    {
        await SetOpenAsync(false, MenuOpenChangeReason.OutsidePress);
    }

    /// <summary>
    /// Invoked from JavaScript when the Escape key is pressed.
    /// </summary>
    [JSInvokable]
    public async Task OnEscapeKey()
    {
        await SetOpenAsync(false, MenuOpenChangeReason.EscapeKey);
    }

    /// <summary>
    /// Invoked from JavaScript after the starting transition style has been applied.
    /// </summary>
    [JSInvokable]
    public void OnStartingStyleApplied()
    {
        if (transitionStatus == TransitionStatus.Starting)
        {
            transitionStatus = TransitionStatus.Undefined;
            context.TransitionStatus = transitionStatus;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Invoked from JavaScript when a transition animation completes.
    /// </summary>
    [JSInvokable]
    public void OnTransitionEnd(bool open)
    {
        transitionStatus = TransitionStatus.Undefined;
        context.TransitionStatus = transitionStatus;

        if (!open && !preventUnmountOnClose)
        {
            isMounted = false;
            context.Mounted = false;
            activeIndex = null;
            context.ActiveIndex = activeIndex;
            activePayload = null;
        }

        preventUnmountOnClose = false;
        instantType = MenuInstantType.None;
        context.MenuInstantType = instantType;

        _ = InvokeOpenChangeCompleteAsync(open);
        StateHasChanged();
    }

    /// <summary>
    /// Invoked from JavaScript when the active item index changes.
    /// </summary>
    [JSInvokable]
    public void OnActiveIndexChange(int index)
    {
        if (activeIndex != index)
        {
            activeIndex = index;
            context.ActiveIndex = index;
        }
    }

    /// <summary>
    /// Invoked from JavaScript when the trigger is hovered to open the menu.
    /// </summary>
    [JSInvokable]
    public async Task OnHoverOpen()
    {
        if (MenuBarContext is not null && !MenuBarContext.GetHasSubmenuOpen())
        {
            return;
        }

        await SetOpenAsync(true, MenuOpenChangeReason.TriggerHover);
    }

    /// <summary>
    /// Invoked from JavaScript when hover ends to close the menu.
    /// </summary>
    [JSInvokable]
    public async Task OnHoverClose()
    {
        await SetOpenAsync(false, MenuOpenChangeReason.TriggerHover);
    }

    /// <summary>
    /// Sets the open state of the menu with the specified reason and optional payload.
    /// </summary>
    internal async Task SetOpenAsync(bool nextOpen, MenuOpenChangeReason reason, object? payload = null, string? triggerId = null)
    {
        if (CurrentOpen == nextOpen)
        {
            if (nextOpen && triggerId is not null && triggerId != activeTriggerId && hasViewport)
            {
                await HandleViewportTriggerSwapAsync(triggerId, payload);
            }

            return;
        }

        var args = new MenuOpenChangeEventArgs(nextOpen, reason, payload);
        await OnOpenChange.InvokeAsync(args);

        if (args.IsCanceled)
        {
            return;
        }

        if (!nextOpen && args.PreventUnmount)
        {
            preventUnmountOnClose = true;
        }

        openChangeReason = reason;
        context.MenuOpenChangeReason = reason;

        if (nextOpen)
        {
            if (ParentType == MenuParentType.Menubar &&
                (reason == MenuOpenChangeReason.TriggerFocus ||
                 reason == MenuOpenChangeReason.SiblingOpen ||
                 reason == MenuOpenChangeReason.FocusOut ||
                 reason == MenuOpenChangeReason.TriggerHover ||
                 reason == MenuOpenChangeReason.ListNavigation))
            {
                instantType = MenuInstantType.Group;
            }
            else if (reason == MenuOpenChangeReason.TriggerPress && payload is "keyboard")
            {
                instantType = MenuInstantType.Click;
            }
            else
            {
                instantType = MenuInstantType.None;
            }

            transitionStatus = TransitionStatus.Starting;
            isMounted = true;
            activeIndex = payload is "highlight-last" ? null : 0;
            activePayload = payload;

            if (triggerId is not null)
            {
                activeTriggerId = triggerId;
            }
        }
        else
        {
            var isKeyboardClose = (reason is MenuOpenChangeReason.TriggerPress
                or MenuOpenChangeReason.ClosePress
                or MenuOpenChangeReason.ItemPress)
                && payload is "keyboard";
            instantType = reason is MenuOpenChangeReason.EscapeKey
                ? MenuInstantType.Dismiss
                : isKeyboardClose
                    ? MenuInstantType.Click
                    : MenuInstantType.None;
            transitionStatus = TransitionStatus.Ending;
            context.InteractionType = null;
        }

        context.MenuInstantType = instantType;
        context.TransitionStatus = transitionStatus;
        context.Mounted = isMounted;
        context.ActiveIndex = activeIndex;

        if (!IsControlled)
        {
            isOpen = nextOpen;
        }

        state = new MenuRootState(nextOpen);
        context.Open = nextOpen;

        if (hasRendered)
        {
            try
            {
                var module = await ModuleTask.Value;
                var reasonString = reason switch
                {
                    MenuOpenChangeReason.TriggerHover => "trigger-hover",
                    MenuOpenChangeReason.EscapeKey => "escape-key",
                    MenuOpenChangeReason.ItemPress => "item-press",
                    MenuOpenChangeReason.OutsidePress => "outside-press",
                    MenuOpenChangeReason.ClosePress => "close-press",
                    _ => null
                };
                var highlightLast = payload is "highlight-last";
                await module.InvokeVoidAsync("setRootOpen", rootId, nextOpen, reasonString, highlightLast, context.InteractionType);
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }

        await OpenChanged.InvokeAsync(nextOpen);

        if (ParentType == MenuParentType.Menubar)
        {
            MenuBarContext?.SetHasSubmenuOpen(nextOpen, nextOpen ? context.InteractionType : null);
        }

        StateHasChanged();
    }

    private async Task InitializeJsAsync()
    {
        try
        {
            var module = await ModuleTask.Value;
            var isNested = ParentType != MenuParentType.None;
            var modal = !isNested && Modal == MenuModalMode.True;
            var menubarElement = ParentType == MenuParentType.Menubar ? MenuBarContext?.GetElement() : null;
            var orientationStr = Orientation == MenuOrientation.Horizontal ? "horizontal" : "vertical";
            var directionStr = (DirectionContext?.Direction ?? Direction.Ltr).ToAttributeString() ?? "ltr";
            var parentTypeStr = ParentType switch
            {
                MenuParentType.ContextMenu => "context-menu",
                MenuParentType.Menu => "menu",
                MenuParentType.Menubar => "menubar",
                _ => (string?)null
            };
            await module.InvokeVoidAsync("initializeRoot", rootId, dotNetRef, CloseParentOnEsc, LoopFocus, modal, menubarElement, orientationStr, HighlightItemOnHover, directionStr, isNested, context?.FinalFocusMode, context?.FinalFocusElement, parentTypeStr);

            if (triggerElement.HasValue)
            {
                await module.InvokeVoidAsync("setTriggerElement", rootId, triggerElement.Value);
            }

            if (positionerElement.HasValue)
            {
                await module.InvokeVoidAsync("setPositionerElement", rootId, positionerElement.Value);
            }

            if (popupElement.HasValue)
            {
                await module.InvokeVoidAsync("setPopupElement", rootId, popupElement.Value, context?.InsideToolbar ?? false);
            }

            if (CurrentOpen)
            {
                await module.InvokeVoidAsync("setRootOpen", rootId, true, (string?)null, false);
            }
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private void SetMenuInstantTypeValue(MenuInstantType type)
    {
        instantType = type;
        context.MenuInstantType = type;
    }

    private void SetTriggerElement(ElementReference? element)
    {
        triggerElement = element;

        if (hasRendered && element.HasValue)
        {
            _ = SetTriggerElementAsync(element.Value);
        }
    }

    private async Task SetTriggerElementAsync(ElementReference element)
    {
        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync("setTriggerElement", rootId, element);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private void SetPositionerElement(ElementReference? element)
    {
        positionerElement = element;

        if (hasRendered && element.HasValue)
        {
            _ = SetPositionerElementAsync(element.Value);
        }
    }

    private async Task SetPositionerElementAsync(ElementReference element)
    {
        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync("setPositionerElement", rootId, element);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private void SetPopupElement(ElementReference? element)
    {
        popupElement = element;

        if (hasRendered && element.HasValue)
        {
            _ = SetPopupElementAsync(element.Value);
        }
    }

    private ElementReference? GetTriggerElementById(string? triggerId)
    {
        if (triggerId is null)
        {
            return null;
        }

        return Handle?.GetTriggerElement(triggerId);
    }

    private async Task HandleViewportTriggerSwapAsync(string newTriggerId, object? payload)
    {
        var previousTriggerId = activeTriggerId;
        activeTriggerId = newTriggerId;

        var handlePayload = Handle?.GetTriggerPayloadAsObject(newTriggerId);
        if (handlePayload is not null)
        {
            activePayload = handlePayload;
        }
        else if (payload is not null)
        {
            activePayload = payload;
        }

        Handle?.SyncState(true, activeTriggerId, activePayload);

        instantType = MenuInstantType.None;
        context.MenuInstantType = instantType;

        if (hasRendered)
        {
            try
            {
                var module = await ModuleTask.Value;
                var prevTriggerElement = GetTriggerElementById(previousTriggerId);
                var newTriggerElement = GetTriggerElementById(newTriggerId);
                if (prevTriggerElement.HasValue && newTriggerElement.HasValue)
                {
                    await module.InvokeVoidAsync("onViewportTriggerChange", rootId,
                        prevTriggerElement.Value, newTriggerElement.Value);
                }
            }
            catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
            {
                _ = ex; // Expected during circuit disconnect - safe to ignore.
            }
        }

        StateHasChanged();
    }

    private async Task SetPopupElementAsync(ElementReference element)
    {
        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync("setPopupElement", rootId, element, context?.InsideToolbar ?? false);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private void SetActiveIndex(int? index)
    {
        if (activeIndex == index)
        {
            return;
        }

        activeIndex = index;
        context.ActiveIndex = index;

        if (hasRendered)
        {
            _ = SetActiveIndexAsync(index);
        }
    }

    private async Task SetActiveIndexAsync(int? index)
    {
        try
        {
            var module = await ModuleTask.Value;
            await module.InvokeVoidAsync("setActiveIndex", rootId, index);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private Task SetOpenAsyncFromContext(bool nextOpen, MenuOpenChangeReason reason, object? payload)
    {
        return SetOpenAsync(nextOpen, reason, payload);
    }

    private void EmitClose(MenuOpenChangeReason reason, object? payload)
    {
        _ = SetOpenAsync(false, reason, payload);
    }

    private void ForceUnmount()
    {
        isMounted = false;
        context.Mounted = false;
        transitionStatus = TransitionStatus.Undefined;
        context.TransitionStatus = transitionStatus;
        activePayload = null;
        _ = InvokeOpenChangeCompleteAsync(false);
        StateHasChanged();
    }

    private async Task UpdateRootJsAsync()
    {
        try
        {
            var module = await ModuleTask.Value;
            var modal = ParentType == MenuParentType.None && Modal == MenuModalMode.True;
            var orientationStr = Orientation == MenuOrientation.Horizontal ? "horizontal" : "vertical";
            await module.InvokeVoidAsync("updateRoot", rootId, modal, orientationStr, LoopFocus, HighlightItemOnHover);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or TaskCanceledException)
        {
            _ = ex; // Expected during circuit disconnect - safe to ignore.
        }
    }

    private async Task SetOpenWithExceptionHandlingAsync(bool nextOpen, MenuOpenChangeReason reason)
    {
        try
        {
            await SetOpenAsync(nextOpen, reason);
        }
        catch (Exception ex)
        {
            await DispatchExceptionAsync(ex);
        }
    }

    private async Task InvokeOpenChangeCompleteAsync(bool open)
    {
        try
        {
            await OnOpenChangeComplete.InvokeAsync(open);
        }
        catch (Exception ex)
        {
            await DispatchExceptionAsync(ex);
        }
    }

    void IMenuHandleSubscriber.OnTriggerRegistered(string triggerId, ElementReference? element)
    {
        if (element.HasValue)
        {
            SetTriggerElement(element);
        }
    }

    void IMenuHandleSubscriber.OnTriggerUnregistered(string triggerId)
    {
    }

    void IMenuHandleSubscriber.OnTriggerElementUpdated(string triggerId, ElementReference? element)
    {
        if (element.HasValue)
        {
            SetTriggerElement(element);
        }
    }

    void IMenuHandleSubscriber.OnOpenChangeRequested(bool open, MenuOpenChangeReason reason, string? triggerId)
    {
        var payload = Handle?.GetTriggerPayloadAsObject(triggerId);
        _ = SetOpenAsync(open, reason, payload, triggerId);

        if (open && triggerId is not null)
        {
            var element = Handle?.GetTriggerElement(triggerId);
            if (element.HasValue)
            {
                SetTriggerElement(element);
            }
        }

        Handle?.SyncState(CurrentOpen, triggerId, payload);
    }

    void IMenuHandleSubscriber.OnStateChanged()
    {
        StateHasChanged();
    }
}
