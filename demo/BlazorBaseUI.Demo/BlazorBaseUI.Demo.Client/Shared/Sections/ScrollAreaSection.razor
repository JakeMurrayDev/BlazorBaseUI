@using BlazorBaseUI.ScrollArea
@using BlazorBaseUI.Tabs

<ComponentShowcase ComponentName="Scroll Area"
                   Description="A native scroll container with custom scrollbars."
                   BaseRoute="/scroll-area"
                   IsWasmMode="IsWasmMode">
    <style>
        .scroll-area-demo-stack {
            display: grid;
            width: 100%;
            gap: 12px;
            justify-items: center;
        }

        .scroll-area-demo-root {
            position: relative;
            overflow: hidden;
            width: min(100%, 24rem);
            height: 12rem;
            --scroll-area-demo-scrollbar-bg: color-mix(in srgb, var(--demo-text) 16%, transparent);
            border: 1px solid var(--demo-stroke);
            border-radius: var(--demo-radius-large);
            background: var(--demo-surface);
            box-shadow: var(--demo-shadow-2);
            color: var(--demo-text);
        }

        .scroll-area-demo-root--article {
            height: 8.5rem;
        }

        .scroll-area-demo-root--grid {
            width: min(100%, 20rem);
            height: 20rem;
        }

        .scroll-area-demo-root--fade {
            height: 12rem;
            background: var(--demo-surface-layer);
        }

        .scroll-area-demo-root--tabs {
            width: min(100%, 28rem);
            height: auto;
            overflow: visible;
            border: 0;
            background: transparent;
            box-shadow: none;
        }

        .scroll-area-demo-viewport {
            width: 100%;
            height: 100%;
            outline: none;
        }

        .scroll-area-demo-viewport:focus-visible {
            outline: 2px solid var(--demo-focus);
            outline-offset: -2px;
        }

        .scroll-area-demo-viewport--fade {
            --scroll-area-demo-fade-size: 40px;
            mask-image: linear-gradient(
                to bottom,
                transparent 0,
                black min(var(--scroll-area-demo-fade-size), var(--scroll-area-overflow-y-start, 0px)),
                black calc(100% - min(var(--scroll-area-demo-fade-size), var(--scroll-area-overflow-y-end, 0px))),
                transparent 100%);
            mask-repeat: no-repeat;
        }

        .scroll-area-demo-copy {
            display: grid;
            gap: 14px;
            padding: 14px 32px 14px 16px;
            color: var(--demo-text);
            font-size: 14px;
            line-height: 20px;
        }

        .scroll-area-demo-copy p {
            margin: 0;
        }

        .scroll-area-demo-content--grid {
            width: 48rem;
            min-height: 48rem;
            padding: 16px;
        }

        .scroll-area-demo-content--keep-mounted {
            width: 42rem;
            min-height: 32rem;
            padding: 16px;
        }

        .scroll-area-demo-grid {
            display: grid;
            grid-template-columns: repeat(6, 6.5rem);
            gap: 12px;
        }

        .scroll-area-demo-grid--dense {
            grid-template-columns: repeat(5, 6.25rem);
        }

        .scroll-area-demo-item {
            display: grid;
            min-height: 64px;
            place-items: center;
            border: 1px solid var(--demo-stroke);
            border-radius: var(--demo-radius-medium);
            background: var(--demo-surface-layer);
            color: var(--demo-text);
            font-size: 14px;
            font-weight: 500;
            box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--demo-surface) 70%, transparent);
        }

        .scroll-area-demo-scrollbar {
            display: flex;
            justify-content: flex-start;
            border-radius: 999px;
            background: var(--scroll-area-demo-scrollbar-bg);
            opacity: 0;
            transition: opacity var(--demo-motion), background-color var(--demo-motion);
        }

        .scroll-area-demo-root:hover .scroll-area-demo-scrollbar,
        .scroll-area-demo-scrollbar[data-hovering],
        .scroll-area-demo-scrollbar[data-scrolling],
        .scroll-area-demo-scrollbar--visible {
            opacity: 1;
        }

        .scroll-area-demo-scrollbar[data-orientation='vertical'] {
            flex-direction: column;
            align-items: stretch;
            width: 14px;
            padding-block: 2px;
            padding-inline: 3px;
        }

        .scroll-area-demo-scrollbar[data-orientation='horizontal'] {
            flex-direction: row;
            align-items: stretch;
            height: 14px;
            padding-block: 3px;
            padding-inline: 2px;
        }

        .scroll-area-demo-thumb {
            border-radius: 999px;
            background: var(--demo-brand);
            box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--demo-surface) 34%, transparent);
        }

        .scroll-area-demo-thumb:hover,
        .scroll-area-demo-thumb[data-dragging] {
            background: var(--demo-brand-hover);
        }

        .scroll-area-demo-thumb[data-orientation='vertical'] {
            width: 100%;
        }

        .scroll-area-demo-thumb[data-orientation='horizontal'] {
            height: 100%;
        }

        .scroll-area-demo-corner {
            border-end-end-radius: var(--demo-radius-large);
            background: var(--scroll-area-demo-scrollbar-bg);
        }

        .scroll-area-tabs-shell {
            display: grid;
            gap: 12px;
            width: min(100%, 28rem);
        }

        .scroll-area-tabs-strip {
            position: relative;
            overflow: hidden;
            height: 52px;
            --scroll-area-demo-scrollbar-bg: color-mix(in srgb, var(--demo-text) 16%, transparent);
            border: 1px solid var(--demo-stroke);
            border-radius: var(--demo-radius-large);
            background: var(--demo-surface);
            box-shadow: var(--demo-shadow-2);
        }

        .scroll-area-tabs-viewport {
            height: 100%;
            --scroll-area-demo-fade-size: 36px;
            mask-image: linear-gradient(
                to right,
                transparent 0,
                black min(var(--scroll-area-demo-fade-size), var(--scroll-area-overflow-x-start, 0px)),
                black calc(100% - min(var(--scroll-area-demo-fade-size), var(--scroll-area-overflow-x-end, 0px))),
                transparent 100%);
            mask-repeat: no-repeat;
        }

        .scroll-area-tabs-content {
            width: max-content;
            min-width: 100%;
            padding: 6px 18px 14px 6px;
        }

        .scroll-area-tabs-list {
            position: relative;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .scroll-area-tabs-tab {
            min-width: max-content;
            height: 32px;
            border: 0;
            border-radius: var(--demo-radius-medium);
            background: transparent;
            padding: 0 12px;
            color: var(--demo-text-muted);
            font: inherit;
            font-weight: 600;
            cursor: pointer;
        }

        .scroll-area-tabs-tab:hover {
            background: var(--demo-control-bg-hover);
            color: var(--demo-text);
        }

        .scroll-area-tabs-tab[data-active] {
            background: var(--demo-accent-subtle);
            color: var(--demo-brand);
        }

        .scroll-area-tabs-indicator {
            position: absolute;
            bottom: -4px;
            height: 2px;
            border-radius: 999px;
            background: var(--demo-brand);
            translate: var(--active-tab-left, 0) 0;
            width: var(--active-tab-width, 0);
            transition: translate var(--demo-motion), width var(--demo-motion);
        }

        .scroll-area-tabs-panel {
            min-height: 96px;
            border: 1px solid var(--demo-stroke);
            border-radius: var(--demo-radius-large);
            background: var(--demo-surface);
            padding: 16px;
            box-shadow: var(--demo-shadow-2);
            color: var(--demo-text);
        }
    </style>

    <DemoSection Title="Basic Usage"
                 Description="The vertical article sample from the Base UI Scroll Area documentation.">
        <div class="scroll-area-demo-stack">
            <ScrollAreaRoot class="scroll-area-demo-root scroll-area-demo-root--article">
                <ScrollAreaViewport class="scroll-area-demo-viewport">
                    <ScrollAreaContent class="scroll-area-demo-copy">
                        @foreach (var paragraph in ArticleParagraphs)
                        {
                            <p>@paragraph</p>
                        }
                    </ScrollAreaContent>
                </ScrollAreaViewport>
                <ScrollAreaScrollbar class="scroll-area-demo-scrollbar scroll-area-demo-scrollbar--visible">
                    <ScrollAreaThumb class="scroll-area-demo-thumb" />
                </ScrollAreaScrollbar>
            </ScrollAreaRoot>
        </div>
    </DemoSection>

    <DemoSection Title="Both Scrollbars"
                 Description="The two-axis documentation sample with visible vertical and horizontal tracks.">
        <ScrollAreaRoot OverflowEdgeThreshold="@EdgeThreshold"
                        class="scroll-area-demo-root scroll-area-demo-root--grid">
            <ScrollAreaViewport class="scroll-area-demo-viewport">
                <ScrollAreaContent class="scroll-area-demo-content--grid">
                    <div class="scroll-area-demo-grid">
                        @for (var i = 1; i <= 60; i++)
                        {
                            <div class="scroll-area-demo-item">Item @i</div>
                        }
                    </div>
                </ScrollAreaContent>
            </ScrollAreaViewport>
            <ScrollAreaScrollbar class="scroll-area-demo-scrollbar scroll-area-demo-scrollbar--visible">
                <ScrollAreaThumb class="scroll-area-demo-thumb" />
            </ScrollAreaScrollbar>
            <ScrollAreaScrollbar Orientation="Orientation.Horizontal"
                                 class="scroll-area-demo-scrollbar scroll-area-demo-scrollbar--visible">
                <ScrollAreaThumb class="scroll-area-demo-thumb" />
            </ScrollAreaScrollbar>
            <ScrollAreaCorner class="scroll-area-demo-corner" />
        </ScrollAreaRoot>
    </DemoSection>

    <DemoSection Title="Gradient Scroll Fade"
                 Description="The overflow-edge CSS variables drive the fade at the top and bottom edges.">
        <ScrollAreaRoot OverflowEdgeThreshold="@EdgeThreshold"
                        class="scroll-area-demo-root scroll-area-demo-root--fade">
            <ScrollAreaViewport class="scroll-area-demo-viewport scroll-area-demo-viewport--fade">
                <ScrollAreaContent class="scroll-area-demo-copy">
                    @foreach (var paragraph in ArticleParagraphs)
                    {
                        <p>@paragraph</p>
                    }
                </ScrollAreaContent>
            </ScrollAreaViewport>
            <ScrollAreaScrollbar class="scroll-area-demo-scrollbar scroll-area-demo-scrollbar--visible">
                <ScrollAreaThumb class="scroll-area-demo-thumb" />
            </ScrollAreaScrollbar>
        </ScrollAreaRoot>
    </DemoSection>

    <DemoSection Title="Combining With Tabs"
                 Description="The tab list is placed inside a horizontal ScrollArea and uses overflow variables for edge fading.">
        <TabsRoot TValue="string"
                  DefaultValue="@TabItems[0].Value"
                  class="scroll-area-tabs-shell">
            <ScrollAreaRoot class="scroll-area-tabs-strip">
                <ScrollAreaViewport class="scroll-area-demo-viewport scroll-area-tabs-viewport">
                    <ScrollAreaContent class="scroll-area-tabs-content">
                        <TabsList TValue="string"
                                  ActivateOnFocus="true"
                                  class="scroll-area-tabs-list">
                            @foreach (var tab in TabItems)
                            {
                                <TabsTab TValue="string"
                                         Value="@tab.Value"
                                         ClassValue="GetTabClass">
                                    @tab.Label
                                </TabsTab>
                            }
                            <TabsIndicator TValue="string"
                                           class="scroll-area-tabs-indicator" />
                        </TabsList>
                    </ScrollAreaContent>
                </ScrollAreaViewport>
                <ScrollAreaScrollbar Orientation="Orientation.Horizontal"
                                     class="scroll-area-demo-scrollbar scroll-area-demo-scrollbar--visible">
                    <ScrollAreaThumb class="scroll-area-demo-thumb" />
                </ScrollAreaScrollbar>
            </ScrollAreaRoot>
            @foreach (var tab in TabItems)
            {
                <TabsPanel TValue="string"
                           Value="@tab.Value"
                           KeepMounted="true"
                           class="scroll-area-tabs-panel">
                    @tab.Panel
                </TabsPanel>
            }
        </TabsRoot>
    </DemoSection>

    <DemoSection Title="Keep Mounted"
                 Description="Mounted tracks remain interactive while the viewport still scrolls in both directions.">
        <ScrollAreaRoot OverflowEdgeThreshold="@EdgeThreshold"
                        class="scroll-area-demo-root scroll-area-demo-root--grid">
            <ScrollAreaViewport class="scroll-area-demo-viewport">
                <ScrollAreaContent class="scroll-area-demo-content--keep-mounted">
                    <div class="scroll-area-demo-grid scroll-area-demo-grid--dense">
                        @for (var i = 1; i <= 40; i++)
                        {
                            <div class="scroll-area-demo-item">Card @i</div>
                        }
                    </div>
                </ScrollAreaContent>
            </ScrollAreaViewport>
            <ScrollAreaScrollbar KeepMounted="true"
                                 class="scroll-area-demo-scrollbar scroll-area-demo-scrollbar--visible">
                <ScrollAreaThumb class="scroll-area-demo-thumb" />
            </ScrollAreaScrollbar>
            <ScrollAreaScrollbar Orientation="Orientation.Horizontal"
                                 KeepMounted="true"
                                 class="scroll-area-demo-scrollbar scroll-area-demo-scrollbar--visible">
                <ScrollAreaThumb class="scroll-area-demo-thumb" />
            </ScrollAreaScrollbar>
            <ScrollAreaCorner class="scroll-area-demo-corner" />
        </ScrollAreaRoot>
    </DemoSection>
</ComponentShowcase>

@code {
    private static readonly string[] ArticleParagraphs =
    {
        "Scroll Area keeps the browser's native scroll behavior while exposing unstyled slots for the track, thumb, viewport, and corner.",
        "The viewport remains keyboard focusable when content overflows, so pointer users and keyboard users operate the same scroll container.",
        "Overflow edge variables are written to the root, viewport, and content. They let styles react to whether the user can scroll farther.",
        "The component supports vertical, horizontal, and two-axis layouts without changing the structure of the content inside the viewport."
    };

    private static readonly (string Value, string Label, string Panel)[] TabItems =
    {
        ("overview", "Overview", "A compact overview panel remains linked to the selected tab while the list scrolls horizontally."),
        ("accessibility", "Accessibility", "Tabs keep their native roles and keyboard model while Scroll Area owns only the overflow surface."),
        ("performance", "Performance", "DOM measurement stays in JavaScript and C# receives only the state required for rendering."),
        ("tokens", "Design Tokens", "The sample consumes the same Fluent 2 tokens used by the rest of the demo application."),
        ("interop", "Interop", "Track clicks, drag state, hover state, and overflow edges are coordinated by the component-specific module."),
        ("validation", "Validation", "The Playwright suite exercises active scrollbars, mounted scrollbars, focus, drag, and RTL behavior.")
    };

    private static ScrollAreaOverflowEdgeThreshold EdgeThreshold => ScrollAreaOverflowEdgeThreshold.All(8);

    [Parameter]
    public bool IsWasmMode { get; set; }

    private static string GetTabClass(TabsTabState state)
    {
        return "scroll-area-tabs-tab";
    }
}
