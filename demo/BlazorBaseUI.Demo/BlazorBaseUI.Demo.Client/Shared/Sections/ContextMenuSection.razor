@using BlazorBaseUI.ContextMenu
@using BlazorBaseUI.Menu

<ComponentShowcase ComponentName="Context Menu"
                   Description="A popup menu activated by right-clicking or long pressing an area. Supports all Menu sub-components including submenus, checkbox items, radio groups, groups, and separators."
                   BaseRoute="/context-menu"
                   IsWasmMode="IsWasmMode">

    <DemoSection Title="Basic Context Menu"
                 Description="Right-click (or long press on touch) the shaded area to open the context menu.">
        <ContextMenuRoot>
            <ContextMenuTrigger ClassValue="@(_ => TriggerAreaClass())">
                Right-click here
            </ContextMenuTrigger>
            <ContextMenuPositioner SideOffset="4">
                <ContextMenuPopup ClassValue="@(_ => PopupClass())">
                    <ContextMenuItem ClassValue="@(_ => ItemClass())">Cut</ContextMenuItem>
                    <ContextMenuItem ClassValue="@(_ => ItemClass())">Copy</ContextMenuItem>
                    <ContextMenuItem ClassValue="@(_ => ItemClass())">Paste</ContextMenuItem>
                    <ContextMenuSeparator ClassValue="@(_ => SeparatorClass())" />
                    <ContextMenuItem ClassValue="@(_ => ItemClass())">Select All</ContextMenuItem>
                </ContextMenuPopup>
            </ContextMenuPositioner>
        </ContextMenuRoot>
    </DemoSection>

    <DemoSection Title="Nested Submenu"
                 Description="Context menu with a submenu that opens on hover or arrow key navigation.">
        <ContextMenuRoot>
            <ContextMenuTrigger ClassValue="@(_ => TriggerAreaClass())">
                Right-click for file options
            </ContextMenuTrigger>
            <ContextMenuPositioner SideOffset="4">
                <ContextMenuPopup ClassValue="@(_ => PopupClass())">
                    <ContextMenuItem ClassValue="@(_ => ItemClass())">New File</ContextMenuItem>
                    <ContextMenuItem ClassValue="@(_ => ItemClass())">Open...</ContextMenuItem>
                    <ContextMenuSubmenuRoot>
                        <ContextMenuSubmenuTrigger ClassValue="@(_ => SubmenuTriggerClass())">
                            <span>Open Recent</span>
                            @ChevronRightIcon
                        </ContextMenuSubmenuTrigger>
                        <ContextMenuPositioner SideOffset="0" AlignOffset="-4">
                            <ContextMenuPopup ClassValue="@(_ => PopupClass())">
                                <ContextMenuItem ClassValue="@(_ => ItemClass())">Document 1.txt</ContextMenuItem>
                                <ContextMenuItem ClassValue="@(_ => ItemClass())">Document 2.txt</ContextMenuItem>
                                <ContextMenuItem ClassValue="@(_ => ItemClass())">Document 3.txt</ContextMenuItem>
                            </ContextMenuPopup>
                        </ContextMenuPositioner>
                    </ContextMenuSubmenuRoot>
                    <ContextMenuSeparator ClassValue="@(_ => SeparatorClass())" />
                    <ContextMenuItem ClassValue="@(_ => ItemClass())">Save</ContextMenuItem>
                    <ContextMenuItem ClassValue="@(_ => ItemClass())">Save As...</ContextMenuItem>
                </ContextMenuPopup>
            </ContextMenuPositioner>
        </ContextMenuRoot>
    </DemoSection>

    <DemoSection Title="Checkbox and Radio Items"
                 Description="Context menu with checkbox items for toggling options and radio items for single selection.">
        <div class="flex flex-col gap-4">
            <ContextMenuRoot>
                <ContextMenuTrigger ClassValue="@(_ => TriggerAreaClass())">
                    Right-click for view options
                </ContextMenuTrigger>
                <ContextMenuPositioner SideOffset="4">
                    <ContextMenuPopup ClassValue="@(_ => PopupClass())">
                        <ContextMenuCheckboxItem ClassValue="@(_ => CheckboxItemClass())" Checked="@showToolbar" OnCheckedChange="@(e => showToolbar = e.Checked)">
                            <ContextMenuCheckboxItemIndicator ClassValue="@(_ => IndicatorClass())">
                                @CheckIcon
                            </ContextMenuCheckboxItemIndicator>
                            <span>Show Toolbar</span>
                        </ContextMenuCheckboxItem>
                        <ContextMenuCheckboxItem ClassValue="@(_ => CheckboxItemClass())" Checked="@showSidebar" OnCheckedChange="@(e => showSidebar = e.Checked)">
                            <ContextMenuCheckboxItemIndicator ClassValue="@(_ => IndicatorClass())">
                                @CheckIcon
                            </ContextMenuCheckboxItemIndicator>
                            <span>Show Sidebar</span>
                        </ContextMenuCheckboxItem>
                        <ContextMenuSeparator ClassValue="@(_ => SeparatorClass())" />
                        <ContextMenuRadioGroup Value="@selectedTheme" OnValueChange="HandleThemeChange">
                            <ContextMenuGroupLabel ClassValue="@(_ => GroupLabelClass())">Theme</ContextMenuGroupLabel>
                            <ContextMenuRadioItem ClassValue="@(_ => RadioItemClass())" Value="@("light")">
                                <ContextMenuRadioItemIndicator ClassValue="@(_ => IndicatorClass())">
                                    @DotIcon
                                </ContextMenuRadioItemIndicator>
                                <span>Light</span>
                            </ContextMenuRadioItem>
                            <ContextMenuRadioItem ClassValue="@(_ => RadioItemClass())" Value="@("dark")">
                                <ContextMenuRadioItemIndicator ClassValue="@(_ => IndicatorClass())">
                                    @DotIcon
                                </ContextMenuRadioItemIndicator>
                                <span>Dark</span>
                            </ContextMenuRadioItem>
                            <ContextMenuRadioItem ClassValue="@(_ => RadioItemClass())" Value="@("system")">
                                <ContextMenuRadioItemIndicator ClassValue="@(_ => IndicatorClass())">
                                    @DotIcon
                                </ContextMenuRadioItemIndicator>
                                <span>System</span>
                            </ContextMenuRadioItem>
                        </ContextMenuRadioGroup>
                    </ContextMenuPopup>
                </ContextMenuPositioner>
            </ContextMenuRoot>
            <div class="text-sm text-gray-600">
                <p>Current state:</p>
                <ul class="mt-1 list-inside list-disc">
                    <li>Toolbar: <strong>@(showToolbar ? "visible" : "hidden")</strong></li>
                    <li>Sidebar: <strong>@(showSidebar ? "visible" : "hidden")</strong></li>
                    <li>Theme: <strong>@selectedTheme</strong></li>
                </ul>
            </div>
        </div>
    </DemoSection>

    <DemoSection Title="Groups and Separators"
                 Description="Organize context menu items into groups with labels and visual separators.">
        <ContextMenuRoot>
            <ContextMenuTrigger ClassValue="@(_ => TriggerAreaClass())">
                Right-click for organized menu
            </ContextMenuTrigger>
            <ContextMenuPositioner SideOffset="4">
                <ContextMenuPopup ClassValue="@(_ => PopupClass())">
                    <ContextMenuGroup ClassValue="@(_ => "")">
                        <ContextMenuGroupLabel ClassValue="@(_ => GroupLabelClass())">
                            File
                        </ContextMenuGroupLabel>
                        <ContextMenuItem ClassValue="@(_ => ItemClass())">New</ContextMenuItem>
                        <ContextMenuItem ClassValue="@(_ => ItemClass())">Open</ContextMenuItem>
                        <ContextMenuItem ClassValue="@(_ => ItemClass())">Save</ContextMenuItem>
                    </ContextMenuGroup>
                    <ContextMenuSeparator ClassValue="@(_ => SeparatorClass())" />
                    <ContextMenuGroup ClassValue="@(_ => "")">
                        <ContextMenuGroupLabel ClassValue="@(_ => GroupLabelClass())">
                            Edit
                        </ContextMenuGroupLabel>
                        <ContextMenuItem ClassValue="@(_ => ItemClass())">Undo</ContextMenuItem>
                        <ContextMenuItem ClassValue="@(_ => ItemClass())">Redo</ContextMenuItem>
                        <ContextMenuItem ClassValue="@(_ => ItemClass())" Disabled="true">Cut (nothing selected)</ContextMenuItem>
                    </ContextMenuGroup>
                </ContextMenuPopup>
            </ContextMenuPositioner>
        </ContextMenuRoot>
    </DemoSection>

    <DemoSection Title="Nested Context Menus"
                 Description="Context menus can be nested. Right-clicking the inner area opens its own context menu; right-clicking the outer area opens the outer one.">
        <ContextMenuRoot>
            <ContextMenuTrigger ClassValue="@(_ => TriggerAreaClass() + " relative")">
                <span>Outer area - right-click here</span>
                <ContextMenuRoot>
                    <ContextMenuTrigger ClassValue="@(_ => "mt-3 flex h-24 items-center justify-center rounded-md border-2 border-dashed border-blue-300 bg-blue-50 text-sm text-blue-700")">
                        Inner area - right-click here
                    </ContextMenuTrigger>
                    <ContextMenuPositioner SideOffset="4">
                        <ContextMenuPopup ClassValue="@(_ => PopupClass())">
                            <ContextMenuItem ClassValue="@(_ => ItemClass())">Inner Action 1</ContextMenuItem>
                            <ContextMenuItem ClassValue="@(_ => ItemClass())">Inner Action 2</ContextMenuItem>
                        </ContextMenuPopup>
                    </ContextMenuPositioner>
                </ContextMenuRoot>
            </ContextMenuTrigger>
            <ContextMenuPositioner SideOffset="4">
                <ContextMenuPopup ClassValue="@(_ => PopupClass())">
                    <ContextMenuItem ClassValue="@(_ => ItemClass())">Outer Action 1</ContextMenuItem>
                    <ContextMenuItem ClassValue="@(_ => ItemClass())">Outer Action 2</ContextMenuItem>
                    <ContextMenuItem ClassValue="@(_ => ItemClass())">Outer Action 3</ContextMenuItem>
                </ContextMenuPopup>
            </ContextMenuPositioner>
        </ContextMenuRoot>
    </DemoSection>

    <DemoSection Title="Disabled State"
                 Description="When the context menu root is disabled, right-clicking shows no context menu.">
        <div class="flex gap-4">
            <ContextMenuRoot Disabled="true">
                <ContextMenuTrigger ClassValue="@(_ => "flex h-40 w-full items-center justify-center rounded-lg border-2 border-dashed border-gray-300 bg-gray-100 text-sm text-gray-400 cursor-not-allowed")">
                    Disabled - right-click does nothing
                </ContextMenuTrigger>
                <ContextMenuPositioner SideOffset="4">
                    <ContextMenuPopup ClassValue="@(_ => PopupClass())">
                        <ContextMenuItem ClassValue="@(_ => ItemClass())">This won't appear</ContextMenuItem>
                    </ContextMenuPopup>
                </ContextMenuPositioner>
            </ContextMenuRoot>
        </div>
    </DemoSection>

    <DemoSection Title="Data Attributes"
                 Description="ContextMenu components expose data attributes for styling based on state.">
        <div class="rounded-lg border border-gray-200 bg-white p-4">
            <p class="font-medium text-gray-900">Available data attributes:</p>
            <div class="mt-3 grid gap-4 sm:grid-cols-2">
                <div>
                    <p class="text-sm font-medium text-gray-700">Context Menu Trigger:</p>
                    <ul class="mt-1 list-inside list-disc text-sm text-gray-600">
                        <li><code class="text-xs bg-gray-100 px-1 rounded">data-popup-open</code> - present when the menu is open</li>
                        <li><code class="text-xs bg-gray-100 px-1 rounded">data-disabled</code> - present when disabled</li>
                        <li>Applies <code class="text-xs bg-gray-100 px-1 rounded">-webkit-touch-callout: none</code> style</li>
                    </ul>
                </div>
                <div>
                    <p class="text-sm font-medium text-gray-700">Inherited from Menu:</p>
                    <ul class="mt-1 list-inside list-disc text-sm text-gray-600">
                        <li>Menu Popup: <code class="text-xs bg-gray-100 px-1 rounded">data-open</code> / <code class="text-xs bg-gray-100 px-1 rounded">data-closed</code></li>
                        <li>Menu Item: <code class="text-xs bg-gray-100 px-1 rounded">data-highlighted</code>, <code class="text-xs bg-gray-100 px-1 rounded">data-disabled</code></li>
                        <li>Checkbox/Radio: <code class="text-xs bg-gray-100 px-1 rounded">data-checked</code> / <code class="text-xs bg-gray-100 px-1 rounded">data-unchecked</code></li>
                    </ul>
                </div>
            </div>
        </div>
    </DemoSection>

</ComponentShowcase>

@code {
    [Parameter]
    public bool IsWasmMode { get; set; }

    private bool showToolbar = true;
    private bool showSidebar = true;
    private object? selectedTheme = "light";

    private Task HandleThemeChange(MenuRadioGroupChangeEventArgs e)
    {
        selectedTheme = e.Value;
        return Task.CompletedTask;
    }

    private static string TriggerAreaClass() =>
        "flex h-40 w-full items-center justify-center rounded-lg border-2 border-dashed border-gray-300 bg-gray-50 text-sm text-gray-500 select-none cursor-default";

    private static string PopupClass() =>
        "min-w-[180px] py-1 rounded-md bg-white text-gray-900 outline outline-1 outline-gray-200 shadow-lg origin-[var(--transform-origin)] transition-[scale,opacity] duration-150 data-[starting-style]:opacity-0 data-[starting-style]:scale-90 data-[ending-style]:opacity-0 data-[ending-style]:scale-90";

    private static string ItemClass() =>
        "outline-none cursor-default select-none py-2 px-4 text-sm text-gray-900 data-[highlighted]:bg-gray-900 data-[highlighted]:text-white data-[disabled]:text-gray-400 data-[disabled]:cursor-not-allowed";

    private static string CheckboxItemClass() =>
        "outline-none cursor-default select-none py-2 px-2.5 text-sm text-gray-900 grid grid-cols-[1rem_1fr] gap-2 items-center data-[highlighted]:bg-gray-900 data-[highlighted]:text-white data-[disabled]:text-gray-400";

    private static string RadioItemClass() =>
        "outline-none cursor-default select-none py-2 px-2.5 text-sm text-gray-900 grid grid-cols-[1rem_1fr] gap-2 items-center data-[highlighted]:bg-gray-900 data-[highlighted]:text-white data-[disabled]:text-gray-400";

    private static string IndicatorClass() =>
        "flex items-center justify-center w-4 h-4";

    private static string SeparatorClass() =>
        "mx-4 my-1.5 h-px bg-gray-200";

    private static string GroupLabelClass() =>
        "py-2 px-4 text-xs font-semibold text-gray-500 uppercase tracking-wide";

    private static string SubmenuTriggerClass() =>
        "outline-none cursor-default select-none py-2 px-4 text-sm text-gray-900 flex items-center justify-between gap-4 data-[highlighted]:bg-gray-900 data-[highlighted]:text-white data-[popup-open]:bg-gray-100";
}

@* Icon Components *@

@code {
    private RenderFragment ChevronRightIcon => @<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 6l6 6-6 6" />
    </svg>;

    private RenderFragment CheckIcon => @<svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
        <path d="M5 12l5 5L20 7" />
    </svg>;

    private RenderFragment DotIcon => @<svg class="w-2 h-2" viewBox="0 0 8 8">
        <circle cx="4" cy="4" r="4" fill="currentColor" />
    </svg>;
}
