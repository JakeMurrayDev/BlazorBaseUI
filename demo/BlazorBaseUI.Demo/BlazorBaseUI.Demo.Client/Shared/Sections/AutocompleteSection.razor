@using System.Globalization
@using BlazorBaseUI
@using BlazorBaseUI.Autocomplete
@using BlazorBaseUI.Dialog

<ComponentShowcase ComponentName="Autocomplete"
                   Description="A text input with filterable suggestions, keyboard navigation, inline completion, and native form participation."
                   BaseRoute="/autocomplete"
                   IsWasmMode="IsWasmMode">
    <DemoSection Title="Basic">
        <div class="flex w-full flex-col items-center gap-3">
            <div class="flex w-full max-w-sm flex-col gap-1">
                <label for="autocomplete-basic-input"
                       class="text-sm font-medium text-gray-700">Search tags</label>
                <AutocompleteRoot TValue="string"
                                  Items="@TagItems"
                                  @bind-Value="basicValue"
                                  AutoHighlight="AutocompleteAutoHighlight.True"
                                  OpenOnInputClick>
                    <AutocompleteInputGroup ClassValue="@InputGroupClass">
                        <AutocompleteInput Id="autocomplete-basic-input"
                                           Placeholder="e.g. feature"
                                           ClassValue="@InputClass" />
                        <div class="flex shrink-0 items-center gap-1 text-gray-500">
                            <AutocompleteClear ClassValue="@ClearClass"
                                               aria-label="Clear selection">
                                <svg width="16"
                                     height="16"
                                     viewBox="0 0 16 16"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-linecap="square"
                                     stroke-linejoin="round"
                                     style="display: block">
                                    <path d="m4.5 4.5 7 7m-7 0 7-7" />
                                </svg>
                            </AutocompleteClear>
                            <AutocompleteTrigger ClassValue="@TriggerClass"
                                                 aria-label="Open popup">
                                <svg width="16"
                                     height="16"
                                     viewBox="0 0 16 16"
                                     fill="currentColor"
                                     style="display: block">
                                    <path d="M12 6H4l4 4.5z" />
                                </svg>
                            </AutocompleteTrigger>
                        </div>
                    </AutocompleteInputGroup>
                    <AutocompletePortal>
                        <AutocompletePositioner SideOffset="4"
                                                ClassValue="@PositionerClass"
                                                StyleValue="@PositionerStyle">
                            <AutocompletePopup ClassValue="@PopupClass"
                                               StyleValue="@PopupStyle">
                                <AutocompleteEmpty ClassValue="@EmptyClass">No tags found.</AutocompleteEmpty>
                                <AutocompleteList ClassValue="@ListClass"
                                                  StyleValue="@ListStyle">
                                    <AutocompleteCollection TValue="string" Context="entry">
                                        <AutocompleteItem TValue="string"
                                                          Value="@entry.Item"
                                                          Index="@entry.Index"
                                                          ClassValue="@ItemClass">
                                            @entry.Item
                                        </AutocompleteItem>
                                    </AutocompleteCollection>
                                </AutocompleteList>
                            </AutocompletePopup>
                        </AutocompletePositioner>
                    </AutocompletePortal>
                </AutocompleteRoot>
            </div>
            <p class="text-sm text-gray-600">Value: <span class="font-medium text-gray-900">@DisplayValue(basicValue)</span></p>
        </div>
    </DemoSection>

    <DemoSection Title="Async search">
        <div class="flex w-full flex-col items-center gap-3">
            <div class="flex w-full max-w-sm flex-col gap-1">
                <label for="autocomplete-async-input"
                       class="text-sm font-medium text-gray-700">Search movies by name or year</label>
                <AutocompleteRoot TValue="MovieItem"
                                  Items="@asyncSearchResults"
                                  Value="@asyncSearchValue"
                                  OnValueChange="@HandleAsyncSearchValueChange"
                                  ItemToStringValue="@MovieItemToString"
                                  FilterDisabled>
                    <AutocompleteInput Id="autocomplete-async-input"
                                       Placeholder="e.g. Pulp Fiction or 1994"
                                       ClassValue="@AsyncInputClass" />
                    @if (asyncSearchStatus is not null)
                    {
                        <AutocompletePortal>
                            <AutocompletePositioner SideOffset="4"
                                                    ClassValue="@PositionerClass"
                                                    StyleValue="@PositionerStyle">
                                <AutocompletePopup ClassValue="@PopupClass"
                                                   StyleValue="@PopupStyle"
                                                   aria-busy="@(asyncSearchPending ? "true" : null)">
                                    <div class="max-h-[min(var(--available-height,22.5rem),22.5rem)] overflow-y-auto overscroll-contain py-1">
                                        <AutocompleteStatus ClassValue="@AsyncStatusClass">
                                            <span class="flex items-center gap-2 px-3 py-1 text-sm text-gray-500">
                                                @if (asyncSearchPending)
                                                {
                                                    <span class="inline-block h-3 w-3 animate-spin rounded-full border border-current border-r-transparent"
                                                          aria-hidden="true"></span>
                                                }
                                                <span>@asyncSearchStatus</span>
                                            </span>
                                        </AutocompleteStatus>
                                        <AutocompleteList ClassValue="@ListClass"
                                                          StyleValue="@ListStyle">
                                            <AutocompleteCollection TValue="MovieItem" Context="entry">
                                                <AutocompleteItem TValue="MovieItem"
                                                                  Value="@entry.Item"
                                                                  Index="@entry.Index"
                                                                  ClassValue="@AsyncMovieItemClass">
                                                    <span class="flex w-full flex-col gap-1">
                                                        <span class="font-medium text-gray-900">@entry.Item.Title</span>
                                                        <span class="text-sm text-gray-500">@entry.Item.Year</span>
                                                    </span>
                                                </AutocompleteItem>
                                            </AutocompleteCollection>
                                        </AutocompleteList>
                                    </div>
                                </AutocompletePopup>
                            </AutocompletePositioner>
                        </AutocompletePortal>
                    }
                </AutocompleteRoot>
            </div>
        </div>
    </DemoSection>

    <DemoSection Title="Inline completion">
        <div class="flex w-full flex-col items-center gap-3">
            <div class="flex w-full max-w-sm flex-col gap-1">
                <label for="autocomplete-inline-input"
                       class="text-sm font-medium text-gray-700">Search tags</label>
                <AutocompleteRoot TValue="string"
                                  Items="@TagItems"
                                  Mode="AutocompleteMode.Both">
                    <AutocompleteInputGroup ClassValue="@InputGroupClass">
                        <AutocompleteInput Id="autocomplete-inline-input"
                                           Placeholder="e.g. component"
                                           ClassValue="@InputClass" />
                        <div class="flex shrink-0 items-center gap-1 text-gray-500">
                            <AutocompleteTrigger ClassValue="@TriggerClass"
                                                 aria-label="Open popup">
                                <svg width="16"
                                     height="16"
                                     viewBox="0 0 16 16"
                                     fill="currentColor"
                                     style="display: block">
                                    <path d="M12 6H4l4 4.5z" />
                                </svg>
                            </AutocompleteTrigger>
                        </div>
                    </AutocompleteInputGroup>
                    <AutocompletePortal>
                        <AutocompletePositioner SideOffset="4"
                                                ClassValue="@PositionerClass"
                                                StyleValue="@PositionerStyle">
                            <AutocompletePopup ClassValue="@PopupClass"
                                               StyleValue="@PopupStyle">
                                <AutocompleteEmpty ClassValue="@EmptyClass">No matches.</AutocompleteEmpty>
                                <AutocompleteList ClassValue="@ListClass"
                                                  StyleValue="@ListStyle">
                                    <AutocompleteCollection TValue="string" Context="entry">
                                        <AutocompleteItem TValue="string"
                                                          Value="@entry.Item"
                                                          Index="@entry.Index"
                                                          ClassValue="@ItemClass">
                                            @entry.Item
                                        </AutocompleteItem>
                                    </AutocompleteCollection>
                                </AutocompleteList>
                            </AutocompletePopup>
                        </AutocompletePositioner>
                    </AutocompletePortal>
                </AutocompleteRoot>
            </div>
        </div>
    </DemoSection>

    <DemoSection Title="Grouped">
        <div class="flex w-full flex-col items-center gap-3">
            <div class="flex w-full max-w-sm flex-col gap-1">
                <label for="autocomplete-grouped-input"
                       class="text-sm font-medium text-gray-700">Select a tag</label>
                <AutocompleteRoot TValue="string"
                                  Items="@TagItems"
                                  @bind-Value="groupedValue"
                                  AutoHighlight="AutocompleteAutoHighlight.True"
                                  OpenOnInputClick>
                    <AutocompleteInputGroup ClassValue="@InputGroupClass">
                        <AutocompleteInput Id="autocomplete-grouped-input"
                                           Placeholder="e.g. feature"
                                           ClassValue="@InputClass" />
                        <div class="flex shrink-0 items-center gap-1 text-gray-500">
                            <AutocompleteTrigger ClassValue="@TriggerClass"
                                                 aria-label="Open popup">
                                <svg width="16"
                                     height="16"
                                     viewBox="0 0 16 16"
                                     fill="currentColor"
                                     style="display: block">
                                    <path d="M12 6H4l4 4.5z" />
                                </svg>
                            </AutocompleteTrigger>
                        </div>
                    </AutocompleteInputGroup>
                    <AutocompletePortal>
                        <AutocompletePositioner SideOffset="4"
                                                ClassValue="@PositionerClass"
                                                StyleValue="@PositionerStyle">
                            <AutocompletePopup ClassValue="@PopupClass"
                                               StyleValue="@PopupStyle">
                                <AutocompleteEmpty ClassValue="@EmptyClass">No tags found.</AutocompleteEmpty>
                                <AutocompleteList ClassValue="@ListClass"
                                                  StyleValue="@ListStyle">
                                    @{
                                        var visibleTypeTags = GetFilteredTags(TypeTagItems, groupedValue);
                                        var visibleComponentTags = GetFilteredTags(ComponentTagItems, groupedValue);
                                    }
                                    @if (visibleTypeTags.Count > 0)
                                    {
                                        <AutocompleteGroup ClassValue="@GroupClass">
                                            <AutocompleteGroupLabel ClassValue="@GroupLabelClass">Type</AutocompleteGroupLabel>
                                            @foreach (var tag in visibleTypeTags)
                                            {
                                                <AutocompleteItem TValue="string"
                                                                  Value="@tag"
                                                                  ClassValue="@ItemClass">
                                                    @tag
                                                </AutocompleteItem>
                                            }
                                        </AutocompleteGroup>
                                    }
                                    @if (visibleComponentTags.Count > 0)
                                    {
                                        <AutocompleteGroup ClassValue="@GroupClass">
                                            <AutocompleteGroupLabel ClassValue="@GroupLabelClass">Component</AutocompleteGroupLabel>
                                            @foreach (var tag in visibleComponentTags)
                                            {
                                                <AutocompleteItem TValue="string"
                                                                  Value="@tag"
                                                                  ClassValue="@ItemClass">
                                                    @tag
                                                </AutocompleteItem>
                                            }
                                        </AutocompleteGroup>
                                    }
                                </AutocompleteList>
                            </AutocompletePopup>
                        </AutocompletePositioner>
                    </AutocompletePortal>
                </AutocompleteRoot>
            </div>
        </div>
    </DemoSection>

    <DemoSection Title="Fuzzy matching">
        <div class="flex w-full flex-col items-center gap-3">
            <div class="flex w-full max-w-sm flex-col gap-1">
                <label for="autocomplete-fuzzy-input"
                       class="text-sm font-medium text-gray-700">Fuzzy search documentation</label>
                <AutocompleteRoot TValue="DocsSearchItem"
                                  Items="@DocsSearchItems"
                                  Filter="@DocsSearchFilter"
                                  ItemToStringValue="@DocsSearchItemToString"
                                  AutoHighlight="AutocompleteAutoHighlight.True"
                                  OpenOnInputClick>
                    <AutocompleteInputGroup ClassValue="@InputGroupClass">
                        <AutocompleteInput Id="autocomplete-fuzzy-input"
                                           Placeholder="e.g. rct perf"
                                           ClassValue="@InputClass" />
                        <div class="flex shrink-0 items-center gap-1 text-gray-500">
                            <AutocompleteTrigger ClassValue="@TriggerClass"
                                                 aria-label="Open popup">
                                <svg width="16"
                                     height="16"
                                     viewBox="0 0 16 16"
                                     fill="currentColor"
                                     style="display: block">
                                    <path d="M12 6H4l4 4.5z" />
                                </svg>
                            </AutocompleteTrigger>
                        </div>
                    </AutocompleteInputGroup>
                    <AutocompletePortal>
                        <AutocompletePositioner SideOffset="4"
                                                ClassValue="@PositionerClass"
                                                StyleValue="@PositionerStyle">
                            <AutocompletePopup ClassValue="@PopupClass"
                                               StyleValue="@PopupStyle">
                                <AutocompleteEmpty ClassValue="@EmptyClass">No documentation found.</AutocompleteEmpty>
                                <AutocompleteList ClassValue="@ListClass"
                                                  StyleValue="@ListStyle">
                                    <AutocompleteCollection TValue="DocsSearchItem" Context="entry">
                                        <AutocompleteItem TValue="DocsSearchItem"
                                                          Value="@entry.Item"
                                                          Index="@entry.Index"
                                                          ClassValue="@DocsSearchItemClass">
                                            <span class="flex w-full flex-col gap-1">
                                                <span class="font-medium text-gray-900">@entry.Item.Title</span>
                                                <span class="text-sm text-gray-500">@entry.Item.Description</span>
                                            </span>
                                        </AutocompleteItem>
                                    </AutocompleteCollection>
                                </AutocompleteList>
                            </AutocompletePopup>
                        </AutocompletePositioner>
                    </AutocompletePortal>
                </AutocompleteRoot>
            </div>
        </div>
    </DemoSection>

    <DemoSection Title="Limit results">
        <div class="flex w-full flex-col items-center gap-3">
            <div class="flex w-full max-w-sm flex-col gap-1">
                <label for="autocomplete-limit-input"
                       class="text-sm font-medium text-gray-700">Limit results to 8</label>
                <AutocompleteRoot TValue="string"
                                  Items="@TagItems"
                                  @bind-Value="limitValue"
                                  Limit="@VisibleResultLimit"
                                  AutoHighlight="AutocompleteAutoHighlight.True"
                                  OpenOnInputClick>
                    <AutocompleteInputGroup ClassValue="@InputGroupClass">
                        <AutocompleteInput Id="autocomplete-limit-input"
                                           Placeholder="e.g. component"
                                           ClassValue="@InputClass" />
                        <div class="flex shrink-0 items-center gap-1 text-gray-500">
                            <AutocompleteTrigger ClassValue="@TriggerClass"
                                                 aria-label="Open popup">
                                <svg width="16"
                                     height="16"
                                     viewBox="0 0 16 16"
                                     fill="currentColor"
                                     style="display: block">
                                    <path d="M12 6H4l4 4.5z" />
                                </svg>
                            </AutocompleteTrigger>
                        </div>
                    </AutocompleteInputGroup>
                    <AutocompletePortal>
                        <AutocompletePositioner SideOffset="4"
                                                ClassValue="@PositionerClass"
                                                StyleValue="@PositionerStyle">
                            <AutocompletePopup ClassValue="@PopupClass"
                                               StyleValue="@PopupStyle">
                                <AutocompleteEmpty ClassValue="@EmptyClass">No tags found.</AutocompleteEmpty>
                                <AutocompleteList ClassValue="@ListClass"
                                                  StyleValue="@ListStyle">
                                    <AutocompleteCollection TValue="string" Context="entry">
                                        <AutocompleteItem TValue="string"
                                                          Value="@entry.Item"
                                                          Index="@entry.Index"
                                                          ClassValue="@ItemClass">
                                            @entry.Item
                                        </AutocompleteItem>
                                    </AutocompleteCollection>
                                </AutocompleteList>
                                <AutocompleteStatus ClassValue="@StatusClass">
                                    @{
                                        var hiddenResultCount = GetHiddenResultCount(limitValue);
                                    }
                                    @if (hiddenResultCount > 0)
                                    {
                                        <span>Hiding @hiddenResultCount results. Type a more specific query to narrow results.</span>
                                    }
                                </AutocompleteStatus>
                            </AutocompletePopup>
                        </AutocompletePositioner>
                    </AutocompletePortal>
                </AutocompleteRoot>
            </div>
        </div>
    </DemoSection>

    <DemoSection Title="Auto highlight">
        <div class="flex w-full flex-col items-center gap-3">
            <div class="flex w-full max-w-sm flex-col gap-1">
                <label for="autocomplete-auto-highlight-input"
                       class="text-sm font-medium text-gray-700">Auto highlight on type</label>
                <AutocompleteRoot TValue="string"
                                  Items="@TagItems"
                                  AutoHighlight="AutocompleteAutoHighlight.True"
                                  OpenOnInputClick>
                    <AutocompleteInputGroup ClassValue="@InputGroupClass">
                        <AutocompleteInput Id="autocomplete-auto-highlight-input"
                                           Placeholder="e.g. feature"
                                           ClassValue="@InputClass" />
                        <div class="flex shrink-0 items-center gap-1 text-gray-500">
                            <AutocompleteTrigger ClassValue="@TriggerClass"
                                                 aria-label="Open popup">
                                <svg width="16"
                                     height="16"
                                     viewBox="0 0 16 16"
                                     fill="currentColor"
                                     style="display: block">
                                    <path d="M12 6H4l4 4.5z" />
                                </svg>
                            </AutocompleteTrigger>
                        </div>
                    </AutocompleteInputGroup>
                    <AutocompletePortal>
                        <AutocompletePositioner SideOffset="4"
                                                ClassValue="@PositionerClass"
                                                StyleValue="@PositionerStyle">
                            <AutocompletePopup ClassValue="@PopupClass"
                                               StyleValue="@PopupStyle">
                                <AutocompleteEmpty ClassValue="@EmptyClass">No tags found.</AutocompleteEmpty>
                                <AutocompleteList ClassValue="@ListClass"
                                                  StyleValue="@ListStyle">
                                    <AutocompleteCollection TValue="string" Context="entry">
                                        <AutocompleteItem TValue="string"
                                                          Value="@entry.Item"
                                                          Index="@entry.Index"
                                                          ClassValue="@ItemClass">
                                            @entry.Item
                                        </AutocompleteItem>
                                    </AutocompleteCollection>
                                </AutocompleteList>
                            </AutocompletePopup>
                        </AutocompletePositioner>
                    </AutocompletePortal>
                </AutocompleteRoot>
            </div>
        </div>
    </DemoSection>

    <DemoSection Title="Command palette">
        <div class="flex w-full justify-center">
            <DialogRoot Open="@commandPaletteOpen"
                        OpenChanged="@HandleCommandPaletteOpenChanged">
                <DialogTrigger ClassValue="@CommandPaletteTriggerClass">
                    Open command palette
                </DialogTrigger>
                <DialogPortal>
                    <DialogBackdrop ClassValue="@CommandPaletteBackdropClass" />
                    <DialogViewport ClassValue="@CommandPaletteViewportClass"
                                    StyleValue="@CommandPaletteViewportStyle">
                        <DialogPopup ClassValue="@CommandPalettePopupClass"
                                     InitialFocus="@CommandPaletteInitialFocus"
                                     aria-label="Command palette">
                            <AutocompleteRoot TValue="CommandPaletteItem"
                                              Open="true"
                                              Inline
                                              Items="@CommandPaletteItems"
                                              ItemToStringValue="@CommandPaletteItemToString"
                                              AutoHighlight="AutocompleteAutoHighlight.Always"
                                              KeepHighlight
                                              @bind-Value="commandPaletteValue">
                                <AutocompleteInput @ref="commandPaletteInput"
                                                   Placeholder="Search for apps and commands..."
                                                   ClassValue="@CommandPaletteInputClass"
                                                   StyleValue="@CommandPaletteInputStyle" />
                                <DialogClose ClassValue="@CommandPaletteCloseClass">
                                    Close command palette
                                </DialogClose>
                                <div class="min-h-0 flex-1 overflow-y-auto border-t border-gray-200">
                                    <AutocompleteEmpty ClassValue="@CommandPaletteEmptyClass">No results found.</AutocompleteEmpty>
                                    <AutocompleteList ClassValue="@CommandPaletteListClass"
                                                      StyleValue="@CommandPaletteListStyle">
                                        @{
                                            var visibleSuggestionItems = GetFilteredCommandItems(CommandSuggestionItems, commandPaletteValue);
                                            var visibleCommandItems = GetFilteredCommandItems(CommandActionItems, commandPaletteValue);
                                        }
                                        @if (visibleSuggestionItems.Count > 0)
                                        {
                                            <AutocompleteGroup ClassValue="@CommandPaletteGroupClass">
                                                <AutocompleteGroupLabel ClassValue="@CommandPaletteGroupLabelClass">Suggestions</AutocompleteGroupLabel>
                                                @foreach (var item in visibleSuggestionItems)
                                                {
                                                    <AutocompleteItem TValue="CommandPaletteItem"
                                                                      Value="@item"
                                                                      ClassValue="@CommandPaletteItemClass"
                                                                      @onclick="@HandleCommandPaletteItemClick">
                                                        <span class="min-w-0 truncate">@item.Label</span>
                                                        <span class="shrink-0 text-xs text-gray-500">Application</span>
                                                    </AutocompleteItem>
                                                }
                                            </AutocompleteGroup>
                                        }
                                        @if (visibleCommandItems.Count > 0)
                                        {
                                            <AutocompleteGroup ClassValue="@CommandPaletteGroupClass">
                                                <AutocompleteGroupLabel ClassValue="@CommandPaletteGroupLabelClass">Commands</AutocompleteGroupLabel>
                                                @foreach (var item in visibleCommandItems)
                                                {
                                                    <AutocompleteItem TValue="CommandPaletteItem"
                                                                      Value="@item"
                                                                      ClassValue="@CommandPaletteItemClass"
                                                                      @onclick="@HandleCommandPaletteItemClick">
                                                        <span class="min-w-0 truncate">@item.Label</span>
                                                        <span class="shrink-0 text-xs text-gray-500">Command</span>
                                                    </AutocompleteItem>
                                                }
                                            </AutocompleteGroup>
                                        }
                                    </AutocompleteList>
                                </div>
                            </AutocompleteRoot>
                        </DialogPopup>
                    </DialogViewport>
                </DialogPortal>
            </DialogRoot>
        </div>
    </DemoSection>

    <DemoSection Title="Grid layout">
        <div class="flex w-full flex-col items-center gap-3">
            <div class="flex w-full flex-col gap-1"
                 style="max-width:16rem;">
                <label for="autocomplete-grid-message-input"
                       class="text-sm font-medium text-gray-700">Message</label>
                <div class="relative flex w-full">
                    <input id="autocomplete-grid-message-input"
                           type="text"
                           placeholder="iMessage"
                           value="@gridTextValue"
                           @oninput="@HandleGridTextInput"
                           class="min-w-0 flex-1 rounded-l-md border border-gray-300 bg-white px-3 text-sm text-gray-900 shadow-sm outline-none placeholder:text-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20"
                           style="height:2.25rem;border-right-width:0;" />
                    <AutocompleteRoot TValue="GridPickerItem"
                                  Open="@gridOpen"
                                  OpenChanged="@HandleGridOpenChanged"
                                  OnOpenChangeComplete="@HandleGridOpenComplete"
                                  Value="@gridSearchValue"
                                  OnValueChange="@HandleGridSearchValueChange"
                                  Items="@GridPickerItems"
                                  ItemToStringValue="@GridPickerItemToString"
                                  Grid>
                        <AutocompleteTrigger ClassValue="@GridTriggerClass"
                                             StyleValue="@GridTriggerStyle"
                                             aria-label="Choose emoji">
                            <span aria-hidden="true">☺</span>
                        </AutocompleteTrigger>
                        <AutocompletePortal>
                            <AutocompletePositioner SideOffset="4"
                                                    Align="Align.End"
                                                    ClassValue="@PositionerClass"
                                                    StyleValue="@GridPositionerStyle">
                                <AutocompletePopup ClassValue="@GridPopupClass"
                                                   StyleValue="@GridPopupStyle"
                                                   aria-label="Select emoji">
                                    <AutocompleteInput Id="autocomplete-grid-input"
                                                       Placeholder="Search emojis..."
                                                       ClassValue="@GridSearchInputClass"
                                                       StyleValue="@GridSearchInputStyle" />
                                    <AutocompleteEmpty ClassValue="@EmptyClass">No emojis found.</AutocompleteEmpty>
                                    <AutocompleteList ClassValue="@GridListClass"
                                                      StyleValue="@GridListStyle">
                                        @{
                                            var visibleGridGroups = GetFilteredGridGroups(gridSearchValue);
                                        }
                                        @foreach (var group in visibleGridGroups)
                                        {
                                            <AutocompleteGroup ClassValue="@GroupClass">
                                                <AutocompleteGroupLabel ClassValue="@GroupLabelClass">@group.Label</AutocompleteGroupLabel>
                                                <div class="px-2 pb-2"
                                                     role="presentation">
                                                    @foreach (var row in GetGridRows(group.Items))
                                                    {
                                                        <AutocompleteRow ClassValue="@GridRowClass"
                                                                         StyleValue="@GridRowStyle">
                                                            @foreach (var item in row)
                                                            {
                                                                <AutocompleteItem TValue="GridPickerItem"
                                                                                  Value="@item"
                                                                                  ClassValue="@GridItemClass"
                                                                                  StyleValue="@GridItemStyle"
                                                                                  @onclick="@(() => HandleGridPickerItemClick(item))">
                                                                    <span class="leading-none"
                                                                          aria-hidden="true">@item.Symbol</span>
                                                                    <span class="sr-only">@item.Name</span>
                                                                </AutocompleteItem>
                                                            }
                                                        </AutocompleteRow>
                                                    }
                                                </div>
                                            </AutocompleteGroup>
                                        }
                                    </AutocompleteList>
                                </AutocompletePopup>
                            </AutocompletePositioner>
                        </AutocompletePortal>
                    </AutocompleteRoot>
                </div>
            </div>
        </div>
    </DemoSection>

    <DemoSection Title="Virtualized">
        <div class="flex w-full flex-col items-center gap-3">
            <div class="flex w-full max-w-sm flex-col gap-1">
                <label for="autocomplete-virtualized-input"
                       class="text-sm font-medium text-gray-700">Search 10,000 items</label>
                <AutocompleteRoot TValue="VirtualizedItem"
                                  Items="@VirtualizedItems"
                                  ItemToStringValue="@VirtualizedItemToString"
                                  @bind-Value="virtualizedValue"
                                  OpenOnInputClick
                                  Virtualized>
                    <AutocompleteInputGroup ClassValue="@InputGroupClass">
                        <AutocompleteInput Id="autocomplete-virtualized-input"
                                           Placeholder="e.g. Item 0042"
                                           ClassValue="@InputClass" />
                        <div class="flex shrink-0 items-center gap-1 text-gray-500">
                            <AutocompleteTrigger ClassValue="@TriggerClass"
                                                 aria-label="Open popup">
                                <svg width="16"
                                     height="16"
                                     viewBox="0 0 16 16"
                                     fill="currentColor"
                                     style="display: block">
                                    <path d="M12 6H4l4 4.5z" />
                                </svg>
                            </AutocompleteTrigger>
                        </div>
                    </AutocompleteInputGroup>
                    <AutocompletePortal>
                        <AutocompletePositioner SideOffset="4"
                                                ClassValue="@PositionerClass"
                                                StyleValue="@PositionerStyle">
                            <AutocompletePopup ClassValue="@PopupClass"
                                               StyleValue="@PopupStyle">
                                <AutocompleteEmpty ClassValue="@EmptyClass">No items found.</AutocompleteEmpty>
                                @{
                                    var virtualizedRenderItems = GetFilteredVirtualizedRenderItems(virtualizedValue);
                                }
                                <AutocompleteList ClassValue="@VirtualizedListClass"
                                                  StyleValue="@VirtualizedListStyleValue(virtualizedRenderItems.Length)">
                                    <Virtualize Items="@virtualizedRenderItems"
                                                Context="entry"
                                                ItemSize="32"
                                                OverscanCount="20">
                                        <AutocompleteItem TValue="VirtualizedItem"
                                                          Value="@entry.Item"
                                                          Index="@entry.Index"
                                                          ClassValue="@ItemClass"
                                                          aria-setsize="@virtualizedRenderItems.Length"
                                                          aria-posinset="@(entry.Index + 1)">
                                            @entry.Item.Name
                                        </AutocompleteItem>
                                    </Virtualize>
                                </AutocompleteList>
                            </AutocompletePopup>
                        </AutocompletePositioner>
                    </AutocompletePortal>
                </AutocompleteRoot>
            </div>
        </div>
    </DemoSection>

    <DemoSection Title="Events">
        <div class="flex w-full flex-col items-center gap-3">
            <div class="flex w-full max-w-sm flex-col gap-1">
                <label for="autocomplete-events-input"
                       class="text-sm font-medium text-gray-700">Search cities</label>
                <AutocompleteRoot TValue="string"
                                  Items="@CityItems"
                                  DefaultValue="Tokyo"
