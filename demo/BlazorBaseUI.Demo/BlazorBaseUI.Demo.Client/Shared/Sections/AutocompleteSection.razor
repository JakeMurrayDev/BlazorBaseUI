    private static IReadOnlyList<string> GetFilteredTags(IReadOnlyList<string> source, string value)
    {
        var query = value.Trim();
        if (query.Length == 0)
        {
            return source;
        }

        return source.Where(item => MatchesTag(item, query)).ToArray();
    }

    private static int GetHiddenResultCount(string value)
    {
        var matchCount = CountTagMatches(value);
        return Math.Max(0, matchCount - VisibleResultLimit);
    }

    private static int CountTagMatches(string value)
    {
        var query = value.Trim();
        return query.Length == 0
            ? TagItems.Count
            : TagItems.Count(item => MatchesTag(item, query));
    }

    private static bool MatchesTag(string item, string query)
    {
        return item.Contains(query, StringComparison.CurrentCultureIgnoreCase);
    }

    private static IReadOnlyList<CommandPaletteItem> GetFilteredCommandItems(IReadOnlyList<CommandPaletteItem> source, string value)
    {
        var query = value.Trim();
        if (query.Length == 0)
        {
            return source;
        }

        return source.Where(item => MatchesCommandPaletteItem(item, query)).ToArray();
    }

    private static bool MatchesCommandPaletteItem(CommandPaletteItem item, string query)
    {
        return item.Label.Contains(query, StringComparison.CurrentCultureIgnoreCase) ||
            item.Kind.Contains(query, StringComparison.CurrentCultureIgnoreCase);
    }

    private static string? CommandPaletteItemToString(CommandPaletteItem? item)
    {
        return item?.Label;
    }

    private static IReadOnlyList<GridPickerGroup> GetFilteredGridGroups(string value)
    {
        var query = value.Trim();
        if (query.Length == 0)
        {
            return GridPickerGroups;
        }

        return GridPickerGroups
            .Select(group => group with
            {
                Items = group.Items
                    .Where(item => MatchesGridPickerItem(item, query))
                    .ToArray()
            })
            .Where(group => group.Items.Count > 0)
            .ToArray();
    }

    private static bool MatchesGridPickerItem(GridPickerItem item, string query)
    {
        return item.Name.Contains(query, StringComparison.CurrentCultureIgnoreCase) ||
            item.Symbol.Contains(query, StringComparison.CurrentCultureIgnoreCase);
    }

    private static IEnumerable<IReadOnlyList<GridPickerItem>> GetGridRows(IReadOnlyList<GridPickerItem> items)
    {
        for (var index = 0; index < items.Count; index += GridColumnCount)
        {
            yield return items.Skip(index).Take(GridColumnCount).ToArray();
        }
    }

    private static string? GridPickerItemToString(GridPickerItem? item)
    {
        return item?.Name;
    }

    private static VirtualizedRenderItem[] GetFilteredVirtualizedRenderItems(string value)
    {
        var query = value.Trim();
        var filteredItems = query.Length == 0
            ? VirtualizedItems
            : VirtualizedItems
                .Where(item => item.Name.Contains(query, StringComparison.CurrentCultureIgnoreCase))
                .ToArray();

        return filteredItems
            .Select((item, index) => new VirtualizedRenderItem(item, index))
            .ToArray();
    }

