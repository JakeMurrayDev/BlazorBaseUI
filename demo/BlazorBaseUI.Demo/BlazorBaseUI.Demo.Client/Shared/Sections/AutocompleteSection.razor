    private static string? DocsSearchItemToString(DocsSearchItem? item)
    {
        return item?.Title;
    }

    private static bool DocsSearchFilter(DocsSearchItem item, string query, Func<DocsSearchItem, string?>? stringify)
    {
        var trimmed = query.Trim();
        if (trimmed.Length == 0)
        {
            return true;
        }

        return trimmed
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .All(token =>
                IsFuzzyMatch(item.Title, token) ||
                IsFuzzyMatch(item.Description, token) ||
                IsFuzzyMatch(item.Category, token));
    }

    private static bool IsFuzzyMatch(string value, string query)
    {
        if (value.Contains(query, StringComparison.CurrentCultureIgnoreCase))
        {
            return true;
        }

        foreach (var word in value.Split(SearchWordSeparators, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            if (IsSubsequenceMatch(word, query))
            {
                return true;
            }
        }

        return false;
    }

    private static bool IsSubsequenceMatch(string value, string query)
    {
        if (value.Contains(query, StringComparison.CurrentCultureIgnoreCase))
        {
            return true;
        }

        var queryIndex = 0;
        foreach (var character in value)
        {
            if (char.ToUpperInvariant(character) == char.ToUpperInvariant(query[queryIndex]))
            {
                queryIndex++;
                if (queryIndex == query.Length)
                {
                    return true;
                }
            }
        }

        return false;
    }

    private static bool MatchesMovieItem(MovieItem item, string query)
    {
        return item.Title.Contains(query, StringComparison.CurrentCultureIgnoreCase) ||
            item.Year.ToString(CultureInfo.InvariantCulture).Contains(query, StringComparison.CurrentCultureIgnoreCase);
    }

    private static string DisplayValue(string value)
    {
        return string.IsNullOrEmpty(value) ? "Empty" : value;
    }

    private async Task HandleAsyncSearchValueChange(AutocompleteValueChangeEventArgs args)
    {
        asyncSearchValue = args.Value;
        asyncSearchError = null;

        var query = args.Value.Trim();
        var searchVersion = ++asyncSearchVersion;
        if (query.Length == 0)
        {
            asyncSearchResults = [];
            asyncSearchPending = false;
            asyncSearchStatus = null;
            return;
        }

        asyncSearchPending = true;
        asyncSearchStatus = GetAsyncSearchStatus(query);
        await InvokeAsync(StateHasChanged);

        await Task.Delay(250);
        if (searchVersion != asyncSearchVersion)
        {
            return;
        }

        asyncSearchPending = false;
        if (query.Equals("will_error", StringComparison.CurrentCultureIgnoreCase))
        {
            asyncSearchResults = [];
            asyncSearchError = "Failed to fetch movies. Please try again.";
        }
        else
        {
            asyncSearchResults = MovieItems.Where(item => MatchesMovieItem(item, query)).ToArray();
        }

        asyncSearchStatus = GetAsyncSearchStatus(query);
    }

    private string? GetAsyncSearchStatus(string query)
    {
        if (asyncSearchPending)
        {
            return "Searching...";
        }

        if (asyncSearchError is not null)
        {
            return asyncSearchError;
        }

        if (query.Length == 0)
        {
            return null;
        }

        if (asyncSearchResults.Count == 0)
        {
            return $"Movie or year \"{query}\" does not exist in the Top 100 IMDb movies";
        }

        return $"{asyncSearchResults.Count} result{(asyncSearchResults.Count == 1 ? string.Empty : "s")} found";
    }

    private void HandleCommandPaletteOpenChanged(bool open)
    {
        commandPaletteOpen = open;
        if (!open)
        {
            commandPaletteValue = string.Empty;
        }
        else
        {
            commandPaletteFocusRequest++;
        }
    }

    private void HandleCommandPaletteItemClick(MouseEventArgs args)
    {
        commandPaletteOpen = false;
    }

    private void HandleGridOpenChanged(bool open)
    {
        gridOpen = open;
        if (!open)
        {
            gridSearchValue = string.Empty;
        }
    }

    private void HandleGridOpenComplete(bool open)
    {
        if (!open)
        {
            gridSearchValue = string.Empty;
        }
    }

    private void HandleGridSearchValueChange(AutocompleteValueChangeEventArgs args)
    {
        if (args.Reason != AutocompleteChangeReason.ItemPress)
        {
            gridSearchValue = args.Value;
        }
    }

    private void HandleGridTextInput(ChangeEventArgs args)
    {
        gridTextValue = Convert.ToString(args.Value) ?? string.Empty;
    }

    private void HandleGridPickerItemClick(GridPickerItem item)
    {
        gridTextValue += item.Symbol;
        gridSearchValue = string.Empty;
        gridOpen = false;
    }

    private void HandleEventValueChange(AutocompleteValueChangeEventArgs args)
    {
        eventValueMessage = $"{args.Reason}: {DisplayValue(args.Value)}";
    }

    private void HandleEventHighlightChange(AutocompleteHighlightEventArgs<string> args)
    {
        eventHighlightMessage = args.Index < 0 ? "None" : $"{args.Value} ({args.Reason})";
    }

