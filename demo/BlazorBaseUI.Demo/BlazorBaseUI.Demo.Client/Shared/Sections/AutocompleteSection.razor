    private static string GetVirtualizedListStyle(int itemCount)
    {
        var height = itemCount == 0 ? 0 : itemCount * VirtualizedItemSize + VirtualizedListPadding;
        return $"box-sizing:border-box;height:min(22.5rem,{height}px);max-height:var(--available-height,22.5rem);overflow-y:auto;overscroll-behavior:contain;scroll-padding-block:0.25rem;";
