    <DemoSection Title="Final focus"
                 Description="Use the FinalFocus parameter on SelectPopup to redirect focus on close. Here, focus jumps to the trailing 'Continue' button after an item is picked.">
        <div class="flex items-center gap-2">
            <SelectRoot TValue="string" @bind-Value="finalFocusValue">
                <SelectTrigger ClassValue="@(state => TriggerClass(state))">
                    <SelectValue TValue="string" Placeholder="Pick one..." />
                    <SelectIcon>@ArrowIcon</SelectIcon>
                </SelectTrigger>
                <SelectPortal>
                    <SelectPositioner SideOffset="4">
                        <SelectPopup ClassValue="@(state => PopupClass(state))"
                                     FinalFocus="@(BlazorBaseUI.FloatingFocusManager.FinalFocusTarget.From(closeType => closeType == BlazorBaseUI.InteractionType.Keyboard ? BlazorBaseUI.FloatingFocusManager.FinalFocusResult.Default : BlazorBaseUI.FloatingFocusManager.FinalFocusResult.To(continueButton)))">
                            <SelectItem TValue="string" Value="@("apple")" Label="Apple" ClassValue="@(state => ItemClass(state))">
                                <SelectItemIndicator class="col-start-1">@CheckIcon</SelectItemIndicator>
                                <SelectItemText class="col-start-2">Apple</SelectItemText>
                            </SelectItem>
                            <SelectItem TValue="string" Value="@("banana")" Label="Banana" ClassValue="@(state => ItemClass(state))">
                                <SelectItemIndicator class="col-start-1">@CheckIcon</SelectItemIndicator>
                                <SelectItemText class="col-start-2">Banana</SelectItemText>
                            </SelectItem>
                        </SelectPopup>
                    </SelectPositioner>
                </SelectPortal>
            </SelectRoot>
            <button @ref="continueButton"
                    type="button"
                    class="rounded bg-blue-600 px-3 py-1 text-white hover:bg-blue-700">
                Continue
            </button>
        </div>
        <p class="mt-2 text-sm text-gray-500">
            Click an item with the mouse — focus moves to "Continue".
            Use Enter on the keyboard — focus returns to the trigger (default).
        </p>
    </DemoSection>

    <DemoSection Title="Window resize closes popup"
                 Description="Uses the default 'align item with trigger' placement; resizing the browser window closes the open select.">
        <SelectRoot TValue="string"
                    Id="select-default-open-resize"
                    Modal="SelectModalMode.False"
                    @bind-Value="resizeValue">
            <SelectTrigger ClassValue="@(state => TriggerClass(state))">
                <SelectValue TValue="string" Placeholder="Open me, then resize..." />
                <SelectIcon>@ArrowIcon</SelectIcon>
            </SelectTrigger>
            <SelectPortal>
                <SelectPositioner SideOffset="4" AlignItemWithTrigger="true">
                    <SelectPopup ClassValue="@(state => PopupClass(state))">
                        <SelectItem TValue="string" Value="@("one")" Label="One" ClassValue="@(state => ItemClass(state))">
                            <SelectItemIndicator class="col-start-1">@CheckIcon</SelectItemIndicator>
                            <SelectItemText class="col-start-2">One</SelectItemText>
                        </SelectItem>
                        <SelectItem TValue="string" Value="@("two")" Label="Two" ClassValue="@(state => ItemClass(state))">
                            <SelectItemIndicator class="col-start-1">@CheckIcon</SelectItemIndicator>
                            <SelectItemText class="col-start-2">Two</SelectItemText>
                        </SelectItem>
                    </SelectPopup>
                </SelectPositioner>
            </SelectPortal>
        </SelectRoot>
    </DemoSection>

    <DemoSection Title="Multiple Selection"
                 Description="Uses Multiple, DefaultValues, ValuesContent, KeepMounted indicators, and the multi-value OnValueChange payload.">
        <div class="w-full space-y-4">
            <SelectRoot TValue="string"
                        Multiple="true"
                        DefaultValues="@DefaultFruitValues"
                        Items="@FruitItems"
                        OnValueChange="HandleMultipleValueChange">
                <SelectTrigger ClassValue="@(state => StableTriggerClass(state))">
                    <SelectValue TValue="string"
                                 PlaceholderContent="@MultiPlaceholder"
                                 ValuesContent="@MultipleFruitValueContent" />
                    <SelectIcon ClassValue="@(state => IconClass(state))">@ArrowIcon</SelectIcon>
                </SelectTrigger>
                <SelectPortal KeepMounted="true">
                    <SelectPositioner SideOffset="4" AlignItemWithTrigger="false">
                        <SelectPopup ClassValue="@(state => PopupClass(state))">
                            <SelectList ClassValue="@(_ => ListClass)">
                                @foreach (var option in FruitItems)
                                {
                                    <SelectItem TValue="string" Value="@option.Value" Label="@option.Label" ClassValue="@(state => ItemClass(state))">
                                        <SelectItemIndicator KeepMounted="true"
                                                             Render="RenderIndicatorAsSpan"
                                                             ClassValue="@(state => IndicatorClass(state))"
                                                             StyleValue="IndicatorStyle"
                                                             data-feature="indicator-render-style">
                                            @CheckIcon
                                        </SelectItemIndicator>
                                        <SelectItemText class="col-start-2">@option.Label</SelectItemText>
                                    </SelectItem>
                                }
                            </SelectList>
                        </SelectPopup>
                    </SelectPositioner>
                </SelectPortal>
            </SelectRoot>

            <p class="text-sm text-gray-500">@multipleChangeMessage</p>

            <SelectRoot TValue="string"
                        Multiple="true"
                        Values="@controlledValues"
                        ValuesChanged="HandleControlledValuesChanged"
                        Items="@FruitItems">
                <SelectTrigger ClassValue="@(state => StableTriggerClass(state))">
                    <SelectValue TValue="string"
                                 Placeholder="Controlled values..."
                                 ValuesContent="@MultipleFruitValueContent" />
                    <SelectIcon ClassValue="@(state => IconClass(state))">@ArrowIcon</SelectIcon>
                </SelectTrigger>
                <SelectPortal>
                    <SelectPositioner SideOffset="4" AlignItemWithTrigger="false">
                        <SelectPopup ClassValue="@(state => PopupClass(state))">
                            @foreach (var option in FruitItems)
                            {
                                <SelectItem TValue="string" Value="@option.Value" Label="@option.Label" ClassValue="@(state => ItemClass(state))">
                                    <SelectItemIndicator class="col-start-1">@CheckIcon</SelectItemIndicator>
                                    <SelectItemText class="col-start-2">@option.Label</SelectItemText>
                                </SelectItem>
                            }
                        </SelectPopup>
                    </SelectPositioner>
                </SelectPortal>
            </SelectRoot>

            <p class="text-sm text-gray-500">@controlledValuesMessage</p>
        </div>
    </DemoSection>

    <DemoSection Title="Controlled State and Events"
                 Description="Exercises controlled Open/Value, OpenChanged, ValueChanged, OnOpenChange canceling, OnValueChange canceling, OnOpenChangeComplete, ActionsRef, and InputRef.">
        <div class="w-full space-y-4">
            <div class="flex flex-wrap gap-2">
                <button type="button"
                        class="rounded bg-slate-900 px-3 py-1.5 text-sm text-white hover:bg-slate-700"
                        @onclick="ToggleControlledOpen">
                    Toggle open
                </button>
                <button type="button"
                        class="rounded border border-gray-300 px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-50"
                        @onclick="CancelNextOpen">
                    Cancel next open
                </button>
                <button type="button"
                        class="rounded border border-gray-300 px-3 py-1.5 text-sm text-gray-700 hover:bg-gray-50"
                        @onclick="UnmountControlledSelect">
                    Force unmount
                </button>
            </div>

            <SelectRoot TValue="string"
                        Id="controlled-select-root"
                        Open="@controlledOpen"
                        OpenChanged="HandleControlledOpenChanged"
                        Value="@controlledValue"
                        ValueChanged="HandleControlledValueChanged"
                        OnOpenChange="HandleControlledOpenChange"
                        OnOpenChangeComplete="HandleControlledOpenChangeComplete"
                        OnValueChange="HandleControlledValueChange"
                        ActionsRef="controlledActions"
                        InputRef="HandleInputRef"
                        Name="controlled-fruit"
                        Items="@FruitItems">
                <SelectTrigger Id="controlled-select-trigger" ClassValue="@(state => TriggerClass(state))">
                    <SelectValue TValue="string" Placeholder="Try selecting Date..." />
                    <SelectIcon ClassValue="@(state => IconClass(state))">@ArrowIcon</SelectIcon>
                </SelectTrigger>
                <SelectPortal KeepMounted="true">
                    <SelectPositioner SideOffset="4"
                                      AlignItemWithTrigger="false">
                        <SelectPopup ClassValue="@(state => PopupClass(state))">
                            @foreach (var option in FruitItems)
                            {
                                <SelectItem TValue="string" Value="@option.Value" Label="@option.Label" ClassValue="@(state => ItemClass(state))">
                                    <SelectItemIndicator class="col-start-1">@CheckIcon</SelectItemIndicator>
                                    <SelectItemText class="col-start-2">@option.Label</SelectItemText>
                                </SelectItem>
                            }
                        </SelectPopup>
                    </SelectPositioner>
                </SelectPortal>
            </SelectRoot>

            <div class="grid gap-1 text-sm text-gray-500 md:grid-cols-2">
                <span>Open: @controlledOpen</span>
                <span>Value: @(controlledValue ?? "none")</span>
                <span>Open event: @controlledOpenMessage</span>
                <span>Value event: @controlledValueMessage</span>
                <span>Complete: @controlledOpenCompleteMessage</span>
                <span>InputRef: @inputRefMessage</span>
            </div>
        </div>
    </DemoSection>

    <DemoSection Title="Object Values and Grouped Data"
                 Description="Uses object values, ItemGroups, ItemToStringLabel, ItemToStringValue, and IsItemEqualToValue for stable equality.">
        <SelectRoot TValue="ShippingMethod"
                    @bind-Value="shippingValue"
                    ItemGroups="@ShippingGroups"
                    ItemToStringLabel="@FormatShippingLabel"
                    ItemToStringValue="@FormatShippingValue"
                    IsItemEqualToValue="@ShippingMethodsEqual">
            <SelectTrigger ClassValue="@(state => TriggerClass(state))">
                <SelectValue TValue="ShippingMethod"
                             Placeholder="Choose shipping..."
                             ValueContent="@ShippingValueContent" />
                <SelectIcon ClassValue="@(state => IconClass(state))">@ArrowIcon</SelectIcon>
            </SelectTrigger>
            <SelectPortal>
