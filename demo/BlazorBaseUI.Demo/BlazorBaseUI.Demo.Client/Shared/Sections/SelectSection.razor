@using BlazorBaseUI.Select
@using BlazorBaseUI.Csp
@using BlazorBaseUI.DirectionProvider
@using BlazorBaseUI.Field
@using BlazorBaseUI.FloatingFocusManager

<ComponentShowcase ComponentName="Select"
                   Description="A dropdown selection component that allows users to choose one or more items from a list. Provides keyboard navigation, typeahead, and full ARIA support."
                   BaseRoute="/select"
                   IsWasmMode="IsWasmMode">

    <DemoSection Title="Basic Select"
                 Description="A simple select with string values. Click the trigger to open, then select an item.">
        <SelectRoot TValue="string" @bind-Value="basicValue">
            <SelectLabel class="cursor-default text-sm leading-5 font-bold text-gray-900">
                Fruit
            </SelectLabel>
            <SelectTrigger ClassValue="@(state => TriggerClass(state))">
                <SelectValue class="data-[placeholder]:opacity-60" TValue="string" Placeholder="Select a fruit..." />
                <SelectIcon class="flex">@ArrowIcon</SelectIcon>
            </SelectTrigger>
            <SelectPortal>
                <SelectPositioner SideOffset="4">
                    <SelectPopup ClassValue="@(state => PopupClass(state))">
                        <SelectScrollUpArrow class="top-0 z-[1] flex h-4 w-full cursor-default items-center justify-center rounded-md bg-[canvas] text-center text-xs before:absolute data-[side=none]:before:top-[-100%] before:left-0 before:h-full before:w-full before:content-['']" />
                        <SelectItem TValue="string" Value="@("apple")" Label="Apple" ClassValue="@(state => ItemClass(state))">
                            <SelectItemIndicator class="col-start-1">@CheckIcon</SelectItemIndicator>
                            <SelectItemText class="col-start-2">Apple</SelectItemText>
                        </SelectItem>
                        <SelectItem TValue="string" Value="@("banana")" Label="Banana" ClassValue="@(state => ItemClass(state))">
                            <SelectItemIndicator class="col-start-1">@CheckIcon</SelectItemIndicator>
                            <SelectItemText class="col-start-2">Banana</SelectItemText>
                        </SelectItem>
                        <SelectItem TValue="string" Value="@("cherry")" Label="Cherry" ClassValue="@(state => ItemClass(state))">
                            <SelectItemIndicator class="col-start-1">@CheckIcon</SelectItemIndicator>
                            <SelectItemText class="col-start-2">Cherry</SelectItemText>
                        </SelectItem>
                        <SelectItem TValue="string" Value="@("date")" Label="Date" ClassValue="@(state => ItemClass(state))">
                            <SelectItemIndicator class="col-start-1">@CheckIcon</SelectItemIndicator>
                            <SelectItemText class="col-start-2">Date</SelectItemText>
                        </SelectItem>
                        <SelectScrollDownArrow class="bottom-0 z-[1] flex h-4 w-full cursor-default items-center justify-center rounded-md bg-[canvas] text-center text-xs before:absolute before:left-0 before:h-full before:w-full before:content-[''] bottom-0 data-[side=none]:before:bottom-[-100%]" />
                    </SelectPopup>
                </SelectPositioner>
            </SelectPortal>
        </SelectRoot>
        <p class="mt-2 text-sm text-gray-500">Selected: @(basicValue ?? "none")</p>
    </DemoSection>

