                                <SelectItemIndicator class="col-start-1">@CheckIcon</SelectItemIndicator>
                                <SelectItemText class="col-start-2">Banana</SelectItemText>
                            </SelectItem>
                        </SelectGroup>
                        <SelectGroup>
