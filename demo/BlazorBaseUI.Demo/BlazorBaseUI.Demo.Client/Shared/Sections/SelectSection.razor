    private void HandleMultipleValueChange(SelectValueChangeEventArgs<string> args)
    {
        var values = args.Values is { Count: > 0 }
            ? string.Join(", ", args.Values)
            : "none";

        multipleChangeMessage = $"OnValueChange value: {args.Value ?? "null"}; next values: {values}";
    }

    private void HandleControlledValuesChanged(IReadOnlyList<string> values)
    {
        controlledValues = values;
        controlledValuesMessage = values.Count == 0
            ? "Controlled values: none"
            : $"Controlled values: {string.Join(", ", values)}";
    }

    private void ToggleControlledOpen()
    {
        controlledOpen = !controlledOpen;
        controlledOpenMessage = $"External Open parameter set: {controlledOpen}";
    }

    private void CancelNextOpen()
    {
        cancelControlledOpenOnce = true;
        controlledOpenMessage = "The next open request will be canceled.";
    }

    private void UnmountControlledSelect()
    {
        controlledActions.Unmount?.Invoke();
        controlledOpenMessage = "ActionsRef.Unmount invoked.";
    }

    private void HandleControlledOpenChanged(bool open)
    {
        controlledOpen = open;
        controlledOpenMessage = $"OpenChanged: {open}";
    }

    private void HandleControlledValueChanged(string? value)
    {
        controlledValue = value;
        controlledValueMessage = $"ValueChanged: {value ?? "none"}";
    }

    private void HandleControlledOpenChange(SelectOpenChangeEventArgs args)
    {
        controlledOpenMessage = $"OnOpenChange: {args.Open} via {args.Reason}";

        if (args.Open && cancelControlledOpenOnce)
        {
            args.Cancel();
            cancelControlledOpenOnce = false;
            controlledOpenMessage += " (canceled)";
        }
    }

    private void HandleControlledOpenChangeComplete(bool open)
    {
        controlledOpenCompleteMessage = $"OnOpenChangeComplete: {open}";
    }

    private void HandleControlledValueChange(SelectValueChangeEventArgs<string> args)
    {
        controlledValueMessage = $"OnValueChange: {args.Value ?? "none"}";

        if (args.Value == "date")
        {
            args.Cancel();
            controlledValueMessage += " (canceled)";
        }
    }

    private void HandleInputRef(ElementReference? element)
    {
        inputRefMessage = element.HasValue ? "Hidden input captured." : "Hidden input released.";
    }

    private static RenderFragment ArrowIcon => builder =>
