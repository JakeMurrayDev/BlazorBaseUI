@using BlazorBaseUI.Drawer

<ComponentShowcase ComponentName="Drawer"
                   Description="A panel that slides in from the edge of the screen with swipe gestures, snap points, nested stacking, and Dialog accessibility semantics."
                   BaseRoute="/drawer"
                   IsWasmMode="IsWasmMode">
    <style>
        .drawer-demo-backdrop {
            backdrop-filter: blur(2px);
            opacity: calc(var(--drawer-demo-backdrop-opacity, 0.4) * (1 - var(--drawer-swipe-progress, 0)));
            transition-duration: 240ms;
            transition-property: opacity, backdrop-filter;
            transition-timing-function: cubic-bezier(0.32, 0.72, 0, 1);
        }

        .drawer-demo-contained-backdrop {
            --drawer-demo-backdrop-opacity: 0.25;
        }

        .drawer-demo-panel {
            background: var(--demo-surface);
            border: 1px solid var(--demo-stroke-subtle);
            box-shadow: var(--demo-shadow-64);
            box-sizing: border-box;
            color: var(--demo-text);
            outline: none;
            pointer-events: auto;
            transition-duration: 260ms;
            transition-property: transform, opacity, box-shadow, height, padding-bottom;
            transition-timing-function: cubic-bezier(0.32, 0.72, 0, 1);
            will-change: transform;
        }

        .drawer-demo-side-panel {
            border-radius: var(--demo-radius-large);
            height: calc(100dvh - 24px);
            margin: 12px;
            max-width: calc(100vw - 24px);
            overflow-y: auto;
            width: min(420px, calc(100vw - 24px));
        }

        .drawer-demo-contained-side-panel {
            border-radius: 0;
            height: 100%;
            margin: 0;
            max-width: 100%;
            width: min(18rem, 100%);
        }

        .drawer-demo-sheet-panel {
            border-radius: var(--demo-radius-large) var(--demo-radius-large) 0 0;
            margin: 0 12px;
            max-height: min(76dvh, 42rem);
            min-height: 18rem;
            overflow-y: auto;
            width: min(42rem, calc(100vw - 24px));
        }

        .drawer-demo-contained-sheet-panel {
            margin: 0 12px 12px;
            max-height: calc(100% - 24px);
            width: min(42rem, calc(100% - 24px));
        }

        .drawer-demo-top-panel {
            border-radius: 0 0 var(--demo-radius-large) var(--demo-radius-large);
            margin: 0 12px;
            max-height: min(70dvh, 34rem);
            min-height: 14rem;
            overflow-y: auto;
            width: min(42rem, calc(100vw - 24px));
        }

        .drawer-demo-stacked-panel {
            max-height: min(76dvh, 42rem);
            min-height: 22rem;
            overflow-y: auto;
        }

        .drawer-demo-snap-panel {
            border-radius: var(--demo-radius-large) var(--demo-radius-large) 0 0;
            display: flex;
            flex-direction: column;
            height: min(calc(100dvh - var(--top-margin, 1rem) - 16px), 44rem);
            margin: 0 12px;
            max-height: calc(100dvh - var(--top-margin, 1rem) - 16px);
            overflow: hidden;
            width: min(46rem, calc(100vw - 24px));
        }

        .drawer-demo-mobile-panel {
            border-radius: var(--demo-radius-large) var(--demo-radius-large) 0 0;
            display: flex;
            flex-direction: column;
            height: min(42rem, calc(100dvh - 24px));
            margin: 0 12px;
            overflow: hidden;
            width: min(40rem, calc(100vw - 24px));
        }

        .drawer-demo-action-panel {
            background: transparent;
            border: 0;
            box-shadow: none;
            display: grid;
            gap: 8px;
            margin: 0 auto 12px;
            padding: 0 12px;
            width: min(30rem, 100vw);
        }

        .drawer-demo-action-card {
            background: var(--demo-surface);
            border: 1px solid var(--demo-stroke-subtle);
            border-radius: var(--demo-radius-large);
            box-shadow: var(--demo-shadow-16);
            overflow: hidden;
        }

        .drawer-demo-contained-host {
            background: var(--demo-surface-subtle);
            border: 1px solid var(--demo-stroke);
            border-radius: var(--demo-radius-large);
            box-sizing: border-box;
            min-height: 16rem;
            overflow: hidden;
            position: relative;
            width: min(100%, 36rem);
        }

        .drawer-demo-swipe-host {
            min-height: 15rem;
            width: min(100%, 36rem);
        }

        .drawer-demo-side-content {
            display: flex;
            flex-direction: column;
            gap: 16px;
            min-height: 100%;
            padding: 24px;
        }

        .drawer-demo-side-content > :last-child {
            display: flex;
            justify-content: flex-end;
            margin-top: auto;
        }

        .drawer-demo-sheet-content {
            margin: 0 auto;
            max-width: 32rem;
            padding: 0 24px 24px;
            width: 100%;
        }

        .drawer-demo-snap-scroll {
            flex: 1 1 auto;
            min-height: 0;
            overflow-y: auto;
            overscroll-behavior: contain;
            padding: 16px 24px 24px;
        }

        .drawer-demo-grabber {
            background: var(--demo-stroke-strong);
            border-radius: 999px;
            display: block;
            height: 4px;
            margin: 0 auto 16px;
            width: 48px;
        }

        .drawer-demo-snap[data-ending-style],
        .drawer-demo-snap[data-starting-style],
        .drawer-demo-stacked[data-ending-style],
        .drawer-demo-stacked[data-starting-style] {
            transform: translateY(100%);
        }

        .drawer-demo-backdrop[data-swiping],
        .drawer-demo-panel[data-swiping] {
            transition-duration: 0ms;
        }

        .drawer-demo-backdrop[data-ending-style],
        .drawer-demo-backdrop[data-starting-style],
        .drawer-demo-panel[data-ending-style],
        .drawer-demo-panel[data-starting-style] {
            opacity: 0;
        }

        .drawer-demo-from-bottom {
            transform: translateY(var(--drawer-swipe-movement-y, 0px));
        }

        .drawer-demo-from-top {
            transform: translateY(var(--drawer-swipe-movement-y, 0px));
        }

        .drawer-demo-from-right {
            transform: translateX(var(--drawer-swipe-movement-x, 0px));
        }

        .drawer-demo-from-left {
            transform: translateX(var(--drawer-swipe-movement-x, 0px));
        }

        .drawer-demo-from-bottom[data-ending-style],
        .drawer-demo-from-bottom[data-starting-style] {
            transform: translateY(100%);
        }

        .drawer-demo-from-top[data-ending-style],
        .drawer-demo-from-top[data-starting-style] {
            transform: translateY(-100%);
        }

        .drawer-demo-from-right[data-ending-style],
        .drawer-demo-from-right[data-starting-style] {
            transform: translateX(100%);
        }

        .drawer-demo-from-left[data-ending-style],
        .drawer-demo-from-left[data-starting-style] {
            transform: translateX(-100%);
        }

        .drawer-demo-stacked {
            transform: translateY(calc(var(--drawer-swipe-movement-y, 0px) - (var(--nested-drawers, 0) * 0.75rem))) scale(calc(1 - (var(--nested-drawers, 0) * 0.05)));
            transform-origin: 50% calc(100% - 3rem);
        }

        .drawer-demo-snap {
            padding-bottom: max(0px, calc(var(--drawer-snap-point-offset, 0px) + var(--drawer-swipe-movement-y, 0px)));
            transform: translateY(calc(var(--drawer-snap-point-offset, 0px) + var(--drawer-swipe-movement-y, 0px)));
        }

        .drawer-demo-panel[data-open] .drawer-demo-reveal {
            animation: drawer-demo-content-in 320ms cubic-bezier(0.16, 1, 0.3, 1) 110ms both;
        }

        .drawer-demo-panel[data-open] .drawer-demo-grabber {
            animation: drawer-demo-grabber-in 360ms cubic-bezier(0.16, 1, 0.3, 1) 80ms both;
        }

        .drawer-demo-swipe-rail::after {
            animation: drawer-demo-rail-pulse 1.8s ease-in-out infinite;
            background: currentColor;
            border-radius: 9999px;
            content: "";
            height: 4rem;
            opacity: 0.16;
            position: absolute;
            right: 0.45rem;
            width: 0.25rem;
        }

        @@keyframes drawer-demo-content-in {
            from {
                opacity: 0;
                transform: translateY(0.75rem);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes drawer-demo-grabber-in {
            from {
                opacity: 0;
                transform: scaleX(0.45);
            }

            to {
                opacity: 1;
                transform: scaleX(1);
            }
        }

        @@keyframes drawer-demo-rail-pulse {
            0%, 100% {
                opacity: 0.12;
                transform: translateY(-0.35rem);
            }

            50% {
                opacity: 0.34;
                transform: translateY(0.35rem);
            }
        }

        @@media (prefers-reduced-motion: reduce) {
            .drawer-demo-panel,
            .drawer-demo-backdrop,
            .drawer-demo-panel *,
            .drawer-demo-swipe-rail::after {
                animation-duration: 1ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 1ms !important;
            }
        }
    </style>

    <DemoSection Title="Hero: Side Drawer"
                 Description="The source documentation hero uses a side drawer that swipes to the right to dismiss.">
        <DrawerRoot SwipeDirection="DrawerSwipeDirection.Right">
            <DrawerTrigger ClassValue="@(_ => TriggerClass)">
                Open drawer
            </DrawerTrigger>
            <DrawerPortal>
                <DrawerBackdrop ClassValue="@(_ => BackdropClass)" />
                <DrawerViewport ClassValue="@(_ => RightViewportClass)">
                    <DrawerPopup ClassValue="@(_ => RightPopupClass)">
                        <DrawerContent class="drawer-demo-reveal drawer-demo-side-content">
                            <DrawerTitle class="text-lg font-semibold text-gray-950">
                                Drawer
                            </DrawerTitle>
                            <DrawerDescription class="mt-2 text-sm text-gray-600">
                                This is a drawer that slides in from the side. You can swipe to dismiss it.
                            </DrawerDescription>
                            <div class="mt-auto flex justify-end">
                                <DrawerClose ClassValue="@(_ => SecondaryButtonClass)">
                                    Close
                                </DrawerClose>
                            </div>
                        </DrawerContent>
                    </DrawerPopup>
                </DrawerViewport>
            </DrawerPortal>
        </DrawerRoot>
    </DemoSection>

    <DemoSection Title="Controlled State"
                 Description="Drawer supports both uncontrolled state and explicit Open/OpenChanged state control.">
        <div class="grid gap-4 lg:grid-cols-2">
            <div class="rounded border border-gray-200 bg-white p-4">
                <p class="mb-3 text-sm font-medium text-gray-900">Uncontrolled drawer</p>
                <DrawerRoot>
                    <DrawerTrigger ClassValue="@(_ => TriggerClass)">
                        Open uncontrolled
                    </DrawerTrigger>
                    <DrawerPortal>
                        <DrawerBackdrop ClassValue="@(_ => BackdropClass)" />
                        <DrawerViewport ClassValue="@(_ => BottomViewportClass)">
                            <DrawerPopup ClassValue="@(_ => BottomPopupClass)">
                                <div class="@HandleClass"></div>
                                <DrawerContent class="@SheetContentClass">
                                    <DrawerTitle class="@SheetTitleClass">Example drawer</DrawerTitle>
                                    <DrawerDescription class="@SheetDescriptionClass">
                                        This drawer owns its open state.
                                    </DrawerDescription>
                                    <div class="flex justify-center">
                                        <DrawerClose ClassValue="@(_ => SecondaryButtonClass)">
                                            Close
                                        </DrawerClose>
                                    </div>
                                </DrawerContent>
                            </DrawerPopup>
                        </DrawerViewport>
                    </DrawerPortal>
                </DrawerRoot>
            </div>

            <div class="rounded border border-gray-200 bg-white p-4">
                <p class="mb-3 text-sm font-medium text-gray-900">
                    Controlled drawer: <span class="font-mono text-xs">@(controlledOpen ? "open" : "closed")</span>
                </p>
                <div class="flex flex-wrap gap-2">
                    <button type="button" class="@TriggerClass" @onclick="@(() => controlledOpen = true)">
                        Open controlled
                    </button>
                    <button type="button" class="@SecondaryButtonClass" @onclick="@(() => controlledOpen = false)">
                        Close controlled
                    </button>
                </div>
                <DrawerRoot Open="controlledOpen"
                            OpenChanged="HandleControlledOpenChanged">
                    <DrawerPortal>
                        <DrawerBackdrop ClassValue="@(_ => BackdropClass)" />
                        <DrawerViewport ClassValue="@(_ => BottomViewportClass)">
                            <DrawerPopup ClassValue="@(_ => BottomPopupClass)">
                                <div class="@HandleClass"></div>
                                <DrawerContent class="@SheetContentClass">
                                    <DrawerTitle class="@SheetTitleClass">Controlled drawer</DrawerTitle>
                                    <DrawerDescription class="@SheetDescriptionClass">
                                        External state drives this drawer and receives updates from close interactions.
                                    </DrawerDescription>
                                    <div class="flex justify-center">
                                        <DrawerClose ClassValue="@(_ => SecondaryButtonClass)">
                                            Close
                                        </DrawerClose>
                                    </div>
                                </DrawerContent>
                            </DrawerPopup>
                        </DrawerViewport>
                    </DrawerPortal>
                </DrawerRoot>
            </div>
        </div>
    </DemoSection>

    <DemoSection Title="Position"
                 Description="Positioning is handled by styles; swipe direction selects the dismissal axis.">
        <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
            <DrawerRoot SwipeDirection="DrawerSwipeDirection.Down">
                <DrawerTrigger ClassValue="@(_ => TriggerClass)">Bottom</DrawerTrigger>
                <DrawerPortal>
                    <DrawerBackdrop ClassValue="@(_ => BackdropClass)" />
                    <DrawerViewport ClassValue="@(_ => BottomViewportClass)">
                        <DrawerPopup ClassValue="@(_ => BottomPopupClass)">
                            <div class="@HandleClass"></div>
                            <DrawerContent class="@SheetContentClass">
                                <DrawerTitle class="@SheetTitleClass">Notifications</DrawerTitle>
                                <DrawerDescription class="@SheetDescriptionClass">
                                    You are all caught up. Good job!
                                </DrawerDescription>
                                <div class="flex justify-center">
                                    <DrawerClose ClassValue="@(_ => SecondaryButtonClass)">Close</DrawerClose>
                                </div>
                            </DrawerContent>
                        </DrawerPopup>
                    </DrawerViewport>
                </DrawerPortal>
            </DrawerRoot>

            <DrawerRoot SwipeDirection="DrawerSwipeDirection.Right">
                <DrawerTrigger ClassValue="@(_ => TriggerClass)">Right</DrawerTrigger>
                <DrawerPortal>
                    <DrawerBackdrop ClassValue="@(_ => BackdropClass)" />
                    <DrawerViewport ClassValue="@(_ => RightViewportClass)">
                        <DrawerPopup ClassValue="@(_ => RightPopupClass)">
                            <DrawerContent class="drawer-demo-reveal drawer-demo-side-content">
                                <DrawerTitle class="@SideTitleClass">Right drawer</DrawerTitle>
                                <DrawerDescription class="@SideDescriptionClass">
                                    Swipe right to dismiss this side panel.
                                </DrawerDescription>
                                <div class="mt-auto flex justify-end">
                                    <DrawerClose ClassValue="@(_ => SecondaryButtonClass)">Close</DrawerClose>
                                </div>
                            </DrawerContent>
                        </DrawerPopup>
                    </DrawerViewport>
                </DrawerPortal>
            </DrawerRoot>

            <DrawerRoot SwipeDirection="DrawerSwipeDirection.Left">
                <DrawerTrigger ClassValue="@(_ => TriggerClass)">Left</DrawerTrigger>
                <DrawerPortal>
                    <DrawerBackdrop ClassValue="@(_ => BackdropClass)" />
                    <DrawerViewport ClassValue="@(_ => LeftViewportClass)">
                        <DrawerPopup ClassValue="@(_ => LeftPopupClass)">
                            <DrawerContent class="drawer-demo-reveal drawer-demo-side-content">
                                <DrawerTitle class="@SideTitleClass">Left drawer</DrawerTitle>
                                <DrawerDescription class="@SideDescriptionClass">
                                    Swipe left to dismiss this side panel.
                                </DrawerDescription>
                                <div class="mt-auto flex justify-end">
                                    <DrawerClose ClassValue="@(_ => SecondaryButtonClass)">Close</DrawerClose>
                                </div>
                            </DrawerContent>
                        </DrawerPopup>
                    </DrawerViewport>
                </DrawerPortal>
            </DrawerRoot>

            <DrawerRoot SwipeDirection="DrawerSwipeDirection.Up">
                <DrawerTrigger ClassValue="@(_ => TriggerClass)">Top</DrawerTrigger>
                <DrawerPortal>
                    <DrawerBackdrop ClassValue="@(_ => BackdropClass)" />
                    <DrawerViewport ClassValue="@(_ => TopViewportClass)">
                        <DrawerPopup ClassValue="@(_ => TopPopupClass)">
                            <DrawerContent class="@SheetContentClass">
                                <DrawerTitle class="@SheetTitleClass">Top drawer</DrawerTitle>
                                <DrawerDescription class="@SheetDescriptionClass">
                                    Swipe up to dismiss this top sheet.
                                </DrawerDescription>
                                <div class="flex justify-center">
                                    <DrawerClose ClassValue="@(_ => SecondaryButtonClass)">Close</DrawerClose>
                                </div>
                            </DrawerContent>
                        </DrawerPopup>
                    </DrawerViewport>
                </DrawerPortal>
            </DrawerRoot>
        </div>
    </DemoSection>

    <DemoSection Title="Nested Drawers"
                 Description="Nested drawers expose stack depth and frontmost height through data attributes and CSS variables.">
        <DrawerRoot Context="accountDrawerContext">
            <DrawerTrigger ClassValue="@(_ => TriggerClass)">
                Open drawer stack
            </DrawerTrigger>
            <DrawerPortal>
                <DrawerBackdrop ClassValue="@(_ => BackdropClass)" />
                <DrawerViewport ClassValue="@(_ => BottomViewportClass)">
                    <DrawerPopup ClassValue="@(_ => StackedPopupClass)">
                        <div class="@HandleClass"></div>
                        <DrawerContent class="@StackedContentClass">
                            <DrawerTitle class="@SheetTitleClass">Account</DrawerTitle>
                            <DrawerDescription class="@SheetDescriptionClass">
                                Nested drawers can be styled to stack, while each drawer remains independently focus managed.
                            </DrawerDescription>

                            <div class="flex flex-wrap items-center justify-between gap-3">
                                <DrawerRoot Context="securityDrawerContext">
                                    <DrawerTrigger ClassValue="@(_ => TriggerClass)">
                                        Security settings
                                    </DrawerTrigger>
                                    <DrawerPortal>
                                        <DrawerViewport ClassValue="@(_ => BottomViewportClass)">
                                            <DrawerPopup ClassValue="@(_ => StackedPopupClass)">
                                                <div class="@HandleClass"></div>
                                                <DrawerContent class="@StackedContentClass">
                                                    <DrawerTitle class="@SheetTitleClass">Security</DrawerTitle>
                                                    <DrawerDescription class="@SheetDescriptionClass">
                                                        Review sign-in activity and update your security preferences.
                                                    </DrawerDescription>
                                                    <ul class="mb-6 space-y-2 text-sm text-gray-700">
                                                        <li>Passkeys enabled</li>
                                                        <li>2FA via authenticator app</li>
                                                        <li>3 signed-in devices</li>
                                                    </ul>
                                                    <div class="flex flex-wrap items-center justify-between gap-3">
                                                        <DrawerRoot Context="advancedDrawerContext">
                                                            <DrawerTrigger ClassValue="@(_ => TriggerClass)">
                                                                Advanced options
                                                            </DrawerTrigger>
                                                            <DrawerPortal>
                                                                <DrawerViewport ClassValue="@(_ => BottomViewportClass)">
                                                                    <DrawerPopup ClassValue="@(_ => StackedPopupClass)">
                                                                        <div class="@HandleClass"></div>
                                                                        <DrawerContent class="@StackedContentClass">
                                                                            <DrawerTitle class="@SheetTitleClass">Advanced</DrawerTitle>
                                                                            <DrawerDescription class="@SheetDescriptionClass">
                                                                                This drawer is taller to demonstrate variable-height stacking.
                                                                            </DrawerDescription>
                                                                            <div class="grid gap-4 text-sm">
                                                                                <label class="grid gap-1">
                                                                                    <span class="font-medium text-gray-900">Device name</span>
                                                                                    <input class="@InputClass" value="Personal laptop" data-blazor-base-ui-swipe-ignore="true" />
                                                                                </label>
                                                                                <label class="grid gap-1">
                                                                                    <span class="font-medium text-gray-900">Notes</span>
                                                                                    <textarea class="@InputClass" rows="3" data-blazor-base-ui-swipe-ignore="true">Rotate recovery codes and revoke older sessions.</textarea>
                                                                                </label>
                                                                            </div>
                                                                            <div class="mt-6 flex justify-end">
                                                                                <DrawerClose ClassValue="@(_ => SecondaryButtonClass)">
                                                                                    Done
                                                                                </DrawerClose>
                                                                            </div>
                                                                        </DrawerContent>
                                                                    </DrawerPopup>
                                                                </DrawerViewport>
                                                            </DrawerPortal>
                                                        </DrawerRoot>
                                                        <DrawerClose ClassValue="@(_ => SecondaryButtonClass)">Close</DrawerClose>
                                                    </div>
                                                </DrawerContent>
                                            </DrawerPopup>
                                        </DrawerViewport>
                                    </DrawerPortal>
                                </DrawerRoot>
                                <DrawerClose ClassValue="@(_ => SecondaryButtonClass)">Close</DrawerClose>
                            </div>
                        </DrawerContent>
                    </DrawerPopup>
                </DrawerViewport>
            </DrawerPortal>
        </DrawerRoot>
    </DemoSection>

    <DemoSection Title="Snap Points"
                 Description="Snap points constrain a bottom sheet to preset visible heights and expose the active point to Blazor state.">
        <div class="flex flex-col gap-3">
            <div class="text-sm text-gray-700">
                Active snap point: <span class="font-mono">@FormatSnapPoint(activeSnapPoint)</span>
            </div>
            <DrawerRoot SnapPoints="sourceSnapPoints"
                        @bind-SnapPoint="activeSnapPoint"
                        DefaultSnapPoint="@((DrawerSnapPoint)"31rem")">
                <DrawerTrigger ClassValue="@(_ => TriggerClass)">
                    Open snap drawer
                </DrawerTrigger>
                <DrawerPortal>
                    <DrawerBackdrop ClassValue="@(_ => BackdropClass)" />
                    <DrawerViewport ClassValue="@(_ => SnapViewportClass)">
                        <DrawerPopup ClassValue="@(_ => SnapPopupClass)" StyleValue="@(_ => "--top-margin: 1rem;")">
                            <div class="@DragAreaClass">
                                <div class="@HandleClass"></div>
                                <DrawerTitle class="@SheetTitleClass">Snap points</DrawerTitle>
                            </div>
                            <DrawerContent class="@SnapScrollClass">
                                <div class="mx-auto w-full max-w-[32rem]">
                                    <DrawerDescription class="@SheetDescriptionClass">
                                        Drag the sheet to snap between a compact peek and a near full-height view.
                                    </DrawerDescription>
                                    <div class="grid grid-cols-4 gap-2" aria-hidden="true">
                                        @for (var i = 0; i < 20; i++)
                                        {
                                            <div class="h-10 rounded border border-gray-200 bg-gray-100"></div>
                                        }
                                    </div>
                                    <div class="mt-6 flex justify-center">
                                        <DrawerClose ClassValue="@(_ => SecondaryButtonClass)">
                                            Close
                                        </DrawerClose>
                                    </div>
                                </div>
                            </DrawerContent>
                        </DrawerPopup>
                    </DrawerViewport>
                </DrawerPortal>
            </DrawerRoot>
        </div>
    </DemoSection>

    <DemoSection Title="Indent Effect"
                 Description="DrawerProvider marks background and indent surfaces active while any nested drawer is open.">
        <DrawerProvider>
            <div id="drawer-indent-demo" class="drawer-demo-contained-host relative overflow-hidden rounded border border-gray-200 bg-gray-50 p-5">
                <DrawerIndentBackground class="absolute inset-0 bg-slate-200 opacity-0 transition data-[active]:opacity-100"></DrawerIndentBackground>
                <DrawerIndent class="relative rounded border border-gray-300 bg-white p-5 transition data-[active]:scale-[0.96] data-[active]:shadow-xl">
                    <div class="flex min-h-40 items-center justify-center">
                        <DrawerRoot Modal="DrawerModalMode.False">
                            <DrawerTrigger ClassValue="@(_ => TriggerClass)">
                                Open drawer
                            </DrawerTrigger>
                            <DrawerPortal Container="#drawer-indent-demo">
                                <DrawerBackdrop ClassValue="@(_ => ContainedBackdropClass)" />
                                <DrawerViewport ClassValue="@(_ => ContainedBottomViewportClass)">
                                    <DrawerPopup ClassValue="@(_ => ContainedBottomPopupClass)">
                                        <div class="@HandleClass"></div>
                                        <DrawerContent class="@SheetContentClass">
                                            <DrawerTitle class="@SheetTitleClass">Notifications</DrawerTitle>
                                            <DrawerDescription class="@SheetDescriptionClass">
                                                You are all caught up. Good job!
                                            </DrawerDescription>
                                            <div class="flex justify-center">
                                                <DrawerClose ClassValue="@(_ => SecondaryButtonClass)">Close</DrawerClose>
                                            </div>
                                        </DrawerContent>
                                    </DrawerPopup>
                                </DrawerViewport>
                            </DrawerPortal>
                        </DrawerRoot>
                    </div>
                </DrawerIndent>
            </div>
        </DrawerProvider>
    </DemoSection>

    <DemoSection Title="Non-modal"
                 Description="Set Modal to False and DisablePointerDismissal to keep the page interactive while the drawer is open.">
        <DrawerRoot SwipeDirection="DrawerSwipeDirection.Right"
                    Modal="DrawerModalMode.False"
                    DisablePointerDismissal="true">
            <DrawerTrigger ClassValue="@(_ => TriggerClass)">
                Open non-modal drawer
            </DrawerTrigger>
            <DrawerPortal>
                <DrawerViewport ClassValue="@(_ => RightViewportClass)">
                    <DrawerPopup ClassValue="@(_ => RightPopupClass)">
                        <DrawerContent class="drawer-demo-reveal drawer-demo-side-content">
                            <DrawerTitle class="@SideTitleClass">Non-modal drawer</DrawerTitle>
                            <DrawerDescription class="@SideDescriptionClass">
                                This drawer does not trap focus and ignores outside clicks. Use the close button or swipe to dismiss it.
                            </DrawerDescription>
                            <div class="mt-auto flex justify-end">
                                <DrawerClose ClassValue="@(_ => SecondaryButtonClass)">Close</DrawerClose>
                            </div>
                        </DrawerContent>
                    </DrawerPopup>
                </DrawerViewport>
            </DrawerPortal>
        </DrawerRoot>
    </DemoSection>

    <DemoSection Title="Mobile Navigation"
                 Description="A full-height navigation sheet with a scrollable list and flick-down dismissal from the top.">
        <DrawerRoot>
            <DrawerTrigger ClassValue="@(_ => TriggerClass)">
                Open mobile menu
            </DrawerTrigger>
            <DrawerPortal>
                <DrawerBackdrop ClassValue="@(_ => BackdropClass)" />
                <DrawerViewport ClassValue="@(_ => BottomViewportClass)">
                    <DrawerPopup ClassValue="@(_ => MobileNavPopupClass)">
                        <nav aria-label="Navigation" class="drawer-demo-reveal flex h-full flex-col">
                            <div class="grid grid-cols-[2rem_1fr_2rem] items-center px-4 py-3">
                                <span aria-hidden="true"></span>
                                <div class="@HandleClass"></div>
                                <DrawerClose aria-label="Close menu" ClassValue="@(_ => IconButtonClass)">
                                    x
                                </DrawerClose>
                            </div>
                            <DrawerContent class="min-h-0 flex-1 overflow-y-auto px-6 pb-8">
                                <DrawerTitle class="text-center text-base font-semibold text-gray-950">Menu</DrawerTitle>
                                <DrawerDescription class="mt-1 text-center text-sm text-gray-600">
                                    Scroll the long list. Flick down from the top to dismiss.
                                </DrawerDescription>
                                <ul class="mt-6 space-y-2">
                                    @foreach (var item in mobileNavPrimaryItems)
                                    {
                                        <li>
                                            <a class="@MobileNavLinkClass" href="@item.Href">@item.Label</a>
                                        </li>
                                    }
                                </ul>
                                <ul class="mt-6 space-y-2 border-t border-gray-200 pt-6" aria-label="Component links">
                                    @foreach (var item in mobileNavComponentItems)
                                    {
                                        <li>
                                            <a class="@MobileNavLinkClass" href="@item.Href">@item.Label</a>
                                        </li>
                                    }
                                </ul>
                            </DrawerContent>
                        </nav>
                    </DrawerPopup>
                </DrawerViewport>
            </DrawerPortal>
        </DrawerRoot>
    </DemoSection>

    <DemoSection Title="Swipe to Open"
                 Description="DrawerSwipeArea can be placed at an edge to open the drawer with a swipe gesture.">
        <div id="drawer-swipe-area-demo" class="drawer-demo-contained-host drawer-demo-swipe-host relative min-h-60 overflow-hidden rounded border border-gray-200 bg-gray-50">
            <DrawerRoot SwipeDirection="DrawerSwipeDirection.Right"
                        Modal="DrawerModalMode.False">
                <DrawerSwipeArea ClassValue="@(_ => SwipeAreaClass)">
                    <span class="rotate-180 text-xs font-medium text-gray-600 [writing-mode:vertical-rl]">Swipe here</span>
                </DrawerSwipeArea>
                <div class="flex min-h-60 items-center justify-center px-6 text-center text-sm text-gray-600">
                    Swipe from the right edge to open the drawer.
                </div>
                <DrawerPortal Container="#drawer-swipe-area-demo">
                    <DrawerBackdrop ClassValue="@(_ => ContainedBackdropClass)" />
                    <DrawerViewport ClassValue="@(_ => ContainedRightViewportClass)">
                        <DrawerPopup ClassValue="@(_ => ContainedRightPopupClass)">
                            <DrawerContent class="drawer-demo-reveal drawer-demo-side-content">
                                <DrawerTitle class="@SideTitleClass">Library</DrawerTitle>
                                <DrawerDescription class="@SideDescriptionClass">
                                    Swipe from the edge whenever you want to jump back into your playlists.
                                </DrawerDescription>
                                <div class="mt-auto flex justify-end">
                                    <DrawerClose ClassValue="@(_ => SecondaryButtonClass)">Close</DrawerClose>
                                </div>
                            </DrawerContent>
                        </DrawerPopup>
                    </DrawerViewport>
                </DrawerPortal>
            </DrawerRoot>
        </div>
    </DemoSection>

    <DemoSection Title="Action Sheet"
                 Description="An uncontained action sheet can group regular actions separately from a destructive action.">
        <DrawerRoot Open="actionSheetOpen"
                    OpenChanged="HandleActionSheetOpenChanged">
            <DrawerTrigger ClassValue="@(_ => TriggerClass)">
                Open action sheet
            </DrawerTrigger>
            <DrawerPortal>
                <DrawerBackdrop ClassValue="@(_ => BackdropClass)" />
                <DrawerViewport ClassValue="@(_ => BottomViewportClass)">
                    <DrawerPopup ClassValue="@(_ => ActionSheetPopupClass)">
                        <DrawerContent class="drawer-demo-action-card">
                            <DrawerTitle class="sr-only">Profile actions</DrawerTitle>
                            <DrawerDescription class="sr-only">
                                Choose an action for this user.
                            </DrawerDescription>
                            <ul class="divide-y divide-gray-200" aria-label="Profile actions">
                                @foreach (var action in actionSheetActions)
                                {
                                    <li>
                                        @if (action == actionSheetActions[0])
                                        {
                                            <DrawerClose class="sr-only">Close action sheet</DrawerClose>
                                        }
                                        <button type="button" class="@ActionSheetButtonClass" @onclick="CloseActionSheet">
                                            @action
                                        </button>
                                    </li>
                                }
                            </ul>
                        </DrawerContent>
                        <div class="drawer-demo-action-card">
                            <button type="button" class="@DangerActionButtonClass" @onclick="CloseActionSheet">
                                Block User
                            </button>
                        </div>
                    </DrawerPopup>
                </DrawerViewport>
            </DrawerPortal>
        </DrawerRoot>
    </DemoSection>

    <DemoSection Title="Detached Triggers"
                 Description="A Drawer handle connects triggers outside the root and passes payload data into shared drawer content.">
        <div class="flex flex-col gap-4">
            <div class="flex flex-wrap gap-2">
                <DrawerTypedTrigger TPayload="string"
                                    Handle="@detachedDrawerHandle"
                                    Id="profile-drawer-trigger"
                                    Payload="@("Profile")"
                                    ClassValue="@(_ => TriggerClass)">
                    Profile
                </DrawerTypedTrigger>
                <DrawerTypedTrigger TPayload="string"
                                    Handle="@detachedDrawerHandle"
                                    Id="settings-drawer-trigger"
                                    Payload="@("Settings")"
                                    ClassValue="@(_ => TriggerClass)">
                    Settings
                </DrawerTypedTrigger>
            </div>

            <DrawerRoot Handle="@detachedDrawerHandle">
                @{
                    var payload = context.Payload?.ToString() ?? "Select a trigger";
                }
                <DrawerPortal>
                    <DrawerBackdrop ClassValue="@(_ => BackdropClass)" />
                    <DrawerViewport ClassValue="@(_ => BottomViewportClass)">
                        <DrawerPopup ClassValue="@(_ => BottomPopupClass)">
                            <div class="@HandleClass"></div>
                            <DrawerContent class="@SheetContentClass">
                                <DrawerTitle class="@SheetTitleClass">@payload</DrawerTitle>
                                <DrawerDescription class="@SheetDescriptionClass">
                                    This content is rendered next to the root and selected by a detached trigger payload.
                                </DrawerDescription>
                                <div class="flex justify-center">
                                    <DrawerClose ClassValue="@(_ => SecondaryButtonClass)">
                                        Close
                                    </DrawerClose>
                                </div>
                            </DrawerContent>
                        </DrawerPopup>
                    </DrawerViewport>
                </DrawerPortal>
            </DrawerRoot>
        </div>
    </DemoSection>
</ComponentShowcase>

