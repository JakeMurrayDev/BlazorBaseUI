@inherits LayoutComponentBase

<div class="demo-app-shell" data-theme="light" data-nav-open="false">
    <div class="demo-mobile-scrim" data-demo-mobile-scrim></div>

    <aside id="demo-nav-panel" class="demo-nav-panel" aria-label="Component catalog">
        <NavMenu />
    </aside>

    <div class="demo-app-frame">
        <header class="demo-command-bar">
            <div class="demo-command-bar__left">
                <MobileNavToggle />

                <a class="demo-brand" href="">
                    <span class="demo-brand__mark" aria-hidden="true">
                        <span></span>
                        <span></span>
                        <span></span>
                        <span></span>
                    </span>
                    <span class="demo-brand__text">
                        <span>BlazorBaseUI</span>
                        <span>Fluent demo console</span>
                    </span>
                </a>
            </div>

            <div class="demo-command-search" aria-hidden="true">
                <span></span>
                <span>Search components, props, examples</span>
            </div>

            <div class="demo-command-bar__right">
                <span class="demo-version-chip">v0.0.1-alpha</span>
                <ThemeToggle />
            </div>
        </header>

        <main class="demo-main">
            <div class="demo-main__inner">
                @Body
            </div>
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>
