<nav class="demo-nav" aria-label="BlazorBaseUI demo navigation">
    <div class="demo-nav__header">
        <span class="demo-nav__eyebrow">Catalog</span>
        <strong>27 primitives</strong>
    </div>

    <div class="demo-nav__scroll">
        <div class="demo-nav__section">
            <span class="demo-nav__section-label">Overview</span>
            <NavLink class="demo-nav__link"
                     ActiveClass="demo-nav__link--active"
                     href=""
                     Match="NavLinkMatch.All">
                <span>Overview</span>
            </NavLink>
        </div>

        @NavSection("Inputs", new[]
        {
            ("autocomplete", "Autocomplete", true),
            ("button", "Button", true),
            ("checkbox", "Checkbox", true),
            ("checkbox-group", "Checkbox Group", true),
            ("field", "Field", true),
            ("fieldset", "Fieldset", true),
            ("form", "Form", true),
            ("input", "Input", false),
            ("number-field", "Number Field", true),
            ("radio", "Radio", true),
            ("select", "Select", true),
            ("slider", "Slider", true),
            ("switch", "Switch", true),
            ("toggle", "Toggle", true),
            ("toggle-group", "Toggle Group", true)
        })

        @NavSection("Overlays", new[]
        {
            ("alert-dialog", "Alert Dialog", true),
            ("context-menu", "Context Menu", true),
            ("dialog", "Dialog", true),
            ("menu", "Menu", true),
            ("menubar", "Menubar", true),
            ("popover", "Popover", true),
            ("preview-card", "Preview Card", true),
            ("tooltip", "Tooltip", true)
        })

        @NavSection("Navigation", new[]
        {
            ("accordion", "Accordion", true),
            ("collapsible", "Collapsible", true),
            ("navigation-menu", "Navigation Menu", true),
            ("tabs", "Tabs", true),
            ("toolbar", "Toolbar", true)
        })

        @NavSection("Feedback", new[]
        {
            ("avatar", "Avatar", true),
            ("meter", "Meter", true),
            ("progress", "Progress", true),
            ("separator", "Separator", true),
            ("toast", "Toast", false)
        })

        @NavSection("Utilities", new[]
        {
            ("direction-provider", "Direction Provider", false),
            ("scroll-area", "Scroll Area", false)
        })
    </div>
</nav>

@code {
    private RenderFragment NavSection(string title, IEnumerable<(string Href, string Text, bool Enabled)> links) => __builder =>
    {
        <div class="demo-nav__section">
            <span class="demo-nav__section-label">@title</span>
            @foreach (var link in links)
            {
                @if (link.Enabled)
                {
                    <NavLink class="demo-nav__link"
                             ActiveClass="demo-nav__link--active"
                             href="@link.Href">
                        <span>@link.Text</span>
                    </NavLink>
                }
                else
                {
                    <span class="demo-nav__link demo-nav__link--disabled" aria-disabled="true">
                        <span>@link.Text</span>
                    </span>
                }
            }
        </div>
    };
}
