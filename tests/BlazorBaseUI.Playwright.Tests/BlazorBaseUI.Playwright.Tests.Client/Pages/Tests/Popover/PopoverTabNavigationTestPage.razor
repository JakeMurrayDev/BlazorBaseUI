@page "/tests/popover-tab/wasm"
@using BlazorBaseUI.Popover
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Popover Tab Navigation Test Page (WASM)</PageTitle>

<div data-testid="test-container" data-interactive="@RendererInfo.IsInteractive.ToString().ToLowerInvariant()">
    @if (Layout == "before-trigger")
    {
        <PopoverRoot @bind-Open="isOpen" DefaultOpen="@DefaultOpen" Modal="@(Modal ? ModalMode.True : ModalMode.False)">
            <PopoverPortal>
                <PopoverPositioner data-testid="popover-positioner">
                    <PopoverPopup data-testid="popover-popup">
                        <button data-testid="popup-first">First in Popup</button>
                        <button data-testid="popup-last">Last in Popup</button>
                    </PopoverPopup>
                </PopoverPositioner>
            </PopoverPortal>
            <PopoverTrigger data-testid="popover-trigger">Open Popover</PopoverTrigger>
        </PopoverRoot>
    }
    else if (Layout == "between")
    {
        <PopoverRoot @bind-Open="isOpen" DefaultOpen="@DefaultOpen" Modal="@(Modal ? ModalMode.True : ModalMode.False)">
            <PopoverTrigger data-testid="popover-trigger">Open Popover</PopoverTrigger>
            <button data-testid="between-button">Between Button</button>
            <PopoverPortal>
                <PopoverPositioner data-testid="popover-positioner">
                    <PopoverPopup data-testid="popover-popup">
                        <button data-testid="popup-first">First in Popup</button>
                        <button data-testid="popup-last">Last in Popup</button>
                    </PopoverPopup>
                </PopoverPositioner>
            </PopoverPortal>
        </PopoverRoot>
    }
    else
    {
        <button data-testid="before-button">Before Button</button>
        <PopoverRoot @bind-Open="isOpen" DefaultOpen="@DefaultOpen" Modal="@(Modal ? ModalMode.True : ModalMode.False)">
            <PopoverTrigger data-testid="popover-trigger">Open Popover</PopoverTrigger>
            <PopoverPortal>
                <PopoverPositioner data-testid="popover-positioner">
                    <PopoverPopup data-testid="popover-popup">
                        <button data-testid="popup-first">First in Popup</button>
                        <button data-testid="popup-last">Last in Popup</button>
                    </PopoverPopup>
                </PopoverPositioner>
            </PopoverPortal>
        </PopoverRoot>
        <button data-testid="after-button">After Button</button>
    }

    <div data-testid="state-display" style="margin-top: 20px; padding: 10px; border: 1px solid #ccc;">
        <div>Open: <span data-testid="open-state">@isOpen.ToString().ToLowerInvariant()</span></div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "defaultOpen")]
    public bool DefaultOpen { get; set; }

    [SupplyParameterFromQuery(Name = "modal")]
    public bool Modal { get; set; }

    [SupplyParameterFromQuery(Name = "layout")]
    public string Layout { get; set; } = "after-trigger";

    private bool isOpen;

    protected override void OnInitialized()
    {
        isOpen = DefaultOpen;
    }
}
