@page "/tests/popover-nested/wasm"
@using BlazorBaseUI.Popover
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Popover Nested Test Page (WASM)</PageTitle>

<div data-testid="test-container" data-interactive="@RendererInfo.IsInteractive.ToString().ToLowerInvariant()">
    <PopoverRoot
        @bind-Open="parentOpen"
        Modal="@(ParentModal ? ModalMode.True : ModalMode.False)">
        <PopoverTrigger data-testid="parent-trigger">Open Parent</PopoverTrigger>
        <PopoverPortal>
            @if (ParentModal)
            {
                <PopoverBackdrop data-testid="parent-backdrop" />
            }
            <PopoverPositioner data-testid="parent-positioner">
                <PopoverPopup data-testid="parent-popup">
                    <div data-testid="parent-content">Parent Content</div>
                    <PopoverClose data-testid="parent-close">Close Parent</PopoverClose>

                    <PopoverRoot
                        @bind-Open="childOpen"
                        Modal="@(ChildModal ? ModalMode.True : ModalMode.False)">
                        <PopoverTrigger data-testid="child-trigger">Open Child</PopoverTrigger>
                        <PopoverPortal>
                            <PopoverPositioner data-testid="child-positioner">
                                <PopoverPopup data-testid="child-popup">
                                    <div data-testid="child-content">Child Content</div>
                                    <PopoverClose data-testid="child-close">Close Child</PopoverClose>
                                </PopoverPopup>
                            </PopoverPositioner>
                        </PopoverPortal>
                    </PopoverRoot>
                </PopoverPopup>
            </PopoverPositioner>
        </PopoverPortal>
    </PopoverRoot>

    <button data-testid="outside-button" style="margin-top: 10px;">Outside Button</button>

    <div data-testid="state-display" style="margin-top: 20px; padding: 10px; border: 1px solid #ccc;">
        <div>Parent Open: <span data-testid="parent-open-state">@parentOpen.ToString().ToLowerInvariant()</span></div>
        <div>Child Open: <span data-testid="child-open-state">@childOpen.ToString().ToLowerInvariant()</span></div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "parentModal")]
    public bool ParentModal { get; set; }

    [SupplyParameterFromQuery(Name = "childModal")]
    public bool ChildModal { get; set; }

    private bool parentOpen;
    private bool childOpen;
}
