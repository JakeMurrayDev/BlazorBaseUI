@page "/tests/scroll-area/server"
@using BlazorBaseUI.DirectionProvider
@using BlazorBaseUI.ScrollArea
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>ScrollArea Test Page (Server)</PageTitle>

<style>
    .scroll-area-root {
        width: 240px;
        height: 180px;
        border: 1px solid #334155;
        position: relative;
        background: #ffffff;
    }

    .scroll-area-viewport {
        width: 100%;
        height: 100%;
        outline: none;
    }

    .scroll-area-viewport:focus-visible {
        outline: 2px solid #2563eb;
        outline-offset: 2px;
    }

    .scroll-area-content {
        width: var(--test-content-width);
        height: var(--test-content-height);
        padding: 12px;
        background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    }

    .scroll-area-scrollbar {
        display: flex;
        justify-content: flex-start;
        background: rgba(15, 23, 42, 0.10);
    }

    .scroll-area-scrollbar[data-orientation='vertical'] {
        flex-direction: column;
        align-items: stretch;
        width: 14px;
        padding-block: 2px;
    }

    .scroll-area-scrollbar[data-orientation='horizontal'] {
        flex-direction: row;
        align-items: stretch;
        height: 14px;
        padding-inline: 2px;
    }

    .scroll-area-thumb {
        border-radius: 999px;
        background: #475569;
    }

    .scroll-area-thumb[data-orientation='vertical'] {
        width: 100%;
    }

    .scroll-area-thumb[data-orientation='horizontal'] {
        height: 100%;
    }

    .scroll-area-corner {
        background: #cbd5e1;
    }

    .scroll-area-cell-grid {
        display: grid;
        grid-template-columns: var(--test-grid-columns);
        gap: 8px;
    }

    .scroll-area-cell {
        height: 56px;
        border: 1px solid #94a3b8;
        background: #ffffff;
        display: grid;
        place-items: center;
        font-size: 12px;
    }
</style>

<DirectionProvider Direction="@ParsedDirection">
    <div data-testid="test-container"
         data-interactive="@RendererInfo.IsInteractive.ToString().ToLowerInvariant()"
         dir="@Direction">
        <ScrollAreaRoot OverflowEdgeThreshold="@ResolvedThreshold"
                        class="scroll-area-root"
                        style="@RootStyle"
                        data-testid="scroll-root">
            <ScrollAreaViewport class="scroll-area-viewport" data-testid="scroll-viewport">
                <ScrollAreaContent class="scroll-area-content" data-testid="scroll-content">
                    <div class="scroll-area-cell-grid">
                        @for (var i = 1; i <= CellCount; i++)
                        {
                            <div class="scroll-area-cell">Cell @i</div>
                        }
                    </div>
                </ScrollAreaContent>
            </ScrollAreaViewport>
            <ScrollAreaScrollbar class="scroll-area-scrollbar"
                                 KeepMounted="@KeepMounted"
                                 data-testid="vertical-scrollbar">
                <ScrollAreaThumb class="scroll-area-thumb" data-testid="vertical-thumb" />
            </ScrollAreaScrollbar>
            <ScrollAreaScrollbar class="scroll-area-scrollbar"
                                 Orientation="Orientation.Horizontal"
                                 KeepMounted="@KeepMounted"
                                 data-testid="horizontal-scrollbar">
                <ScrollAreaThumb class="scroll-area-thumb" data-testid="horizontal-thumb" />
            </ScrollAreaScrollbar>
            <ScrollAreaCorner class="scroll-area-corner" data-testid="scroll-corner" />
        </ScrollAreaRoot>

        <button type="button" data-testid="outside-button">Outside button</button>
    </div>
</DirectionProvider>

@code {
    [SupplyParameterFromQuery(Name = "keepMounted")]
    public bool KeepMounted { get; set; }

    [SupplyParameterFromQuery(Name = "smallContent")]
    public bool SmallContent { get; set; }

    [SupplyParameterFromQuery(Name = "direction")]
    public string Direction { get; set; } = "ltr";

    [SupplyParameterFromQuery(Name = "threshold")]
    public double Threshold { get; set; }

    private string ContentWidth => SmallContent ? "120px" : "620px";

    private string ContentHeight => SmallContent ? "100px" : "520px";

    private string GridColumns => SmallContent ? "88px" : "repeat(6, 88px)";

    private int CellCount => SmallContent ? 1 : 30;

    private string RootStyle => $"--test-content-width:{ContentWidth};--test-content-height:{ContentHeight};--test-grid-columns:{GridColumns};direction:{Direction};";

    private ScrollAreaOverflowEdgeThreshold ResolvedThreshold => ScrollAreaOverflowEdgeThreshold.All(Threshold);

    private Direction ParsedDirection => Direction?.ToLowerInvariant() == "rtl"
        ? BlazorBaseUI.Direction.Rtl
        : BlazorBaseUI.Direction.Ltr;
}
