@page "/tests/tooltip/server"
@using BlazorBaseUI.Popover
@using BlazorBaseUI.Tooltip
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Tooltip Test Page (Server)</PageTitle>

<style>
    .test-tooltip-arrow {
        display: block;
        width: 20px;
        height: 10px;
        line-height: 0;
    }

    .test-tooltip-arrow > svg {
        display: block;
    }

    .test-tooltip-arrow[data-side="bottom"] {
        top: -9px;
    }

    .test-tooltip-arrow[data-side="top"] {
        bottom: -9px;
        transform: rotate(180deg);
    }

    .test-tooltip-arrow[data-side="left"] {
        right: -14px;
        transform: rotate(90deg);
    }

    .test-tooltip-arrow[data-side="right"] {
        left: -14px;
        transform: rotate(-90deg);
    }

    .test-tooltip-popup-hidden {
        opacity: 0;
        transform: scale(0.9);
    }

    .test-tooltip-popup-visible {
        opacity: 1;
        transform: scale(1);
    }
</style>

<div data-testid="test-container"
     data-interactive="@RendererInfo.IsInteractive.ToString().ToLowerInvariant()"
     style="@(StyledArrow ? "padding: 240px 320px;" : null)">
    @if (ProviderGroup)
    {
        <TooltipProvider Delay="@Delay" CloseDelay="@CloseDelay" Timeout="@ProviderTimeout">
            <TooltipRoot
                @bind-Open="providerOpenOne"
                DisableHoverablePopup="@DisableHoverablePopup">
                <TooltipTrigger
                    Id="provider-trigger-one"
                    Delay="@Delay"
                    CloseDelay="@CloseDelay"
                    data-testid="provider-trigger-one">
                    Provider One
                </TooltipTrigger>
                <TooltipPortal>
                    <TooltipPositioner
                        SideOffset="@SideOffset"
                        data-testid="provider-positioner-one">
                        <TooltipPopup data-testid="provider-popup-one">
                            <div data-testid="provider-content-one">Provider Content One</div>
                        </TooltipPopup>
                    </TooltipPositioner>
                </TooltipPortal>
            </TooltipRoot>

            <TooltipRoot
                @bind-Open="providerOpenTwo"
                DisableHoverablePopup="@DisableHoverablePopup">
                <TooltipTrigger
                    Id="provider-trigger-two"
                    Delay="@Delay"
                    CloseDelay="@CloseDelay"
                    data-testid="provider-trigger-two">
                    Provider Two
                </TooltipTrigger>
                <TooltipPortal>
                    <TooltipPositioner
                        SideOffset="@SideOffset"
                        data-testid="provider-positioner-two">
                        <TooltipPopup data-testid="provider-popup-two">
                            <div data-testid="provider-content-two">Provider Content Two</div>
                        </TooltipPopup>
                    </TooltipPositioner>
                </TooltipPortal>
            </TooltipRoot>
        </TooltipProvider>

        <div data-testid="provider-state-display">
            <div>Provider One Open: <span data-testid="provider-open-one">@providerOpenOne.ToString().ToLowerInvariant()</span></div>
            <div>Provider Two Open: <span data-testid="provider-open-two">@providerOpenTwo.ToString().ToLowerInvariant()</span></div>
        </div>
    }
    else if (MultiTrigger)
    {
        <TooltipRoot
            @bind-Open="isOpen"
            DefaultOpen="@DefaultOpen"
            Disabled="@Disabled"
            DisableHoverablePopup="@DisableHoverablePopup"
            ActionsRef="@actionsRef"
            OnOpenChange="HandleOpenChange"
            OnOpenChangeComplete="HandleOpenChangeComplete">
            <ChildContentWithPayload Context="payloadContext">
                <TooltipTrigger
                    Id="trigger-one"
                    Payload="@("one")"
                    Delay="@Delay"
                    CloseDelay="@CloseDelay"
                    data-testid="tooltip-trigger-one">
                    One
                </TooltipTrigger>
                <TooltipTrigger
                    Id="trigger-two"
                    Payload="@("two")"
                    Delay="@Delay"
                    CloseDelay="@CloseDelay"
                    data-testid="tooltip-trigger-two">
                    Two
                </TooltipTrigger>
                <TooltipPortal KeepMounted="@KeepMounted">
                    <TooltipPositioner
                        SideOffset="@SideOffset"
                        Side="@(Side == "top" ? BlazorBaseUI.Side.Top : Side == "left" ? BlazorBaseUI.Side.Left : Side == "right" ? BlazorBaseUI.Side.Right : BlazorBaseUI.Side.Bottom)"
                        Align="@(Align == "start" ? BlazorBaseUI.Align.Start : Align == "end" ? BlazorBaseUI.Align.End : BlazorBaseUI.Align.Center)"
                        data-testid="tooltip-positioner">
                        <TooltipPopup data-testid="tooltip-popup" ClassValue="AnimatedPopupClass">
                            @if (ShowArrow)
                            {
                                <TooltipArrow data-testid="tooltip-arrow" ClassValue="StyledArrowClass">
                                    @if (StyledArrow)
                                    {
                                        @ArrowSvg
                                    }
                                </TooltipArrow>
                            }
                            <div data-testid="tooltip-content">@payloadContext.Payload</div>
                        </TooltipPopup>
                    </TooltipPositioner>
                </TooltipPortal>
            </ChildContentWithPayload>
        </TooltipRoot>
    }
    else
    {
        @if (FlexLayout)
        {
            <div data-testid="tooltip-flex-row"
                 style="display: flex; align-items: center; justify-content: center; gap: 16px; width: 760px;">
                <TooltipRoot
                    @bind-Open="isOpen"
                    DefaultOpen="@DefaultOpen"
                    Disabled="@Disabled"
                    DisableHoverablePopup="@DisableHoverablePopup"
                    ActionsRef="@actionsRef"
                    OnOpenChange="HandleOpenChange"
                    OnOpenChangeComplete="HandleOpenChangeComplete">
                    <TooltipTrigger
                        Delay="@Delay"
                        CloseDelay="@CloseDelay"
                        style="height: 40px; padding: 0 14px; border: 1px solid #d1d5db; border-radius: 6px;"
                        data-testid="tooltip-trigger">
                        Default (Not Hoverable)
                    </TooltipTrigger>
                    <TooltipPortal KeepMounted="@KeepMounted">
                        <TooltipPositioner
                            SideOffset="@SideOffset"
                            Side="@(Side == "top" ? BlazorBaseUI.Side.Top : Side == "left" ? BlazorBaseUI.Side.Left : Side == "right" ? BlazorBaseUI.Side.Right : BlazorBaseUI.Side.Bottom)"
                            Align="@(Align == "start" ? BlazorBaseUI.Align.Start : Align == "end" ? BlazorBaseUI.Align.End : BlazorBaseUI.Align.Center)"
                            data-testid="tooltip-positioner">
                            <TooltipPopup data-testid="tooltip-popup">
                                <div data-testid="tooltip-content">Tooltip Content</div>
                            </TooltipPopup>
                        </TooltipPositioner>
                    </TooltipPortal>
                </TooltipRoot>

                <button data-testid="tooltip-flex-sibling"
                        style="height: 40px; padding: 0 14px; border: 1px solid #d1d5db; border-radius: 6px;">
                    Hoverable Popup
                </button>
            </div>
        }
        else if (ControlledExternal)
        {
            <TooltipRoot
                Open="@isOpen"
                DefaultOpen="@DefaultOpen"
                Disabled="@Disabled"
                DisableHoverablePopup="@DisableHoverablePopup"
                ActionsRef="@actionsRef"
                OnOpenChange="HandleOpenChange"
                OnOpenChangeComplete="HandleOpenChangeComplete">
                <TooltipTrigger
                    Delay="@Delay"
                    CloseDelay="@CloseDelay"
                    data-testid="tooltip-trigger">
                    Hover Me
                </TooltipTrigger>
                <TooltipPortal KeepMounted="@KeepMounted">
                    <TooltipPositioner
                        SideOffset="@SideOffset"
                        Side="@(Side == "top" ? BlazorBaseUI.Side.Top : Side == "left" ? BlazorBaseUI.Side.Left : Side == "right" ? BlazorBaseUI.Side.Right : BlazorBaseUI.Side.Bottom)"
                        Align="@(Align == "start" ? BlazorBaseUI.Align.Start : Align == "end" ? BlazorBaseUI.Align.End : BlazorBaseUI.Align.Center)"
                        data-testid="tooltip-positioner">
                        <TooltipPopup data-testid="tooltip-popup" ClassValue="AnimatedPopupClass">
                            @if (ShowArrow)
                            {
                                <TooltipArrow data-testid="tooltip-arrow" ClassValue="StyledArrowClass">
                                    @if (StyledArrow)
                                    {
                                        @ArrowSvg
                                    }
                                </TooltipArrow>
                            }
                            <div data-testid="tooltip-content">Tooltip Content</div>
                        </TooltipPopup>
                    </TooltipPositioner>
                </TooltipPortal>
            </TooltipRoot>
        }
        else
        {
            <TooltipRoot
                @bind-Open="isOpen"
                DefaultOpen="@DefaultOpen"
                Disabled="@Disabled"
                DisableHoverablePopup="@DisableHoverablePopup"
                ActionsRef="@actionsRef"
                OnOpenChange="HandleOpenChange"
                OnOpenChangeComplete="HandleOpenChangeComplete">
                <TooltipTrigger
                    Delay="@Delay"
                    CloseDelay="@CloseDelay"
                    data-testid="tooltip-trigger">
                    Hover Me
                </TooltipTrigger>
                <TooltipPortal KeepMounted="@KeepMounted">
                    <TooltipPositioner
                        SideOffset="@SideOffset"
                        Side="@(Side == "top" ? BlazorBaseUI.Side.Top : Side == "left" ? BlazorBaseUI.Side.Left : Side == "right" ? BlazorBaseUI.Side.Right : BlazorBaseUI.Side.Bottom)"
                        Align="@(Align == "start" ? BlazorBaseUI.Align.Start : Align == "end" ? BlazorBaseUI.Align.End : BlazorBaseUI.Align.Center)"
                        data-testid="tooltip-positioner">
                        <TooltipPopup data-testid="tooltip-popup">
                            @if (ShowArrow)
                            {
                                <TooltipArrow data-testid="tooltip-arrow" ClassValue="StyledArrowClass">
                                    @if (StyledArrow)
                                    {
                                        @ArrowSvg
                                    }
                                </TooltipArrow>
                            }
                            <div data-testid="tooltip-content">Tooltip Content</div>
                        </TooltipPopup>
                    </TooltipPositioner>
                </TooltipPortal>
            </TooltipRoot>
        }
    }

    <div data-testid="state-display" style="margin-top: 20px; padding: 10px; border: 1px solid #ccc;">
        <div>Open: <span data-testid="open-state">@isOpen.ToString().ToLowerInvariant()</span></div>
        <div>Change Count: <span data-testid="change-count">@changeCount</span></div>
        <div>Last Reason: <span data-testid="last-reason">@lastReason</span></div>
        <div>Complete Count: <span data-testid="complete-count">@completeCount</span></div>
    </div>

    <div style="margin-top: 10px;">
        <button data-testid="outside-button">Outside Button</button>
        <input data-testid="focusable-input" type="text" placeholder="Focusable input" />
    </div>

    <div style="margin-top: 10px;">
        <button data-testid="actions-close" @onclick="HandleActionsClose">Close via Actions</button>
        <button data-testid="actions-open" @onclick="HandleActionsOpen">Open via Actions</button>
        @if (ControlledExternal)
        {
            <button data-testid="external-open" @onclick="HandleExternalOpen">Open via External State</button>
            <button data-testid="external-close" @onclick="HandleExternalClose">Close via External State</button>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "defaultOpen")]
    public bool DefaultOpen { get; set; }

    [SupplyParameterFromQuery(Name = "controlledExternal")]
    public bool ControlledExternal { get; set; }

    [SupplyParameterFromQuery(Name = "animated")]
    public bool Animated { get; set; }

    [SupplyParameterFromQuery(Name = "disabled")]
    public bool Disabled { get; set; }

    [SupplyParameterFromQuery(Name = "disableHoverablePopup")]
    public bool DisableHoverablePopup { get; set; }

    [SupplyParameterFromQuery(Name = "flexLayout")]
    public bool FlexLayout { get; set; }

    [SupplyParameterFromQuery(Name = "delay")]
    public int Delay { get; set; } = 600;

    [SupplyParameterFromQuery(Name = "closeDelay")]
    public int CloseDelay { get; set; } = 300;

    [SupplyParameterFromQuery(Name = "keepMounted")]
    public bool KeepMounted { get; set; }

    [SupplyParameterFromQuery(Name = "showArrow")]
    public bool ShowArrow { get; set; }

    [SupplyParameterFromQuery(Name = "styledArrow")]
    public bool StyledArrow { get; set; }

    [SupplyParameterFromQuery(Name = "multiTrigger")]
    public bool MultiTrigger { get; set; }

    [SupplyParameterFromQuery(Name = "providerGroup")]
    public bool ProviderGroup { get; set; }

    [SupplyParameterFromQuery(Name = "providerTimeout")]
    public int ProviderTimeout { get; set; } = 400;

    [SupplyParameterFromQuery(Name = "sideOffset")]
    public int SideOffset { get; set; }

    [SupplyParameterFromQuery(Name = "side")]
    public string Side { get; set; } = "top";

    [SupplyParameterFromQuery(Name = "align")]
    public string Align { get; set; } = "center";

    private bool isOpen;
    private bool providerOpenOne;
    private bool providerOpenTwo;
    private int changeCount;
    private string lastReason = "";
    private int completeCount;
    private TooltipRootActions actionsRef = new();

    protected override void OnInitialized()
    {
        isOpen = DefaultOpen;
    }

    private void HandleOpenChange(TooltipOpenChangeEventArgs args)
    {
        changeCount++;
        lastReason = args.Reason.ToString();
    }

    private void HandleOpenChangeComplete(bool open)
    {
        completeCount++;
    }

    private void HandleActionsClose()
    {
        actionsRef.Close?.Invoke();
    }

    private void HandleActionsOpen()
    {
        actionsRef.Open?.Invoke();
    }

    private void HandleExternalOpen()
    {
        isOpen = true;
    }

    private void HandleExternalClose()
    {
        isOpen = false;
    }

    private static readonly RenderFragment ArrowSvg = __builder =>
    {
        <svg width="20" height="10" viewBox="0 0 20 10" fill="none" style="display: block;">
            <path d="M9.66437 2.60207L4.80758 6.97318C4.07308 7.63423 3.11989 8 2.13172 8H0V10H20V8H18.5349C17.5468 8 16.5936 7.63423 15.8591 6.97318L11.0023 2.60207C10.622 2.2598 10.0447 2.25979 9.66437 2.60207Z" fill="white" />
            <path d="M8.99542 1.85876C9.75604 1.17425 10.9106 1.17422 11.6713 1.85878L16.5281 6.22989C17.0789 6.72568 17.7938 7.00001 18.5349 7.00001L15.89 7L11.0023 2.60207C10.622 2.2598 10.0447 2.2598 9.66436 2.60207L4.77734 7L2.13171 7.00001C2.87284 7.00001 3.58774 6.72568 4.13861 6.22989L8.99542 1.85876Z" fill="#e5e7eb" />
            <path d="M10.3333 3.34539L5.47654 7.71648C4.55842 8.54279 3.36693 9 2.13172 9H0V8H2.13172C3.11989 8 4.07308 7.63423 4.80758 6.97318L9.66437 2.60207C10.0447 2.25979 10.622 2.2598 11.0023 2.60207L15.8591 6.97318C16.5936 7.63423 17.5468 8 18.5349 8H20V9H18.5349C17.2998 9 16.1083 8.54278 15.1901 7.71648L10.3333 3.34539Z" fill="#d1d5db" />
        </svg>
    };

    private string StyledArrowClass(TooltipArrowState _) => StyledArrow ? "test-tooltip-arrow" : string.Empty;

    private string AnimatedPopupClass(TooltipPopupState state)
    {
        if (!Animated)
        {
            return string.Empty;
        }

        return state.TransitionStatus is TransitionStatus.Starting or TransitionStatus.Ending
            ? "test-tooltip-popup-hidden"
            : "test-tooltip-popup-visible";
    }
}
